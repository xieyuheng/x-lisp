(import-all "my-list")

(import-all "my-list-map-zip")

(define-function (main)
  (block body
    (= _₁ (my-list-map-zip iadd nil nil))
    (perform (assert-equal nil _₁))
    (= _₂ (li 6 nil))
    (= _₃ (li 4 _₂))
    (= _₄ (li 2 _₃))
    (= _₅ (li 3 nil))
    (= _₆ (li 2 _₅))
    (= _₇ (li 1 _₆))
    (= _₈ (li 3 nil))
    (= _₉ (li 2 _₈))
    (= _₁₀ (li 1 _₉))
    (= _₁₁ (my-list-map-zip iadd _₇ _₁₀))
    (perform (assert-equal _₄ _₁₁))
    (= _₁₂ (my-list-map-zip-2 iadd nil nil))
    (perform (assert-equal nil _₁₂))
    (= _₁₃ (li 6 nil))
    (= _₁₄ (li 4 _₁₃))
    (= _₁₅ (li 2 _₁₄))
    (= _₁₆ (li 3 nil))
    (= _₁₇ (li 2 _₁₆))
    (= _₁₈ (li 1 _₁₇))
    (= _₁₉ (li 3 nil))
    (= _₂₀ (li 2 _₁₉))
    (= _₂₁ (li 1 _₂₀))
    (= _₂₂ (my-list-map-zip-2 iadd _₁₈ _₂₁))
    (return (assert-equal _₁₅ _₂₂))))