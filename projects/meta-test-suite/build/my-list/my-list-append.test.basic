(import-all "my-list")

(import-all "my-list-append")

(define-function (main)
  (block body
    (= _₁ (my-list-append nil nil))
    (perform (assert-equal nil _₁))
    (= _₂ (li 6 nil))
    (= _₃ (li 5 _₂))
    (= _₄ (li 4 _₃))
    (= _₅ (li 3 _₄))
    (= _₆ (li 2 _₅))
    (= _₇ (li 1 _₆))
    (= _₈ (li 3 nil))
    (= _₉ (li 2 _₈))
    (= _₁₀ (li 1 _₉))
    (= _₁₁ (li 6 nil))
    (= _₁₂ (li 5 _₁₁))
    (= _₁₃ (li 4 _₁₂))
    (= _₁₄ (my-list-append _₁₀ _₁₃))
    (return (assert-equal _₇ _₁₄))))