(import-all "my-list")

(export-all)

(define-function (my-list-adjacent-dedup list)
  (block body (test (nil? list)) (branch then₉ else₁₀))
  (block then₁
    (= _₁ (li second₁ rest₁))
    (return (my-list-adjacent-dedup _₁)))
  (block else₂
    (= _₂ (li second₁ rest₁))
    (= _₃ (my-list-adjacent-dedup _₂))
    (return (li first₁ _₃)))
  (block then₃
    (= tail₂₁ (li-tail tail₁₁))
    (= head₂₁ (li-head tail₁₁))
    (= rest₁ tail₂₁)
    (= second₁ head₂₁)
    (= first₁ head₁₁)
    (test (equal? first₁ second₁))
    (branch then₁ else₂))
  (block else₄ (return (error "cond mismatch")))
  (block then₅ (= head₁ head₁₁) (return (li head₁ nil)))
  (block else₆ (test (li? tail₁₁)) (branch then₃ else₄))
  (block then₇
    (= tail₁₁ (li-tail list))
    (= head₁₁ (li-head list))
    (test (nil? tail₁₁))
    (branch then₅ else₆))
  (block else₈ (return (error "cond mismatch")))
  (block then₉ (return nil))
  (block else₁₀ (test (li? list)) (branch then₇ else₈)))