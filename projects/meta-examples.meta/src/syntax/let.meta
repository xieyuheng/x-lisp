(module test-suite)

(define-test let-test
  (assert-equal 3 (let* ((x 1)
                         (y (iadd 1 x)))
                    (iadd x y)))
  (assert-equal 3 (let ((x 1)
                        (y 2))
                    (iadd x y)))
  (assert-equal 3 (let ((x 1)
                        (y 2))
                    (assert-equal x 1)
                    (assert-equal y 2)
                    (let ((x y)
                          (y x))
                      (assert-equal x 2)
                      (assert-equal y 1)
                      (iadd x y)))))
