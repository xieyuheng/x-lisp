(module test-suite)

(define-test eoc-05-01
  (print 1)
  (newline)
  (print 2)
  (newline)
  (print 3)
  (newline)
  void)

(define-test eoc-05-02
  (= x (begin
         (print 1)
         (newline)
         (print 2)
         (newline)
         (print 3)
         (newline)
         6))
  (begin
    (print 4)
    (newline)
    (print 5)
    (newline)
    (print 6)
    (newline)
    (print (iadd x x))
    (newline)
    void))

(define-test eoc-05-03
  (if (begin
        (print 1)
        (newline)
        (print 2)
        (newline)
        (print 3)
        (newline)
        (equal? 1 2))
    (begin
      (print 111)
      (newline))
    (begin
      (print 222)
      (newline))))
