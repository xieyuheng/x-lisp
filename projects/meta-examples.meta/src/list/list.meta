(module test-suite)

(define-test list-test
  (= list (make-list))
  (list-push! 1 list)
  (list-push! 2 list)
  (list-push! 3 list)
  (println list)

  (println (the (list-t int-t) [1 2 3]))
  (println [1 2 3])
  (println '(1 2 3))
  (println (@list 1 2 3))

  (println ['a 'b 'c])
  (println '(a b c))

  (assert-equal [1 2 3] '(1 2 3))
  (assert-equal ['a 'b 'c] '(a b c))

  (assert-equal
    [[1 2 3]
     [4 5 6]
     [7 8 9]]
    [[1 2 3]
     [4 5 6]
     [7 8 9]])

  (assert-not-equal
    [[1 2 3]
     [4 5 6]
     [7 8 9]]
    [[1 2 3]
     [4 5 6]
     [7 8 10]])

  (assert (list-empty? []))
  (assert-not (list-empty? [1]))

  (assert-equal (cons 1 (cons 2 (cons 3 []))) [1 2 3])
  (assert-equal (car [1 2 3]) 1)
  (assert-equal (cdr [1 2 3]) [2 3])

  (assert-equal (list-head [1 2 3]) 1)
  (assert-equal (list-tail [1 2 3]) [2 3])

  (assert-equal (list-init [1 2 3]) [1 2])
  (assert-equal (list-last [1 2 3]) 3)

  (assert-equal (@set 1 2 3) (list-to-set [1 2 3]))

  (assert-equal (list-copy [1 2 3]) [1 2 3])

  (assert-equal (list-get 0 [1 2 3]) 1)
  (assert-equal (list-get 1 [1 2 3]) 2)
  (assert-equal (list-get 2 [1 2 3]) 3)

  (assert-equal (list-length []) 0)
  (assert-equal (list-length [1 2 3]) 3)
  (assert-equal
    (list-length [[1 2 3]
                  [4 5 6]
                  [7 8 9]])
    3)

  ;; list of functions

  (begin
    (= fs (the (list-t (-> int-t int-t))
            [(iadd 1) (iadd 2) (iadd 3)]))
    (assert-equal 1 ((list-get 0 fs) 0))
    (assert-equal 2 ((list-get 1 fs) 0))
    (assert-equal 3 ((list-get 2 fs) 0))))

(define-test list-pop-test
  (begin
    (= list [1 2 3])
    (assert-equal 3 (list-pop! list))
    (assert-equal 2 (list-pop! list))
    (assert-equal 1 (list-pop! list))
    (assert-equal list [])))

(define-test list-push-test
  (begin
    (= list [])
    (= list (list-push 1 list))
    (= list (list-push 2 list))
    (= list (list-push 3 list))
    (assert-equal list [1 2 3]))

  ;; list-push has NO side effect:

  (begin
    (= list [])
    (list-push 1 list)
    (list-push 2 list)
    (list-push 3 list)
    (assert-equal list []))

  ;; list-push! has side effect:

  (begin
    (= list [])
    (list-push! 1 list)
    (list-push! 2 list)
    (list-push! 3 list)
    (assert-equal list [1 2 3])))

(define-test list-put-test
  (begin
    (= list [0 0 0])
    (= list (list-put 0 1 list))
    (= list (list-put 1 2 list))
    (= list (list-put 2 3 list))
    (assert-equal list [1 2 3]))

  ;; list-put has NO side effect:

  (begin
    (= list [0 0 0])
    (list-put 0 1 list)
    (list-put 1 2 list)
    (list-put 2 3 list)
    (assert-equal list [0 0 0]))

  ;; list-put! has side effect:

  (begin
    (= list [0 0 0])
    (list-put! 0 1 list)
    (list-put! 1 2 list)
    (list-put! 2 3 list)
    (assert-equal list [1 2 3])))

(define-test list-reverse-test
  (assert-equal (list-reverse [1 2 3]) [3 2 1]))

(define-test list-pop-front-test
  (begin
    (= list [1 2 3])
    (assert-equal 1 (list-pop-front! list))
    (assert-equal 2 (list-pop-front! list))
    (assert-equal 3 (list-pop-front! list))
    (assert-equal list []))

  (begin
    (= list [])
    (list-push-front! 3 list)
    (list-push-front! 2 list)
    (list-push-front! 1 list)
    (assert-equal list [1 2 3])))
