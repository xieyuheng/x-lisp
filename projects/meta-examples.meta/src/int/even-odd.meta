(module test-suite)

;; can infer type of mutual recursive function

(define (even? n)
  (if (equal? n 0)
    true
    (odd? (isub n 1))))

(define (odd? n)
  (if (equal? n 0)
    false
    (even? (isub n 1))))

(define-test even-test
  (assert (even? 0))
  (assert-not (even? 1))
  (assert (even? 2))
  (assert-not (even? 3))
  (assert (even? 4)))

(define-test odd-test
  (assert-not (odd? 0))
  (assert (odd? 1))
  (assert-not (odd? 2))
  (assert (odd? 3))
  (assert-not (odd? 4)))
