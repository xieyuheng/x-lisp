{
  "name": "@xieyuheng/meta-lisp.js",
  "version": "0.1.4",
  "repository": "github:xieyuheng/meta-lisp",
  "license": "GPL-3.0-or-later",
  "type": "module",
  "main": "./dist/index.js",
  "files": [
    "src",
    "dist",
    "lisp",
    "bin"
  ],
  "bin": {
    "meta-lisp.js": "dist/main.js"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "tsc",
    "build:watch": "tsc --watch",
    "test": "node --test 'src/**/*.test.ts'",
    "format": "prettier src --write"
  },
  "prettier": {
    "semi": false,
    "trailingComma": "all",
    "plugins": [
      "prettier-plugin-organize-imports"
    ]
  },
  "dependencies": {
    "@xieyuheng/cmd.js": "workspace:*",
    "@xieyuheng/helpers.js": "workspace:*",
    "@xieyuheng/ppml.js": "workspace:*",
    "@xieyuheng/sexp.js": "workspace:*",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "prettier-plugin-organize-imports": "^4.3.0",
    "@types/node": "^25.6.0",
    "prettier": "^3.8.3",
    "typescript": "^5.9.3"
  }
}
