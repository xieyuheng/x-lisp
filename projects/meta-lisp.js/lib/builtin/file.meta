(module builtin)

(claim file-t type-t)
(claim open-input-file (-> string-t file-t))
(claim open-output-file (-> string-t file-t))
(claim file-close (-> file-t void-t))
(claim file-read (-> file-t string-t))
(claim file-write (-> file-t string-t void-t))
(claim file-writeln (-> file-t string-t void-t))
(claim print (polymorphic (A) (-> A void-t)))
(claim println (polymorphic (A) (-> A void-t)))
(claim write (-> string-t void-t))
(claim newline (-> void-t))
