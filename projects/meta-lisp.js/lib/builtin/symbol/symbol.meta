(module builtin)

(declare-primitive-variable symbol-t)
(declare-primitive-function symbol? 1)
(declare-primitive-function symbol-length 1)
(declare-primitive-function symbol-to-string 1)
(declare-primitive-function symbol-append 2)
(declare-primitive-function symbol-concat 1)

(claim symbol-t type-t)
(claim symbol? (polymorphic (A) (-> A bool-t)))
(claim symbol-length (-> symbol-t int-t))
(claim symbol-to-string (-> symbol-t string-t))
(claim symbol-append (-> symbol-t symbol-t symbol-t))
(claim symbol-concat (-> (list-t symbol-t) symbol-t))
