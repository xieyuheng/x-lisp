(module builtin)

(declare-primitive-variable file-t)
(declare-primitive-function open-input-file 1)
(declare-primitive-function open-output-file 1)
(declare-primitive-function file-close 1)
(declare-primitive-function file-read 1)
(declare-primitive-function file-write 2)
(declare-primitive-function file-writeln 2)
(declare-primitive-function print 1)
(declare-primitive-function println 1)
(declare-primitive-function write 1)
(declare-primitive-function newline 0)

(claim file-t type-t)
(claim open-input-file (-> string-t file-t))
(claim open-output-file (-> string-t file-t))
(claim file-close (-> file-t void-t))
(claim file-read (-> file-t string-t))
(claim file-write (-> file-t string-t void-t))
(claim file-writeln (-> file-t string-t void-t))
(claim print (polymorphic (A) (-> A void-t)))
(claim println (polymorphic (A) (-> A void-t)))
(claim write (-> string-t void-t))
(claim newline (-> void-t))
