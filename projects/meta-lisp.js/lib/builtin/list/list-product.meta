(module builtin)

(define (list-product lhs rhs)
    (list-concat
     (list-map
      (lambda (left)
        (list-map (lambda (right)
                    (make-pair left right))
                  rhs))
      lhs)))

(define-test list-product-test
  (assert-equal
    [(make-pair 1 1) (make-pair 1 2) (make-pair 1 3)
     (make-pair 2 1) (make-pair 2 2) (make-pair 2 3)
     (make-pair 3 1) (make-pair 3 2) (make-pair 3 3)]
    (list-product [1 2 3] [1 2 3])))
