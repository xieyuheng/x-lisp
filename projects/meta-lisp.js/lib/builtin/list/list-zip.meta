(module builtin)

(claim list-zip
  (polymorphic (A B)
    (-> (list-t A) (list-t B)
        (list-t (interface :first A :second B)))))

(define (list-zip left right)
  (if (or (list-empty? left)
          (list-empty? right))
    []
    (cons {:first (car left) :second (car right)}
          (list-zip (cdr left) (cdr right)))))

