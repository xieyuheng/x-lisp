(module builtin)

(claim list-zip
  (polymorphic (A B)
    (-> (list-t A) (list-t B)
        (list-t (pair-t A B)))))

(define (list-zip left right)
  (if (or (list-empty? left)
          (list-empty? right))
    []
    (cons (make-pair (car left) (car right))
          (list-zip (cdr left) (cdr right)))))

(define-test list-zip-test
  (assert-equal
    (list-zip ['a 'b 'c] [1 2 3])
    [(make-pair 'a 1) (make-pair 'b 2) (make-pair 'c 3)])
  (assert-equal
    (list-zip ['a 'b 'c] [1 2])
    [(make-pair 'a 1) (make-pair 'b 2)]))

(claim list-unzip
  (polymorphic (A B)
    (-> (list-t (pair-t A B))
        (pair-t (list-t A) (list-t B)))))

(define (list-unzip pairs)
  (make-pair (list-map pair-first pairs)
             (list-map pair-second pairs)))

(define-test list-unzip-test
  (assert-equal
    (list-unzip [(make-pair 'a 1) (make-pair 'b 2) (make-pair 'c 3)])
    (make-pair ['a 'b 'c] [1 2 3])))
