(module builtin)

(declare-primitive-function hash-t 2)
(declare-primitive-function make-hash 0)
(declare-primitive-function hash-empty? 1)
(declare-primitive-function hash-length 1)
(declare-primitive-function hash-get 2)
(declare-primitive-function hash-has? 2)
(declare-primitive-function hash-put 3)
(declare-primitive-function hash-put! 3)
(declare-primitive-function hash-delete! 2)
(declare-primitive-function hash-copy 1)
(declare-primitive-function hash-entries 1)
(declare-primitive-function hash-keys 1)
(declare-primitive-function hash-values 1)

(claim hash-t (-> type-t type-t type-t))
(claim make-hash (polymorphic (K V) (-> (hash-t K V))))
(claim hash-empty? (polymorphic (K V) (-> (hash-t K V) bool-t)))
(claim hash-length (polymorphic (K V) (-> (hash-t K V) int-t)))
(claim hash-get (polymorphic (K V) (-> K (hash-t K V) V)))
(claim hash-has? (polymorphic (K V) (-> K (hash-t K V) bool-t)))
(claim hash-put (polymorphic (K V) (-> K V (hash-t K V) (hash-t K V))))
(claim hash-put! (polymorphic (K V) (-> K V (hash-t K V) (hash-t K V))))
(claim hash-delete! (polymorphic (K V) (-> K (hash-t K V) (hash-t K V))))
(claim hash-copy (polymorphic (K V) (-> (hash-t K V) (hash-t K V))))

(define-interface (hash-entry-t K V)
  :key K :value V)

(define (make-hash-entry key value)
  {:key key :value value})

(claim hash-entries (polymorphic (K V) (-> (hash-t K V) (list-t (hash-entry-t K V)))))
(claim hash-keys (polymorphic (K V) (-> (hash-t K V) (list-t K))))
(claim hash-values (polymorphic (K V) (-> (hash-t K V) (list-t V))))
