(module builtin)

(declare-primitive-type float-t)
(declare-primitive-function float? 1)
(declare-primitive-function float-positive? 1)
(declare-primitive-function float-non-negative? 1)
(declare-primitive-function float-non-zero? 1)
(declare-primitive-function fneg 1)
(declare-primitive-function fadd 2)
(declare-primitive-function fsub 2)
(declare-primitive-function fmul 2)
(declare-primitive-function fdiv 2)
(declare-primitive-function fmod 2)
(declare-primitive-function float-max 2)
(declare-primitive-function float-min 2)
(declare-primitive-function float-greater? 2)
(declare-primitive-function float-less? 2)
(declare-primitive-function float-greater-or-equal? 2)
(declare-primitive-function float-less-or-equal? 2)
(declare-primitive-function float-compare-ascending 2)
(declare-primitive-function float-compare-descending 2)

(claim float-t type-t)
(claim float? (polymorphic (A) (-> A bool-t)))
(claim float-positive? (-> float-t bool-t))
(claim float-non-negative? (-> float-t bool-t))
(claim float-non-zero? (-> float-t bool-t))
(claim fneg (-> float-t float-t))
(claim fadd (-> float-t float-t float-t))
(claim fsub (-> float-t float-t float-t))
(claim fmul (-> float-t float-t float-t))
(claim fdiv (-> float-t float-t float-t))
(claim fmod (-> float-t float-t float-t))
(claim float-max (-> float-t float-t float-t))
(claim float-min (-> float-t float-t float-t))
(claim float-greater? (-> float-t float-t bool-t))
(claim float-less? (-> float-t float-t bool-t))
(claim float-greater-or-equal? (-> float-t float-t bool-t))
(claim float-less-or-equal? (-> float-t float-t bool-t))
(claim float-compare-ascending (-> float-t float-t int-t))
(claim float-compare-descending (-> float-t float-t int-t))
