(module builtin)

(declare-primitive-variable int-t)
(declare-primitive-function int? 1)
(declare-primitive-function int-positive? 1)
(declare-primitive-function int-non-negative? 1)
(declare-primitive-function int-non-zero? 1)
(declare-primitive-function ineg 1)
(declare-primitive-function iadd 2)
(declare-primitive-function isub 2)
(declare-primitive-function imul 2)
(declare-primitive-function idiv 2)
(declare-primitive-function imod 2)
(declare-primitive-function int-max 2)
(declare-primitive-function int-min 2)
(declare-primitive-function int-greater? 2)
(declare-primitive-function int-less? 2)
(declare-primitive-function int-greater-or-equal? 2)
(declare-primitive-function int-less-or-equal? 2)
(declare-primitive-function int-compare-ascending 2)
(declare-primitive-function int-compare-descending 2)

(claim int-t type-t)
(claim int? (polymorphic (A) (-> A bool-t)))
(claim int-positive? (-> int-t bool-t))
(claim int-non-negative? (-> int-t bool-t))
(claim int-non-zero? (-> int-t bool-t))
(claim ineg (-> int-t int-t))
(claim iadd (-> int-t int-t int-t))
(claim isub (-> int-t int-t int-t))
(claim imul (-> int-t int-t int-t))
(claim idiv (-> int-t int-t int-t))
(claim imod (-> int-t int-t int-t))
(claim int-max (-> int-t int-t int-t))
(claim int-min (-> int-t int-t int-t))
(claim int-greater? (-> int-t int-t bool-t))
(claim int-less? (-> int-t int-t bool-t))
(claim int-greater-or-equal? (-> int-t int-t bool-t))
(claim int-less-or-equal? (-> int-t int-t bool-t))
(claim int-compare-ascending (-> int-t int-t int-t))
(claim int-compare-descending (-> int-t int-t int-t))
