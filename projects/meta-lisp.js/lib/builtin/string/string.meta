(module builtin)

(declare-primitive-variable string-t)
(declare-primitive-function string? 1)
(declare-primitive-function string-length 1)
(declare-primitive-function string-empty? 1)
(declare-primitive-function string-append 2)
(declare-primitive-function string-concat 1)
(declare-primitive-function string-join 2)
(declare-primitive-function string-compare-lexical 2)
(declare-primitive-function string-to-symbol 1)

(claim string-t type-t)
(claim string? (polymorphic (A) (-> A bool-t)))
(claim string-length (-> string-t int-t))
(claim string-empty? (-> string-t bool-t))
(claim string-append (-> string-t string-t string-t))
(claim string-concat (-> (list-t string-t) string-t))
(claim string-join (-> string-t (list-t string-t) string-t))
(claim string-compare-lexical (-> string-t string-t int-t))
(claim string-to-symbol (-> string-t symbol-t))
;; (claim string-split (-> string-t string-t (list-t string-t)))
;; (claim string-lines (-> string-t (list-t string-t)))
;; (claim string-chars (-> string-t (list-t string-t)))
;; (claim string-replace (-> string-t string-t string-t string-t))
