(module builtin)

(define-test string-test
  (println "abc")

  (assert-equal 2 (string-length "中文"))

  (assert (string-empty? ""))
  (assert-not (string-empty? " "))

  (assert (string-blank? ""))
  (assert (string-blank? " "))
  (assert (string-blank? "  "))
  (assert (string-blank? " \n "))
  (assert (string-blank? " \n\t "))
  (assert-not (string-blank? " \n.\t "))

  (assert-equal "abcdef" (string-append "abc" "def"))

  (assert-equal ["a" "b" "c"] (string-chars "abc"))

  (assert-equal ["123" "456" "789"] (string-lines "123\n456\n789\n"))
  (assert-equal ["123" "456" "789"] (string-lines "123\n456\n789"))
  (assert-equal ["123" "" "789"] (string-lines "123\n\n789\n"))
  (assert-equal ["123" "" "789"] (string-lines "123\n\n789"))

  (assert-equal "中" (string-substring 0 1 "中文"))
  (assert-equal "文" (string-substring 1 2 "中文")))

(define-test string-join-test
  (assert-equal "a.b.c" (string-join "." ["a" "b" "c"]))
  (assert-equal "a..b..c" (string-join ".." ["a" "b" "c"])))

(define-test string-split-test
  (assert-equal ["a" "b" "c"] (string-split "." "a.b.c"))
  (assert-equal ["a" "b" "c"] (string-split ".." "a..b..c")))

(define-test string-replace-test
  (assert-equal "a/b/c" (string-replace "." "/" "a.b.c")))

(define-test string-starts-with-test
  (assert (string-starts-with? "" "abc"))
  (assert (string-starts-with? "a" "abc"))
  (assert (string-starts-with? "ab" "abc"))
  (assert (string-starts-with? "abc" "abc"))
  (assert-not (string-starts-with? "abc~" "abc"))
  (assert-not (string-starts-with? "b" "abc"))

  (assert (string-ends-with? "" "abc"))
  (assert (string-ends-with? "c" "abc"))
  (assert (string-ends-with? "bc" "abc"))
  (assert (string-ends-with? "abc" "abc"))
  (assert-not (string-ends-with? "~abc" "abc"))
  (assert-not (string-ends-with? "b" "abc")))

(define-test string-to-upper-case-test
  (assert-equal "ABC" (string-to-upper-case "abc"))
  (assert-equal "abc" (string-to-lower-case "ABC")))

(define-test string-get-code-point-test
  (assert-equal 97 (string-get-code-point 0 "abc"))
  (assert-equal 98 (string-get-code-point 1 "abc"))
  (assert-equal 99 (string-get-code-point 2 "abc")))

(define-test string-contains-test
  (assert (string-contains? "bb" "aabbcc"))
  (assert (string-contains? "ab" "aabbcc"))
  (assert-not (string-contains? "ba" "aabbcc")))

(define-test string-find-index-test
  (assert-equal 0 (string-find-index "0" "01234"))
  (assert-equal 1 (string-find-index "1" "01234"))
  (assert-equal 2 (string-find-index "2" "01234"))
  (assert-equal -1 (string-find-index "5" "01234"))

  (assert-equal 0 (string-find-index "01" "01234"))
  (assert-equal 1 (string-find-index "12" "01234"))
  (assert-equal 2 (string-find-index "23" "01234"))
  (assert-equal -1 (string-find-index "21" "01234")))

(define-test string-trim-test
  (assert-equal "abc  " (string-trim-left "  abc  "))
  (assert-equal "  abc" (string-trim-right "  abc  "))
  (assert-equal "abc  " (string-trim-start "  abc  "))
  (assert-equal "  abc" (string-trim-end "  abc  "))
  (assert-equal "abc" (string-trim "  abc  ")))
