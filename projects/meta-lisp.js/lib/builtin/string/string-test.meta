(module builtin)

(define-test string-test
  (println "abc")

  (assert-equal 2 (string-length "中文"))

  (assert (string-empty? ""))
  (assert-not (string-empty? " "))

  (assert (string-blank? ""))
  (assert (string-blank? " "))
  (assert (string-blank? "  "))
  (assert (string-blank? " \n "))
  (assert (string-blank? " \n\t "))
  (assert-not (string-blank? " \n.\t "))

  (assert-equal "abcdef" (string-append "abc" "def"))

  (assert-equal ["a" "b" "c"] (string-chars "abc"))

  (assert-equal ["123" "456" "789"] (string-lines "123\n456\n789\n"))
  (assert-equal ["123" "456" "789"] (string-lines "123\n456\n789"))
  (assert-equal ["123" "" "789"] (string-lines "123\n\n789\n"))
  (assert-equal ["123" "" "789"] (string-lines "123\n\n789"))

  (assert-equal "中" (string-substring 0 1 "中文"))
  (assert-equal "文" (string-substring 1 2 "中文")))

(define-test string-join-test
  (assert-equal "a.b.c" (string-join "." ["a" "b" "c"]))
  (assert-equal "a..b..c" (string-join ".." ["a" "b" "c"])))

(define-test string-split-test
  (assert-equal ["a" "b" "c"] (string-split "." "a.b.c"))
  (assert-equal ["a" "b" "c"] (string-split ".." "a..b..c")))

(define-test string-replace-test
  (assert-equal "a/b/c" (string-replace "." "/" "a.b.c")))

(define-test string-prefix-test
  (assert (string-prefix? "" "abc"))
  (assert (string-prefix? "a" "abc"))
  (assert (string-prefix? "ab" "abc"))
  (assert (string-prefix? "abc" "abc"))
  (assert-not (string-prefix? "abc~" "abc"))
  (assert-not (string-prefix? "b" "abc"))

  (assert (string-suffix? "" "abc"))
  (assert (string-suffix? "c" "abc"))
  (assert (string-suffix? "bc" "abc"))
  (assert (string-suffix? "abc" "abc"))
  (assert-not (string-suffix? "~abc" "abc"))
  (assert-not (string-suffix? "b" "abc")))

(define-test string-to-upper-case-test
  (assert-equal "ABC" (string-to-upper-case "abc"))
  (assert-equal "abc" (string-to-lower-case "ABC")))

(define-test string-get-code-point-test
  (assert-equal 97 (string-get-code-point 0 "abc"))
  (assert-equal 98 (string-get-code-point 1 "abc"))
  (assert-equal 99 (string-get-code-point 2 "abc")))
