(module test-suite)

(define-test list-test
  (= list (make-list))
  (list-push! 1 list)
  (list-push! 2 list)
  (list-push! 3 list)
  (assert-equal [1 2 3] list)

  (assert-equal [1 2 3] '(1 2 3))
  (assert-equal ['a 'b 'c] '(a b c))

  (assert-equal 3 (list-length [1 2 3]))
  (assert-equal 0 (list-length []))
  (assert (list-empty? []))

  (= list (make-list))
  (list-push! 1 list)
  (list-push! 2 list)
  (list-push! 3 list)
  (println list)

  (println (the (list-t int-t) [1 2 3]))
  (println [1 2 3])
  (println '(1 2 3))
  (println (@list 1 2 3))

  (println ['a 'b 'c])
  (println '(a b c)))
