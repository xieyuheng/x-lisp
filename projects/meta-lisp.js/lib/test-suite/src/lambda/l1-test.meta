(module l1)

(define (evaluate-and-print exp)
  (println (evaluate exp empty-env)))

(define-test l1-test
  (evaluate-and-print
   (lambda-exp 'x (var-exp 'x)))

  (evaluate-and-print
   (apply-exp
    (lambda-exp 'x (var-exp 'x))
    (lambda-exp 'x (var-exp 'x))))

  (evaluate-and-print
   (apply-exp
    (apply-exp
     (lambda-exp 'x (var-exp 'x))
     (lambda-exp 'x (var-exp 'x)))
    (apply-exp
     (lambda-exp 'x (var-exp 'x))
     (lambda-exp 'x (var-exp 'x))))))
