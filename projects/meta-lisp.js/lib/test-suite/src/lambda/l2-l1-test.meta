(module l2-l1)

(define (evaluate-and-print exp)
  (println (l2/evaluate exp l2/empty-env)))

(define-test l2-l1-test
  (evaluate-and-print
   (l2/lambda-exp 'x (l2/var-exp 'x)))

  (evaluate-and-print
   (l2/apply-exp
    (l2/lambda-exp 'x (l2/var-exp 'x))
    (l2/lambda-exp 'x (l2/var-exp 'x))))

  (evaluate-and-print
   (l2/apply-exp
    (l2/apply-exp
     (l2/lambda-exp 'x (l2/var-exp 'x))
     (l2/lambda-exp 'x (l2/var-exp 'x)))
    (l2/apply-exp
     (l2/lambda-exp 'x (l2/var-exp 'x))
     (l2/lambda-exp 'x (l2/var-exp 'x)))))

  ;; let

  (evaluate-and-print
   (l2/let-exp
    'id (l2/lambda-exp 'x (l2/var-exp 'x))
    (l2/var-exp 'id)))

  (evaluate-and-print
   (l2/let-exp
    'id (l2/lambda-exp 'x (l2/var-exp 'x))
    (l2/apply-exp (l2/var-exp 'id) (l2/var-exp 'id))))

  (evaluate-and-print
   (l2/let-exp
    'id (l2/lambda-exp 'x (l2/var-exp 'x))
    (l2/apply-exp
     (l2/apply-exp (l2/var-exp 'id) (l2/var-exp 'id))
     (l2/apply-exp (l2/var-exp 'id) (l2/var-exp 'id)))))

  ;; l1

  (evaluate-and-print
   (l1/lambda-exp 'x (l1/var-exp 'x)))

  (evaluate-and-print
   (l1/apply-exp
    (l1/lambda-exp 'x (l1/var-exp 'x))
    (l1/lambda-exp 'x (l1/var-exp 'x))))

  (evaluate-and-print
   (l1/apply-exp
    (l1/apply-exp
     (l1/lambda-exp 'x (l1/var-exp 'x))
     (l1/lambda-exp 'x (l1/var-exp 'x)))
    (l1/apply-exp
     (l1/lambda-exp 'x (l1/var-exp 'x))
     (l1/lambda-exp 'x (l1/var-exp 'x))))))
