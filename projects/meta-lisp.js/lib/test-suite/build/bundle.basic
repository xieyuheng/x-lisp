  (block body (test (list? value)) (branch then₃ else₄))
  (block then₁
    (= _₂ (list-head value))
    (return (equal? _₂ 'li)))
  (block else₂ (return false))
  (block then₃
    (= _₁ (list-length value))
    (test (equal? _₁ 3))
    (branch then₁ else₂))
  (block else₄ (return false)))

(define-function (my-list/li-head target)
  (block body (return (list-get 1 target))))

(define-function (my-list/li-tail target)
  (block body (return (list-get 2 target))))

(define-function (my-list/li-put-head value target)
  (block body (return (list-put 1 value target))))

(define-function (my-list/li-put-tail value target)
  (block body (return (list-put 2 value target))))

(define-function (my-list/li-put-head! value target)
  (block body (return (list-put! 1 value target))))

(define-function (my-list/li-put-tail! value target)
  (block body (return (list-put! 2 value target))))

(define-function (row-polymorphism/point-x point)
  (block body (= _₁ (record-get :x)) (return (_₁ point))))

(define-function (row-polymorphism/point-y point)
  (block body (= _₁ (record-get :y)) (return (_₁ point))))

