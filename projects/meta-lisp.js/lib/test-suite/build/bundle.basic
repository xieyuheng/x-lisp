    (= _₂ (_₁ point))
    (= _₃ (record-get :x))
    (= _₄ (_₃ point))
    (= _₅ (fmul _₂ _₄))
    (= _₆ (record-get :y))
    (= _₇ (_₆ point))
    (= _₈ (record-get :y))
    (= _₉ (_₈ point))
    (= _₁₀ (fmul _₇ _₉))
    (return (fadd _₅ _₁₀))))

(define-function (row-polymorphism-test)
  (block body
    (= record₁ (make-record))
    (perform (record-put! :x 1.0 record₁))
    (perform (record-put! :y 2.0 record₁))
    (= point₁ record₁)
    (= _₁ (record-get :x))
    (= _₂ (_₁ point₁))
    (perform (assert-equal 1.0 _₂))
    (= _₃ (record-get :y))
    (= _₄ (_₃ point₁))
    (perform (assert-equal 2.0 _₄))
    (= _₅ (point-x point₁))
    (perform (assert-equal 1.0 _₅))
    (= _₆ (point-y point₁))
    (perform (assert-equal 2.0 _₆))
    (= _₇ (point-distance-squared point₁))
    (return (assert-equal 5.0 _₇))))

(define-function (point-println point)
  (block body (return (println point))))

(define-function (main)
  (block body
    (= record₁ (make-record))
    (perform (record-put! :x 1.0 record₁))
    (perform (record-put! :y 2.0 record₁))
    (perform (point-println record₁))
    (= record₁ (make-record))
    (perform (record-put! :x 1.0 record₁))
    (return (point-println record₁))))

(define-function (main)
  (block body
    (= record₁ (make-record))
    (perform (record-put! :x 1.0 record₁))
    (perform (record-put! :y 2.0 record₁))
    (perform record₁)
    (= record₁ (make-record))
    (perform (record-put! :x 1.0 record₁))
    (return record₁)))
