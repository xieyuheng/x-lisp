(define-function (record-update-test)
  (block body
    (= record₁ (make-record))
    (perform (record-put! :x 1.0 record₁))
    (perform (record-put! :y 2.0 record₁))
    (= point₁ record₁)
    (= record₁ (make-record))
    (perform (record-put! :x 2.0 record₁))
    (perform (record-put! :y 2.0 record₁))
    (= _₁ (point-put-x 2.0 point₁))
    (perform (assert-equal record₁ _₁))
    (= record₁ (make-record))
    (perform (record-put! :x 1.0 record₁))
    (perform (record-put! :y 2.0 record₁))
    (perform (assert-equal record₁ point₁))
