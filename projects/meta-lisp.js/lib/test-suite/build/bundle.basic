(define-variable my-list/nil (block body (return 'nil)))

(define-function (my-list/nil? value)
  (block body (return (equal? value 'nil))))

(define-function (my-list/li head tail)
  (block body
    (= list₁ (make-list))
    (perform (list-push! 'li list₁))
    (perform (list-push! head list₁))
    (perform (list-push! tail list₁))
    (return list₁)))

