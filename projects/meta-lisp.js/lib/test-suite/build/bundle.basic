(define-function (float-product xs)
  (block body (test (list-empty? xs)) (branch then₁ else₂))
  (block then₁ (return 1.0))
  (block else₂
    (= _₁ (car xs))
    (= _₂ (cdr xs))
    (= _₃ (float-product _₂))
    (return (fmul _₁ _₃))))

