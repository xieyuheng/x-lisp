(define-function (int-align alignment n)
  (block body
    (= remainder₁ (imod n alignment))
    (test (equal? 0 remainder₁))
    (branch then₁ else₂))
  (block then₁ (return n))
  (block else₂
    (= _₁ (isub n remainder₁))
    (return (iadd _₁ alignment))))

