(define-function (file-test)
  (block body
    (= file₁ (open-input-file "src/file/file-1.txt"))
    (= _₁ (file-read file₁))
    (perform (assert-equal "abc\n" _₁))
    (perform (file-close file₁))
    (= file₂ (open-output-file "src/file/file-2.txt"))
    (perform (file-write file₂ "123\n"))
    (perform (file-close file₂))
    (= file₃ (open-input-file "src/file/file-2.txt"))
    (= _₂ (file-read file₃))
    (perform (assert-equal "123\n" _₂))
    (perform (file-close file₃))
    (= file₄ (open-output-file "src/file/file-2.txt"))
    (perform (file-write file₄ "abc\n"))
    (perform (file-close file₄))
    (= file₅ (open-input-file "src/file/file-2.txt"))
    (= _₃ (file-read file₅))
    (perform (assert-equal "abc\n" _₃))
    (return (file-close file₅))))

(define-function (fs-test)
  (block body
    (= _₁ (fs-read "src/fs/file-1.txt"))
    (perform (assert-equal "abc\n" _₁))
    (perform (fs-write "src/fs/file-2.txt" "123\n"))
    (= _₂ (fs-read "src/fs/file-2.txt"))
    (perform (assert-equal "123\n" _₂))
    (perform (fs-write "src/fs/file-2.txt" "abc\n"))
    (= _₃ (fs-read "src/fs/file-2.txt"))
    (perform (assert-equal "abc\n" _₃))
    (= _₄ (fs-list "src/fs"))
    (return (println _₄))))

(define-function (S x y z)
  (block body (= _₁ (y z)) (return (x z _₁))))

(define-function (K x y) (block body (return x)))

(define-function (I x) (block body (return x)))

(define-variable SKI (block body (return (S K I))))

(define-variable SKI-tuple
  (block body
    (= S₁ SKI-tuple©λ₁)
    (= K₁ SKI-tuple©λ₂)
    (= I₁ SKI-tuple©λ₃)
    (= list₁ (make-list))
    (perform (list-push! S₁ list₁))
    (perform (list-push! K₁ list₁))
    (perform (list-push! I₁ list₁))
    (return list₁)))

(define-function (SKI-tuple©λ₁ x₁ y₁ z₁)
  (block body (= _₁ (y₁ z₁)) (return (x₁ z₁ _₁))))

(define-function (SKI-tuple©λ₂ x₁ y₁)
  (block body (return x₁)))

(define-function (SKI-tuple©λ₃ x₁) (block body (return x₁)))

(define-function (compose f g x)
  (block body (= _₁ (g x)) (return (f _₁))))

(define-function (compose-test)
  (block body
    (= add1₁ (iadd 1))
    (= _₁ (compose add1₁ add1₁))
    (= _₂ (_₁ 1))
    (return (assert-equal 3 _₂))))

(define-function (curry-test)
  (block body
    (perform (assert-equal iadd iadd))
    (= _₁ (iadd 1))
    (= _₂ (iadd 1))
    (perform (assert-equal _₁ _₂))
    (= _₃ (iadd 1))
    (= _₄ (iadd 2))
    (perform (assert-not-equal _₃ _₄))
    (= _₅ (iadd 1))
    (= _₆ (_₅ 2))
    (= _₇ (iadd 1 2))
    (perform (assert-equal _₆ _₇))
    (= _₈ (isub 2))
    (= _₉ (_₈ 1))
    (perform (assert-equal 1 _₉))
    (= _₁₀ (isub 2 1))
    (return (assert-equal 1 _₁₀))))

(define-function (swap f x y) (block body (return (f y x))))

(define-function (drop f) (block body (return (drop©λ₁ f))))

(define-function (drop©λ₁ f dropped₁)
  (block body (return (drop©λ₁©λ₁ f))))

(define-function (drop©λ₁©λ₁ f x₁)
  (block body (return (f x₁))))

(define-function (dup f) (block body (return (dup©λ₁ f))))

(define-function (dup©λ₁ f x₁)
  (block body (return (f x₁ x₁))))

(define-function (forth-test)
  (block body
    (= f₁ forth-test©λ₁)
    (= square₁ (dup imul))
    (= _₁ (f₁ 1))
    (= _₂ (square₁ _₁))
    (perform (println _₂))
    (= _₃ (f₁ 2))
    (= _₄ (square₁ _₃))
    (perform (println _₄))
    (= _₅ (f₁ 3))
    (= _₆ (square₁ _₅))
    (perform (println _₆))
    (= _₇ (f₁ 4))
    (= _₈ (square₁ _₇))
    (return (println _₈))))

(define-function (forth-test©λ₁ x₁)
  (block body (return x₁)))

(define-function (function-test)
  (block body
    (perform (println iadd))
    (= _₁ (iadd 1))
    (return (println _₁))))

(define-function (identity x) (block body (return x)))

(define-function (identity-test)
  (block body
    (= add1₁ (iadd 1))
    (= _₁ (add1₁ 1))
    (perform (assert-equal 2 _₁))
    (= _₂ (identity 1))
    (= _₃ (iadd _₂))
    (= add1₂ (identity _₃))
    (perform identity)
    (perform identity)
    (perform identity)
    (= _₄ (add1₂ 1))
    (return (assert-equal 2 _₄))))

(define-function (hash-test)
  (block body
    (= hash₁ (make-hash))
    (= _₁ (hash-empty? hash₁))
    (perform (assert _₁))
    (= hash₁ (make-hash))
    (perform (println hash₁))
    (= hash₁ (make-hash))
    (perform (hash-put! 1 2 hash₁))
    (perform (println hash₁))
    (= hash₁ (make-hash))
    (perform (hash-put! 1 3 hash₁))
    (perform (println hash₁))
    (= hash₁ (make-hash))
    (perform (hash-put! 1 2 hash₁))
    (perform (hash-put! 3 4 hash₁))
    (return (println hash₁))))

(define-function (factorial n)
  (block body
    (test (int-less-or-equal? n 1))
    (branch then₁ else₂))
  (block then₁ (return 1))
  (block else₂
    (= _₁ (isub n 1))
    (= _₂ (factorial _₁))
    (return (imul _₂ n))))

(define-function (factorial-test)
  (block body
    (= _₁ (factorial 0))
    (perform (assert-equal 1 _₁))
    (= _₂ (factorial 1))
    (perform (assert-equal 1 _₂))
    (= _₃ (factorial 2))
    (perform (assert-equal 2 _₃))
    (= _₄ (factorial 3))
    (perform (assert-equal 6 _₄))
    (= _₅ (factorial 4))
    (perform (assert-equal 24 _₅))
    (= _₆ (factorial 5))
    (perform (assert-equal 120 _₆))
    (= _₇ (factorial 6))
    (return (assert-equal 720 _₇))))

(define-function (fibonacci n)
  (block body
    (test (int-less-or-equal? n 1))
    (branch then₁ else₂))
  (block then₁ (return n))
  (block else₂
    (= _₁ (isub n 1))
    (= _₂ (fibonacci _₁))
    (= _₃ (isub n 2))
    (= _₄ (fibonacci _₃))
    (return (iadd _₂ _₄))))

(define-function (fibonacci-test)
  (block body
    (= _₁ (fibonacci 0))
    (perform (assert-equal 0 _₁))
    (= _₂ (fibonacci 1))
    (perform (assert-equal 1 _₂))
    (= _₃ (fibonacci 2))
    (perform (assert-equal 1 _₃))
    (= _₄ (fibonacci 3))
    (perform (assert-equal 2 _₄))
    (= _₅ (fibonacci 4))
    (perform (assert-equal 3 _₅))
    (= _₆ (fibonacci 5))
    (perform (assert-equal 5 _₆))
    (= _₇ (fibonacci 6))
    (perform (assert-equal 8 _₇))
    (= _₈ (fibonacci 7))
    (perform (assert-equal 13 _₈))
    (= _₉ (fibonacci 8))
    (perform (assert-equal 21 _₉))
    (= _₁₀ (fibonacci 9))
    (return (assert-equal 34 _₁₀))))

(define-function (gcd a b)
  (block body (test (equal? b 0)) (branch then₁ else₂))
  (block then₁ (return a))
  (block else₂ (= _₁ (imod a b)) (return (gcd b _₁))))

(define-function (gcd-test)
  (block body
    (= _₁ (gcd 13 7))
    (perform (assert-equal 1 _₁))
    (= _₂ (gcd 12 8))
    (return (assert-equal 4 _₂))))

(define-function (square x)
  (block body (return (imul x x))))

(define-function (square-test)
  (block body
    (= _₁ (square 3))
    (= _₂ (square _₁))
    (return (assert-equal 81 _₂))))

(define-function (keyword-test)
  (block body
    (= _₁ (keyword-append :abc :def))
    (perform (assert-equal :abcdef _₁))
    (return (println :abc))))

(define-function (list-test)
  (block body
    (= list₁ (make-list))
    (perform (list-push! 1 list₁))
    (perform (list-push! 2 list₁))
    (perform (list-push! 3 list₁))
    (= list₂ (make-list))
    (perform (list-push! 1 list₂))
    (perform (list-push! 2 list₂))
    (perform (list-push! 3 list₂))
    (perform (assert-equal list₂ list₁))
    (= list₂ (make-list))
    (perform (list-push! 1 list₂))
    (perform (list-push! 2 list₂))
    (perform (list-push! 3 list₂))
    (= list₂ (make-list))
    (perform (list-push! 1 list₂))
    (perform (list-push! 2 list₂))
    (perform (list-push! 3 list₂))
    (perform (assert-equal list₂ list₂))
    (= list₂ (make-list))
    (perform (list-push! 'a list₂))
    (perform (list-push! 'b list₂))
    (perform (list-push! 'c list₂))
    (= list₂ (make-list))
    (perform (list-push! 'a list₂))
    (perform (list-push! 'b list₂))
    (perform (list-push! 'c list₂))
    (perform (assert-equal list₂ list₂))
    (= list₂ (make-list))
    (perform (list-push! 1 list₂))
    (perform (list-push! 2 list₂))
    (perform (list-push! 3 list₂))
    (= _₁ (list-length list₂))
    (perform (assert-equal 3 _₁))
    (= list₂ (make-list))
    (= _₂ (list-length list₂))
    (perform (assert-equal 0 _₂))
    (= list₂ (make-list))
    (= _₃ (list-empty? list₂))
    (perform (assert _₃))
    (= list₂ (make-list))
    (perform (list-push! 1 list₂))
    (perform (list-push! 2 list₂))
    (perform (list-push! 3 list₂))
    (perform (println list₂))
    (= list₃ (make-list))
    (perform (list-push! 1 list₃))
    (perform (list-push! 2 list₃))
    (perform (list-push! 3 list₃))
    (perform (println list₃))
    (= list₃ (make-list))
    (perform (list-push! 1 list₃))
    (perform (list-push! 2 list₃))
    (perform (list-push! 3 list₃))
    (perform (println list₃))
    (= list₃ (make-list))
    (perform (list-push! 1 list₃))
    (perform (list-push! 2 list₃))
    (perform (list-push! 3 list₃))
    (perform (println list₃))
    (= list₃ (make-list))
    (perform (list-push! 1 list₃))
    (perform (list-push! 2 list₃))
    (perform (list-push! 3 list₃))
    (perform (println list₃))
    (= list₃ (make-list))
    (perform (list-push! 'a list₃))
    (perform (list-push! 'b list₃))
    (perform (list-push! 'c list₃))
    (perform (println list₃))
    (= list₃ (make-list))
    (perform (list-push! 'a list₃))
    (perform (list-push! 'b list₃))
    (perform (list-push! 'c list₃))
    (return (println list₃))))

(define-function (cond-mismatch-test)
  (block body (test (equal? 1 2)) (branch then₃ else₄))
  (block then₁ (return void))
  (block else₂ (return (error "cond mismatch")))
  (block then₃ (return void))
  (block else₄ (test (equal? 1 2)) (branch then₁ else₂)))

(define-function (cond-test)
  (block body (test (equal? 1 1)) (branch then₁₃ else₁₄))
  (block then₁ (return (assert false)))
  (block else₂ (return (assert true)))
  (block let-body₃ (test (equal? 1 2)) (branch then₁ else₂))
  (block let-body₄ (goto let-body₃))
  (block then₅ (perform (assert true)) (goto let-body₃))
  (block else₆ (perform (assert false)) (goto let-body₄))
  (block let-body₇
    (perform (assert-equal 2 _₂))
    (test (equal? 1 1))
    (branch then₅ else₆))
  (block let-body₈ (goto let-body₇))
  (block then₉ (= _₂ 1) (goto let-body₇))
  (block else₁₀ (= _₂ 2) (goto let-body₈))
  (block let-body₁₁
    (perform (assert-equal 1 _₁))
    (test (equal? 1 2))
    (branch then₉ else₁₀))
  (block let-body₁₂ (goto let-body₁₁))
  (block then₁₃ (= _₁ 1) (goto let-body₁₁))
  (block else₁₄ (= _₁ 2) (goto let-body₁₂)))

(define-function (if-test)
  (block body (= _₁ 1) (goto let-body₁₀))
  (block let-body₁ (= _₈ (not _₇)) (return (assert _₈)))
  (block let-body₂ (goto let-body₁))
  (block let-body₃
    (perform (assert _₆))
    (= _₇ false)
    (goto let-body₂))
  (block let-body₄ (goto let-body₃))
  (block let-body₅
    (= _₅ (not _₄))
    (perform (assert _₅))
    (= _₆ true)
    (goto let-body₄))
  (block let-body₆ (goto let-body₅))
  (block let-body₇
    (perform (assert _₃))
    (= _₄ false)
    (goto let-body₆))
  (block let-body₈ (goto let-body₇))
  (block let-body₉
    (perform (assert-equal _₂ 2))
    (= _₃ true)
    (goto let-body₈))
  (block let-body₁₀
    (perform (assert-equal _₁ 1))
    (= _₂ 2)
    (goto let-body₉)))

