    (branch then₆ else₇))
  (block let-body₁ (return (println _₁)))
  (block then₂ (= _₁ 0) (goto let-body₁))
  (block else₃ (= _₁ 42) (goto let-body₁))
  (block then₄ (goto then₂))
  (block else₅ (goto else₃))
  (block then₆
    (= _₃ (random-dice))
    (test (equal? _₃ 2))
    (branch then₄ else₅))
  (block else₇ (goto else₃)))

