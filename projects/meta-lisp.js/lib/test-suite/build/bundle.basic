    (perform (list-push! 2.0 list₁))
    (perform (list-push! 3.0 list₁))
    (= _₂ (float-product list₁))
    (perform (assert-equal 6.0 _₂))
    (= list₁ (make-list))
    (perform (list-push! 1.0 list₁))
    (perform (list-push! 2.0 list₁))
    (perform (list-push! 3.0 list₁))
    (perform (list-push! 4.0 list₁))
    (= _₃ (float-product list₁))
    (return (assert-equal 24.0 _₃))))

