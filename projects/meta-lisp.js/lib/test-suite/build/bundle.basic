(define-function (eoc-04-02)
  (block body
    (= x₁ (random-dice))
    (= y₁ (random-dice))
    (test (int-less? x₁ 1))
    (branch then₈ else₉))
  (block let-body₁ (return (println _₁)))
  (block then₂ (= _₁ (iadd y₁ 2)) (goto let-body₁))
  (block else₃ (= _₁ (iadd y₁ 10)) (goto let-body₁))
  (block then₄ (goto then₂))
  (block else₅ (goto else₃))
  (block then₆ (goto then₂))
  (block else₇ (goto else₃))
  (block then₈ (test (equal? x₁ 0)) (branch then₄ else₅))
  (block else₉ (test (equal? x₁ 2)) (branch then₆ else₇)))

(define-function (eoc-04-03)
  (block body
    (= x₁ (random-dice))
    (= y₁ (random-dice))
    (test (int-less? x₁ 1))
    (branch then₁₇ else₁₈))
  (block let-body₁
    (= _₃ (iadd _₁ _₂))
    (return (println _₃)))
  (block then₂ (= _₂ (iadd y₁ 2)) (goto let-body₁))
  (block else₃ (= _₂ (iadd y₁ 10)) (goto let-body₁))
  (block then₄ (goto then₂))
  (block else₅ (goto else₃))
  (block then₆ (goto then₂))
  (block else₇ (goto else₃))
  (block then₈ (test (equal? x₁ 0)) (branch then₄ else₅))
  (block else₉ (test (equal? x₁ 2)) (branch then₆ else₇))
  (block let-body₁₀
    (test (int-less? x₁ 1))
    (branch then₈ else₉))
  (block then₁₁ (= _₁ (iadd y₁ 2)) (goto let-body₁₀))
  (block else₁₂ (= _₁ (iadd y₁ 10)) (goto let-body₁₀))
  (block then₁₃ (goto then₁₁))
  (block else₁₄ (goto else₁₂))
  (block then₁₅ (goto then₁₁))
  (block else₁₆ (goto else₁₂))
  (block then₁₇ (test (equal? x₁ 0)) (branch then₁₃ else₁₄))
  (block else₁₈ (test (equal? x₁ 2)) (branch then₁₅ else₁₆)))

(define-function (eoc-04-04)
