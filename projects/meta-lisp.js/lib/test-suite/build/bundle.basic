    (perform (assert-equal 0 _₁))
    (= _₂ (int-align 16 8))
    (perform (assert-equal 16 _₂))
    (= _₃ (int-align 16 16))
    (perform (assert-equal 16 _₃))
    (= _₄ (int-align 16 24))
    (return (assert-equal 32 _₄))))

