(define-function (main)
  (block body
    (= _₁ (path-directory-name "a/b/c/file.test.txt"))
    (perform (assert-equal "a/b/c" _₁))
    (= _₂ (path-base-name "a/b/c/file.test.txt"))
    (perform (assert-equal "file.test.txt" _₂))
    (= _₃ (path-extension "a/b/c/file.test.txt"))
    (perform (assert-equal ".txt" _₃))
    (= _₄ (path-stem "a/b/c/file.test.txt"))
    (perform (assert-equal "file.test" _₄))
    (= _₅ (path-absolute? "/a/b/c/file.test.txt"))
    (perform (assert _₅))
    (= _₆ (path-relative? "/a/b/c/file.test.txt"))
    (perform (assert-not _₆))
    (= _₇ (path-relative? "a/b/c/file.test.txt"))
    (perform (assert _₇))
    (= _₈ (path-relative? "./a/b/c/file.test.txt"))
    (perform (assert _₈))
    (= _₉ (path-absolute? "a/b/c/file.test.txt"))
    (perform (assert-not _₉))
    (= _₁₀ (path-absolute? "./a/b/c/file.test.txt"))
    (perform (assert-not _₁₀))
    (= _₁₁ (path-join "a/b/c" "d/e/f"))
    (perform (assert-equal "a/b/c/d/e/f" _₁₁))
    (= _₁₂ (path-join "a/b/c/" "/d/e/f"))
    (perform (assert-equal "a/b/c/d/e/f" _₁₂))
    (= _₁₃ (path-join "/a/b/c/" "/d/e/f"))
    (perform (assert-equal "/a/b/c/d/e/f" _₁₃))
    (= _₁₄ (path-normalize "a/b/c/../d"))
    (perform (assert-equal "a/b/d" _₁₄))
    (= _₁₅ (path-normalize "///a/b/c/"))
    (return (assert-equal "/a/b/c" _₁₅))))