(define-function (main)
  (block body
    (= list₁ (make-list))
    (perform (list-push! 1 list₁))
    (perform (list-push! 2 list₁))
    (perform (list-push! 3 list₁))
    (= list₂ (make-list))
    (perform (list-push! 1 list₂))
    (perform (list-push! 2 list₂))
    (perform (list-push! 3 list₂))
    (perform (assert-equal list₂ list₁))
    (= list₂ (make-list))
    (perform (list-push! 1 list₂))
    (perform (list-push! 2 list₂))
    (perform (list-push! 3 list₂))
    (= list₂ (make-list))
    (perform (list-push! 1 list₂))
    (perform (list-push! 2 list₂))
    (perform (list-push! 3 list₂))
    (perform (assert-equal list₂ list₂))
    (= list₂ (make-list))
    (perform (list-push! 'a list₂))
    (perform (list-push! 'b list₂))
    (perform (list-push! 'c list₂))
    (= list₂ (make-list))
    (perform (list-push! 'a list₂))
    (perform (list-push! 'b list₂))
    (perform (list-push! 'c list₂))
    (perform (assert-equal list₂ list₂))
    (= list₂ (make-list))
    (perform (list-push! 1 list₂))
    (perform (list-push! 2 list₂))
    (perform (list-push! 3 list₂))
    (= _₁ (list-length list₂))
    (perform (assert-equal 3 _₁))
    (= list₂ (make-list))
    (= _₂ (list-length list₂))
    (perform (assert-equal 0 _₂))
    (= list₂ (make-list))
    (= _₃ (list-empty? list₂))
    (return (assert _₃))))