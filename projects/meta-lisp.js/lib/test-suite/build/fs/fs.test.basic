(define-function (main)
  (block body
    (= _₁ (fs-read "src/fs/file-1.txt"))
    (perform (assert-equal "abc\n" _₁))
    (perform (fs-write "src/fs/file-2.txt" "123\n"))
    (= _₂ (fs-read "src/fs/file-2.txt"))
    (perform (assert-equal "123\n" _₂))
    (perform (fs-write "src/fs/file-2.txt" "abc\n"))
    (= _₃ (fs-read "src/fs/file-2.txt"))
    (return (assert-equal "abc\n" _₃))))