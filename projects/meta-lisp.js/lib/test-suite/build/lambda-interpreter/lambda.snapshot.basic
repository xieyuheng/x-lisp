(import-all "lambda")

(define-function (evaluate-and-print exp)
  (block body
    (= _₁ (evaluate exp empty-env))
    (return (println _₁))))

(define-function (main)
  (block body
    (= _₁ (var-exp 'x))
    (= _₂ (lambda-exp 'x _₁))
    (perform (evaluate-and-print _₂))
    (= _₃ (var-exp 'x))
    (= _₄ (lambda-exp 'x _₃))
    (= _₅ (var-exp 'x))
    (= _₆ (lambda-exp 'x _₅))
    (= _₇ (apply-exp _₄ _₆))
    (perform (evaluate-and-print _₇))
    (= _₈ (var-exp 'x))
    (= _₉ (lambda-exp 'x _₈))
    (= _₁₀ (var-exp 'x))
    (= _₁₁ (lambda-exp 'x _₁₀))
    (= _₁₂ (apply-exp _₉ _₁₁))
    (= _₁₃ (var-exp 'x))
    (= _₁₄ (lambda-exp 'x _₁₃))
    (= _₁₅ (var-exp 'x))
    (= _₁₆ (lambda-exp 'x _₁₅))
    (= _₁₇ (apply-exp _₁₄ _₁₆))
    (= _₁₈ (apply-exp _₁₂ _₁₇))
    (return (evaluate-and-print _₁₈))))