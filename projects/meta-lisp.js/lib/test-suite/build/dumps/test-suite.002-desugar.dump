(define-test eoc-04-01 (println (if true 1 2)))

(define-test eoc-04-02
  (println
   (begin
     (= x (random-dice))
     (= y (random-dice))
     (if (if (int-less? x 1) (equal? x 0) (equal? x 2))
       (iadd y 2)
       (iadd y 10)))))

(define-test eoc-04-03
  (println
   (begin
     (= x (random-dice))
     (= y (random-dice))
     (iadd
      (if (if (int-less? x 1) (equal? x 0) (equal? x 2))
        (iadd y 2)
        (iadd y 10))
      (if (if (int-less? x 1) (equal? x 0) (equal? x 2))
        (iadd y 2)
        (iadd y 10))))))

(define-test eoc-04-04
  (println
   (if
       (if (equal? (random-dice) 1)
         (equal? (random-dice) 2)
         false)
     0
     42)))

(define-test eoc-05-01
  (print 1)
  (newline)
  (print 2)
  (newline)
  (print 3)
  (newline)
  void)

(define-test eoc-05-02
  (= x
     (begin
       (print 1)
       (newline)
       (print 2)
       (newline)
       (print 3)
       (newline)
       6))
  (print 4)
  (newline)
  (print 5)
  (newline)
  (print 6)
  (newline)
  (print (iadd x x))
  (newline)
  void)

(define-test eoc-05-03
  (if
      (begin
        (print 1)
        (newline)
        (print 2)
        (newline)
        (print 3)
        (newline)
        (equal? 1 2))
    (begin (print 111) (newline))
    (begin (print 222) (newline))))

(define-test file-test
  (= file (open-input-file "src/file/file-1.txt"))
  (assert-equal "abc\n" (file-read file))
  (file-close file)
  (= file (open-output-file "src/file/file-2.txt"))
  (file-write file "123\n")
  (file-close file)
  (= file (open-input-file "src/file/file-2.txt"))
  (assert-equal "123\n" (file-read file))
  (file-close file)
  (= file (open-output-file "src/file/file-2.txt"))
  (file-write file "abc\n")
  (file-close file)
  (= file (open-input-file "src/file/file-2.txt"))
  (assert-equal "abc\n" (file-read file))
  (file-close file))

(define-test fs-test
  (assert-equal "abc\n" (fs-read "src/fs/file-1.txt"))
  (fs-write "src/fs/file-2.txt" "123\n")
  (assert-equal "123\n" (fs-read "src/fs/file-2.txt"))
  (fs-write "src/fs/file-2.txt" "abc\n")
  (assert-equal "abc\n" (fs-read "src/fs/file-2.txt"))
  (println (fs-list "src/fs")))

(define (S x y z) (x z (y z)))

(define (K x y) x)

(define (I x) x)

(define SKI (S K I))

(define SKI-record
  (= S (lambda (x y z) (x z (y z))))
  (= K (lambda (x y) x))
  (= I (lambda (x) x))
  (@record :S S :K K :I I))

(claim compose
  (polymorphic (A B C) (-> (-> B C) (-> A B) (-> A C))))

(define (compose f g x) (f (g x)))

(define-test compose-test
  (= add1 (iadd 1))
  (assert-equal 3 ((compose add1 add1) 1)))

(define-test curry-test
  (assert-equal iadd iadd)
  (assert-equal (iadd 1) (iadd 1))
  (assert-not-equal (iadd 1) (iadd 2))
  (assert-equal ((iadd 1) 2) (iadd 1 2))
  (assert-equal 1 ((isub 2) 1))
  (assert-equal 1 (isub 2 1)))

(claim swap
  (polymorphic (X Y Z) (-> (-> Y X Z) (-> X Y Z))))

(define (swap f x y) (f y x))

(claim drop (polymorphic (X Y Z) (-> (-> X Z) (-> Y X Z))))

(define (drop f) (lambda (dropped) (lambda (x) (f x))))

(claim dup (polymorphic (X Z) (-> (-> X X Z) (-> X Z))))

(define (dup f) (lambda (x) (f x x)))

(define-test forth-test
  (= f (lambda (x) x))
  (= square (dup imul))
  (println (square (f 1)))
  (println (square (f 2)))
  (println (square (f 3)))
  (println (square (f 4))))

(define-test function-test
  (println iadd)
  (println (iadd 1)))

(claim identity (polymorphic (A) (-> A A)))

(define (identity x) x)

(define-test identity-test
  (= add1 (iadd 1))
  (assert-equal 2 (add1 1))
  (= add1 (identity (iadd (identity 1))))
  (the (-> int-t int-t) identity)
  (the (-> float-t float-t) identity)
  (the (polymorphic (A) (-> A A)) identity)
  (assert-equal 2 (add1 1)))

(define-test hash-test
  (assert
    (hash-empty? (begin (= hash (builtin/make-hash)) hash)))
  (println (begin (= hash (builtin/make-hash)) hash))
  (println
   (begin
     (= hash (builtin/make-hash))
     (builtin/hash-put! 1 2 hash)
     hash))
  (println
   (begin
     (= hash (builtin/make-hash))
     (builtin/hash-put! 1 3 hash)
     hash))
  (println
   (begin
     (= hash (builtin/make-hash))
     (builtin/hash-put! 1 2 hash)
     (builtin/hash-put! 3 4 hash)
     hash)))

(claim factorial (-> builtin/int-t builtin/int-t))

(define (factorial n)
  (if (int-less-or-equal? n 1)
    1
    (imul (factorial (isub n 1)) n)))

(define-test factorial-test
  (assert-equal 1 (factorial 0))
  (assert-equal 1 (factorial 1))
  (assert-equal 2 (factorial 2))
  (assert-equal 6 (factorial 3))
  (assert-equal 24 (factorial 4))
  (assert-equal 120 (factorial 5))
  (assert-equal 720 (factorial 6)))

(claim fibonacci (-> builtin/int-t builtin/int-t))

(define (fibonacci n)
  (if (int-less-or-equal? n 1)
    n
    (iadd (fibonacci (isub n 1)) (fibonacci (isub n 2)))))

(define-test fibonacci-test
  (assert-equal 0 (fibonacci 0))
  (assert-equal 1 (fibonacci 1))
  (assert-equal 1 (fibonacci 2))
  (assert-equal 2 (fibonacci 3))
  (assert-equal 3 (fibonacci 4))
  (assert-equal 5 (fibonacci 5))
  (assert-equal 8 (fibonacci 6))
  (assert-equal 13 (fibonacci 7))
  (assert-equal 21 (fibonacci 8))
  (assert-equal 34 (fibonacci 9)))

(claim gcd (-> builtin/int-t builtin/int-t builtin/int-t))

(define (gcd a b) (if (equal? b 0) a (gcd b (imod a b))))

(define-test gcd-test
  (assert-equal 1 (gcd 13 7))
  (assert-equal 4 (gcd 12 8)))

(claim square (-> builtin/int-t builtin/int-t))

(define (square x) (imul x x))

(define-test square-test
  (assert-equal 81 (square (square 3))))

(define-test keyword-test
  (assert-equal :abcdef (keyword-append :abc :def))
  (println :abc))

(define-test list-test
  (= list (make-list))
  (list-push! 1 list)
  (list-push! 2 list)
  (list-push! 3 list)
  (println list)
  (println
   (the (list-t int-t)
     (begin
       (= list (builtin/make-list))
       (builtin/list-push! 1 list)
       (builtin/list-push! 2 list)
       (builtin/list-push! 3 list)
       list)))
  (println
   (begin
     (= list (builtin/make-list))
     (builtin/list-push! 1 list)
     (builtin/list-push! 2 list)
     (builtin/list-push! 3 list)
     list))
  (println
   (begin
     (= list (builtin/make-list))
     (builtin/list-push! 1 list)
     (builtin/list-push! 2 list)
     (builtin/list-push! 3 list)
     list))
  (println
   (begin
     (= list (builtin/make-list))
     (builtin/list-push! 1 list)
     (builtin/list-push! 2 list)
     (builtin/list-push! 3 list)
     list))
  (println
   (begin
     (= list (builtin/make-list))
     (builtin/list-push! 'a list)
     (builtin/list-push! 'b list)
     (builtin/list-push! 'c list)
     list))
  (println
   (begin
     (= list (builtin/make-list))
     (builtin/list-push! 'a list)
     (builtin/list-push! 'b list)
     (builtin/list-push! 'c list)
     list))
  (assert-equal
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 1 list)
      (builtin/list-push! 2 list)
      (builtin/list-push! 3 list)
      list)
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 1 list)
      (builtin/list-push! 2 list)
      (builtin/list-push! 3 list)
      list))
  (assert-equal
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 'a list)
      (builtin/list-push! 'b list)
      (builtin/list-push! 'c list)
      list)
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 'a list)
      (builtin/list-push! 'b list)
      (builtin/list-push! 'c list)
      list))
  (assert-equal
    (begin
      (= list (builtin/make-list))
      (builtin/list-push!
       (begin
         (= list (builtin/make-list))
         (builtin/list-push! 1 list)
         (builtin/list-push! 2 list)
         (builtin/list-push! 3 list)
         list)
       list)
      (builtin/list-push!
       (begin
         (= list (builtin/make-list))
         (builtin/list-push! 4 list)
         (builtin/list-push! 5 list)
         (builtin/list-push! 6 list)
         list)
       list)
      (builtin/list-push!
       (begin
         (= list (builtin/make-list))
         (builtin/list-push! 7 list)
         (builtin/list-push! 8 list)
         (builtin/list-push! 9 list)
         list)
       list)
      list)
    (begin
      (= list (builtin/make-list))
      (builtin/list-push!
       (begin
         (= list (builtin/make-list))
         (builtin/list-push! 1 list)
         (builtin/list-push! 2 list)
         (builtin/list-push! 3 list)
         list)
       list)
      (builtin/list-push!
       (begin
         (= list (builtin/make-list))
         (builtin/list-push! 4 list)
         (builtin/list-push! 5 list)
         (builtin/list-push! 6 list)
         list)
       list)
      (builtin/list-push!
       (begin
         (= list (builtin/make-list))
         (builtin/list-push! 7 list)
         (builtin/list-push! 8 list)
         (builtin/list-push! 9 list)
         list)
       list)
      list))
  (assert-not-equal
    (begin
      (= list (builtin/make-list))
      (builtin/list-push!
       (begin
         (= list (builtin/make-list))
         (builtin/list-push! 1 list)
         (builtin/list-push! 2 list)
         (builtin/list-push! 3 list)
         list)
       list)
      (builtin/list-push!
       (begin
         (= list (builtin/make-list))
         (builtin/list-push! 4 list)
         (builtin/list-push! 5 list)
         (builtin/list-push! 6 list)
         list)
       list)
      (builtin/list-push!
       (begin
         (= list (builtin/make-list))
         (builtin/list-push! 7 list)
         (builtin/list-push! 8 list)
         (builtin/list-push! 9 list)
         list)
       list)
      list)
    (begin
      (= list (builtin/make-list))
      (builtin/list-push!
       (begin
         (= list (builtin/make-list))
         (builtin/list-push! 1 list)
         (builtin/list-push! 2 list)
         (builtin/list-push! 3 list)
         list)
       list)
      (builtin/list-push!
       (begin
         (= list (builtin/make-list))
         (builtin/list-push! 4 list)
         (builtin/list-push! 5 list)
         (builtin/list-push! 6 list)
         list)
       list)
      (builtin/list-push!
       (begin
         (= list (builtin/make-list))
         (builtin/list-push! 7 list)
         (builtin/list-push! 8 list)
         (builtin/list-push! 10 list)
         list)
       list)
      list))
  (assert
    (list-empty? (begin (= list (builtin/make-list)) list)))
  (assert-not
    (list-empty?
     (begin
       (= list (builtin/make-list))
       (builtin/list-push! 1 list)
       list)))
  (assert-equal
    (cons
     1
     (cons
      2
      (cons 3 (begin (= list (builtin/make-list)) list))))
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 1 list)
      (builtin/list-push! 2 list)
      (builtin/list-push! 3 list)
      list))
  (assert-equal
    (car (begin
           (= list (builtin/make-list))
           (builtin/list-push! 1 list)
           (builtin/list-push! 2 list)
           (builtin/list-push! 3 list)
           list))
    1)
  (assert-equal
    (cdr (begin
           (= list (builtin/make-list))
           (builtin/list-push! 1 list)
           (builtin/list-push! 2 list)
           (builtin/list-push! 3 list)
           list))
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 2 list)
      (builtin/list-push! 3 list)
      list))
  (assert-equal
    (list-head
     (begin
       (= list (builtin/make-list))
       (builtin/list-push! 1 list)
       (builtin/list-push! 2 list)
       (builtin/list-push! 3 list)
       list))
    1)
  (assert-equal
    (list-tail
     (begin
       (= list (builtin/make-list))
       (builtin/list-push! 1 list)
       (builtin/list-push! 2 list)
       (builtin/list-push! 3 list)
       list))
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 2 list)
      (builtin/list-push! 3 list)
      list))
  (assert-equal
    (list-init
     (begin
       (= list (builtin/make-list))
       (builtin/list-push! 1 list)
       (builtin/list-push! 2 list)
       (builtin/list-push! 3 list)
       list))
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 1 list)
      (builtin/list-push! 2 list)
      list))
  (assert-equal
    (list-last
     (begin
       (= list (builtin/make-list))
       (builtin/list-push! 1 list)
       (builtin/list-push! 2 list)
       (builtin/list-push! 3 list)
       list))
    3)
  (assert-equal
    (begin
      (= set (builtin/make-set))
      (builtin/set-add! 1 set)
      (builtin/set-add! 2 set)
      (builtin/set-add! 3 set)
      set)
    (list-to-set
     (begin
       (= list (builtin/make-list))
       (builtin/list-push! 1 list)
       (builtin/list-push! 2 list)
       (builtin/list-push! 3 list)
       list)))
  (assert-equal
    (list-copy
     (begin
       (= list (builtin/make-list))
       (builtin/list-push! 1 list)
       (builtin/list-push! 2 list)
       (builtin/list-push! 3 list)
       list))
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 1 list)
      (builtin/list-push! 2 list)
      (builtin/list-push! 3 list)
      list))
  (assert-equal
    (list-get
     0
     (begin
       (= list (builtin/make-list))
       (builtin/list-push! 1 list)
       (builtin/list-push! 2 list)
       (builtin/list-push! 3 list)
       list))
    1)
  (assert-equal
    (list-get
     1
     (begin
       (= list (builtin/make-list))
       (builtin/list-push! 1 list)
       (builtin/list-push! 2 list)
       (builtin/list-push! 3 list)
       list))
    2)
  (assert-equal
    (list-get
     2
     (begin
       (= list (builtin/make-list))
       (builtin/list-push! 1 list)
       (builtin/list-push! 2 list)
       (builtin/list-push! 3 list)
       list))
    3)
  (assert-equal
    (list-length (begin (= list (builtin/make-list)) list))
    0)
  (assert-equal
    (list-length
     (begin
       (= list (builtin/make-list))
       (builtin/list-push! 1 list)
       (builtin/list-push! 2 list)
       (builtin/list-push! 3 list)
       list))
    3)
  (assert-equal
    (list-length
     (begin
       (= list (builtin/make-list))
       (builtin/list-push!
        (begin
          (= list (builtin/make-list))
          (builtin/list-push! 1 list)
          (builtin/list-push! 2 list)
          (builtin/list-push! 3 list)
          list)
        list)
       (builtin/list-push!
        (begin
          (= list (builtin/make-list))
          (builtin/list-push! 4 list)
          (builtin/list-push! 5 list)
          (builtin/list-push! 6 list)
          list)
        list)
       (builtin/list-push!
        (begin
          (= list (builtin/make-list))
          (builtin/list-push! 7 list)
          (builtin/list-push! 8 list)
          (builtin/list-push! 9 list)
          list)
        list)
       list))
    3)
  (= fs
     (the (list-t (-> int-t int-t))
       (begin
         (= list (builtin/make-list))
         (builtin/list-push! (iadd 1) list)
         (builtin/list-push! (iadd 2) list)
         (builtin/list-push! (iadd 3) list)
         list)))
  (assert-equal 1 ((list-get 0 fs) 0))
  (assert-equal 2 ((list-get 1 fs) 0))
  (assert-equal 3 ((list-get 2 fs) 0)))

(define-test list-pop-test
  (= list
     (begin
       (= list (builtin/make-list))
       (builtin/list-push! 1 list)
       (builtin/list-push! 2 list)
       (builtin/list-push! 3 list)
       list))
  (assert-equal 3 (list-pop! list))
  (assert-equal 2 (list-pop! list))
  (assert-equal 1 (list-pop! list))
  (assert-equal
    list
    (begin (= list (builtin/make-list)) list)))

(define-test list-push-test
  (begin
    (= list (begin (= list (builtin/make-list)) list))
    (= list (list-push 1 list))
    (= list (list-push 2 list))
    (= list (list-push 3 list))
    (assert-equal
      list
      (begin
        (= list (builtin/make-list))
        (builtin/list-push! 1 list)
        (builtin/list-push! 2 list)
        (builtin/list-push! 3 list)
        list)))
  (begin
    (= list (begin (= list (builtin/make-list)) list))
    (list-push 1 list)
    (list-push 2 list)
    (list-push 3 list)
    (assert-equal
      list
      (begin (= list (builtin/make-list)) list)))
  (= list (begin (= list (builtin/make-list)) list))
  (list-push! 1 list)
  (list-push! 2 list)
  (list-push! 3 list)
  (assert-equal
    list
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 1 list)
      (builtin/list-push! 2 list)
      (builtin/list-push! 3 list)
      list)))

(define-test list-put-test
  (begin
    (= list
       (begin
         (= list (builtin/make-list))
         (builtin/list-push! 0 list)
         (builtin/list-push! 0 list)
         (builtin/list-push! 0 list)
         list))
    (= list (list-put 0 1 list))
    (= list (list-put 1 2 list))
    (= list (list-put 2 3 list))
    (assert-equal
      list
      (begin
        (= list (builtin/make-list))
        (builtin/list-push! 1 list)
        (builtin/list-push! 2 list)
        (builtin/list-push! 3 list)
        list)))
  (begin
    (= list
       (begin
         (= list (builtin/make-list))
         (builtin/list-push! 0 list)
         (builtin/list-push! 0 list)
         (builtin/list-push! 0 list)
         list))
    (list-put 0 1 list)
    (list-put 1 2 list)
    (list-put 2 3 list)
    (assert-equal
      list
      (begin
        (= list (builtin/make-list))
        (builtin/list-push! 0 list)
        (builtin/list-push! 0 list)
        (builtin/list-push! 0 list)
        list)))
  (= list
     (begin
       (= list (builtin/make-list))
       (builtin/list-push! 0 list)
       (builtin/list-push! 0 list)
       (builtin/list-push! 0 list)
       list))
  (list-put! 0 1 list)
  (list-put! 1 2 list)
  (list-put! 2 3 list)
  (assert-equal
    list
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 1 list)
      (builtin/list-push! 2 list)
      (builtin/list-push! 3 list)
      list)))

(define-test list-reverse-test
  (assert-equal
    (list-reverse
     (begin
       (= list (builtin/make-list))
       (builtin/list-push! 1 list)
       (builtin/list-push! 2 list)
       (builtin/list-push! 3 list)
       list))
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 3 list)
      (builtin/list-push! 2 list)
      (builtin/list-push! 1 list)
      list)))

(define-test list-shift-test
  (begin
    (= list
       (begin
         (= list (builtin/make-list))
         (builtin/list-push! 1 list)
         (builtin/list-push! 2 list)
         (builtin/list-push! 3 list)
         list))
    (assert-equal 1 (list-shift! list))
    (assert-equal 2 (list-shift! list))
    (assert-equal 3 (list-shift! list))
    (assert-equal
      list
      (begin (= list (builtin/make-list)) list)))
  (= list (begin (= list (builtin/make-list)) list))
  (list-unshift! 3 list)
  (list-unshift! 2 list)
  (list-unshift! 1 list)
  (assert-equal
    list
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 1 list)
      (builtin/list-push! 2 list)
      (builtin/list-push! 3 list)
      list)))

(define-test cond-test
  (assert-equal
    1
    (if (equal? 1 1)
      1
      (if true 2 (builtin/error "cond mismatch"))))
  (assert-equal
    2
    (if (equal? 1 2)
      1
      (if true 2 (builtin/error "cond mismatch"))))
  (if (equal? 1 1)
    (assert true)
    (if true (assert false) (builtin/error "cond mismatch")))
  (if (equal? 1 2)
    (assert false)
    (if true (assert true) (builtin/error "cond mismatch"))))

(define-test if-test
  (assert-equal (if true 1 2) 1)
  (assert-equal (if false 1 2) 2)
  (assert (if true (if true true false) false))
  (assert (not (if true (if true false false) false)))
  (assert (if false true (if false true true)))
  (assert (not (if false true (if false true false)))))

(define-test the-test
  (assert-equal 1 (the int-t 1))
  (assert-equal 'a (the symbol-t 'a)))

(define-test path-test
  (assert-equal
    "a/b/c"
    (path-directory-name "a/b/c/file.test.txt"))
  (assert-equal
    "file.test.txt"
    (path-base-name "a/b/c/file.test.txt"))
  (assert-equal
    ".txt"
    (path-extension "a/b/c/file.test.txt"))
  (assert-equal
    "file.test"
    (path-stem "a/b/c/file.test.txt"))
  (assert (path-absolute? "/a/b/c/file.test.txt"))
  (assert-not (path-relative? "/a/b/c/file.test.txt"))
  (assert (path-relative? "a/b/c/file.test.txt"))
  (assert (path-relative? "./a/b/c/file.test.txt"))
  (assert-not (path-absolute? "a/b/c/file.test.txt"))
  (assert-not (path-absolute? "./a/b/c/file.test.txt"))
  (assert-equal "a/b/c/d/e/f" (path-join "a/b/c" "d/e/f"))
  (assert-equal "a/b/c/d/e/f" (path-join "a/b/c/" "/d/e/f"))
  (assert-equal
    "/a/b/c/d/e/f"
    (path-join "/a/b/c/" "/d/e/f"))
  (assert-equal "a/b/d" (path-normalize "a/b/c/../d"))
  (assert-equal "/a/b/c" (path-normalize "///a/b/c/")))

(define-test reocrd-test
  (println
   (the (interface :x int-t :y int-t) (@record :x 1 :y 2)))
  (println
   (the (interface :x int-t :y int-t) (@record :x 1 :y 2))))

(define-interface point-t :x float-t :y float-t)

(define (with-color color point)
  (extend point :color color))

(define-test record-extend-test
  (= point (@record :x 1.0 :y 2.0))
  (assert-equal
    (@record :x 1.0 :y 2.0 :color "red")
    (with-color "red" point)))

(define (point-put-x x point) (update point :x x))

(define (point-put-y! y point) (update! point :y y))

(define-test record-update-test
  (= point (@record :x 1.0 :y 2.0))
  (assert-equal
    (@record :x 2.0 :y 2.0)
    (point-put-x 2.0 point))
  (assert-equal (@record :x 1.0 :y 2.0) point)
  (assert-equal
    (@record :x 1.0 :y 1.0)
    (point-put-y! 1.0 point))
  (assert-equal (@record :x 1.0 :y 1.0) point))

(define-test set-test
  (assert-equal
    (begin
      (= set (builtin/make-set))
      (builtin/set-add! 1 set)
      (builtin/set-add! 2 set)
      (builtin/set-add! 3 set)
      set)
    (begin
      (= set (builtin/make-set))
      (builtin/set-add! 3 set)
      (builtin/set-add! 2 set)
      (builtin/set-add! 1 set)
      set))
  (println
   (the (set-t int-t)
     (begin
       (= set (builtin/make-set))
       (builtin/set-add! 1 set)
       (builtin/set-add! 2 set)
       (builtin/set-add! 3 set)
       set))))

(claim my-string-repeat
  (-> builtin/int-t builtin/string-t builtin/string-t))

(define (my-string-repeat n string)
  (if (equal? n 0)
    ""
    (string-append
     string
     (my-string-repeat (isub n 1) string))))

(define-test my-string-repeat-test
  (assert-equal "" (my-string-repeat 0 "a"))
  (assert-equal "a" (my-string-repeat 1 "a"))
  (assert-equal "aa" (my-string-repeat 2 "a"))
  (assert-equal "aaa" (my-string-repeat 3 "a")))

(define-test string-test
  (assert-equal "abcdef" (string-append "abc" "def"))
  (println "abc"))

(define-test symbol-test
  (assert-equal 'abcdef (symbol-append 'abc 'def))
  (println 'abc))

(define-test void-test (println void))