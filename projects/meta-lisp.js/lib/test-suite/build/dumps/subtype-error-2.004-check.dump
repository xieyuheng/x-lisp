(define-interface point-t
  :x
  builtin/float-t
  :y
  builtin/float-t)

(claim point-println
  (-> subtype-error-2/point-t builtin/void-t))

(define (point-println point) (builtin/println point))

(define (main)
  (subtype-error-2/point-println (@record :x 1.0 :y 2.0))
  (subtype-error-2/point-println (@record :x 1.0)))