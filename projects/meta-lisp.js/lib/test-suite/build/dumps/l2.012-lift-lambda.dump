(claim evaluate-and-print (-> exp-t void-t))

(define (evaluate-and-print exp)
  (builtin/println (l2/evaluate exp l2/empty-env)))

(claim l2-test void-t)

(define-test l2-test
  (l2/evaluate-and-print (l2/lambda-exp 'x (l2/var-exp 'x)))
  (l2/evaluate-and-print
   (l2/apply-exp
    (l2/lambda-exp 'x (l2/var-exp 'x))
    (l2/lambda-exp 'x (l2/var-exp 'x))))
  (l2/evaluate-and-print
   (l2/apply-exp
    (l2/apply-exp
     (l2/lambda-exp 'x (l2/var-exp 'x))
     (l2/lambda-exp 'x (l2/var-exp 'x)))
    (l2/apply-exp
     (l2/lambda-exp 'x (l2/var-exp 'x))
     (l2/lambda-exp 'x (l2/var-exp 'x)))))
  (l2/evaluate-and-print
   (l2/let-exp
    'id
    (l2/lambda-exp 'x (l2/var-exp 'x))
    (l2/var-exp 'id)))
  (l2/evaluate-and-print
   (l2/let-exp
    'id
    (l2/lambda-exp 'x (l2/var-exp 'x))
    (l2/apply-exp (l2/var-exp 'id) (l2/var-exp 'id))))
  (l2/evaluate-and-print
   (l2/let-exp
    'id
    (l2/lambda-exp 'x (l2/var-exp 'x))
    (l2/apply-exp
     (l2/apply-exp (l2/var-exp 'id) (l2/var-exp 'id))
     (l2/apply-exp (l2/var-exp 'id) (l2/var-exp 'id))))))

(define-data exp-t
  (var-exp (name builtin/symbol-t))
  (apply-exp (target l2/exp-t) (arg l2/exp-t))
  (lambda-exp (parameter builtin/symbol-t) (body l2/exp-t))
  (let-exp
   (name builtin/symbol-t)
   (rhs l2/exp-t)
   (body l2/exp-t)))

(claim var-exp (-> builtin/symbol-t l2/exp-t))

(define (var-exp name)
  (= list₁ (builtin/make-list))
  (builtin/list-push! 'var-exp list₁)
  (builtin/list-push! name list₁)
  list₁)

(claim var-exp? (-> l2/exp-t builtin/bool-t))

(define (var-exp? value)
  (if (builtin/list? value)
    (if (builtin/equal? (builtin/list-length value) 2)
      (builtin/equal? (builtin/list-head value) 'var-exp)
      builtin/false)
    builtin/false))

(claim var-exp-name (-> l2/exp-t builtin/symbol-t))

(define (var-exp-name target) (builtin/list-get 1 target))

(claim var-exp-put-name
  (-> builtin/symbol-t l2/exp-t l2/exp-t))

(define (var-exp-put-name value target)
  (builtin/list-put 1 value target))

(claim var-exp-put-name!
  (-> builtin/symbol-t l2/exp-t l2/exp-t))

(define (var-exp-put-name! value target)
  (builtin/list-put! 1 value target))

(claim apply-exp (-> l2/exp-t l2/exp-t l2/exp-t))

(define (apply-exp target arg)
  (= list₁ (builtin/make-list))
  (builtin/list-push! 'apply-exp list₁)
  (builtin/list-push! target list₁)
  (builtin/list-push! arg list₁)
  list₁)

(claim apply-exp? (-> l2/exp-t builtin/bool-t))

(define (apply-exp? value)
  (if (builtin/list? value)
    (if (builtin/equal? (builtin/list-length value) 3)
      (builtin/equal? (builtin/list-head value) 'apply-exp)
      builtin/false)
    builtin/false))

(claim apply-exp-target (-> l2/exp-t l2/exp-t))

(define (apply-exp-target target)
  (builtin/list-get 1 target))

(claim apply-exp-arg (-> l2/exp-t l2/exp-t))

(define (apply-exp-arg target) (builtin/list-get 2 target))

(claim apply-exp-put-target (-> l2/exp-t l2/exp-t l2/exp-t))

(define (apply-exp-put-target value target)
  (builtin/list-put 1 value target))

(claim apply-exp-put-arg (-> l2/exp-t l2/exp-t l2/exp-t))

(define (apply-exp-put-arg value target)
  (builtin/list-put 2 value target))

(claim apply-exp-put-target!
  (-> l2/exp-t l2/exp-t l2/exp-t))

(define (apply-exp-put-target! value target)
  (builtin/list-put! 1 value target))

(claim apply-exp-put-arg! (-> l2/exp-t l2/exp-t l2/exp-t))

(define (apply-exp-put-arg! value target)
  (builtin/list-put! 2 value target))

(claim lambda-exp (-> builtin/symbol-t l2/exp-t l2/exp-t))

(define (lambda-exp parameter body)
  (= list₁ (builtin/make-list))
  (builtin/list-push! 'lambda-exp list₁)
  (builtin/list-push! parameter list₁)
  (builtin/list-push! body list₁)
  list₁)

(claim lambda-exp? (-> l2/exp-t builtin/bool-t))

(define (lambda-exp? value)
  (if (builtin/list? value)
    (if (builtin/equal? (builtin/list-length value) 3)
      (builtin/equal? (builtin/list-head value) 'lambda-exp)
      builtin/false)
    builtin/false))

(claim lambda-exp-parameter (-> l2/exp-t builtin/symbol-t))

(define (lambda-exp-parameter target)
  (builtin/list-get 1 target))

(claim lambda-exp-body (-> l2/exp-t l2/exp-t))

(define (lambda-exp-body target)
  (builtin/list-get 2 target))

(claim lambda-exp-put-parameter
  (-> builtin/symbol-t l2/exp-t l2/exp-t))

(define (lambda-exp-put-parameter value target)
  (builtin/list-put 1 value target))

(claim lambda-exp-put-body (-> l2/exp-t l2/exp-t l2/exp-t))

(define (lambda-exp-put-body value target)
  (builtin/list-put 2 value target))

(claim lambda-exp-put-parameter!
  (-> builtin/symbol-t l2/exp-t l2/exp-t))

(define (lambda-exp-put-parameter! value target)
  (builtin/list-put! 1 value target))

(claim lambda-exp-put-body! (-> l2/exp-t l2/exp-t l2/exp-t))

(define (lambda-exp-put-body! value target)
  (builtin/list-put! 2 value target))

(claim let-exp
  (-> builtin/symbol-t l2/exp-t l2/exp-t l2/exp-t))

(define (let-exp name rhs body)
  (= list₁ (builtin/make-list))
  (builtin/list-push! 'let-exp list₁)
  (builtin/list-push! name list₁)
  (builtin/list-push! rhs list₁)
  (builtin/list-push! body list₁)
  list₁)

(claim let-exp? (-> l2/exp-t builtin/bool-t))

(define (let-exp? value)
  (if (builtin/list? value)
    (if (builtin/equal? (builtin/list-length value) 4)
      (builtin/equal? (builtin/list-head value) 'let-exp)
      builtin/false)
    builtin/false))

(claim let-exp-name (-> l2/exp-t builtin/symbol-t))

(define (let-exp-name target) (builtin/list-get 1 target))

(claim let-exp-rhs (-> l2/exp-t l2/exp-t))

(define (let-exp-rhs target) (builtin/list-get 2 target))

(claim let-exp-body (-> l2/exp-t l2/exp-t))

(define (let-exp-body target) (builtin/list-get 3 target))

(claim let-exp-put-name
  (-> builtin/symbol-t l2/exp-t l2/exp-t))

(define (let-exp-put-name value target)
  (builtin/list-put 1 value target))

(claim let-exp-put-rhs (-> l2/exp-t l2/exp-t l2/exp-t))

(define (let-exp-put-rhs value target)
  (builtin/list-put 2 value target))

(claim let-exp-put-body (-> l2/exp-t l2/exp-t l2/exp-t))

(define (let-exp-put-body value target)
  (builtin/list-put 3 value target))

(claim let-exp-put-name!
  (-> builtin/symbol-t l2/exp-t l2/exp-t))

(define (let-exp-put-name! value target)
  (builtin/list-put! 1 value target))

(claim let-exp-put-rhs! (-> l2/exp-t l2/exp-t l2/exp-t))

(define (let-exp-put-rhs! value target)
  (builtin/list-put! 2 value target))

(claim let-exp-put-body! (-> l2/exp-t l2/exp-t l2/exp-t))

(define (let-exp-put-body! value target)
  (builtin/list-put! 3 value target))

(define-data env-t
  empty-env
  (extend-env
   (key builtin/symbol-t)
   (value l2/value-t)
   (rest l2/env-t)))

(claim empty-env l2/env-t)

(define empty-env 'empty-env)

(claim empty-env? (-> l2/env-t builtin/bool-t))

(define (empty-env? value)
  (builtin/equal? value 'empty-env))

(claim extend-env
  (-> builtin/symbol-t l2/value-t l2/env-t l2/env-t))

(define (extend-env key value rest)
  (= list₁ (builtin/make-list))
  (builtin/list-push! 'extend-env list₁)
  (builtin/list-push! key list₁)
  (builtin/list-push! value list₁)
  (builtin/list-push! rest list₁)
  list₁)

(claim extend-env? (-> l2/env-t builtin/bool-t))

(define (extend-env? value)
  (if (builtin/list? value)
    (if (builtin/equal? (builtin/list-length value) 4)
      (builtin/equal? (builtin/list-head value) 'extend-env)
      builtin/false)
    builtin/false))

(claim extend-env-key (-> l2/env-t builtin/symbol-t))

(define (extend-env-key target) (builtin/list-get 1 target))

(claim extend-env-value (-> l2/env-t l2/value-t))

(define (extend-env-value target)
  (builtin/list-get 2 target))

(claim extend-env-rest (-> l2/env-t l2/env-t))

(define (extend-env-rest target)
  (builtin/list-get 3 target))

(claim extend-env-put-key
  (-> builtin/symbol-t l2/env-t l2/env-t))

(define (extend-env-put-key value target)
  (builtin/list-put 1 value target))

(claim extend-env-put-value
  (-> l2/value-t l2/env-t l2/env-t))

(define (extend-env-put-value value target)
  (builtin/list-put 2 value target))

(claim extend-env-put-rest (-> l2/env-t l2/env-t l2/env-t))

(define (extend-env-put-rest value target)
  (builtin/list-put 3 value target))

(claim extend-env-put-key!
  (-> builtin/symbol-t l2/env-t l2/env-t))

(define (extend-env-put-key! value target)
  (builtin/list-put! 1 value target))

(claim extend-env-put-value!
  (-> l2/value-t l2/env-t l2/env-t))

(define (extend-env-put-value! value target)
  (builtin/list-put! 2 value target))

(claim extend-env-put-rest! (-> l2/env-t l2/env-t l2/env-t))

(define (extend-env-put-rest! value target)
  (builtin/list-put! 3 value target))

(claim env-has?
  (-> builtin/symbol-t l2/env-t builtin/bool-t))

(define (env-has? name env)
  (if (l2/empty-env? env)
    builtin/false
    (if (l2/extend-env? env)
      (begin
        (= rest₃₁ (l2/extend-env-rest env))
        (= value₃₁ (l2/extend-env-value env))
        (= key₃₁ (l2/extend-env-key env))
        (= rest₁ rest₃₁)
        (= value₁ value₃₁)
        (= key₁ key₃₁)
        (if (builtin/equal? key₁ name)
          builtin/true
          (l2/env-has? name rest₁)))
      (builtin/error "cond mismatch"))))

(claim env-lookup-of-fail
  (-> builtin/symbol-t l2/env-t l2/value-t))

(define (env-lookup-of-fail name env)
  (if (l2/empty-env? env)
    (builtin/error "undefined name")
    (if (l2/extend-env? env)
      (begin
        (= rest₄₁ (l2/extend-env-rest env))
        (= value₄₁ (l2/extend-env-value env))
        (= key₄₁ (l2/extend-env-key env))
        (= rest₁ rest₄₁)
        (= value₁ value₄₁)
        (= key₁ key₄₁)
        (if (builtin/equal? key₁ name)
          value₁
          (l2/env-lookup-of-fail name rest₁)))
      (builtin/error "cond mismatch"))))

(define-data value-t
  (closure-value
   (env l2/env-t)
   (parameter builtin/symbol-t)
   (body l2/exp-t)))

(claim closure-value
  (-> l2/env-t builtin/symbol-t l2/exp-t l2/value-t))

(define (closure-value env parameter body)
  (= list₁ (builtin/make-list))
  (builtin/list-push! 'closure-value list₁)
  (builtin/list-push! env list₁)
  (builtin/list-push! parameter list₁)
  (builtin/list-push! body list₁)
  list₁)

(claim closure-value? (-> l2/value-t builtin/bool-t))

(define (closure-value? value)
  (if (builtin/list? value)
    (if (builtin/equal? (builtin/list-length value) 4)
      (builtin/equal?
       (builtin/list-head value)
       'closure-value)
      builtin/false)
    builtin/false))

(claim closure-value-env (-> l2/value-t l2/env-t))

(define (closure-value-env target)
  (builtin/list-get 1 target))

(claim closure-value-parameter
  (-> l2/value-t builtin/symbol-t))

(define (closure-value-parameter target)
  (builtin/list-get 2 target))

(claim closure-value-body (-> l2/value-t l2/exp-t))

(define (closure-value-body target)
  (builtin/list-get 3 target))

(claim closure-value-put-env
  (-> l2/env-t l2/value-t l2/value-t))

(define (closure-value-put-env value target)
  (builtin/list-put 1 value target))

(claim closure-value-put-parameter
  (-> builtin/symbol-t l2/value-t l2/value-t))

(define (closure-value-put-parameter value target)
  (builtin/list-put 2 value target))

(claim closure-value-put-body
  (-> l2/exp-t l2/value-t l2/value-t))

(define (closure-value-put-body value target)
  (builtin/list-put 3 value target))

(claim closure-value-put-env!
  (-> l2/env-t l2/value-t l2/value-t))

(define (closure-value-put-env! value target)
  (builtin/list-put! 1 value target))

(claim closure-value-put-parameter!
  (-> builtin/symbol-t l2/value-t l2/value-t))

(define (closure-value-put-parameter! value target)
  (builtin/list-put! 2 value target))

(claim closure-value-put-body!
  (-> l2/exp-t l2/value-t l2/value-t))

(define (closure-value-put-body! value target)
  (builtin/list-put! 3 value target))

(claim evaluate (-> l2/exp-t l2/env-t l2/value-t))

(define (evaluate exp env)
  (if (l2/var-exp? exp)
    (begin
      (= name₂₁ (l2/var-exp-name exp))
      (= name₁ name₂₁)
      (l2/env-lookup-of-fail name₁ env))
    (if (l2/apply-exp? exp)
      (begin
        (= arg₂₁ (l2/apply-exp-arg exp))
        (= target₂₁ (l2/apply-exp-target exp))
        (= arg₁ arg₂₁)
        (= target₁ target₂₁)
        (l2/apply
         (l2/evaluate target₁ env)
         (l2/evaluate arg₁ env)))
      (if (l2/lambda-exp? exp)
        (begin
          (= body₃₁ (l2/lambda-exp-body exp))
          (= parameter₃₁ (l2/lambda-exp-parameter exp))
          (= body₁ body₃₁)
          (= parameter₁ parameter₃₁)
          (l2/closure-value env parameter₁ body₁))
        (if (l2/let-exp? exp)
          (begin
            (= body₄₁ (l2/let-exp-body exp))
            (= rhs₁₁ (l2/let-exp-rhs exp))
            (= name₃₁ (l2/let-exp-name exp))
            (= body₂ body₄₁)
            (= rhs₁ rhs₁₁)
            (= name₂ name₃₁)
            (= env₁
               (l2/extend-env
                name₂
                (l2/evaluate rhs₁ env)
                env))
            (l2/evaluate body₂ env₁))
          (builtin/error "cond mismatch"))))))

(claim apply (-> l2/value-t l2/value-t l2/value-t))

(define (apply target arg)
  (if (l2/closure-value? target)
    (begin
      (= body₅₁ (l2/closure-value-body target))
      (= parameter₄₁ (l2/closure-value-parameter target))
      (= env₂₁ (l2/closure-value-env target))
      (= body₁ body₅₁)
      (= parameter₁ parameter₄₁)
      (= env₁ env₂₁)
      (l2/evaluate body₁ (l2/extend-env parameter₁ arg env₁)))
    (builtin/error "cond mismatch")))