(claim identity-type-error-2/identity
  (polymorphic (A) (-> A A)))

(define (identity-type-error-2/identity x) x)

(define-test identity-type-error-2/identity-test
  (the (polymorphic (A) (-> A A))
    identity-type-error-2/identity)
  (the (polymorphic (A B) (-> A B))
    identity-type-error-2/identity))