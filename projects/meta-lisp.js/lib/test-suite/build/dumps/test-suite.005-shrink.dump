        (builtin/newline)
        (builtin/print 3)
        (builtin/newline)
        (builtin/equal? 1 2))
    (begin (builtin/print 111) (builtin/newline))
    (begin (builtin/print 222) (builtin/newline))))

(claim file-test void-t)

(define-test file-test
  (= file (builtin/open-input-file "src/file/file-1.txt"))
  (builtin/assert-equal "abc\n" (builtin/file-read file))
  (builtin/file-close file)
  (= file (builtin/open-output-file "src/file/file-2.txt"))
  (builtin/file-write file "123\n")
  (builtin/file-close file)
  (= file (builtin/open-input-file "src/file/file-2.txt"))
  (builtin/assert-equal "123\n" (builtin/file-read file))
  (builtin/file-close file)
  (= file (builtin/open-output-file "src/file/file-2.txt"))
  (builtin/file-write file "abc\n")
  (builtin/file-close file)
  (= file (builtin/open-input-file "src/file/file-2.txt"))
  (builtin/assert-equal "abc\n" (builtin/file-read file))
  (builtin/file-close file))

(claim fs-test void-t)

(define-test fs-test
  (builtin/assert-equal
   "abc\n"
   (builtin/fs-read "src/fs/file-1.txt"))
  (builtin/fs-write "src/fs/file-2.txt" "123\n")
  (builtin/assert-equal
   "123\n"
   (builtin/fs-read "src/fs/file-2.txt"))
  (builtin/fs-write "src/fs/file-2.txt" "abc\n")
  (builtin/assert-equal
   "abc\n"
   (builtin/fs-read "src/fs/file-2.txt"))
  (builtin/println (builtin/fs-list "src/fs")))

(claim S
  (polymorphic (A B C) (-> (-> A B C) (-> A B) (-> A C))))

(define (S x y z) (x z (y z)))

(claim K (polymorphic (A B) (-> A B A)))

(define (K x y) x)

(claim I (polymorphic (A) (-> A A)))

(define (I x) x)

(claim SKI (polymorphic (A) (-> A A)))

(define SKI (test-suite/S test-suite/K test-suite/I))

(claim SKI-record
  (polymorphic (A B C D E F)
    (interface
      :S
      (-> (-> A B C) (-> A B) (-> A C))
      :K
      (-> D E D)
      :I
      (-> F F))))

(define SKI-record
  (= S (lambda (x y z) (x z (y z))))
  (= K (lambda (x y) x))
  (= I (lambda (x) x))
  (= record (builtin/make-record))
  (builtin/record-put! :S S record)
  (builtin/record-put! :K K record)
  (builtin/record-put! :I I record)
  record)

(claim compose
  (polymorphic (A B C) (-> (-> B C) (-> A B) (-> A C))))

(define (compose f g x) (f (g x)))

(claim compose-test void-t)

(define-test compose-test
  (= add1 (builtin/iadd 1))
  (builtin/assert-equal 3 ((test-suite/compose add1 add1) 1)))

(claim curry-test void-t)

(define-test curry-test
  (builtin/assert-equal builtin/iadd builtin/iadd)
  (builtin/assert-equal (builtin/iadd 1) (builtin/iadd 1))
  (builtin/assert-not-equal
   (builtin/iadd 1)
   (builtin/iadd 2))
  (builtin/assert-equal
   ((builtin/iadd 1) 2)
   (builtin/iadd 1 2))
  (builtin/assert-equal 1 ((builtin/isub 2) 1))
  (builtin/assert-equal 1 (builtin/isub 2 1)))

(claim swap
  (polymorphic (X Y Z) (-> (-> Y X Z) (-> X Y Z))))

(define (swap f x y) (f y x))

(claim drop (polymorphic (X Y Z) (-> (-> X Z) (-> Y X Z))))

(define (drop f) (lambda (dropped) (lambda (x) (f x))))

(claim dup (polymorphic (X Z) (-> (-> X X Z) (-> X Z))))

(define (dup f) (lambda (x) (f x x)))

(claim forth-test void-t)

(define-test forth-test
  (= f (lambda (x) x))
  (= square (builtin/dup builtin/imul))
  (builtin/println (square (f 1)))
  (builtin/println (square (f 2)))
  (builtin/println (square (f 3)))
  (builtin/println (square (f 4))))

(claim function-test void-t)

(define-test function-test
  (builtin/println builtin/iadd)
  (builtin/println (builtin/iadd 1)))

(claim identity (polymorphic (A) (-> A A)))

(define (identity x) x)

(claim identity-test void-t)

(define-test identity-test
  (= add1 (builtin/iadd 1))
  (builtin/assert-equal 2 (add1 1))
  (= add1
     (builtin/identity (builtin/iadd (builtin/identity 1))))
  builtin/identity
  builtin/identity
  builtin/identity
  (builtin/assert-equal 2 (add1 1)))

(claim hash-test void-t)

(define-test hash-test
  (builtin/assert
   (builtin/hash-empty?
    (begin (= hash (builtin/make-hash)) hash)))
  (builtin/println (begin (= hash (builtin/make-hash)) hash))
  (builtin/println
   (begin
     (= hash (builtin/make-hash))
     (builtin/hash-put! 1 2 hash)
     hash))
  (builtin/println
   (begin
     (= hash (builtin/make-hash))
     (builtin/hash-put! 1 3 hash)
     hash))
  (builtin/println
   (begin
     (= hash (builtin/make-hash))
     (builtin/hash-put! 1 2 hash)
     (builtin/hash-put! 3 4 hash)
     hash)))

(claim factorial (-> builtin/int-t builtin/int-t))

(define (factorial n)
  (if (builtin/int-less-or-equal? n 1)
    1
    (builtin/imul
     (test-suite/factorial (builtin/isub n 1))
     n)))

(claim factorial-test void-t)

(define-test factorial-test
  (builtin/assert-equal 1 (test-suite/factorial 0))
  (builtin/assert-equal 1 (test-suite/factorial 1))
  (builtin/assert-equal 2 (test-suite/factorial 2))
  (builtin/assert-equal 6 (test-suite/factorial 3))
  (builtin/assert-equal 24 (test-suite/factorial 4))
  (builtin/assert-equal 120 (test-suite/factorial 5))
  (builtin/assert-equal 720 (test-suite/factorial 6)))

(claim fibonacci (-> builtin/int-t builtin/int-t))

(define (fibonacci n)
  (if (builtin/int-less-or-equal? n 1)
    n
    (builtin/iadd
     (test-suite/fibonacci (builtin/isub n 1))
     (test-suite/fibonacci (builtin/isub n 2)))))

(claim fibonacci-test void-t)

(define-test fibonacci-test
  (builtin/assert-equal 0 (test-suite/fibonacci 0))
  (builtin/assert-equal 1 (test-suite/fibonacci 1))
  (builtin/assert-equal 1 (test-suite/fibonacci 2))
  (builtin/assert-equal 2 (test-suite/fibonacci 3))
  (builtin/assert-equal 3 (test-suite/fibonacci 4))
  (builtin/assert-equal 5 (test-suite/fibonacci 5))
  (builtin/assert-equal 8 (test-suite/fibonacci 6))
  (builtin/assert-equal 13 (test-suite/fibonacci 7))
  (builtin/assert-equal 21 (test-suite/fibonacci 8))
  (builtin/assert-equal 34 (test-suite/fibonacci 9)))

(claim gcd (-> builtin/int-t builtin/int-t builtin/int-t))

(define (gcd a b)
  (if (builtin/equal? b 0)
    a
    (test-suite/gcd b (builtin/imod a b))))

(claim gcd-test void-t)

(define-test gcd-test
  (builtin/assert-equal 1 (test-suite/gcd 13 7))
  (builtin/assert-equal 4 (test-suite/gcd 12 8)))

(claim square (-> builtin/int-t builtin/int-t))

(define (square x) (builtin/imul x x))

(claim square-test void-t)

(define-test square-test
  (builtin/assert-equal
   81
   (test-suite/square (test-suite/square 3))))

(claim keyword-test void-t)

(define-test keyword-test
  (builtin/assert-equal
   :abcdef
   (builtin/keyword-append :abc :def))
  (builtin/println :abc))

(claim list-test void-t)

(define-test list-test
  (= list (builtin/make-list))
  (builtin/list-push! 1 list)
  (builtin/list-push! 2 list)
  (builtin/list-push! 3 list)
  (builtin/println list)
  (builtin/println
   (begin
     (= list (builtin/make-list))
     (builtin/list-push! 1 list)
     (builtin/list-push! 2 list)
     (builtin/list-push! 3 list)
     list))
  (builtin/println
   (begin
     (= list (builtin/make-list))
     (builtin/list-push! 1 list)
     (builtin/list-push! 2 list)
     (builtin/list-push! 3 list)
     list))
  (builtin/println
   (begin
     (= list (builtin/make-list))
     (builtin/list-push! 1 list)
     (builtin/list-push! 2 list)
     (builtin/list-push! 3 list)
     list))
  (builtin/println
   (begin
     (= list (builtin/make-list))
     (builtin/list-push! 1 list)
     (builtin/list-push! 2 list)
     (builtin/list-push! 3 list)
     list))
  (builtin/println
   (begin
     (= list (builtin/make-list))
     (builtin/list-push! 'a list)
     (builtin/list-push! 'b list)
     (builtin/list-push! 'c list)
     list))
  (builtin/println
   (begin
     (= list (builtin/make-list))
     (builtin/list-push! 'a list)
     (builtin/list-push! 'b list)
     (builtin/list-push! 'c list)
     list))
  (builtin/assert-equal
   (begin
     (= list (builtin/make-list))
     (builtin/list-push! 1 list)
     (builtin/list-push! 2 list)
     (builtin/list-push! 3 list)
     list)
   (begin
     (= list (builtin/make-list))
     (builtin/list-push! 1 list)
     (builtin/list-push! 2 list)
     (builtin/list-push! 3 list)
     list))
  (builtin/assert-equal
   (begin
     (= list (builtin/make-list))
     (builtin/list-push! 'a list)
     (builtin/list-push! 'b list)
     (builtin/list-push! 'c list)
     list)
   (begin
     (= list (builtin/make-list))
     (builtin/list-push! 'a list)
     (builtin/list-push! 'b list)
     (builtin/list-push! 'c list)
     list))
  (builtin/assert-equal
   (begin
     (= list (builtin/make-list))
     (builtin/list-push!
      (begin
        (= list (builtin/make-list))
        (builtin/list-push! 1 list)
        (builtin/list-push! 2 list)
        (builtin/list-push! 3 list)
        list)
      list)
     (builtin/list-push!
      (begin
        (= list (builtin/make-list))
        (builtin/list-push! 4 list)
        (builtin/list-push! 5 list)
        (builtin/list-push! 6 list)
        list)
      list)
     (builtin/list-push!
      (begin
        (= list (builtin/make-list))
        (builtin/list-push! 7 list)
        (builtin/list-push! 8 list)
        (builtin/list-push! 9 list)
        list)
      list)
     list)
   (begin
     (= list (builtin/make-list))
     (builtin/list-push!
      (begin
        (= list (builtin/make-list))
        (builtin/list-push! 1 list)
        (builtin/list-push! 2 list)
        (builtin/list-push! 3 list)
        list)
      list)
     (builtin/list-push!
      (begin
        (= list (builtin/make-list))
        (builtin/list-push! 4 list)
        (builtin/list-push! 5 list)
        (builtin/list-push! 6 list)
        list)
      list)
     (builtin/list-push!
      (begin
        (= list (builtin/make-list))
        (builtin/list-push! 7 list)
        (builtin/list-push! 8 list)
        (builtin/list-push! 9 list)
        list)
      list)
     list))
  (builtin/assert-not-equal
   (begin
     (= list (builtin/make-list))
     (builtin/list-push!
      (begin
        (= list (builtin/make-list))
        (builtin/list-push! 1 list)
        (builtin/list-push! 2 list)
        (builtin/list-push! 3 list)
        list)
      list)
     (builtin/list-push!
      (begin
        (= list (builtin/make-list))
        (builtin/list-push! 4 list)
        (builtin/list-push! 5 list)
        (builtin/list-push! 6 list)
        list)
      list)
     (builtin/list-push!
      (begin
        (= list (builtin/make-list))
        (builtin/list-push! 7 list)
        (builtin/list-push! 8 list)
        (builtin/list-push! 9 list)
        list)
      list)
     list)
   (begin
     (= list (builtin/make-list))
     (builtin/list-push!
      (begin
        (= list (builtin/make-list))
        (builtin/list-push! 1 list)
        (builtin/list-push! 2 list)
        (builtin/list-push! 3 list)
        list)
      list)
     (builtin/list-push!
      (begin
        (= list (builtin/make-list))
        (builtin/list-push! 4 list)
        (builtin/list-push! 5 list)
        (builtin/list-push! 6 list)
        list)
      list)
     (builtin/list-push!
      (begin
        (= list (builtin/make-list))
        (builtin/list-push! 7 list)
        (builtin/list-push! 8 list)
        (builtin/list-push! 10 list)
        list)
      list)
     list))
  (builtin/assert
   (builtin/list-empty?
    (begin (= list (builtin/make-list)) list)))
  (builtin/assert-not
   (builtin/list-empty?
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 1 list)
      list)))
  (builtin/assert-equal
   (builtin/cons
    1
    (builtin/cons
     2
     (builtin/cons
      3
      (begin (= list (builtin/make-list)) list))))
   (begin
     (= list (builtin/make-list))
     (builtin/list-push! 1 list)
     (builtin/list-push! 2 list)
     (builtin/list-push! 3 list)
     list))
  (builtin/assert-equal
   (builtin/car
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 1 list)
      (builtin/list-push! 2 list)
      (builtin/list-push! 3 list)
      list))
   1)
  (builtin/assert-equal
   (builtin/cdr
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 1 list)
      (builtin/list-push! 2 list)
      (builtin/list-push! 3 list)
      list))
   (begin
     (= list (builtin/make-list))
     (builtin/list-push! 2 list)
     (builtin/list-push! 3 list)
     list))
  (builtin/assert-equal
   (builtin/list-head
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 1 list)
      (builtin/list-push! 2 list)
      (builtin/list-push! 3 list)
      list))
   1)
  (builtin/assert-equal
   (builtin/list-tail
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 1 list)
      (builtin/list-push! 2 list)
      (builtin/list-push! 3 list)
      list))
   (begin
     (= list (builtin/make-list))
     (builtin/list-push! 2 list)
     (builtin/list-push! 3 list)
     list))
  (builtin/assert-equal
   (builtin/list-init
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 1 list)
      (builtin/list-push! 2 list)
      (builtin/list-push! 3 list)
      list))
   (begin
     (= list (builtin/make-list))
     (builtin/list-push! 1 list)
     (builtin/list-push! 2 list)
     list))
  (builtin/assert-equal
   (builtin/list-last
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 1 list)
      (builtin/list-push! 2 list)
      (builtin/list-push! 3 list)
      list))
   3)
  (builtin/assert-equal
   (begin
     (= set (builtin/make-set))
     (builtin/set-add! 1 set)
     (builtin/set-add! 2 set)
     (builtin/set-add! 3 set)
     set)
   (builtin/list-to-set
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 1 list)
      (builtin/list-push! 2 list)
      (builtin/list-push! 3 list)
      list)))
  (builtin/assert-equal
   (builtin/list-copy
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 1 list)
      (builtin/list-push! 2 list)
      (builtin/list-push! 3 list)
      list))
   (begin
     (= list (builtin/make-list))
     (builtin/list-push! 1 list)
     (builtin/list-push! 2 list)
     (builtin/list-push! 3 list)
     list))
  (builtin/assert-equal
   (builtin/list-get
    0
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 1 list)
      (builtin/list-push! 2 list)
      (builtin/list-push! 3 list)
      list))
   1)
  (builtin/assert-equal
   (builtin/list-get
    1
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 1 list)
      (builtin/list-push! 2 list)
      (builtin/list-push! 3 list)
      list))
   2)
  (builtin/assert-equal
   (builtin/list-get
    2
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 1 list)
      (builtin/list-push! 2 list)
      (builtin/list-push! 3 list)
      list))
   3)
  (builtin/assert-equal
   (builtin/list-length
    (begin (= list (builtin/make-list)) list))
   0)
  (builtin/assert-equal
   (builtin/list-length
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 1 list)
      (builtin/list-push! 2 list)
      (builtin/list-push! 3 list)
      list))
   3)
  (builtin/assert-equal
   (builtin/list-length
    (begin
      (= list (builtin/make-list))
      (builtin/list-push!
       (begin
         (= list (builtin/make-list))
         (builtin/list-push! 1 list)
         (builtin/list-push! 2 list)
         (builtin/list-push! 3 list)
         list)
       list)
      (builtin/list-push!
       (begin
         (= list (builtin/make-list))
         (builtin/list-push! 4 list)
         (builtin/list-push! 5 list)
         (builtin/list-push! 6 list)
         list)
       list)
      (builtin/list-push!
       (begin
         (= list (builtin/make-list))
         (builtin/list-push! 7 list)
         (builtin/list-push! 8 list)
         (builtin/list-push! 9 list)
         list)
       list)
      list))
   3)
  (= fs
     (begin
       (= list (builtin/make-list))
       (builtin/list-push! (builtin/iadd 1) list)
       (builtin/list-push! (builtin/iadd 2) list)
       (builtin/list-push! (builtin/iadd 3) list)
       list))
  (builtin/assert-equal 1 ((builtin/list-get 0 fs) 0))
  (builtin/assert-equal 2 ((builtin/list-get 1 fs) 0))
  (builtin/assert-equal 3 ((builtin/list-get 2 fs) 0)))

(claim list-pop-test void-t)

(define-test list-pop-test
  (= list
