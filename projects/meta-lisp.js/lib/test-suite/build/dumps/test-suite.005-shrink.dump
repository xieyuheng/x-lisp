     (builtin/list-push! 3 list)
     list)))

(claim cond-test void-t)

(define-test cond-test
  (builtin/assert-equal
   1
   (if (builtin/equal? 1 1)
     1
     (if builtin/true 2 (builtin/error "cond mismatch"))))
  (builtin/assert-equal
   2
   (if (builtin/equal? 1 2)
     1
     (if builtin/true 2 (builtin/error "cond mismatch"))))
  (if (builtin/equal? 1 1)
    (builtin/assert builtin/true)
    (if builtin/true
      (builtin/assert builtin/false)
      (builtin/error "cond mismatch")))
  (if (builtin/equal? 1 2)
    (builtin/assert builtin/false)
    (if builtin/true
      (builtin/assert builtin/true)
      (builtin/error "cond mismatch"))))

(claim if-test void-t)

(define-test if-test
  (builtin/assert-equal (if builtin/true 1 2) 1)
  (builtin/assert-equal (if builtin/false 1 2) 2)
  (builtin/assert
   (if builtin/true
     (if builtin/true builtin/true builtin/false)
     builtin/false))
  (builtin/assert
   (builtin/not
    (if builtin/true
      (if builtin/true builtin/false builtin/false)
      builtin/false)))
  (builtin/assert
   (if builtin/false
     builtin/true
     (if builtin/false builtin/true builtin/true)))
  (builtin/assert
   (builtin/not
    (if builtin/false
      builtin/true
      (if builtin/false builtin/true builtin/false)))))

(claim the-test void-t)

(define-test the-test
  (builtin/assert-equal 1 1)
  (builtin/assert-equal 'a 'a))

(claim path-test void-t)

(define-test path-test
  (builtin/assert-equal
   "a/b/c"
   (builtin/path-directory-name "a/b/c/file.test.txt"))
  (builtin/assert-equal
   "file.test.txt"
   (builtin/path-base-name "a/b/c/file.test.txt"))
  (builtin/assert-equal
   ".txt"
   (builtin/path-extension "a/b/c/file.test.txt"))
  (builtin/assert-equal
   "file.test"
   (builtin/path-stem "a/b/c/file.test.txt"))
  (builtin/assert
   (builtin/path-absolute? "/a/b/c/file.test.txt"))
  (builtin/assert-not
   (builtin/path-relative? "/a/b/c/file.test.txt"))
  (builtin/assert
   (builtin/path-relative? "a/b/c/file.test.txt"))
  (builtin/assert
   (builtin/path-relative? "./a/b/c/file.test.txt"))
  (builtin/assert-not
   (builtin/path-absolute? "a/b/c/file.test.txt"))
  (builtin/assert-not
   (builtin/path-absolute? "./a/b/c/file.test.txt"))
  (builtin/assert-equal
   "a/b/c/d/e/f"
   (builtin/path-join "a/b/c" "d/e/f"))
  (builtin/assert-equal
   "a/b/c/d/e/f"
   (builtin/path-join "a/b/c/" "/d/e/f"))
  (builtin/assert-equal
   "/a/b/c/d/e/f"
   (builtin/path-join "/a/b/c/" "/d/e/f"))
  (builtin/assert-equal
   "a/b/d"
   (builtin/path-normalize "a/b/c/../d"))
  (builtin/assert-equal
   "/a/b/c"
   (builtin/path-normalize "///a/b/c/")))

(claim reocrd-test void-t)

(define-test reocrd-test
  (builtin/println
   (begin
     (= record (builtin/make-record))
     (builtin/record-put! :x 1 record)
     (builtin/record-put! :y 2 record)
     record))
  (builtin/println
   (begin
     (= record (builtin/make-record))
     (builtin/record-put! :x 1 record)
     (builtin/record-put! :y 2 record)
     record)))

(define-interface point-t
  :x
  builtin/float-t
  :y
  builtin/float-t)

(claim with-color
  (polymorphic (A B C)
    (-> A (extend-interface B) (extend-interface B :color C))))

(define (with-color color point)
  (= record point)
  (= record (builtin/record-put :color color record))
  record)

(claim record-extend-test void-t)

(define-test record-extend-test
  (= point
     (begin
       (= record (builtin/make-record))
       (builtin/record-put! :x 1.0 record)
       (builtin/record-put! :y 2.0 record)
       record))
  (builtin/assert-equal
   (begin
     (= record (builtin/make-record))
     (builtin/record-put! :x 1.0 record)
     (builtin/record-put! :y 2.0 record)
     (builtin/record-put! :color "red" record)
     record)
   (test-suite/with-color "red" point)))

(claim point-put-x
  (polymorphic (A B C)
    (-> A
        (extend-interface B :x C)
        (extend-interface B :x C))))

(define (point-put-x x point)
  (= record point)
  (= record (builtin/record-put :x x record))
  record)

(claim point-put-y!
  (polymorphic (A B C)
    (-> A
        (extend-interface B :y C)
        (extend-interface B :y C))))

(define (point-put-y! y point)
