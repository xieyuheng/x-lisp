(claim my-string-repeat
  (-> builtin/int-t builtin/string-t builtin/string-t))

(define (my-string-repeat n string)
  (if (builtin/equal? n 0)
    ""
    (builtin/string-append
     string
     (test-suite/my-string-repeat (builtin/isub n 1) string))))

(claim my-string-repeat-test void-t)

(define-test my-string-repeat-test
  (builtin/assert-equal
   ""
   (test-suite/my-string-repeat 0 "a"))
  (builtin/assert-equal
   "a"
   (test-suite/my-string-repeat 1 "a"))
  (builtin/assert-equal
   "aa"
   (test-suite/my-string-repeat 2 "a"))
  (builtin/assert-equal
   "aaa"
   (test-suite/my-string-repeat 3 "a")))

