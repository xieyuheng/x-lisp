  (builtin/println (if builtin/true 1 2)))

(claim eoc-04-02 void-t)

(define-test eoc-04-02
  (builtin/println
   (begin
     (= x (builtin/random-dice))
     (= y (builtin/random-dice))
     (if
         (if (builtin/int-less? x 1)
           (builtin/equal? x 0)
           (builtin/equal? x 2))
       (builtin/iadd y 2)
       (builtin/iadd y 10)))))

(claim eoc-04-03 void-t)

(define-test eoc-04-03
  (builtin/println
   (begin
     (= x (builtin/random-dice))
     (= y (builtin/random-dice))
     (builtin/iadd
      (if
          (if (builtin/int-less? x 1)
            (builtin/equal? x 0)
            (builtin/equal? x 2))
        (builtin/iadd y 2)
        (builtin/iadd y 10))
      (if
          (if (builtin/int-less? x 1)
            (builtin/equal? x 0)
            (builtin/equal? x 2))
        (builtin/iadd y 2)
        (builtin/iadd y 10))))))

