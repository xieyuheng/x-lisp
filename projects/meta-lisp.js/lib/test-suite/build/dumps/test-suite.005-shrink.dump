(claim list-put-test void-t)

(define-test list-put-test
  (begin
    (= list
       (begin
         (= list (builtin/make-list))
         (builtin/list-push! 0 list)
         (builtin/list-push! 0 list)
         (builtin/list-push! 0 list)
