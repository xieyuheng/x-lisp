(claim my-list-adjacent-dedup
  (polymorphic (E)
    (-> (my-list/my-list-t E) (my-list/my-list-t E))))

(define (my-list-adjacent-dedup list)
  (if (nil? list)
    nil
    (if (li? list)
      (begin
        (= tail₁ (li-tail list))
        (= head₁ (li-head list))
        (if (nil? tail₁)
          (begin (= head head₁) (li head nil))
          (if (li? tail₁)
            (begin
              (= tail₂ (li-tail tail₁))
              (= head₂ (li-head tail₁))
              (= rest tail₂)
              (= second head₂)
              (= first head₁)
              (if (equal? first second)
                (my-list-adjacent-dedup (li second rest))
                (li first
                    (my-list-adjacent-dedup (li second rest)))))
            (error "cond mismatch"))))
      (error "cond mismatch"))))

(define-test
 my-list-adjacent-dedup-test
 (assert-equal nil (my-list-adjacent-dedup nil))
 (assert-equal
   (li 1 (li 2 (li 3 (li 1 (li 2 (li 3 nil))))))
   (my-list-adjacent-dedup
    (li 1 (li 2 (li 3 (li 1 (li 2 (li 3 nil))))))))
 (assert-equal
   (li 1 (li 2 (li 3 nil)))
   (my-list-adjacent-dedup
    (li 1 (li 1 (li 2 (li 2 (li 3 (li 3 nil)))))))))

(claim my-list-append
  (polymorphic (E)
    (-> (my-list/my-list-t E)
        (my-list/my-list-t E)
        (my-list/my-list-t E))))

(define (my-list-append left right)
  (if (nil? left)
    right
    (if (li? left)
      (begin
        (= tail₃ (li-tail left))
        (= head₃ (li-head left))
        (= tail tail₃)
        (= head head₃)
        (li head (my-list-append tail right)))
      (error "cond mismatch"))))

(define-test
 my-list-append-test
 (assert-equal nil (my-list-append nil nil))
 (assert-equal
   (li 1 (li 2 (li 3 (li 4 (li 5 (li 6 nil))))))
   (my-list-append
    (li 1 (li 2 (li 3 nil)))
    (li 4 (li 5 (li 6 nil))))))

(claim my-list-length
  (polymorphic (E) (-> (my-list/my-list-t E) int-t)))

(define (my-list-length list)
  (if (nil? list)
    0
    (if (li? list)
      (begin
        (= tail₄ (li-tail list))
        (= head₄ (li-head list))
        (= tail tail₄)
        (= head head₄)
        (iadd 1 (my-list-length tail)))
      (error "cond mismatch"))))

(define-test
 my-list-length-test
 (assert-equal 0 (my-list-length nil))
 (assert-equal 3 (my-list-length (li 1 (li 2 (li 3 nil))))))

(claim my-list-map-zip
  (polymorphic (A B C)
    (-> (-> A B C)
        (my-list/my-list-t A)
        (my-list/my-list-t B)
        (my-list/my-list-t C))))

(define (my-list-map-zip f list1 list2)
  (if (nil? list1)
    (begin (= _ list2) nil)
    (if (li? list1)
      (begin
        (= tail₅ (li-tail list1))
        (= head₅ (li-head list1))
        (if (nil? list2)
          (begin (= tail1 tail₅) (= head1 head₅) nil)
          (if (li? list2)
            (begin
              (= tail₆ (li-tail list2))
              (= head₆ (li-head list2))
              (= tail2 tail₆)
              (= head2 head₆)
              (= tail1 tail₅)
              (= head1 head₅)
              (li (f head1 head2)
                  (my-list-map-zip f tail1 tail2)))
            (error "cond mismatch"))))
      (error "cond mismatch"))))

(claim my-list-map-zip-2
  (polymorphic (A B C)
    (-> (-> A B C)
        (my-list/my-list-t A)
        (my-list/my-list-t B)
        (my-list/my-list-t C))))

(define (my-list-map-zip-2 f list1 list2)
  (if (nil? list1)
    (begin (= _ list2) nil)
    (if (li? list1)
      (begin
        (= tail₁₀ (li-tail list1))
        (= head₁₀ (li-head list1))
        (if (nil? list2)
          (begin (= _ list1) nil)
          (if (li? list2)
            (begin
              (= tail₉ (li-tail list2))
              (= head₉ (li-head list2))
              (if (nil? list1)
                (error "match mismatch")
                (if (li? list1)
                  (begin
                    (= tail₇ (li-tail list1))
                    (= head₇ (li-head list1))
                    (if (nil? list2)
                      (error "match mismatch")
                      (if (li? list2)
                        (begin
                          (= tail₈ (li-tail list2))
                          (= head₈ (li-head list2))
                          (= tail2 tail₈)
                          (= head2 head₈)
                          (= tail1 tail₇)
                          (= head1 head₇)
                          (li (f head1 head2)
                              (my-list-map-zip-2
                               f
                               tail1
                               tail2)))
                        (error "cond mismatch"))))
                  (error "cond mismatch"))))
            (error "cond mismatch"))))
      (error "cond mismatch"))))

(define-test
 my-list-map-zip-test
 (assert-equal nil (my-list-map-zip iadd nil nil))
 (assert-equal
   (li 2 (li 4 (li 6 nil)))
   (my-list-map-zip
    iadd
    (li 1 (li 2 (li 3 nil)))
    (li 1 (li 2 (li 3 nil)))))
 (assert-equal nil (my-list-map-zip-2 iadd nil nil))
 (assert-equal
   (li 2 (li 4 (li 6 nil)))
   (my-list-map-zip-2
    iadd
    (li 1 (li 2 (li 3 nil)))
    (li 1 (li 2 (li 3 nil))))))

(claim my-list-map
  (polymorphic (A B)
    (-> (-> A B) (my-list/my-list-t A) (my-list/my-list-t B))))

(define (my-list-map f list)
  (if (nil? list)
    nil
    (if (li? list)
      (begin
        (= tail₁₁ (li-tail list))
        (= head₁₁ (li-head list))
        (= tail tail₁₁)
        (= head head₁₁)
        (li (f head) (my-list-map f tail)))
      (error "cond mismatch"))))

(define-test
 my-list-map-test
 (assert-equal nil (my-list-map (iadd 1) nil))
 (assert-equal
   (li 2 (li 3 (li 4 nil)))
   (my-list-map (iadd 1) (li 1 (li 2 (li 3 nil))))))

(define-test
 my-list-snapshot
 (println nil)
 (println (li 1 (li 2 (li 3 nil)))))

(define-test
 my-list-test
 (assert (nil? nil))
 (assert (li? (li 1 (li 2 (li 3 nil)))))
 (assert-not (li? nil))
 (assert-not (nil? (li 1 (li 2 (li 3 nil)))))
 (assert-equal (li-tail (li 1 nil)) nil)
 (assert-equal (li-head (li 1 nil)) 1)
 (= list (li 1 (li 2 (li 3 nil))))
 (assert-equal (li-head list) 1)
 (li-put-head! 111 list)
 (assert-equal (li-head list) 111)
 (assert-equal (li-tail list) (li 2 (li 3 nil)))
 (li-put-tail! nil list)
 (assert-equal (li-tail list) nil)
 (assert-equal (li 1 nil) ((li 1) nil)))

(define-data (my-list-t E)
  nil
  (li (head E) (tail (my-list-t E))))

(claim nil (polymorphic (E) (my-list/my-list-t E)))

(define nil 'nil)

(claim nil?
  (polymorphic (E) (-> (my-list/my-list-t E) bool-t)))

(define (nil? value) (equal? value 'nil))

(claim li
  (polymorphic (E)
    (-> E (my-list/my-list-t E) (my-list/my-list-t E))))

(define (li head tail)
  (= list (make-list))
  (list-push! 'li list)
  (list-push! head list)
  (list-push! tail list)
  list)

(claim li?
  (polymorphic (E) (-> (my-list/my-list-t E) bool-t)))

(define (li? value)
  (if (list? value)
    (if (equal? (list-length value) 3)
      (equal? (list-head value) 'li)
      false)
    false))

(claim li-head
  (polymorphic (E) (-> (my-list/my-list-t E) E)))

(define (li-head target) (list-get 1 target))

(claim li-tail
  (polymorphic (E)
    (-> (my-list/my-list-t E) (my-list/my-list-t E))))

(define (li-tail target) (list-get 2 target))

(claim li-put-head
  (polymorphic (E)
    (-> E (my-list/my-list-t E) (my-list/my-list-t E))))

(define (li-put-head value target)
  (list-put 1 value target))

(claim li-put-tail
  (polymorphic (E)
    (-> (my-list/my-list-t E)
        (my-list/my-list-t E)
        (my-list/my-list-t E))))

(define (li-put-tail value target)
  (list-put 2 value target))

(claim li-put-head!
  (polymorphic (E)
    (-> E (my-list/my-list-t E) (my-list/my-list-t E))))

(define (li-put-head! value target)
  (list-put! 1 value target))

(claim li-put-tail!
  (polymorphic (E)
    (-> (my-list/my-list-t E)
        (my-list/my-list-t E)
        (my-list/my-list-t E))))

(define (li-put-tail! value target)
  (list-put! 2 value target))