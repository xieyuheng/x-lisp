(define (negate p x) (not (p x)))

(define-test negate-test
  (assert (not (int? 'a)))
  (assert (negate int? 'a))
  (assert ((negate int?) 'a)))

(claim call-with-input-file
  (polymorphic (A)
    (-> builtin/string-t (-> builtin/file-t A) A)))

(define (call-with-input-file path f)
  (= file (open-input-file path))
  (= result (f file))
  (file-close file)
  result)

(claim call-with-output-file
  (polymorphic (A)
    (-> builtin/string-t (-> builtin/file-t A) A)))

(define (call-with-output-file path f)
  (= file (open-output-file path))
  (= result (f file))
  (file-close file)
  result)

(claim float-product
  (-> (builtin/list-t builtin/float-t) builtin/float-t))

(define (float-product xs)
  (if (list-empty? xs)
    1.0
    (fmul (car xs) (float-product (cdr xs)))))

(define-test float-product-test
  (assert-equal 1.0 (float-product []))
  (assert-equal 6.0 (float-product [1.0 2.0 3.0]))
  (assert-equal 24.0 (float-product [1.0 2.0 3.0 4.0])))

(claim float-sum
  (-> (builtin/list-t builtin/float-t) builtin/float-t))

(define (float-sum xs)
  (if (list-empty? xs)
    0.0
    (fadd (car xs) (float-sum (cdr xs)))))

(define-test float-sum-test
  (assert-equal 0.0 (float-sum []))
  (assert-equal 6.0 (float-sum [1.0 2.0 3.0]))
  (assert-equal 10.0 (float-sum [1.0 2.0 3.0 4.0])))

(claim constant (polymorphic (A B) (-> A B A)))

(define (constant x y) x)

(define-test constant-test
  (assert-equal 1 (constant 1 "a")))

(claim swap
  (polymorphic (A B C) (-> (-> A B C) (-> B A C))))

(define (swap f x y) (f y x))

(claim drop (polymorphic (A B C) (-> (-> A B) (-> C A B))))

(define (drop f) (lambda (dropped x) (f x)))

(claim dup (polymorphic (A B) (-> (-> A A B) (-> A B))))

(define (dup f) (lambda (x) (f x x)))

(claim identity (polymorphic (A) (-> A A)))

(define (identity x) x)

(define-test identity-test (assert-equal 1 (identity 1)))

(claim hash-entry-t
  (-> builtin/type-t builtin/type-t builtin/type-t))

(define-type hash-entry-t (interface :key K :value V))

(claim int-align
  (-> builtin/int-t builtin/int-t builtin/int-t))

(define (int-align alignment n)
  (= remainder (imod n alignment))
  (if (equal? 0 remainder)
    n
    (iadd (isub n remainder) alignment)))

(define-test int-align-test
  (assert-equal 0 (int-align 16 0))
  (assert-equal 16 (int-align 16 8))
  (assert-equal 16 (int-align 16 16))
  (assert-equal 32 (int-align 16 24)))

(claim int-product
  (-> (builtin/list-t builtin/int-t) builtin/int-t))

(define (int-product xs)
  (if (list-empty? xs)
    1
    (imul (car xs) (int-product (cdr xs)))))

(define-test int-product-test
  (assert-equal 1 (int-product []))
  (assert-equal 6 (int-product [1 2 3]))
  (assert-equal 24 (int-product [1 2 3 4])))

(claim int-sum
  (-> (builtin/list-t builtin/int-t) builtin/int-t))

(define (int-sum xs)
  (if (list-empty? xs) 0 (iadd (car xs) (int-sum (cdr xs)))))

(define-test int-sum-test
  (assert-equal 0 (int-sum []))
  (assert-equal 6 (int-sum [1 2 3]))
  (assert-equal 10 (int-sum [1 2 3 4])))

(claim list-append
  (polymorphic (A)
    (-> (builtin/list-t A)
        (builtin/list-t A)
        (builtin/list-t A))))

(define (list-append list tail)
  (if (list-empty? list)
    tail
    (cons (car list) (list-append (cdr list) tail))))

(define-test list-append-test
  (assert-equal (list-append [1 2 3] [4 5 6]) [1 2 3 4 5 6]))

(claim list-concat
  (polymorphic (A)
    (-> (builtin/list-t (builtin/list-t A))
        (builtin/list-t A))))

(define (list-concat lists)
  (if (list-empty? lists)
    []
    (list-append (car lists) (list-concat (cdr lists)))))

(define-test list-concat-test
  (assert-equal
    (list-concat [[1 2 3] [4 5 6]])
    [1 2 3 4 5 6]))

(claim list-each
  (polymorphic (A)
    (-> (-> A builtin/void-t)
        (builtin/list-t A)
        builtin/void-t)))

(define (list-each f list)
  (if (list-empty? list)
    void
    (begin (f (car list)) (list-each f (cdr list)))))

(define-test list-each-test
  (list-each (lambda (x) (print x) (write "\n")) [1 2 3]))

(claim list-every?
  (polymorphic (A)
    (-> (-> A builtin/bool-t)
        (builtin/list-t A)
        builtin/bool-t)))

(define (list-every? p list)
  (cond
    ((list-empty? list) true)
    ((not (p (car list))) false)
    (true (list-every? p (cdr list)))))

(define-test list-every-test
  (assert (list-every? int-non-negative? [0 1 2 3]))
  (assert-not (list-every? int-non-negative? [0 1 -1 2 3])))

(claim list-some?
  (polymorphic (A)
    (-> (-> A builtin/bool-t)
        (builtin/list-t A)
        builtin/bool-t)))

(define (list-some? p list)
  (cond
    ((list-empty? list) false)
    ((p (car list)) true)
    (true (list-some? p (cdr list)))))

(define-test list-some-test
  (assert (list-some? int-non-negative? [-1 -2 0]))
  (assert-not (list-some? int-non-negative? [-1 -2 -3])))

(claim list-find
  (polymorphic (A)
    (-> (-> A builtin/bool-t)
        (builtin/list-t A)
        (builtin/maybe-t A))))

(define (list-find p list)
  (cond
    ((list-empty? list) nothing)
    ((p (car list)) (just (car list)))
    (true (list-find p (cdr list)))))

(define-test list-find-test
  (assert-equal (just 3) (list-find int? ['a 'b 3 'd]))
  (assert-equal nothing (list-find int? ['a 'b 'c 'd])))

(claim list-find-index
  (polymorphic (A)
    (-> (-> A builtin/bool-t)
        (builtin/list-t A)
        (builtin/maybe-t builtin/int-t))))

(define (list-find-index p list)
  (list-find-index-aux p list 0))

(claim list-find-index-aux
  (polymorphic (A)
    (-> (-> A builtin/bool-t)
        (builtin/list-t A)
        builtin/int-t
        (builtin/maybe-t builtin/int-t))))

(define (list-find-index-aux p list index)
  (cond
    ((list-empty? list) nothing)
    ((p (car list)) (just index))
    (true (list-find-index-aux p (cdr list) (iadd 1 index)))))

(define-test list-find-index-test
  (assert-equal
    (just 2)
    (list-find-index int? ['a 'b 3 'd]))
  (assert-equal
    nothing
    (list-find-index int? ['a 'b 'c 'd])))

(claim list-fold-left
  (polymorphic (E R) (-> (-> R E R) R (builtin/list-t E) R)))

(define (list-fold-left op e list)
  (if (list-empty? list)
    e
    (list-fold-left
     op
     (op e (list-head list))
     (list-tail list))))

(define-test list-fold-left-test
  (assert-equal 10 (list-fold-left iadd 0 [1 2 3 4]))
  (assert-equal
    [4 3 2 1]
    (list-fold-left (swap cons) [] [1 2 3 4])))

(claim list-fold-right
  (polymorphic (E R) (-> (-> E R R) R (builtin/list-t E) R)))

(define (list-fold-right op e list)
  (if (list-empty? list)
    e
    (list-fold-right
     op
     (op (list-last list) e)
     (list-init list))))

(define-test list-fold-right-test
  (assert-equal 10 (list-fold-right iadd 0 [1 2 3 4]))
  (assert-equal
    [1 2 3 4]
    (list-fold-right cons [] [1 2 3 4])))

(define (list-first list) (car list))

(define (list-second list) (car (cdr list)))

(define (list-third list) (car (cdr (cdr list))))

(claim list-map-zip
  (polymorphic (A B C)
    (-> (-> A B C)
        (builtin/list-t A)
        (builtin/list-t B)
        (builtin/list-t C))))

(define (list-map-zip f left right)
  (list-map
   (lambda (pair) (f (pair-first pair) (pair-second pair)))
   (list-zip left right)))

(define-test list-map-zip-test
  (assert-equal
    (list-map-zip iadd [1 2 3] [10 20 30])
    [11 22 33]))

(claim list-map
  (polymorphic (A B)
    (-> (-> A B) (builtin/list-t A) (builtin/list-t B))))

(define (list-map f list)
  (if (list-empty? list)
    []
    (cons (f (car list)) (list-map f (cdr list)))))

(define-test list-map-test
  (assert-equal (list-map (iadd 10) [1 2 3]) [11 12 13]))

(claim list-member?
  (polymorphic (A) (-> A (builtin/list-t A) builtin/bool-t)))

(define (list-member? x list)
  (cond
    ((list-empty? list) false)
    ((equal? x (car list)) true)
    (true (list-member? x (cdr list)))))

(define-test list-member-test
  (assert (list-member? 2 [1 2 3]))
  (assert-not (list-member? 0 [1 2 3])))

(claim list-select
  (polymorphic (A)
    (-> (-> A builtin/bool-t)
        (builtin/list-t A)
        (builtin/list-t A))))

(define (list-select p list)
  (cond
    ((list-empty? list) list)
    ((p (car list))
     (cons (car list) (list-select p (cdr list))))
    (true (list-select p (cdr list)))))

(define-test list-select-test
  (assert-equal
    (list-select (negate (equal? 0)) [0 1 0 2 0 3])
    [1 2 3]))

(claim list-reject
  (polymorphic (A)
    (-> (-> A builtin/bool-t)
        (builtin/list-t A)
        (builtin/list-t A))))

(define (list-reject p list) (list-select (negate p) list))

(define-test list-reject-test
  (assert-equal
    (list-reject (equal? 0) [0 1 0 2 0 3])
    [1 2 3]))

(claim list-take
  (polymorphic (A)
    (-> builtin/int-t (builtin/list-t A) (builtin/list-t A))))

(define (list-take n list)
  (assert (int-non-negative? n))
  (if (or (equal? n 0) (list-empty? list))
    []
    (cons (car list) (list-take (isub n 1) (cdr list)))))

(define-test list-take-test
  (assert-equal (list-take 0 [1 2 3]) [])
  (assert-equal (list-take 1 [1 2 3]) [1])
  (assert-equal (list-take 2 [1 2 3]) [1 2])
  (assert-equal (list-take 3 [1 2 3]) [1 2 3])
  (assert-equal (list-take 4 [1 2 3]) [1 2 3]))

(claim list-drop
  (polymorphic (A)
    (-> builtin/int-t (builtin/list-t A) (builtin/list-t A))))

(define (list-drop n list)
  (assert (int-non-negative? n))
  (if (or (equal? n 0) (list-empty? list))
    list
    (list-drop (isub n 1) (cdr list))))

(define-test list-drop-test
  (assert-equal (list-drop 0 [1 2 3]) [1 2 3])
  (assert-equal (list-drop 1 [1 2 3]) [2 3])
  (assert-equal (list-drop 2 [1 2 3]) [3])
  (assert-equal (list-drop 3 [1 2 3]) [])
  (assert-equal (list-drop 4 [1 2 3]) []))

(claim list-zip
  (polymorphic (A B)
    (-> (builtin/list-t A)
        (builtin/list-t B)
        (builtin/list-t (builtin/pair-t A B)))))

(define (list-zip left right)
  (if (or (list-empty? left) (list-empty? right))
    []
    (cons
     (make-pair (car left) (car right))
     (list-zip (cdr left) (cdr right)))))

(define-test list-zip-test
  (assert-equal
    (list-zip ['a 'b 'c] [1 2 3])
    [(make-pair 'a 1) (make-pair 'b 2) (make-pair 'c 3)])
  (assert-equal
    (list-zip ['a 'b 'c] [1 2])
    [(make-pair 'a 1) (make-pair 'b 2)]))

(claim list-unzip
  (polymorphic (A B)
    (-> (builtin/list-t (builtin/pair-t A B))
        (builtin/pair-t
         (builtin/list-t A)
         (builtin/list-t B)))))

(define (list-unzip pairs)
  (make-pair
   (list-map pair-first pairs)
   (list-map pair-second pairs)))

(define-test list-unzip-test
  (assert-equal
    (list-unzip
     [(make-pair 'a 1) (make-pair 'b 2) (make-pair 'c 3)])
    (make-pair ['a 'b 'c] [1 2 3])))

(define-data (maybe-t A) (just (value A)) nothing)

(claim just (polymorphic (A) (-> A (builtin/maybe-t A))))

(define (just value) ['just value])

(claim just?
  (polymorphic (A) (-> (builtin/maybe-t A) builtin/bool-t)))

(define (just? value)
  (and (list? value)
       (equal? (list-length value) 2)
       (equal? (list-head value) 'just)))

(claim just-value
  (polymorphic (A) (-> (builtin/maybe-t A) A)))

(define (just-value target) (list-get 1 target))

(claim just-put-value
  (polymorphic (A)
    (-> A (builtin/maybe-t A) (builtin/maybe-t A))))

(define (just-put-value value target)
  (list-put 1 value target))

(claim just-put-value!
  (polymorphic (A)
    (-> A (builtin/maybe-t A) (builtin/maybe-t A))))

(define (just-put-value! value target)
  (list-put! 1 value target))

(claim nothing (polymorphic (A) (builtin/maybe-t A)))

(define nothing 'nothing)

(claim nothing?
  (polymorphic (A) (-> (builtin/maybe-t A) builtin/bool-t)))

(define (nothing? value) (equal? value 'nothing))

(define-interface (pair-t A B) :first A :second B)

(define (make-pair first second)
  (@record :first first :second second))

(define (pair-first pair) (:first pair))

(define (pair-second pair) (:second pair))

(define (pair-put-first first pair)
  (update pair :first first))

(define (pair-put-second second pair)
  (update pair :second second))

(define (pair-put-first! first pair)
  (update! pair :first first))

(define (pair-put-second! second pair)
  (update! pair :second second))

(claim set-each
  (polymorphic (A)
    (-> (-> A builtin/void-t)
        (builtin/set-t A)
        builtin/void-t)))

(define (set-each f set) (list-each f (set-to-list set)))

(claim set-every?
  (polymorphic (A)
    (-> (-> A builtin/bool-t)
        (builtin/set-t A)
        builtin/bool-t)))

(define (set-every? p set)
  (list-every? p (set-to-list set)))

(define-test set-every-test
  (assert (set-every? int-non-negative? {0 1 2 3}))
  (assert-not (set-every? int-non-negative? {0 1 -1 2 3})))

(claim set-some?
  (polymorphic (A)
    (-> (-> A builtin/bool-t)
        (builtin/set-t A)
        builtin/bool-t)))

(define (set-some? p set) (list-some? p (set-to-list set)))

(define-test set-some-test
  (assert (set-some? int-non-negative? {-1 -2 0}))
  (assert-not (set-some? int-non-negative? {-1 -2 -3})))

(claim set-map
  (polymorphic (A B)
    (-> (-> A B) (builtin/set-t A) (builtin/set-t B))))

(define (set-map f set)
  (= new-set (make-set))
  (set-each (lambda (e) (set-add! (f e) new-set)) set)
  new-set)

(define-test set-map-test
  (assert-equal
    {2 4 6}
    (set-map (lambda (n) (iadd n n)) {1 2 3})))

(claim set-select
  (polymorphic (A)
    (-> (-> A builtin/bool-t)
        (builtin/set-t A)
        (builtin/set-t A))))

(define (set-select p set)
  (= new-set {})
  (set-each
   (lambda (e)
     (when (p e) (begin (set-add! e new-set) void)))
   set)
  new-set)

(define-test set-select-test
  (assert-equal
    {0 1 2}
    (set-select int-non-negative? {-2 -1 0 1 2})))

(claim set-reject
  (polymorphic (A)
    (-> (-> A builtin/bool-t)
        (builtin/set-t A)
        (builtin/set-t A))))

(define (set-reject p set) (set-select (negate p) set))

(define-test set-reject-test
  (assert-equal
    {-1 -2}
    (set-reject int-non-negative? {-2 -1 0 1 2})))

(define-interface source-location-t
  :span
  source-span-t
  :path
  string-t)

(define-interface source-span-t
  :start
  source-position-t
  :end
  source-position-t)

(define-interface source-position-t
  :index
  int-t
  :row
  int-t
  :column
  int-t)

(define-data located-sexp-t
  (symbol-sexp
   (content symbol-t)
   (location source-location-t))
  (keyword-sexp
   (content keyword-t)
   (location source-location-t))
  (string-sexp
   (content string-t)
   (location source-location-t))
  (int-sexp (content int-t) (location source-location-t))
  (float-sexp (content float-t) (location source-location-t))
  (list-sexp
   (elements (list-t located-sexp-t))
   (location source-location-t)))

(claim symbol-sexp
  (-> builtin/symbol-t
      builtin/source-location-t
      builtin/located-sexp-t))

(define (symbol-sexp content location)
  ['symbol-sexp content location])

(claim symbol-sexp?
  (-> builtin/located-sexp-t builtin/bool-t))

(define (symbol-sexp? value)
  (and (list? value)
       (equal? (list-length value) 3)
       (equal? (list-head value) 'symbol-sexp)))

(claim symbol-sexp-content
  (-> builtin/located-sexp-t builtin/symbol-t))

(define (symbol-sexp-content target) (list-get 1 target))

(claim symbol-sexp-location
  (-> builtin/located-sexp-t builtin/source-location-t))

(define (symbol-sexp-location target) (list-get 2 target))

(claim symbol-sexp-put-content
  (-> builtin/symbol-t
      builtin/located-sexp-t
      builtin/located-sexp-t))

(define (symbol-sexp-put-content value target)
  (list-put 1 value target))

(claim symbol-sexp-put-location
  (-> builtin/source-location-t
      builtin/located-sexp-t
      builtin/located-sexp-t))

(define (symbol-sexp-put-location value target)
  (list-put 2 value target))

(claim symbol-sexp-put-content!
  (-> builtin/symbol-t
      builtin/located-sexp-t
      builtin/located-sexp-t))

(define (symbol-sexp-put-content! value target)
  (list-put! 1 value target))

(claim symbol-sexp-put-location!
  (-> builtin/source-location-t
      builtin/located-sexp-t
      builtin/located-sexp-t))

(define (symbol-sexp-put-location! value target)
  (list-put! 2 value target))

(claim keyword-sexp
  (-> builtin/keyword-t
      builtin/source-location-t
      builtin/located-sexp-t))

(define (keyword-sexp content location)
  ['keyword-sexp content location])

(claim keyword-sexp?
  (-> builtin/located-sexp-t builtin/bool-t))

(define (keyword-sexp? value)
  (and (list? value)
       (equal? (list-length value) 3)
       (equal? (list-head value) 'keyword-sexp)))

(claim keyword-sexp-content
  (-> builtin/located-sexp-t builtin/keyword-t))

(define (keyword-sexp-content target) (list-get 1 target))

(claim keyword-sexp-location
  (-> builtin/located-sexp-t builtin/source-location-t))

(define (keyword-sexp-location target) (list-get 2 target))

(claim keyword-sexp-put-content
  (-> builtin/keyword-t
      builtin/located-sexp-t
      builtin/located-sexp-t))

(define (keyword-sexp-put-content value target)
  (list-put 1 value target))

(claim keyword-sexp-put-location
  (-> builtin/source-location-t
      builtin/located-sexp-t
      builtin/located-sexp-t))

(define (keyword-sexp-put-location value target)
  (list-put 2 value target))

(claim keyword-sexp-put-content!
  (-> builtin/keyword-t
      builtin/located-sexp-t
      builtin/located-sexp-t))

(define (keyword-sexp-put-content! value target)
  (list-put! 1 value target))

(claim keyword-sexp-put-location!
  (-> builtin/source-location-t
      builtin/located-sexp-t
      builtin/located-sexp-t))

(define (keyword-sexp-put-location! value target)
  (list-put! 2 value target))

(claim string-sexp
  (-> builtin/string-t
      builtin/source-location-t
      builtin/located-sexp-t))

(define (string-sexp content location)
  ['string-sexp content location])

(claim string-sexp?
  (-> builtin/located-sexp-t builtin/bool-t))

(define (string-sexp? value)
  (and (list? value)
       (equal? (list-length value) 3)
       (equal? (list-head value) 'string-sexp)))

(claim string-sexp-content
  (-> builtin/located-sexp-t builtin/string-t))

(define (string-sexp-content target) (list-get 1 target))

(claim string-sexp-location
  (-> builtin/located-sexp-t builtin/source-location-t))

(define (string-sexp-location target) (list-get 2 target))

(claim string-sexp-put-content
  (-> builtin/string-t
      builtin/located-sexp-t
      builtin/located-sexp-t))

(define (string-sexp-put-content value target)
  (list-put 1 value target))

(claim string-sexp-put-location
  (-> builtin/source-location-t
      builtin/located-sexp-t
      builtin/located-sexp-t))

(define (string-sexp-put-location value target)
  (list-put 2 value target))

(claim string-sexp-put-content!
  (-> builtin/string-t
      builtin/located-sexp-t
      builtin/located-sexp-t))

(define (string-sexp-put-content! value target)
  (list-put! 1 value target))

(claim string-sexp-put-location!
  (-> builtin/source-location-t
      builtin/located-sexp-t
      builtin/located-sexp-t))

(define (string-sexp-put-location! value target)
  (list-put! 2 value target))

(claim int-sexp
  (-> builtin/int-t
      builtin/source-location-t
      builtin/located-sexp-t))

(define (int-sexp content location)
  ['int-sexp content location])

(claim int-sexp? (-> builtin/located-sexp-t builtin/bool-t))

(define (int-sexp? value)
  (and (list? value)
       (equal? (list-length value) 3)
       (equal? (list-head value) 'int-sexp)))

(claim int-sexp-content
  (-> builtin/located-sexp-t builtin/int-t))

(define (int-sexp-content target) (list-get 1 target))

(claim int-sexp-location
  (-> builtin/located-sexp-t builtin/source-location-t))

(define (int-sexp-location target) (list-get 2 target))

(claim int-sexp-put-content
  (-> builtin/int-t
      builtin/located-sexp-t
      builtin/located-sexp-t))

(define (int-sexp-put-content value target)
  (list-put 1 value target))

(claim int-sexp-put-location
  (-> builtin/source-location-t
      builtin/located-sexp-t
      builtin/located-sexp-t))

(define (int-sexp-put-location value target)
  (list-put 2 value target))

(claim int-sexp-put-content!
  (-> builtin/int-t
      builtin/located-sexp-t
      builtin/located-sexp-t))

(define (int-sexp-put-content! value target)
  (list-put! 1 value target))

(claim int-sexp-put-location!
  (-> builtin/source-location-t
      builtin/located-sexp-t
      builtin/located-sexp-t))

(define (int-sexp-put-location! value target)
  (list-put! 2 value target))

(claim float-sexp
  (-> builtin/float-t
      builtin/source-location-t
      builtin/located-sexp-t))

(define (float-sexp content location)
  ['float-sexp content location])

(claim float-sexp?
  (-> builtin/located-sexp-t builtin/bool-t))

(define (float-sexp? value)
  (and (list? value)
       (equal? (list-length value) 3)
       (equal? (list-head value) 'float-sexp)))

(claim float-sexp-content
  (-> builtin/located-sexp-t builtin/float-t))

(define (float-sexp-content target) (list-get 1 target))

(claim float-sexp-location
  (-> builtin/located-sexp-t builtin/source-location-t))

(define (float-sexp-location target) (list-get 2 target))

(claim float-sexp-put-content
  (-> builtin/float-t
      builtin/located-sexp-t
      builtin/located-sexp-t))

(define (float-sexp-put-content value target)
  (list-put 1 value target))

(claim float-sexp-put-location
  (-> builtin/source-location-t
      builtin/located-sexp-t
      builtin/located-sexp-t))

(define (float-sexp-put-location value target)
  (list-put 2 value target))

(claim float-sexp-put-content!
  (-> builtin/float-t
      builtin/located-sexp-t
      builtin/located-sexp-t))

(define (float-sexp-put-content! value target)
  (list-put! 1 value target))

(claim float-sexp-put-location!
  (-> builtin/source-location-t
      builtin/located-sexp-t
      builtin/located-sexp-t))

(define (float-sexp-put-location! value target)
