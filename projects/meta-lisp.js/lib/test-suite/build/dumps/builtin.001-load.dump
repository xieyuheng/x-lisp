(claim float-product (-> (list-t float-t) float-t))

(define (float-product xs)
  (if (list-empty? xs)
    1.0
    (fmul (car xs) (float-product (cdr xs)))))

(define-test float-product-test
  (assert-equal 1.0 (float-product []))
  (assert-equal 6.0 (float-product [1.0 2.0 3.0]))
  (assert-equal 24.0 (float-product [1.0 2.0 3.0 4.0])))

(claim float-sum (-> (list-t float-t) float-t))

(define (float-sum xs)
  (if (list-empty? xs)
    0.0
    (fadd (car xs) (float-sum (cdr xs)))))

(define-test float-sum-test
  (assert-equal 0.0 (float-sum []))
  (assert-equal 6.0 (float-sum [1.0 2.0 3.0]))
  (assert-equal 10.0 (float-sum [1.0 2.0 3.0 4.0])))

(claim int-align (-> int-t int-t int-t))

(define (int-align alignment n)
  (= remainder (imod n alignment))
  (if (equal? 0 remainder)
    n
    (iadd (isub n remainder) alignment)))

(define-test int-align-test
  (assert-equal 0 (int-align 16 0))
  (assert-equal 16 (int-align 16 8))
  (assert-equal 16 (int-align 16 16))
  (assert-equal 32 (int-align 16 24)))

(claim int-product (-> (list-t int-t) int-t))

(define (int-product xs)
  (if (list-empty? xs)
    1
    (imul (car xs) (int-product (cdr xs)))))

(define-test int-product-test
  (assert-equal 1 (int-product []))
  (assert-equal 6 (int-product [1 2 3]))
  (assert-equal 24 (int-product [1 2 3 4])))

(claim int-sum (-> (list-t int-t) int-t))

(define (int-sum xs)
  (if (list-empty? xs) 0 (iadd (car xs) (int-sum (cdr xs)))))

(define-test int-sum-test
  (assert-equal 0 (int-sum []))
  (assert-equal 6 (int-sum [1 2 3]))
  (assert-equal 10 (int-sum [1 2 3 4])))

(claim list-append
  (polymorphic (A) (-> (list-t A) (list-t A) (list-t A))))

(define (list-append list tail)
  (if (list-empty? list)
    tail
    (cons (car list) (list-append (cdr list) tail))))

(define-test list-append-test
  (assert-equal (list-append [1 2 3] [4 5 6]) [1 2 3 4 5 6]))

(claim list-concat
  (polymorphic (A) (-> (list-t (list-t A)) (list-t A))))

(define (list-concat lists)
  (if (list-empty? lists)
    []
    (list-append (car lists) (list-concat (cdr lists)))))

(define-test list-concat-test
  (assert-equal
    (list-concat [[1 2 3] [4 5 6]])
    [1 2 3 4 5 6]))

(define-interface source-location-t
  :span
  source-span-t
  :path
  string-t)

(define-interface source-span-t
  :start
  source-position-t
  :end
  source-position-t)

(define-interface source-position-t
  :index
  int-t
  :row
  int-t
  :column
  int-t)

(define-data located-sexp-t
  (symbol-sexp
   (content symbol-t)
   (location source-location-t))
  (keyword-sexp
   (content keyword-t)
   (location source-location-t))
  (string-sexp
   (content string-t)
   (location source-location-t))
  (int-sexp (content int-t) (location source-location-t))
  (float-sexp (content float-t) (location source-location-t))
  (list-sexp
   (elements (list-t located-sexp-t))
   (location source-location-t)))

(claim symbol-sexp
  (-> symbol-t source-location-t located-sexp-t))

(define (symbol-sexp content location)
  ['symbol-sexp content location])

(claim symbol-sexp? (-> located-sexp-t bool-t))

(define (symbol-sexp? value)
  (and (list? value)
       (equal? (list-length value) 3)
       (equal? (list-head value) 'symbol-sexp)))

(claim symbol-sexp-content (-> located-sexp-t symbol-t))

(define (symbol-sexp-content target) (list-get 1 target))

(claim symbol-sexp-location
  (-> located-sexp-t source-location-t))

(define (symbol-sexp-location target) (list-get 2 target))

(claim symbol-sexp-put-content
  (-> symbol-t located-sexp-t located-sexp-t))

(define (symbol-sexp-put-content value target)
  (list-put 1 value target))

(claim symbol-sexp-put-location
  (-> source-location-t located-sexp-t located-sexp-t))

(define (symbol-sexp-put-location value target)
  (list-put 2 value target))

(claim symbol-sexp-put-content!
  (-> symbol-t located-sexp-t located-sexp-t))

(define (symbol-sexp-put-content! value target)
  (list-put! 1 value target))

(claim symbol-sexp-put-location!
  (-> source-location-t located-sexp-t located-sexp-t))

(define (symbol-sexp-put-location! value target)
  (list-put! 2 value target))

