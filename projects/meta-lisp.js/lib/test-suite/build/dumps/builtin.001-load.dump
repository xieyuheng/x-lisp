(claim list-sexp
  (-> (builtin/list-t builtin/located-sexp-t)
      builtin/source-location-t
      builtin/located-sexp-t))

(define (list-sexp elements location)
  ['list-sexp elements location])

(claim list-sexp?
  (-> builtin/located-sexp-t builtin/bool-t))

(define (list-sexp? value)
  (and (list? value)
       (equal? (list-length value) 3)
       (equal? (list-head value) 'list-sexp)))

(claim list-sexp-elements
  (-> builtin/located-sexp-t
      (builtin/list-t builtin/located-sexp-t)))

(define (list-sexp-elements target) (list-get 1 target))

(claim list-sexp-location
  (-> builtin/located-sexp-t builtin/source-location-t))

(define (list-sexp-location target) (list-get 2 target))

(claim list-sexp-put-elements
  (-> (builtin/list-t builtin/located-sexp-t)
      builtin/located-sexp-t
      builtin/located-sexp-t))

(define (list-sexp-put-elements value target)
  (list-put 1 value target))

(claim list-sexp-put-location
  (-> builtin/source-location-t
      builtin/located-sexp-t
      builtin/located-sexp-t))

(define (list-sexp-put-location value target)
  (list-put 2 value target))

(claim list-sexp-put-elements!
  (-> (builtin/list-t builtin/located-sexp-t)
      builtin/located-sexp-t
      builtin/located-sexp-t))

(define (list-sexp-put-elements! value target)
  (list-put! 1 value target))

(claim list-sexp-put-location!
  (-> builtin/source-location-t
      builtin/located-sexp-t
      builtin/located-sexp-t))

(define (list-sexp-put-location! value target)
  (list-put! 2 value target))

(claim string-repeat
  (-> builtin/int-t builtin/string-t builtin/string-t))

(define (string-repeat n string)
  (if (equal? n 0)
    ""
    (string-append string (string-repeat (isub n 1) string))))

(define-test string-repeat-test
  (assert-equal "" (string-repeat 0 "a"))
  (assert-equal "a" (string-repeat 1 "a"))
  (assert-equal "aa" (string-repeat 2 "a"))
  (assert-equal "aaa" (string-repeat 3 "a")))