  (-> float-t source-location-t located-sexp-t))

(define (float-sexp content location)
  ['float-sexp content location])

(claim float-sexp? (-> located-sexp-t bool-t))

(define (float-sexp? value)
  (and (list? value)
       (equal? (list-length value) 3)
       (equal? (list-head value) 'float-sexp)))

(claim float-sexp-content (-> located-sexp-t float-t))

