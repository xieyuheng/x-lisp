    (= _₁₃ l1/var-exp)
    (= _₁₄ (_₁₃ 'x))
    (= _₁₅ (_₁₂ 'x _₁₄))
    (= _₁₆ (_₇ _₁₁ _₁₅))
    (_₆ _₁₆))
  (= _₁₇ l1/evaluate-and-print)
  (= _₁₈ l1/apply-exp)
  (= _₁₉ l1/apply-exp)
  (= _₂₀ l1/lambda-exp)
  (= _₂₁ l1/var-exp)
  (= _₂₂ (_₂₁ 'x))
  (= _₂₃ (_₂₀ 'x _₂₂))
  (= _₂₄ l1/lambda-exp)
  (= _₂₅ l1/var-exp)
  (= _₂₆ (_₂₅ 'x))
  (= _₂₇ (_₂₄ 'x _₂₆))
  (= _₂₈ (_₁₉ _₂₃ _₂₇))
  (= _₂₉ l1/apply-exp)
  (= _₃₀ l1/lambda-exp)
  (= _₃₁ l1/var-exp)
  (= _₃₂ (_₃₁ 'x))
  (= _₃₃ (_₃₀ 'x _₃₂))
  (= _₃₄ l1/lambda-exp)
  (= _₃₅ l1/var-exp)
  (= _₃₆ (_₃₅ 'x))
  (= _₃₇ (_₃₄ 'x _₃₆))
  (= _₃₈ (_₂₉ _₃₃ _₃₇))
  (= _₃₉ (_₁₈ _₂₈ _₃₈))
