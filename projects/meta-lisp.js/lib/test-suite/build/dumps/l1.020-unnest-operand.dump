(claim evaluate (-> l1/exp-t l1/env-t l1/value-t))

(define (evaluate exp env)
  (if (begin (= _₁ l1/var-exp?) (_₁ exp))
    (begin
      (= name₁₁ (begin (= _₂ l1/var-exp-name) (_₂ exp)))
      (= name₁ name₁₁)
      (= _₃ l1/env-lookup-of-fail)
      (_₃ name₁ env))
    (if (begin (= _₄ l1/apply-exp?) (_₄ exp))
      (begin
        (= arg₁₁ (begin (= _₅ l1/apply-exp-arg) (_₅ exp)))
        (= target₁₁
           (begin (= _₆ l1/apply-exp-target) (_₆ exp)))
        (= arg₁ arg₁₁)
        (= target₁ target₁₁)
        (= _₇ l1/apply)
        (= _₈ l1/evaluate)
        (= _₉ (_₈ target₁ env))
        (= _₁₀ l1/evaluate)
        (= _₁₁ (_₁₀ arg₁ env))
        (_₇ _₉ _₁₁))
      (if (begin (= _₁₂ l1/lambda-exp?) (_₁₂ exp))
        (begin
          (= body₁₁
             (begin (= _₁₃ l1/lambda-exp-body) (_₁₃ exp)))
          (= parameter₁₁
             (begin
               (= _₁₄ l1/lambda-exp-parameter)
               (_₁₄ exp)))
          (= body₁ body₁₁)
          (= parameter₁ parameter₁₁)
          (= _₁₅ l1/closure-value)
          (_₁₅ env parameter₁ body₁))
        (error "cond mismatch")))))

(claim apply (-> l1/value-t l1/value-t l1/value-t))

(define (apply target arg)
  (if (begin (= _₁ l1/closure-value?) (_₁ target))
    (begin
      (= body₂₁
         (begin (= _₂ l1/closure-value-body) (_₂ target)))
      (= parameter₂₁
         (begin
           (= _₃ l1/closure-value-parameter)
           (_₃ target)))
      (= env₁₁
         (begin (= _₄ l1/closure-value-env) (_₄ target)))
      (= body₁ body₂₁)
      (= parameter₁ parameter₂₁)
      (= env₁ env₁₁)
      (= _₅ l1/evaluate)
      (= _₆ l1/extend-env)
      (= _₇ (_₆ parameter₁ arg env₁))
      (_₅ body₁ _₇))
    (error "cond mismatch")))