(define-data exp-t
  (var-exp (name symbol-t))
  (apply-exp (target l1/exp-t) (arg l1/exp-t))
  (lambda-exp (parameter symbol-t) (body l1/exp-t)))

(claim var-exp (-> symbol-t l1/exp-t))

(define (var-exp name)
  (= list₁ (make-list))
  (list-push! 'var-exp list₁)
  (list-push! name list₁)
  list₁)

(claim var-exp? (-> l1/exp-t bool-t))

(define (var-exp? value)
  (if (list? value)
    (if (begin (= _₁ (list-length value)) (equal? _₁ 2))
      (begin (= _₂ (list-head value)) (equal? _₂ 'var-exp))
      false)
    false))

(claim var-exp-name (-> l1/exp-t symbol-t))

(define (var-exp-name target) (list-get 1 target))

(claim var-exp-put-name (-> symbol-t l1/exp-t l1/exp-t))

(define (var-exp-put-name value target)
