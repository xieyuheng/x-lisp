(define (negate p x) (builtin/not (p x)))

(define-test negate-test
  (builtin/assert (builtin/not (builtin/int? 'a)))
  (builtin/assert (builtin/negate builtin/int? 'a))
  (builtin/assert ((builtin/negate builtin/int?) 'a)))

(claim call-with-input-file
  (polymorphic (A)
    (-> builtin/string-t (-> builtin/file-t A) A)))

(define (call-with-input-file path f)
  (= file (builtin/open-input-file path))
  (= result (f file))
  (builtin/file-close file)
  result)

(claim call-with-output-file
  (polymorphic (A)
    (-> builtin/string-t (-> builtin/file-t A) A)))

(define (call-with-output-file path f)
  (= file (builtin/open-output-file path))
  (= result (f file))
  (builtin/file-close file)
  result)

(claim float-product
  (-> (builtin/list-t builtin/float-t) builtin/float-t))

(define (float-product xs)
  (if (builtin/list-empty? xs)
    1.0
    (builtin/fmul
     (builtin/car xs)
     (builtin/float-product (builtin/cdr xs)))))

(define-test float-product-test
  (builtin/assert-equal
   1.0
   (builtin/float-product
    (begin (= list (builtin/make-list)) list)))
  (builtin/assert-equal
   6.0
   (builtin/float-product
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 1.0 list)
      (builtin/list-push! 2.0 list)
      (builtin/list-push! 3.0 list)
      list)))
  (builtin/assert-equal
   24.0
   (builtin/float-product
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 1.0 list)
      (builtin/list-push! 2.0 list)
      (builtin/list-push! 3.0 list)
      (builtin/list-push! 4.0 list)
      list))))

(claim float-sum
  (-> (builtin/list-t builtin/float-t) builtin/float-t))

(define (float-sum xs)
  (if (builtin/list-empty? xs)
    0.0
    (builtin/fadd
     (builtin/car xs)
     (builtin/float-sum (builtin/cdr xs)))))

(define-test float-sum-test
  (builtin/assert-equal
   0.0
   (builtin/float-sum
    (begin (= list (builtin/make-list)) list)))
  (builtin/assert-equal
   6.0
   (builtin/float-sum
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 1.0 list)
      (builtin/list-push! 2.0 list)
      (builtin/list-push! 3.0 list)
      list)))
  (builtin/assert-equal
   10.0
   (builtin/float-sum
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 1.0 list)
      (builtin/list-push! 2.0 list)
      (builtin/list-push! 3.0 list)
      (builtin/list-push! 4.0 list)
      list))))

(claim constant (polymorphic (A B) (-> A B A)))

(define (constant x y) x)

(define-test constant-test
  (builtin/assert-equal 1 (builtin/constant 1 "a")))

(claim swap
  (polymorphic (A B C) (-> (-> A B C) (-> B A C))))

(define (swap f x y) (f y x))

(claim drop (polymorphic (A B C) (-> (-> A B) (-> C A B))))

(define (drop f) (lambda (dropped x) (f x)))

(claim dup (polymorphic (A B) (-> (-> A A B) (-> A B))))

(define (dup f) (lambda (x) (f x x)))

(claim identity (polymorphic (A) (-> A A)))

(define (identity x) x)

(define-test identity-test
  (builtin/assert-equal 1 (builtin/identity 1)))

(claim hash-entry-t
  (-> builtin/type-t builtin/type-t builtin/type-t))

(define-type hash-entry-t (interface :key K :value V))

(claim int-align
  (-> builtin/int-t builtin/int-t builtin/int-t))

(define (int-align alignment n)
  (= remainder (builtin/imod n alignment))
  (if (builtin/equal? 0 remainder)
    n
    (builtin/iadd (builtin/isub n remainder) alignment)))

(define-test int-align-test
  (builtin/assert-equal 0 (builtin/int-align 16 0))
  (builtin/assert-equal 16 (builtin/int-align 16 8))
  (builtin/assert-equal 16 (builtin/int-align 16 16))
  (builtin/assert-equal 32 (builtin/int-align 16 24)))

(claim int-product
  (-> (builtin/list-t builtin/int-t) builtin/int-t))

(define (int-product xs)
  (if (builtin/list-empty? xs)
    1
    (builtin/imul
     (builtin/car xs)
     (builtin/int-product (builtin/cdr xs)))))

(define-test int-product-test
  (builtin/assert-equal
   1
   (builtin/int-product
    (begin (= list (builtin/make-list)) list)))
  (builtin/assert-equal
   6
   (builtin/int-product
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 1 list)
      (builtin/list-push! 2 list)
      (builtin/list-push! 3 list)
      list)))
  (builtin/assert-equal
   24
   (builtin/int-product
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 1 list)
      (builtin/list-push! 2 list)
      (builtin/list-push! 3 list)
      (builtin/list-push! 4 list)
      list))))

(claim int-sum
  (-> (builtin/list-t builtin/int-t) builtin/int-t))

(define (int-sum xs)
  (if (builtin/list-empty? xs)
    0
    (builtin/iadd
     (builtin/car xs)
     (builtin/int-sum (builtin/cdr xs)))))

(define-test int-sum-test
  (builtin/assert-equal
   0
   (builtin/int-sum
    (begin (= list (builtin/make-list)) list)))
  (builtin/assert-equal
   6
   (builtin/int-sum
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 1 list)
      (builtin/list-push! 2 list)
      (builtin/list-push! 3 list)
      list)))
  (builtin/assert-equal
   10
   (builtin/int-sum
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 1 list)
      (builtin/list-push! 2 list)
      (builtin/list-push! 3 list)
      (builtin/list-push! 4 list)
      list))))

(claim list-append
  (polymorphic (A)
    (-> (builtin/list-t A)
        (builtin/list-t A)
        (builtin/list-t A))))

(define (list-append list tail)
  (if (builtin/list-empty? list)
    tail
    (builtin/cons
     (builtin/car list)
     (builtin/list-append (builtin/cdr list) tail))))

(define-test list-append-test
  (builtin/assert-equal
   (builtin/list-append
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 1 list)
      (builtin/list-push! 2 list)
      (builtin/list-push! 3 list)
      list)
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 4 list)
      (builtin/list-push! 5 list)
      (builtin/list-push! 6 list)
      list))
   (begin
     (= list (builtin/make-list))
     (builtin/list-push! 1 list)
     (builtin/list-push! 2 list)
     (builtin/list-push! 3 list)
     (builtin/list-push! 4 list)
     (builtin/list-push! 5 list)
     (builtin/list-push! 6 list)
     list)))

(claim list-concat
  (polymorphic (A)
    (-> (builtin/list-t (builtin/list-t A))
        (builtin/list-t A))))

(define (list-concat lists)
  (if (builtin/list-empty? lists)
    (begin (= list (builtin/make-list)) list)
    (builtin/list-append
     (builtin/car lists)
     (builtin/list-concat (builtin/cdr lists)))))

(define-test list-concat-test
  (builtin/assert-equal
   (builtin/list-concat
    (begin
      (= list (builtin/make-list))
      (builtin/list-push!
       (begin
         (= list (builtin/make-list))
         (builtin/list-push! 1 list)
         (builtin/list-push! 2 list)
         (builtin/list-push! 3 list)
         list)
       list)
      (builtin/list-push!
       (begin
         (= list (builtin/make-list))
         (builtin/list-push! 4 list)
         (builtin/list-push! 5 list)
         (builtin/list-push! 6 list)
         list)
       list)
      list))
   (begin
     (= list (builtin/make-list))
     (builtin/list-push! 1 list)
     (builtin/list-push! 2 list)
     (builtin/list-push! 3 list)
     (builtin/list-push! 4 list)
     (builtin/list-push! 5 list)
     (builtin/list-push! 6 list)
     list)))

(claim list-each
  (polymorphic (A)
    (-> (-> A builtin/void-t)
        (builtin/list-t A)
        builtin/void-t)))

(define (list-each f list)
  (if (builtin/list-empty? list)
    builtin/void
    (begin
      (f (builtin/car list))
      (builtin/list-each f (builtin/cdr list)))))

(define-test list-each-test
  (builtin/list-each
   (lambda (x) (builtin/print x) (builtin/write "\n"))
   (begin
     (= list (builtin/make-list))
     (builtin/list-push! 1 list)
     (builtin/list-push! 2 list)
     (builtin/list-push! 3 list)
     list)))

(claim list-every?
  (polymorphic (A)
    (-> (-> A builtin/bool-t)
        (builtin/list-t A)
        builtin/bool-t)))

(define (list-every? p list)
  (if (builtin/list-empty? list)
    builtin/true
    (if (builtin/not (p (builtin/car list)))
      builtin/false
      (if builtin/true
        (builtin/list-every? p (builtin/cdr list))
        (builtin/error "cond mismatch")))))

(define-test list-every-test
  (builtin/assert
   (builtin/list-every?
    builtin/int-non-negative?
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 0 list)
      (builtin/list-push! 1 list)
      (builtin/list-push! 2 list)
      (builtin/list-push! 3 list)
      list)))
  (builtin/assert-not
   (builtin/list-every?
    builtin/int-non-negative?
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 0 list)
      (builtin/list-push! 1 list)
      (builtin/list-push! -1 list)
      (builtin/list-push! 2 list)
      (builtin/list-push! 3 list)
      list))))

(claim list-some?
  (polymorphic (A)
    (-> (-> A builtin/bool-t)
        (builtin/list-t A)
        builtin/bool-t)))

(define (list-some? p list)
  (if (builtin/list-empty? list)
    builtin/false
    (if (p (builtin/car list))
      builtin/true
      (if builtin/true
        (builtin/list-some? p (builtin/cdr list))
        (builtin/error "cond mismatch")))))

(define-test list-some-test
  (builtin/assert
   (builtin/list-some?
    builtin/int-non-negative?
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! -1 list)
      (builtin/list-push! -2 list)
      (builtin/list-push! 0 list)
      list)))
  (builtin/assert-not
   (builtin/list-some?
    builtin/int-non-negative?
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! -1 list)
      (builtin/list-push! -2 list)
      (builtin/list-push! -3 list)
      list))))

(claim list-fold-left
  (polymorphic (E R) (-> (-> R E R) R (builtin/list-t E) R)))

(define (list-fold-left op e list)
  (if (builtin/list-empty? list)
    e
    (builtin/list-fold-left
     op
     (op e (builtin/list-head list))
     (builtin/list-tail list))))

(define-test list-fold-left-test
  (builtin/assert-equal
   10
   (builtin/list-fold-left
    builtin/iadd
    0
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 1 list)
      (builtin/list-push! 2 list)
      (builtin/list-push! 3 list)
      (builtin/list-push! 4 list)
      list)))
  (builtin/assert-equal
   (begin
     (= list (builtin/make-list))
     (builtin/list-push! 4 list)
     (builtin/list-push! 3 list)
     (builtin/list-push! 2 list)
     (builtin/list-push! 1 list)
     list)
   (builtin/list-fold-left
    (builtin/swap builtin/cons)
    (begin (= list (builtin/make-list)) list)
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 1 list)
      (builtin/list-push! 2 list)
      (builtin/list-push! 3 list)
      (builtin/list-push! 4 list)
      list))))

(claim list-fold-right
  (polymorphic (E R) (-> (-> E R R) R (builtin/list-t E) R)))

(define (list-fold-right op e list)
  (if (builtin/list-empty? list)
    e
    (builtin/list-fold-right
     op
     (op (builtin/list-last list) e)
     (builtin/list-init list))))

(define-test list-fold-right-test
  (builtin/assert-equal
   10
   (builtin/list-fold-right
    builtin/iadd
    0
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 1 list)
      (builtin/list-push! 2 list)
      (builtin/list-push! 3 list)
      (builtin/list-push! 4 list)
      list)))
  (builtin/assert-equal
   (begin
     (= list (builtin/make-list))
     (builtin/list-push! 1 list)
     (builtin/list-push! 2 list)
     (builtin/list-push! 3 list)
     (builtin/list-push! 4 list)
     list)
   (builtin/list-fold-right
    builtin/cons
    (begin (= list (builtin/make-list)) list)
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 1 list)
      (builtin/list-push! 2 list)
      (builtin/list-push! 3 list)
      (builtin/list-push! 4 list)
      list))))

(define (list-first list) (builtin/car list))

(define (list-second list) (builtin/car (builtin/cdr list)))

(define (list-third list)
  (builtin/car (builtin/cdr (builtin/cdr list))))

(claim list-map-zip
  (polymorphic (A B C)
    (-> (-> A B C)
        (builtin/list-t A)
        (builtin/list-t B)
        (builtin/list-t C))))

(define (list-map-zip f left right)
  (builtin/list-map
   (lambda (pair)
     (f (builtin/pair-first pair) (builtin/pair-second pair)))
   (builtin/list-zip left right)))

(define-test list-map-zip-test
  (builtin/assert-equal
   (builtin/list-map-zip
    builtin/iadd
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 1 list)
      (builtin/list-push! 2 list)
      (builtin/list-push! 3 list)
      list)
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 10 list)
      (builtin/list-push! 20 list)
      (builtin/list-push! 30 list)
      list))
   (begin
     (= list (builtin/make-list))
     (builtin/list-push! 11 list)
     (builtin/list-push! 22 list)
     (builtin/list-push! 33 list)
     list)))

(claim list-map
  (polymorphic (A B)
    (-> (-> A B) (builtin/list-t A) (builtin/list-t B))))

(define (list-map f list)
  (if (builtin/list-empty? list)
    (begin (= list (builtin/make-list)) list)
    (builtin/cons
     (f (builtin/car list))
     (builtin/list-map f (builtin/cdr list)))))

(define-test list-map-test
  (builtin/assert-equal
   (builtin/list-map
    (builtin/iadd 10)
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 1 list)
      (builtin/list-push! 2 list)
      (builtin/list-push! 3 list)
      list))
   (begin
     (= list (builtin/make-list))
     (builtin/list-push! 11 list)
     (builtin/list-push! 12 list)
     (builtin/list-push! 13 list)
     list)))

(claim list-member?
  (polymorphic (A) (-> A (builtin/list-t A) builtin/bool-t)))

(define (list-member? x list)
  (if (builtin/list-empty? list)
    builtin/false
    (if (builtin/equal? x (builtin/car list))
      builtin/true
      (if builtin/true
        (builtin/list-member? x (builtin/cdr list))
        (builtin/error "cond mismatch")))))

(define-test list-member-test
  (builtin/assert
   (builtin/list-member?
    2
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 1 list)
      (builtin/list-push! 2 list)
      (builtin/list-push! 3 list)
      list)))
  (builtin/assert-not
   (builtin/list-member?
    0
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 1 list)
      (builtin/list-push! 2 list)
      (builtin/list-push! 3 list)
      list))))

(claim list-select
  (polymorphic (A)
    (-> (-> A builtin/bool-t)
        (builtin/list-t A)
        (builtin/list-t A))))

(define (list-select p list)
  (if (builtin/list-empty? list)
    list
    (if (p (builtin/car list))
      (builtin/cons
       (builtin/car list)
       (builtin/list-select p (builtin/cdr list)))
      (if builtin/true
        (builtin/list-select p (builtin/cdr list))
        (builtin/error "cond mismatch")))))

(define-test list-select-test
  (builtin/assert-equal
   (builtin/list-select
    (builtin/negate (builtin/equal? 0))
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 0 list)
      (builtin/list-push! 1 list)
      (builtin/list-push! 0 list)
      (builtin/list-push! 2 list)
      (builtin/list-push! 0 list)
      (builtin/list-push! 3 list)
      list))
   (begin
     (= list (builtin/make-list))
     (builtin/list-push! 1 list)
     (builtin/list-push! 2 list)
     (builtin/list-push! 3 list)
     list)))

(claim list-reject
  (polymorphic (A)
    (-> (-> A builtin/bool-t)
        (builtin/list-t A)
        (builtin/list-t A))))

(define (list-reject p list)
  (builtin/list-select (builtin/negate p) list))

(define-test list-reject-test
  (builtin/assert-equal
   (builtin/list-reject
    (builtin/equal? 0)
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 0 list)
      (builtin/list-push! 1 list)
      (builtin/list-push! 0 list)
      (builtin/list-push! 2 list)
      (builtin/list-push! 0 list)
      (builtin/list-push! 3 list)
      list))
   (begin
     (= list (builtin/make-list))
     (builtin/list-push! 1 list)
     (builtin/list-push! 2 list)
     (builtin/list-push! 3 list)
     list)))

(claim list-take
  (polymorphic (A)
    (-> builtin/int-t (builtin/list-t A) (builtin/list-t A))))

(define (list-take n list)
  (builtin/assert (builtin/int-non-negative? n))
  (if
      (if (builtin/equal? n 0)
        builtin/true
        (builtin/list-empty? list))
    (begin (= list (builtin/make-list)) list)
    (builtin/cons
     (builtin/car list)
     (builtin/list-take
      (builtin/isub n 1)
      (builtin/cdr list)))))

(define-test list-take-test
  (builtin/assert-equal
   (builtin/list-take
    0
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 1 list)
      (builtin/list-push! 2 list)
      (builtin/list-push! 3 list)
      list))
   (begin (= list (builtin/make-list)) list))
  (builtin/assert-equal
   (builtin/list-take
    1
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 1 list)
      (builtin/list-push! 2 list)
      (builtin/list-push! 3 list)
      list))
   (begin
     (= list (builtin/make-list))
     (builtin/list-push! 1 list)
     list))
  (builtin/assert-equal
   (builtin/list-take
    2
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 1 list)
      (builtin/list-push! 2 list)
      (builtin/list-push! 3 list)
      list))
   (begin
     (= list (builtin/make-list))
     (builtin/list-push! 1 list)
     (builtin/list-push! 2 list)
     list))
  (builtin/assert-equal
   (builtin/list-take
    3
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 1 list)
      (builtin/list-push! 2 list)
      (builtin/list-push! 3 list)
      list))
   (begin
     (= list (builtin/make-list))
     (builtin/list-push! 1 list)
     (builtin/list-push! 2 list)
     (builtin/list-push! 3 list)
     list))
  (builtin/assert-equal
   (builtin/list-take
    4
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 1 list)
      (builtin/list-push! 2 list)
      (builtin/list-push! 3 list)
      list))
   (begin
     (= list (builtin/make-list))
     (builtin/list-push! 1 list)
     (builtin/list-push! 2 list)
     (builtin/list-push! 3 list)
     list)))

(claim list-drop
  (polymorphic (A)
    (-> builtin/int-t (builtin/list-t A) (builtin/list-t A))))

(define (list-drop n list)
  (builtin/assert (builtin/int-non-negative? n))
  (if
      (if (builtin/equal? n 0)
        builtin/true
        (builtin/list-empty? list))
    list
    (builtin/list-drop (builtin/isub n 1) (builtin/cdr list))))

(define-test list-drop-test
  (builtin/assert-equal
   (builtin/list-drop
    0
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 1 list)
      (builtin/list-push! 2 list)
      (builtin/list-push! 3 list)
      list))
   (begin
     (= list (builtin/make-list))
     (builtin/list-push! 1 list)
     (builtin/list-push! 2 list)
     (builtin/list-push! 3 list)
     list))
  (builtin/assert-equal
   (builtin/list-drop
    1
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 1 list)
      (builtin/list-push! 2 list)
      (builtin/list-push! 3 list)
      list))
   (begin
     (= list (builtin/make-list))
     (builtin/list-push! 2 list)
     (builtin/list-push! 3 list)
     list))
  (builtin/assert-equal
   (builtin/list-drop
    2
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 1 list)
      (builtin/list-push! 2 list)
      (builtin/list-push! 3 list)
      list))
   (begin
     (= list (builtin/make-list))
     (builtin/list-push! 3 list)
     list))
  (builtin/assert-equal
   (builtin/list-drop
    3
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 1 list)
      (builtin/list-push! 2 list)
      (builtin/list-push! 3 list)
      list))
   (begin (= list (builtin/make-list)) list))
  (builtin/assert-equal
   (builtin/list-drop
    4
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 1 list)
      (builtin/list-push! 2 list)
      (builtin/list-push! 3 list)
      list))
   (begin (= list (builtin/make-list)) list)))

(claim list-zip
  (polymorphic (A B)
    (-> (builtin/list-t A)
        (builtin/list-t B)
        (builtin/list-t (builtin/pair-t A B)))))

(define (list-zip left right)
  (if
      (if (builtin/list-empty? left)
        builtin/true
        (builtin/list-empty? right))
    (begin (= list (builtin/make-list)) list)
    (builtin/cons
     (builtin/make-pair
      (builtin/car left)
      (builtin/car right))
     (builtin/list-zip
      (builtin/cdr left)
      (builtin/cdr right)))))

(define-test list-zip-test
  (builtin/assert-equal
   (builtin/list-zip
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 'a list)
      (builtin/list-push! 'b list)
      (builtin/list-push! 'c list)
      list)
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 1 list)
      (builtin/list-push! 2 list)
      (builtin/list-push! 3 list)
      list))
   (begin
     (= list (builtin/make-list))
     (builtin/list-push! (builtin/make-pair 'a 1) list)
     (builtin/list-push! (builtin/make-pair 'b 2) list)
     (builtin/list-push! (builtin/make-pair 'c 3) list)
     list))
  (builtin/assert-equal
   (builtin/list-zip
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 'a list)
      (builtin/list-push! 'b list)
      (builtin/list-push! 'c list)
      list)
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 1 list)
      (builtin/list-push! 2 list)
      list))
   (begin
     (= list (builtin/make-list))
     (builtin/list-push! (builtin/make-pair 'a 1) list)
     (builtin/list-push! (builtin/make-pair 'b 2) list)
     list)))

(claim list-unzip
  (polymorphic (A B)
    (-> (builtin/list-t (builtin/pair-t A B))
        (builtin/pair-t
         (builtin/list-t A)
         (builtin/list-t B)))))

(define (list-unzip pairs)
  (builtin/make-pair
   (builtin/list-map builtin/pair-first pairs)
   (builtin/list-map builtin/pair-second pairs)))

(define-test list-unzip-test
  (builtin/assert-equal
   (builtin/list-unzip
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! (builtin/make-pair 'a 1) list)
      (builtin/list-push! (builtin/make-pair 'b 2) list)
      (builtin/list-push! (builtin/make-pair 'c 3) list)
      list))
   (builtin/make-pair
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 'a list)
      (builtin/list-push! 'b list)
      (builtin/list-push! 'c list)
      list)
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 1 list)
      (builtin/list-push! 2 list)
      (builtin/list-push! 3 list)
      list))))

(define-interface (pair-t A B) :first A :second B)

(define (make-pair first second)
  (@record :first first :second second))

(define (pair-first pair) (:first pair))

(define (pair-second pair) (:second pair))

(define (pair-put-first first pair)
  (update pair :first first))

(define (pair-put-second second pair)
  (update pair :second second))

(define (pair-put-first! first pair)
  (update! pair :first first))

(define (pair-put-second! second pair)
  (update! pair :second second))

(define-interface source-location-t
  :span
  builtin/source-span-t
  :path
  builtin/string-t)

(define-interface source-span-t
  :start
  builtin/source-position-t
  :end
  builtin/source-position-t)

(define-interface source-position-t
  :index
  builtin/int-t
  :row
  builtin/int-t
  :column
  builtin/int-t)

(define-data located-sexp-t
  (symbol-sexp
   (content builtin/symbol-t)
   (location builtin/source-location-t))
  (keyword-sexp
   (content builtin/keyword-t)
   (location builtin/source-location-t))
  (string-sexp
   (content builtin/string-t)
   (location builtin/source-location-t))
  (int-sexp
   (content builtin/int-t)
   (location builtin/source-location-t))
  (float-sexp
   (content builtin/float-t)
   (location builtin/source-location-t))
  (list-sexp
   (elements (builtin/list-t builtin/located-sexp-t))
   (location builtin/source-location-t)))

(claim symbol-sexp
  (-> builtin/symbol-t
      builtin/source-location-t
      builtin/located-sexp-t))

(define (symbol-sexp content location)
  (= list (builtin/make-list))
  (builtin/list-push! 'symbol-sexp list)
  (builtin/list-push! content list)
  (builtin/list-push! location list)
  list)

(claim symbol-sexp?
  (-> builtin/located-sexp-t builtin/bool-t))

(define (symbol-sexp? value)
  (if (builtin/list? value)
    (if (builtin/equal? (builtin/list-length value) 3)
      (builtin/equal? (builtin/list-head value) 'symbol-sexp)
      builtin/false)
    builtin/false))

