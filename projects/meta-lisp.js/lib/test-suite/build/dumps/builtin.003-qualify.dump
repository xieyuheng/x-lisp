(define (negate p x) (builtin/not (p x)))

(define-test negate-test
  (builtin/assert (builtin/not (builtin/int? 'a)))
  (builtin/assert (builtin/negate builtin/int? 'a))
  (builtin/assert ((builtin/negate builtin/int?) 'a)))

(claim call-with-input-file
  (polymorphic (A)
    (-> builtin/string-t (-> builtin/file-t A) A)))

(define (call-with-input-file path f)
  (= file (builtin/open-input-file path))
  (= result (f file))
  (builtin/file-close file)
  result)

(claim call-with-output-file
  (polymorphic (A)
    (-> builtin/string-t (-> builtin/file-t A) A)))

(define (call-with-output-file path f)
  (= file (builtin/open-output-file path))
  (= result (f file))
  (builtin/file-close file)
  result)

(claim float-product
  (-> (builtin/list-t builtin/float-t) builtin/float-t))

(define (float-product xs)
  (if (builtin/list-empty? xs)
    1.0
    (builtin/fmul
     (builtin/car xs)
     (builtin/float-product (builtin/cdr xs)))))

(define-test float-product-test
  (builtin/assert-equal
   1.0
   (builtin/float-product
    (begin (= list (builtin/make-list)) list)))
  (builtin/assert-equal
   6.0
   (builtin/float-product
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 1.0 list)
      (builtin/list-push! 2.0 list)
      (builtin/list-push! 3.0 list)
      list)))
  (builtin/assert-equal
   24.0
   (builtin/float-product
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 1.0 list)
      (builtin/list-push! 2.0 list)
      (builtin/list-push! 3.0 list)
      (builtin/list-push! 4.0 list)
      list))))

(claim float-sum
  (-> (builtin/list-t builtin/float-t) builtin/float-t))

(define (float-sum xs)
  (if (builtin/list-empty? xs)
    0.0
    (builtin/fadd
     (builtin/car xs)
     (builtin/float-sum (builtin/cdr xs)))))

(define-test float-sum-test
  (builtin/assert-equal
   0.0
   (builtin/float-sum
    (begin (= list (builtin/make-list)) list)))
  (builtin/assert-equal
   6.0
   (builtin/float-sum
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 1.0 list)
      (builtin/list-push! 2.0 list)
      (builtin/list-push! 3.0 list)
      list)))
  (builtin/assert-equal
   10.0
   (builtin/float-sum
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 1.0 list)
      (builtin/list-push! 2.0 list)
      (builtin/list-push! 3.0 list)
      (builtin/list-push! 4.0 list)
      list))))

(claim constant (polymorphic (A B) (-> A B A)))

(define (constant x y) x)

(define-test constant-test
  (builtin/assert-equal 1 (builtin/constant 1 "a")))

(claim swap
  (polymorphic (A B C) (-> (-> A B C) (-> B A C))))

(define (swap f x y) (f y x))

(claim drop (polymorphic (A B C) (-> (-> A B) (-> C A B))))

(define (drop f) (lambda (dropped x) (f x)))

(claim dup (polymorphic (A B) (-> (-> A A B) (-> A B))))

(define (dup f) (lambda (x) (f x x)))

(claim identity (polymorphic (A) (-> A A)))

(define (identity x) x)

(define-test identity-test
  (builtin/assert-equal 1 (builtin/identity 1)))

(claim hash-each-value
  (polymorphic (K V Any)
    (-> (-> V Any) (builtin/hash-t K V) builtin/void-t)))

(define (hash-each-value f hash)
  (builtin/list-each f (builtin/hash-values hash)))

(claim hash-each-key
  (polymorphic (K V Any)
    (-> (-> K Any) (builtin/hash-t K V) builtin/void-t)))

(define (hash-each-key f hash)
  (builtin/list-each f (builtin/hash-keys hash)))

(claim hash-each-entry
  (polymorphic (K V Any)
    (-> (-> (builtin/hash-entry-t K V) Any)
        (builtin/hash-t K V)
        builtin/void-t)))

(define (hash-each-entry f hash)
  (builtin/list-each f (builtin/hash-entries hash)))

(claim hash-each
  (polymorphic (K V Any)
    (-> (-> K V Any) (builtin/hash-t K V) builtin/void-t)))

(define (hash-each f hash)
  (builtin/list-each
   (lambda (entry) (f (:key entry) (:value entry)))
   (builtin/hash-entries hash)))

(define-test hash-each-value-test
  (= hash
     (begin
       (= hash (builtin/make-hash))
       (builtin/hash-put! 1 2 hash)
       (builtin/hash-put! 3 4 hash)
       hash))
  (= list (begin (= list (builtin/make-list)) list))
  (builtin/hash-each-value
   (lambda (value) (builtin/list-push! value list))
   hash)
  (builtin/assert-equal
   (begin
     (= list (builtin/make-list))
     (builtin/list-push! 2 list)
     (builtin/list-push! 4 list)
     list)
   list))

(define-test hash-each-key-test
  (= hash
     (begin
       (= hash (builtin/make-hash))
       (builtin/hash-put! 1 2 hash)
       (builtin/hash-put! 3 4 hash)
       hash))
  (= list (begin (= list (builtin/make-list)) list))
  (builtin/hash-each-key
   (lambda (key) (builtin/list-push! key list))
   hash)
  (builtin/assert-equal
   (begin
     (= list (builtin/make-list))
     (builtin/list-push! 1 list)
     (builtin/list-push! 3 list)
     list)
   list))

(define-test hash-each-entry-test
  (= hash
     (begin
       (= hash (builtin/make-hash))
       (builtin/hash-put! 1 2 hash)
       (builtin/hash-put! 3 4 hash)
       hash))
  (= list (begin (= list (builtin/make-list)) list))
  (builtin/hash-each-entry
   (lambda (entry) (builtin/list-push! entry list))
   hash)
  (builtin/assert-equal
   (begin
     (= list (builtin/make-list))
     (builtin/list-push! (builtin/make-hash-entry 1 2) list)
     (builtin/list-push! (builtin/make-hash-entry 3 4) list)
     list)
   list))

(define-test hash-each-test
  (= hash
     (begin
       (= hash (builtin/make-hash))
       (builtin/hash-put! 1 2 hash)
       (builtin/hash-put! 3 4 hash)
       hash))
  (= list (begin (= list (builtin/make-list)) list))
  (builtin/hash-each
   (lambda (key value)
     (builtin/list-push! key list)
     (builtin/list-push! value list))
   hash)
  (builtin/assert-equal
   (begin
     (= list (builtin/make-list))
     (builtin/list-push! 1 list)
     (builtin/list-push! 2 list)
     (builtin/list-push! 3 list)
     (builtin/list-push! 4 list)
     list)
   list))

(claim hash-get-maybe
  (polymorphic (K V)
    (-> K (builtin/hash-t K V) (builtin/maybe-t V))))

(define (hash-get-maybe key hash)
  (if (builtin/hash-has? key hash)
    (builtin/just (builtin/hash-get key hash))
    builtin/nothing))

(define-test hash-get-maybe-test
  (builtin/assert-equal
   (builtin/just "b")
   (builtin/hash-get-maybe
    2
    (begin
      (= hash (builtin/make-hash))
      (builtin/hash-put! 1 "a" hash)
      (builtin/hash-put! 2 "b" hash)
      (builtin/hash-put! 3 "c" hash)
      hash)))
  (builtin/assert-equal
   builtin/nothing
   (builtin/hash-get-maybe
    4
    (begin
      (= hash (builtin/make-hash))
      (builtin/hash-put! 1 "a" hash)
      (builtin/hash-put! 2 "b" hash)
      (builtin/hash-put! 3 "c" hash)
      hash))))

(claim hash-put-entries
  (polymorphic (K V)
    (-> (builtin/list-t (builtin/hash-entry-t K V))
        (builtin/hash-t K V)
        (builtin/hash-t K V))))

(define (hash-put-entries entries hash)
  (builtin/hash-put-entries!
   entries
   (builtin/hash-copy hash)))

(define (hash-put-entry entry hash)
  (builtin/hash-put (:key entry) (:value entry) hash))

(define (hash-put-entry! entry hash)
  (builtin/hash-put! (:key entry) (:value entry) hash))

(claim hash-put-entries!
  (polymorphic (K V)
    (-> (builtin/list-t (builtin/hash-entry-t K V))
        (builtin/hash-t K V)
        (builtin/hash-t K V))))

(define (hash-put-entries! entries hash)
  (if (builtin/list-empty? entries)
    hash
    (if builtin/true
      (begin
        (= entry (builtin/car entries))
        (builtin/hash-put-entry! entry hash)
        (builtin/hash-put-entries!
         (builtin/cdr entries)
         hash))
      (builtin/error "cond mismatch"))))

(define-test hash-put-entries-test
  (builtin/assert-equal
   (begin
     (= hash (builtin/make-hash))
     (builtin/hash-put! 'a 1 hash)
     (builtin/hash-put! 'b 2 hash)
     hash)
   (builtin/hash-put-entries
    (begin
      (= list (builtin/make-list))
      (builtin/list-push!
       (builtin/make-hash-entry 'a 1)
       list)
      (builtin/list-push!
       (builtin/make-hash-entry 'b 2)
       list)
      list)
    (begin (= hash (builtin/make-hash)) hash)))
  (= hash (begin (= hash (builtin/make-hash)) hash))
  (builtin/assert-equal
   (begin
     (= hash (builtin/make-hash))
     (builtin/hash-put! 'a 1 hash)
     (builtin/hash-put! 'b 2 hash)
     hash)
   (builtin/hash-put-entries!
    (begin
      (= list (builtin/make-list))
      (builtin/list-push!
       (builtin/make-hash-entry 'a 1)
       list)
      (builtin/list-push!
       (builtin/make-hash-entry 'b 2)
       list)
      list)
    hash))
  (builtin/assert-equal
   (begin
     (= hash (builtin/make-hash))
     (builtin/hash-put! 'a 1 hash)
     (builtin/hash-put! 'b 2 hash)
     hash)
   hash))

(define-interface (hash-entry-t K V) :key K :value V)

(define (make-hash-entry key value)
  (@record :key key :value value))

(claim int-align
  (-> builtin/int-t builtin/int-t builtin/int-t))

(define (int-align alignment n)
  (= remainder (builtin/imod n alignment))
  (if (builtin/equal? 0 remainder)
    n
    (builtin/iadd (builtin/isub n remainder) alignment)))

(define-test int-align-test
  (builtin/assert-equal 0 (builtin/int-align 16 0))
  (builtin/assert-equal 16 (builtin/int-align 16 8))
  (builtin/assert-equal 16 (builtin/int-align 16 16))
  (builtin/assert-equal 32 (builtin/int-align 16 24)))

(claim int-product
  (-> (builtin/list-t builtin/int-t) builtin/int-t))

(define (int-product xs)
  (if (builtin/list-empty? xs)
    1
    (builtin/imul
     (builtin/car xs)
     (builtin/int-product (builtin/cdr xs)))))

(define-test int-product-test
  (builtin/assert-equal
   1
   (builtin/int-product
    (begin (= list (builtin/make-list)) list)))
  (builtin/assert-equal
   6
   (builtin/int-product
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 1 list)
      (builtin/list-push! 2 list)
      (builtin/list-push! 3 list)
      list)))
  (builtin/assert-equal
   24
   (builtin/int-product
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 1 list)
      (builtin/list-push! 2 list)
      (builtin/list-push! 3 list)
      (builtin/list-push! 4 list)
      list))))

(claim int-sum
  (-> (builtin/list-t builtin/int-t) builtin/int-t))

(define (int-sum xs)
  (if (builtin/list-empty? xs)
    0
    (builtin/iadd
     (builtin/car xs)
     (builtin/int-sum (builtin/cdr xs)))))

(define-test int-sum-test
  (builtin/assert-equal
   0
   (builtin/int-sum
    (begin (= list (builtin/make-list)) list)))
  (builtin/assert-equal
   6
   (builtin/int-sum
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 1 list)
      (builtin/list-push! 2 list)
      (builtin/list-push! 3 list)
      list)))
  (builtin/assert-equal
   10
   (builtin/int-sum
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 1 list)
      (builtin/list-push! 2 list)
      (builtin/list-push! 3 list)
      (builtin/list-push! 4 list)
      list))))

(claim list-append
  (polymorphic (A)
    (-> (builtin/list-t A)
        (builtin/list-t A)
        (builtin/list-t A))))

(define (list-append list tail)
  (if (builtin/list-empty? list)
    tail
    (builtin/cons
     (builtin/car list)
     (builtin/list-append (builtin/cdr list) tail))))

(define-test list-append-test
  (builtin/assert-equal
   (builtin/list-append
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 1 list)
      (builtin/list-push! 2 list)
      (builtin/list-push! 3 list)
      list)
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 4 list)
      (builtin/list-push! 5 list)
      (builtin/list-push! 6 list)
      list))
   (begin
     (= list (builtin/make-list))
     (builtin/list-push! 1 list)
     (builtin/list-push! 2 list)
     (builtin/list-push! 3 list)
     (builtin/list-push! 4 list)
     (builtin/list-push! 5 list)
     (builtin/list-push! 6 list)
     list)))

(claim list-concat
  (polymorphic (A)
    (-> (builtin/list-t (builtin/list-t A))
        (builtin/list-t A))))

(define (list-concat lists)
  (if (builtin/list-empty? lists)
    (begin (= list (builtin/make-list)) list)
    (builtin/list-append
     (builtin/car lists)
     (builtin/list-concat (builtin/cdr lists)))))

(define-test list-concat-test
  (builtin/assert-equal
   (builtin/list-concat
    (begin
      (= list (builtin/make-list))
      (builtin/list-push!
       (begin
         (= list (builtin/make-list))
         (builtin/list-push! 1 list)
         (builtin/list-push! 2 list)
         (builtin/list-push! 3 list)
         list)
       list)
      (builtin/list-push!
       (begin
         (= list (builtin/make-list))
         (builtin/list-push! 4 list)
         (builtin/list-push! 5 list)
         (builtin/list-push! 6 list)
         list)
       list)
      list))
   (begin
     (= list (builtin/make-list))
     (builtin/list-push! 1 list)
     (builtin/list-push! 2 list)
     (builtin/list-push! 3 list)
     (builtin/list-push! 4 list)
     (builtin/list-push! 5 list)
     (builtin/list-push! 6 list)
     list)))

(claim list-each
  (polymorphic (A Any)
    (-> (-> A Any) (builtin/list-t A) builtin/void-t)))

(define (list-each f list)
  (if (builtin/list-empty? list)
    builtin/void
    (begin
      (f (builtin/car list))
      (builtin/list-each f (builtin/cdr list)))))

(define-test list-each-test
  (builtin/list-each
   (lambda (x) (builtin/print x) (builtin/write "\n"))
   (begin
     (= list (builtin/make-list))
     (builtin/list-push! 1 list)
     (builtin/list-push! 2 list)
     (builtin/list-push! 3 list)
     list)))

(claim list-every?
  (polymorphic (A)
    (-> (-> A builtin/bool-t)
        (builtin/list-t A)
        builtin/bool-t)))

(define (list-every? p list)
  (if (builtin/list-empty? list)
    builtin/true
    (if (builtin/not (p (builtin/car list)))
      builtin/false
      (if builtin/true
        (builtin/list-every? p (builtin/cdr list))
        (builtin/error "cond mismatch")))))

(define-test list-every-test
  (builtin/assert
   (builtin/list-every?
    builtin/int-non-negative?
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 0 list)
      (builtin/list-push! 1 list)
      (builtin/list-push! 2 list)
      (builtin/list-push! 3 list)
      list)))
  (builtin/assert-not
   (builtin/list-every?
    builtin/int-non-negative?
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 0 list)
      (builtin/list-push! 1 list)
      (builtin/list-push! -1 list)
      (builtin/list-push! 2 list)
      (builtin/list-push! 3 list)
      list))))

(claim list-some?
  (polymorphic (A)
    (-> (-> A builtin/bool-t)
        (builtin/list-t A)
        builtin/bool-t)))

(define (list-some? p list)
  (if (builtin/list-empty? list)
    builtin/false
    (if (p (builtin/car list))
      builtin/true
      (if builtin/true
        (builtin/list-some? p (builtin/cdr list))
        (builtin/error "cond mismatch")))))

(define-test list-some-test
  (builtin/assert
   (builtin/list-some?
    builtin/int-non-negative?
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! -1 list)
      (builtin/list-push! -2 list)
      (builtin/list-push! 0 list)
      list)))
  (builtin/assert-not
   (builtin/list-some?
    builtin/int-non-negative?
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! -1 list)
      (builtin/list-push! -2 list)
      (builtin/list-push! -3 list)
      list))))

(claim list-find
  (polymorphic (A)
    (-> (-> A builtin/bool-t)
        (builtin/list-t A)
        (builtin/maybe-t A))))

(define (list-find p list)
  (if (builtin/list-empty? list)
    builtin/nothing
    (if (p (builtin/car list))
      (builtin/just (builtin/car list))
      (if builtin/true
        (builtin/list-find p (builtin/cdr list))
        (builtin/error "cond mismatch")))))

(define-test list-find-test
  (builtin/assert-equal
   (builtin/just 3)
   (builtin/list-find
    builtin/int?
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 'a list)
      (builtin/list-push! 'b list)
      (builtin/list-push! 3 list)
      (builtin/list-push! 'd list)
      list)))
  (builtin/assert-equal
   builtin/nothing
   (builtin/list-find
    builtin/int?
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 'a list)
      (builtin/list-push! 'b list)
      (builtin/list-push! 'c list)
      (builtin/list-push! 'd list)
      list))))

(claim list-find-index
  (polymorphic (A)
    (-> (-> A builtin/bool-t)
        (builtin/list-t A)
        (builtin/maybe-t builtin/int-t))))

(define (list-find-index p list)
  (builtin/list-find-index-aux p list 0))

(claim list-find-index-aux
  (polymorphic (A)
    (-> (-> A builtin/bool-t)
        (builtin/list-t A)
        builtin/int-t
        (builtin/maybe-t builtin/int-t))))

(define (list-find-index-aux p list index)
  (if (builtin/list-empty? list)
    builtin/nothing
    (if (p (builtin/car list))
      (builtin/just index)
      (if builtin/true
        (builtin/list-find-index-aux
         p
         (builtin/cdr list)
         (builtin/iadd 1 index))
        (builtin/error "cond mismatch")))))

(define-test list-find-index-test
  (builtin/assert-equal
   (builtin/just 2)
   (builtin/list-find-index
    builtin/int?
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 'a list)
      (builtin/list-push! 'b list)
      (builtin/list-push! 3 list)
      (builtin/list-push! 'd list)
      list)))
  (builtin/assert-equal
   builtin/nothing
   (builtin/list-find-index
    builtin/int?
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 'a list)
      (builtin/list-push! 'b list)
      (builtin/list-push! 'c list)
      (builtin/list-push! 'd list)
      list))))

(claim list-fold-left
  (polymorphic (E R) (-> (-> R E R) R (builtin/list-t E) R)))

(define (list-fold-left op e list)
  (if (builtin/list-empty? list)
    e
    (builtin/list-fold-left
     op
     (op e (builtin/list-head list))
     (builtin/list-tail list))))

(define-test list-fold-left-test
  (builtin/assert-equal
   10
   (builtin/list-fold-left
    builtin/iadd
    0
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 1 list)
      (builtin/list-push! 2 list)
      (builtin/list-push! 3 list)
      (builtin/list-push! 4 list)
      list)))
  (builtin/assert-equal
   (begin
     (= list (builtin/make-list))
     (builtin/list-push! 4 list)
     (builtin/list-push! 3 list)
     (builtin/list-push! 2 list)
     (builtin/list-push! 1 list)
     list)
   (builtin/list-fold-left
    (builtin/swap builtin/cons)
    (begin (= list (builtin/make-list)) list)
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 1 list)
      (builtin/list-push! 2 list)
      (builtin/list-push! 3 list)
      (builtin/list-push! 4 list)
      list))))

(claim list-fold-right
  (polymorphic (E R) (-> (-> E R R) R (builtin/list-t E) R)))

(define (list-fold-right op e list)
  (if (builtin/list-empty? list)
    e
    (builtin/list-fold-right
     op
     (op (builtin/list-last list) e)
     (builtin/list-init list))))

(define-test list-fold-right-test
  (builtin/assert-equal
   10
   (builtin/list-fold-right
    builtin/iadd
    0
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 1 list)
      (builtin/list-push! 2 list)
      (builtin/list-push! 3 list)
      (builtin/list-push! 4 list)
      list)))
  (builtin/assert-equal
   (begin
     (= list (builtin/make-list))
     (builtin/list-push! 1 list)
     (builtin/list-push! 2 list)
     (builtin/list-push! 3 list)
     (builtin/list-push! 4 list)
     list)
   (builtin/list-fold-right
    builtin/cons
    (begin (= list (builtin/make-list)) list)
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 1 list)
      (builtin/list-push! 2 list)
      (builtin/list-push! 3 list)
      (builtin/list-push! 4 list)
      list))))

(define (list-first list) (builtin/car list))

(define (list-second list) (builtin/car (builtin/cdr list)))

(define (list-third list)
  (builtin/car (builtin/cdr (builtin/cdr list))))

(claim list-map-zip
  (polymorphic (A B C)
    (-> (-> A B C)
        (builtin/list-t A)
        (builtin/list-t B)
        (builtin/list-t C))))

(define (list-map-zip f left right)
  (builtin/list-map
   (lambda (pair)
     (f (builtin/pair-first pair) (builtin/pair-second pair)))
   (builtin/list-zip left right)))

(define-test list-map-zip-test
  (builtin/assert-equal
   (builtin/list-map-zip
    builtin/iadd
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 1 list)
      (builtin/list-push! 2 list)
      (builtin/list-push! 3 list)
      list)
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 10 list)
      (builtin/list-push! 20 list)
      (builtin/list-push! 30 list)
      list))
   (begin
     (= list (builtin/make-list))
     (builtin/list-push! 11 list)
     (builtin/list-push! 22 list)
     (builtin/list-push! 33 list)
     list)))

(claim list-map
  (polymorphic (A B)
    (-> (-> A B) (builtin/list-t A) (builtin/list-t B))))

(define (list-map f list)
  (if (builtin/list-empty? list)
    (begin (= list (builtin/make-list)) list)
    (builtin/cons
     (f (builtin/car list))
     (builtin/list-map f (builtin/cdr list)))))

(define-test list-map-test
  (builtin/assert-equal
   (builtin/list-map
    (builtin/iadd 10)
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 1 list)
      (builtin/list-push! 2 list)
      (builtin/list-push! 3 list)
      list))
   (begin
     (= list (builtin/make-list))
     (builtin/list-push! 11 list)
     (builtin/list-push! 12 list)
     (builtin/list-push! 13 list)
     list)))

(claim list-member?
  (polymorphic (A) (-> A (builtin/list-t A) builtin/bool-t)))

(define (list-member? x list)
  (if (builtin/list-empty? list)
    builtin/false
    (if (builtin/equal? x (builtin/car list))
      builtin/true
      (if builtin/true
        (builtin/list-member? x (builtin/cdr list))
        (builtin/error "cond mismatch")))))

(define-test list-member-test
  (builtin/assert
   (builtin/list-member?
    2
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 1 list)
      (builtin/list-push! 2 list)
      (builtin/list-push! 3 list)
      list)))
  (builtin/assert-not
   (builtin/list-member?
    0
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 1 list)
      (builtin/list-push! 2 list)
      (builtin/list-push! 3 list)
      list))))

(claim list-select
  (polymorphic (A)
    (-> (-> A builtin/bool-t)
        (builtin/list-t A)
        (builtin/list-t A))))

(define (list-select p list)
  (if (builtin/list-empty? list)
    list
    (if (p (builtin/car list))
      (builtin/cons
       (builtin/car list)
       (builtin/list-select p (builtin/cdr list)))
      (if builtin/true
        (builtin/list-select p (builtin/cdr list))
        (builtin/error "cond mismatch")))))

(define-test list-select-test
  (builtin/assert-equal
   (builtin/list-select
    (builtin/negate (builtin/equal? 0))
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 0 list)
      (builtin/list-push! 1 list)
      (builtin/list-push! 0 list)
      (builtin/list-push! 2 list)
      (builtin/list-push! 0 list)
      (builtin/list-push! 3 list)
      list))
   (begin
     (= list (builtin/make-list))
     (builtin/list-push! 1 list)
     (builtin/list-push! 2 list)
     (builtin/list-push! 3 list)
     list)))

(claim list-reject
  (polymorphic (A)
    (-> (-> A builtin/bool-t)
        (builtin/list-t A)
        (builtin/list-t A))))

(define (list-reject p list)
  (builtin/list-select (builtin/negate p) list))

(define-test list-reject-test
  (builtin/assert-equal
   (builtin/list-reject
    (builtin/equal? 0)
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 0 list)
      (builtin/list-push! 1 list)
      (builtin/list-push! 0 list)
      (builtin/list-push! 2 list)
      (builtin/list-push! 0 list)
      (builtin/list-push! 3 list)
      list))
   (begin
     (= list (builtin/make-list))
     (builtin/list-push! 1 list)
     (builtin/list-push! 2 list)
     (builtin/list-push! 3 list)
     list)))

(claim list-take
  (polymorphic (A)
    (-> builtin/int-t (builtin/list-t A) (builtin/list-t A))))

(define (list-take n list)
  (builtin/assert (builtin/int-non-negative? n))
  (if
      (if (builtin/equal? n 0)
        builtin/true
        (builtin/list-empty? list))
    (begin (= list (builtin/make-list)) list)
    (builtin/cons
     (builtin/car list)
     (builtin/list-take
      (builtin/isub n 1)
      (builtin/cdr list)))))

(define-test list-take-test
  (builtin/assert-equal
   (builtin/list-take
    0
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 1 list)
      (builtin/list-push! 2 list)
      (builtin/list-push! 3 list)
      list))
   (begin (= list (builtin/make-list)) list))
  (builtin/assert-equal
   (builtin/list-take
    1
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 1 list)
      (builtin/list-push! 2 list)
      (builtin/list-push! 3 list)
      list))
   (begin
     (= list (builtin/make-list))
     (builtin/list-push! 1 list)
     list))
  (builtin/assert-equal
   (builtin/list-take
    2
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 1 list)
      (builtin/list-push! 2 list)
      (builtin/list-push! 3 list)
      list))
   (begin
     (= list (builtin/make-list))
     (builtin/list-push! 1 list)
     (builtin/list-push! 2 list)
     list))
  (builtin/assert-equal
   (builtin/list-take
    3
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 1 list)
      (builtin/list-push! 2 list)
      (builtin/list-push! 3 list)
      list))
   (begin
     (= list (builtin/make-list))
     (builtin/list-push! 1 list)
     (builtin/list-push! 2 list)
     (builtin/list-push! 3 list)
     list))
  (builtin/assert-equal
   (builtin/list-take
    4
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 1 list)
      (builtin/list-push! 2 list)
      (builtin/list-push! 3 list)
      list))
   (begin
     (= list (builtin/make-list))
     (builtin/list-push! 1 list)
     (builtin/list-push! 2 list)
     (builtin/list-push! 3 list)
     list)))

(claim list-drop
  (polymorphic (A)
    (-> builtin/int-t (builtin/list-t A) (builtin/list-t A))))

(define (list-drop n list)
  (builtin/assert (builtin/int-non-negative? n))
  (if
      (if (builtin/equal? n 0)
        builtin/true
        (builtin/list-empty? list))
    list
    (builtin/list-drop (builtin/isub n 1) (builtin/cdr list))))

(define-test list-drop-test
  (builtin/assert-equal
   (builtin/list-drop
    0
    (begin
      (= list (builtin/make-list))
