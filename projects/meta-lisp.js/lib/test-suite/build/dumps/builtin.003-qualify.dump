  (builtin/assert-equal
   (builtin/list-drop
    1
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 1 list)
      (builtin/list-push! 2 list)
      (builtin/list-push! 3 list)
      list))
   (begin
     (= list (builtin/make-list))
     (builtin/list-push! 2 list)
     (builtin/list-push! 3 list)
     list))
  (builtin/assert-equal
   (builtin/list-drop
    2
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 1 list)
      (builtin/list-push! 2 list)
      (builtin/list-push! 3 list)
      list))
   (begin
     (= list (builtin/make-list))
     (builtin/list-push! 3 list)
     list))
  (builtin/assert-equal
   (builtin/list-drop
    3
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 1 list)
      (builtin/list-push! 2 list)
      (builtin/list-push! 3 list)
      list))
   (begin (= list (builtin/make-list)) list))
  (builtin/assert-equal
   (builtin/list-drop
    4
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 1 list)
      (builtin/list-push! 2 list)
      (builtin/list-push! 3 list)
      list))
   (begin (= list (builtin/make-list)) list)))

(claim list-zip
  (polymorphic (A B)
    (-> (builtin/list-t A)
        (builtin/list-t B)
        (builtin/list-t (builtin/pair-t A B)))))

(define (list-zip left right)
  (if
      (if (builtin/list-empty? left)
        builtin/true
        (builtin/list-empty? right))
    (begin (= list (builtin/make-list)) list)
    (builtin/cons
     (builtin/make-pair
      (builtin/car left)
      (builtin/car right))
     (builtin/list-zip
      (builtin/cdr left)
      (builtin/cdr right)))))

(define-test list-zip-test
  (builtin/assert-equal
   (builtin/list-zip
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 'a list)
      (builtin/list-push! 'b list)
      (builtin/list-push! 'c list)
      list)
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 1 list)
      (builtin/list-push! 2 list)
      (builtin/list-push! 3 list)
      list))
   (begin
     (= list (builtin/make-list))
     (builtin/list-push! (builtin/make-pair 'a 1) list)
     (builtin/list-push! (builtin/make-pair 'b 2) list)
     (builtin/list-push! (builtin/make-pair 'c 3) list)
     list))
  (builtin/assert-equal
   (builtin/list-zip
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 'a list)
      (builtin/list-push! 'b list)
      (builtin/list-push! 'c list)
      list)
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 1 list)
      (builtin/list-push! 2 list)
      list))
   (begin
     (= list (builtin/make-list))
     (builtin/list-push! (builtin/make-pair 'a 1) list)
     (builtin/list-push! (builtin/make-pair 'b 2) list)
     list)))

(claim list-unzip
  (polymorphic (A B)
    (-> (builtin/list-t (builtin/pair-t A B))
        (builtin/pair-t
         (builtin/list-t A)
         (builtin/list-t B)))))

(define (list-unzip pairs)
  (builtin/make-pair
   (builtin/list-map builtin/pair-first pairs)
   (builtin/list-map builtin/pair-second pairs)))

(define-test list-unzip-test
  (builtin/assert-equal
   (builtin/list-unzip
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! (builtin/make-pair 'a 1) list)
      (builtin/list-push! (builtin/make-pair 'b 2) list)
      (builtin/list-push! (builtin/make-pair 'c 3) list)
      list))
   (builtin/make-pair
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 'a list)
      (builtin/list-push! 'b list)
      (builtin/list-push! 'c list)
      list)
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 1 list)
      (builtin/list-push! 2 list)
      (builtin/list-push! 3 list)
      list))))

(define-data (maybe-t A) (just (value A)) nothing)

(claim just (polymorphic (A) (-> A (builtin/maybe-t A))))

(define (just value)
  (= list (builtin/make-list))
  (builtin/list-push! 'just list)
  (builtin/list-push! value list)
  list)

(claim just?
  (polymorphic (A) (-> (builtin/maybe-t A) builtin/bool-t)))

(define (just? value)
  (if (builtin/list? value)
    (if (builtin/equal? (builtin/list-length value) 2)
      (builtin/equal? (builtin/list-head value) 'just)
      builtin/false)
    builtin/false))

(claim just-value
  (polymorphic (A) (-> (builtin/maybe-t A) A)))

(define (just-value target) (builtin/list-get 1 target))

(claim just-put-value
  (polymorphic (A)
    (-> A (builtin/maybe-t A) (builtin/maybe-t A))))

(define (just-put-value value target)
  (builtin/list-put 1 value target))

(claim just-put-value!
  (polymorphic (A)
    (-> A (builtin/maybe-t A) (builtin/maybe-t A))))

(define (just-put-value! value target)
  (builtin/list-put! 1 value target))

(claim nothing (polymorphic (A) (builtin/maybe-t A)))

(define nothing 'nothing)

(claim nothing?
  (polymorphic (A) (-> (builtin/maybe-t A) builtin/bool-t)))

(define (nothing? value) (builtin/equal? value 'nothing))

(define-interface (pair-t A B) :first A :second B)

(define (make-pair first second)
  (@record :first first :second second))

(define (pair-first pair) (:first pair))

(define (pair-second pair) (:second pair))

(define (pair-put-first first pair)
  (update pair :first first))

(define (pair-put-second second pair)
  (update pair :second second))

(define (pair-put-first! first pair)
  (update! pair :first first))

(define (pair-put-second! second pair)
  (update! pair :second second))

(claim set-each
  (polymorphic (A Any)
    (-> (-> A Any) (builtin/set-t A) builtin/void-t)))

(define (set-each f set)
  (builtin/list-each f (builtin/set-to-list set))
  builtin/void)

(claim set-every?
  (polymorphic (A)
    (-> (-> A builtin/bool-t)
        (builtin/set-t A)
        builtin/bool-t)))

(define (set-every? p set)
  (builtin/list-every? p (builtin/set-to-list set)))

(define-test set-every-test
  (builtin/assert
   (builtin/set-every?
    builtin/int-non-negative?
    (begin
      (= set (builtin/make-set))
      (builtin/set-add! 0 set)
      (builtin/set-add! 1 set)
      (builtin/set-add! 2 set)
      (builtin/set-add! 3 set)
      set)))
  (builtin/assert-not
   (builtin/set-every?
    builtin/int-non-negative?
    (begin
      (= set (builtin/make-set))
      (builtin/set-add! 0 set)
      (builtin/set-add! 1 set)
      (builtin/set-add! -1 set)
      (builtin/set-add! 2 set)
      (builtin/set-add! 3 set)
      set))))

(claim set-some?
  (polymorphic (A)
    (-> (-> A builtin/bool-t)
        (builtin/set-t A)
        builtin/bool-t)))

(define (set-some? p set)
  (builtin/list-some? p (builtin/set-to-list set)))

(define-test set-some-test
  (builtin/assert
   (builtin/set-some?
    builtin/int-non-negative?
    (begin
      (= set (builtin/make-set))
      (builtin/set-add! -1 set)
      (builtin/set-add! -2 set)
      (builtin/set-add! 0 set)
      set)))
  (builtin/assert-not
   (builtin/set-some?
    builtin/int-non-negative?
    (begin
      (= set (builtin/make-set))
      (builtin/set-add! -1 set)
      (builtin/set-add! -2 set)
      (builtin/set-add! -3 set)
      set))))

(claim set-map
  (polymorphic (A B)
    (-> (-> A B) (builtin/set-t A) (builtin/set-t B))))

(define (set-map f set)
  (= new-set (builtin/make-set))
  (builtin/set-each
   (lambda (e) (builtin/set-add! (f e) new-set))
   set)
  new-set)

(define-test set-map-test
  (builtin/assert-equal
   (begin
     (= set (builtin/make-set))
     (builtin/set-add! 2 set)
     (builtin/set-add! 4 set)
     (builtin/set-add! 6 set)
     set)
   (builtin/set-map
    (lambda (n) (builtin/iadd n n))
    (begin
      (= set (builtin/make-set))
      (builtin/set-add! 1 set)
      (builtin/set-add! 2 set)
      (builtin/set-add! 3 set)
      set))))

(claim set-select
  (polymorphic (A)
    (-> (-> A builtin/bool-t)
        (builtin/set-t A)
        (builtin/set-t A))))

(define (set-select p set)
  (= new-set (begin (= set (builtin/make-set)) set))
  (builtin/set-each
   (lambda (e)
     (if (p e)
       (begin (builtin/set-add! e new-set) builtin/void)
       builtin/void))
   set)
  new-set)

(define-test set-select-test
  (builtin/assert-equal
   (begin
     (= set (builtin/make-set))
     (builtin/set-add! 0 set)
     (builtin/set-add! 1 set)
     (builtin/set-add! 2 set)
     set)
   (builtin/set-select
    builtin/int-non-negative?
    (begin
      (= set (builtin/make-set))
      (builtin/set-add! -2 set)
      (builtin/set-add! -1 set)
      (builtin/set-add! 0 set)
      (builtin/set-add! 1 set)
      (builtin/set-add! 2 set)
      set))))

(claim set-reject
  (polymorphic (A)
    (-> (-> A builtin/bool-t)
        (builtin/set-t A)
        (builtin/set-t A))))

(define (set-reject p set)
  (builtin/set-select (builtin/negate p) set))

(define-test set-reject-test
  (builtin/assert-equal
   (begin
     (= set (builtin/make-set))
     (builtin/set-add! -1 set)
     (builtin/set-add! -2 set)
     set)
   (builtin/set-reject
    builtin/int-non-negative?
    (begin
      (= set (builtin/make-set))
      (builtin/set-add! -2 set)
      (builtin/set-add! -1 set)
      (builtin/set-add! 0 set)
      (builtin/set-add! 1 set)
      (builtin/set-add! 2 set)
      set))))

(define-interface source-location-t
  :span
  builtin/source-span-t
  :path
  builtin/string-t)

(define-interface source-span-t
  :start
  builtin/source-position-t
  :end
  builtin/source-position-t)

(define-interface source-position-t
  :index
  builtin/int-t
  :row
  builtin/int-t
  :column
  builtin/int-t)

(define-data located-sexp-t
  (symbol-sexp
   (content builtin/symbol-t)
   (location builtin/source-location-t))
  (keyword-sexp
   (content builtin/keyword-t)
   (location builtin/source-location-t))
  (string-sexp
   (content builtin/string-t)
   (location builtin/source-location-t))
  (int-sexp
   (content builtin/int-t)
   (location builtin/source-location-t))
  (float-sexp
   (content builtin/float-t)
   (location builtin/source-location-t))
  (list-sexp
   (elements (builtin/list-t builtin/located-sexp-t))
   (location builtin/source-location-t)))

(claim symbol-sexp
  (-> builtin/symbol-t
      builtin/source-location-t
      builtin/located-sexp-t))

(define (symbol-sexp content location)
  (= list (builtin/make-list))
  (builtin/list-push! 'symbol-sexp list)
  (builtin/list-push! content list)
  (builtin/list-push! location list)
  list)

(claim symbol-sexp?
  (-> builtin/located-sexp-t builtin/bool-t))

(define (symbol-sexp? value)
  (if (builtin/list? value)
    (if (builtin/equal? (builtin/list-length value) 3)
      (builtin/equal? (builtin/list-head value) 'symbol-sexp)
      builtin/false)
    builtin/false))

(claim symbol-sexp-content
  (-> builtin/located-sexp-t builtin/symbol-t))

(define (symbol-sexp-content target)
  (builtin/list-get 1 target))

(claim symbol-sexp-location
  (-> builtin/located-sexp-t builtin/source-location-t))

(define (symbol-sexp-location target)
  (builtin/list-get 2 target))

(claim symbol-sexp-put-content
  (-> builtin/symbol-t
      builtin/located-sexp-t
      builtin/located-sexp-t))

(define (symbol-sexp-put-content value target)
  (builtin/list-put 1 value target))

(claim symbol-sexp-put-location
  (-> builtin/source-location-t
      builtin/located-sexp-t
      builtin/located-sexp-t))

(define (symbol-sexp-put-location value target)
  (builtin/list-put 2 value target))

(claim symbol-sexp-put-content!
  (-> builtin/symbol-t
      builtin/located-sexp-t
      builtin/located-sexp-t))

(define (symbol-sexp-put-content! value target)
  (builtin/list-put! 1 value target))

(claim symbol-sexp-put-location!
  (-> builtin/source-location-t
      builtin/located-sexp-t
      builtin/located-sexp-t))

(define (symbol-sexp-put-location! value target)
  (builtin/list-put! 2 value target))

(claim keyword-sexp
  (-> builtin/keyword-t
      builtin/source-location-t
      builtin/located-sexp-t))

(define (keyword-sexp content location)
  (= list (builtin/make-list))
  (builtin/list-push! 'keyword-sexp list)
  (builtin/list-push! content list)
  (builtin/list-push! location list)
