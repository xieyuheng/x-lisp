(claim file-test void-t)

(define-test file-test
  (= file₁ (builtin/open-input-file "src/file/file-1.txt"))
  (builtin/assert-equal "abc\n" (builtin/file-read file₁))
  (builtin/file-close file₁)
  (= file₂ (builtin/open-output-file "src/file/file-2.txt"))
  (builtin/file-write file₂ "123\n")
  (builtin/file-close file₂)
  (= file₃ (builtin/open-input-file "src/file/file-2.txt"))
  (builtin/assert-equal "123\n" (builtin/file-read file₃))
  (builtin/file-close file₃)
  (= file₄ (builtin/open-output-file "src/file/file-2.txt"))
  (builtin/file-write file₄ "abc\n")
  (builtin/file-close file₄)
  (= file₅ (builtin/open-input-file "src/file/file-2.txt"))
  (builtin/assert-equal "abc\n" (builtin/file-read file₅))
  (builtin/file-close file₅))

(claim fs-test void-t)

(define-test fs-test
  (builtin/assert-equal
   "abc\n"
   (builtin/fs-read "src/fs/file-1.txt"))
  (builtin/fs-write "src/fs/file-2.txt" "123\n")
  (builtin/assert-equal
   "123\n"
   (builtin/fs-read "src/fs/file-2.txt"))
  (builtin/fs-write "src/fs/file-2.txt" "abc\n")
  (builtin/assert-equal
   "abc\n"
   (builtin/fs-read "src/fs/file-2.txt"))
  (builtin/println (builtin/fs-list "src/fs")))

(claim S
  (polymorphic (A B C) (-> (-> A B C) (-> A B) (-> A C))))

(define (S x y z) (x z (y z)))

(claim K (polymorphic (A B) (-> A B A)))

(define (K x y) x)

(claim I (polymorphic (A) (-> A A)))

(define (I x) x)

(claim SKI (polymorphic (A) (-> A A)))

(define SKI (test-suite/S test-suite/K test-suite/I))

(claim SKI-tuple
  (polymorphic (A B C D E F)
    (tau (-> (-> A B C) (-> A B) (-> A C))
         (-> D E D)
         (-> F F))))

(define SKI-tuple
  (= S₁ test-suite/SKI-tuple©λ₁)
  (= K₁ test-suite/SKI-tuple©λ₂)
  (= I₁ test-suite/SKI-tuple©λ₃)
  (= list₁ (builtin/make-list))
  (builtin/list-push! S₁ list₁)
  (builtin/list-push! K₁ list₁)
  (builtin/list-push! I₁ list₁)
  list₁)

(define (SKI-tuple©λ₁ x₁ y₁ z₁) (x₁ z₁ (y₁ z₁)))

(define (SKI-tuple©λ₂ x₂ y₂) x₂)

(define (SKI-tuple©λ₃ x₃) x₃)

(claim compose
  (polymorphic (A B C) (-> (-> B C) (-> A B) (-> A C))))

(define (compose f g x) (f (g x)))

(claim compose-test void-t)

(define-test compose-test
  (= add1₁ (builtin/iadd 1))
  (builtin/assert-equal
   3
   ((test-suite/compose add1₁ add1₁) 1)))

(claim curry-test void-t)

(define-test curry-test
  (builtin/assert-equal builtin/iadd builtin/iadd)
  (builtin/assert-equal (builtin/iadd 1) (builtin/iadd 1))
  (builtin/assert-not-equal
   (builtin/iadd 1)
   (builtin/iadd 2))
  (builtin/assert-equal
   ((builtin/iadd 1) 2)
   (builtin/iadd 1 2))
  (builtin/assert-equal 1 ((builtin/isub 2) 1))
  (builtin/assert-equal 1 (builtin/isub 2 1)))

(claim swap
  (polymorphic (X Y Z) (-> (-> Y X Z) (-> X Y Z))))

(define (swap f x y) (f y x))

(claim drop (polymorphic (X Y Z) (-> (-> X Z) (-> Y X Z))))

(define (drop f) (test-suite/drop©λ₁ f))

(define (drop©λ₁ f dropped₁) (test-suite/drop©λ₁©λ₁ f))

(define (drop©λ₁©λ₁ f x₁) (f x₁))

(claim dup (polymorphic (X Z) (-> (-> X X Z) (-> X Z))))

(define (dup f) (test-suite/dup©λ₁ f))

(define (dup©λ₁ f x₁) (f x₁ x₁))

