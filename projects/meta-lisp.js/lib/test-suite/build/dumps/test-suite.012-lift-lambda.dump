(claim list-test void-t)

(define-test list-test
  (= list₁ (builtin/make-list))
  (builtin/list-push! 1 list₁)
  (builtin/list-push! 2 list₁)
  (builtin/list-push! 3 list₁)
  (builtin/assert-equal
   (begin
     (= list₂ (builtin/make-list))
     (builtin/list-push! 1 list₂)
     (builtin/list-push! 2 list₂)
     (builtin/list-push! 3 list₂)
     list₂)
   list₁)
  (builtin/assert-equal
   (begin
     (= list₃ (builtin/make-list))
     (builtin/list-push! 1 list₃)
     (builtin/list-push! 2 list₃)
     (builtin/list-push! 3 list₃)
     list₃)
   (begin
     (= list₄ (builtin/make-list))
     (builtin/list-push! 1 list₄)
     (builtin/list-push! 2 list₄)
     (builtin/list-push! 3 list₄)
     list₄))
  (builtin/assert-equal
   (begin
     (= list₅ (builtin/make-list))
     (builtin/list-push! 'a list₅)
     (builtin/list-push! 'b list₅)
     (builtin/list-push! 'c list₅)
     list₅)
   (begin
     (= list₆ (builtin/make-list))
     (builtin/list-push! 'a list₆)
     (builtin/list-push! 'b list₆)
     (builtin/list-push! 'c list₆)
     list₆))
  (builtin/assert-equal
   3
   (builtin/list-length
    (begin
      (= list₇ (builtin/make-list))
      (builtin/list-push! 1 list₇)
      (builtin/list-push! 2 list₇)
      (builtin/list-push! 3 list₇)
      list₇)))
  (builtin/assert-equal
   0
   (builtin/list-length
    (begin (= list₈ (builtin/make-list)) list₈)))
  (builtin/assert
   (builtin/list-empty?
    (begin (= list₉ (builtin/make-list)) list₉)))
  (= list₁₀ (builtin/make-list))
  (builtin/list-push! 1 list₁₀)
  (builtin/list-push! 2 list₁₀)
  (builtin/list-push! 3 list₁₀)
  (builtin/println list₁₀)
  (builtin/println
   (begin
     (= list₁₁ (builtin/make-list))
     (builtin/list-push! 1 list₁₁)
     (builtin/list-push! 2 list₁₁)
     (builtin/list-push! 3 list₁₁)
     list₁₁))
  (builtin/println
   (begin
     (= list₁₂ (builtin/make-list))
     (builtin/list-push! 1 list₁₂)
     (builtin/list-push! 2 list₁₂)
     (builtin/list-push! 3 list₁₂)
     list₁₂))
  (builtin/println
   (begin
     (= list₁₃ (builtin/make-list))
     (builtin/list-push! 1 list₁₃)
     (builtin/list-push! 2 list₁₃)
     (builtin/list-push! 3 list₁₃)
     list₁₃))
  (builtin/println
   (begin
     (= list₁₄ (builtin/make-list))
     (builtin/list-push! 1 list₁₄)
     (builtin/list-push! 2 list₁₄)
     (builtin/list-push! 3 list₁₄)
     list₁₄))
  (builtin/println
   (begin
     (= list₁₅ (builtin/make-list))
     (builtin/list-push! 'a list₁₅)
     (builtin/list-push! 'b list₁₅)
     (builtin/list-push! 'c list₁₅)
     list₁₅))
  (builtin/println
   (begin
     (= list₁₆ (builtin/make-list))
     (builtin/list-push! 'a list₁₆)
     (builtin/list-push! 'b list₁₆)
     (builtin/list-push! 'c list₁₆)
     list₁₆)))

(claim cond-test void-t)

(define-test cond-test
  (builtin/assert-equal
   1
   (if (builtin/equal? 1 1)
     1
     (if builtin/true 2 (builtin/error "cond mismatch"))))
  (builtin/assert-equal
   2
   (if (builtin/equal? 1 2)
     1
     (if builtin/true 2 (builtin/error "cond mismatch"))))
  (if (builtin/equal? 1 1)
    (builtin/assert builtin/true)
    (if builtin/true
      (builtin/assert builtin/false)
      (builtin/error "cond mismatch")))
  (if (builtin/equal? 1 2)
    (builtin/assert builtin/false)
    (if builtin/true
      (builtin/assert builtin/true)
      (builtin/error "cond mismatch"))))

(claim if-test void-t)

(define-test if-test
  (builtin/assert-equal (if builtin/true 1 2) 1)
  (builtin/assert-equal (if builtin/false 1 2) 2)
  (builtin/assert
   (if builtin/true
     (if builtin/true builtin/true builtin/false)
     builtin/false))
  (builtin/assert
   (builtin/not
    (if builtin/true
      (if builtin/true builtin/false builtin/false)
      builtin/false)))
  (builtin/assert
   (if builtin/false
     builtin/true
     (if builtin/false builtin/true builtin/true)))
  (builtin/assert
   (builtin/not
    (if builtin/false
      builtin/true
      (if builtin/false builtin/true builtin/false)))))

(claim the-test void-t)

(define-test the-test
  (builtin/assert-equal 1 1)
  (builtin/assert-equal 'a 'a))

(claim path-test void-t)

(define-test path-test
  (builtin/assert-equal
   "a/b/c"
   (builtin/path-directory-name "a/b/c/file.test.txt"))
  (builtin/assert-equal
   "file.test.txt"
   (builtin/path-base-name "a/b/c/file.test.txt"))
  (builtin/assert-equal
   ".txt"
   (builtin/path-extension "a/b/c/file.test.txt"))
  (builtin/assert-equal
   "file.test"
   (builtin/path-stem "a/b/c/file.test.txt"))
  (builtin/assert
   (builtin/path-absolute? "/a/b/c/file.test.txt"))
  (builtin/assert-not
   (builtin/path-relative? "/a/b/c/file.test.txt"))
  (builtin/assert
   (builtin/path-relative? "a/b/c/file.test.txt"))
  (builtin/assert
   (builtin/path-relative? "./a/b/c/file.test.txt"))
  (builtin/assert-not
   (builtin/path-absolute? "a/b/c/file.test.txt"))
  (builtin/assert-not
   (builtin/path-absolute? "./a/b/c/file.test.txt"))
  (builtin/assert-equal
   "a/b/c/d/e/f"
   (builtin/path-join "a/b/c" "d/e/f"))
  (builtin/assert-equal
   "a/b/c/d/e/f"
   (builtin/path-join "a/b/c/" "/d/e/f"))
  (builtin/assert-equal
   "/a/b/c/d/e/f"
   (builtin/path-join "/a/b/c/" "/d/e/f"))
  (builtin/assert-equal
   "a/b/d"
   (builtin/path-normalize "a/b/c/../d"))
  (builtin/assert-equal
   "/a/b/c"
   (builtin/path-normalize "///a/b/c/")))

(claim reocrd-test void-t)

(define-test reocrd-test
  (builtin/println
   (begin
     (= record₁ (builtin/make-record))
     (builtin/record-put! :x 1 record₁)
     (builtin/record-put! :y 2 record₁)
     record₁))
  (builtin/println
   (begin
     (= record₂ (builtin/make-record))
     (builtin/record-put! :x 1 record₂)
     (builtin/record-put! :y 2 record₂)
     record₂)))

(define-interface point-t
  :x
  builtin/float-t
  :y
  builtin/float-t)

(claim with-color
  (polymorphic (A B C)
    (-> A (extend-interface B) (extend-interface B :color C))))

(define (with-color color point)
  (= record₁ point)
  (= record₂ (builtin/record-put :color color record₁))
  record₂)

(claim record-extend-test void-t)

(define-test record-extend-test
  (= point₁
     (begin
       (= record₁ (builtin/make-record))
       (builtin/record-put! :x 1.0 record₁)
       (builtin/record-put! :y 2.0 record₁)
       record₁))
  (builtin/assert-equal
   (begin
     (= record₂ (builtin/make-record))
     (builtin/record-put! :x 1.0 record₂)
     (builtin/record-put! :y 2.0 record₂)
     (builtin/record-put! :color "red" record₂)
     record₂)
   (test-suite/with-color "red" point₁)))

(claim point-put-x
  (polymorphic (A B C)
    (-> A
        (extend-interface B :x C)
        (extend-interface B :x C))))

(define (point-put-x x point)
  (= record₁ point)
  (= record₂ (builtin/record-put :x x record₁))
  record₂)

(claim point-put-y!
  (polymorphic (A B C)
    (-> A
        (extend-interface B :y C)
        (extend-interface B :y C))))

(define (point-put-y! y point)
  (= record₁ point)
  (builtin/record-put! :y y record₁)
  record₁)

(claim record-update-test void-t)

(define-test record-update-test
  (= point₁
     (begin
       (= record₁ (builtin/make-record))
       (builtin/record-put! :x 1.0 record₁)
       (builtin/record-put! :y 2.0 record₁)
       record₁))
  (builtin/assert-equal
   (begin
     (= record₂ (builtin/make-record))
     (builtin/record-put! :x 2.0 record₂)
     (builtin/record-put! :y 2.0 record₂)
     record₂)
   (test-suite/point-put-x 2.0 point₁))
  (builtin/assert-equal
   (begin
     (= record₃ (builtin/make-record))
     (builtin/record-put! :x 1.0 record₃)
     (builtin/record-put! :y 2.0 record₃)
     record₃)
   point₁)
  (builtin/assert-equal
   (begin
     (= record₄ (builtin/make-record))
     (builtin/record-put! :x 1.0 record₄)
     (builtin/record-put! :y 1.0 record₄)
     record₄)
   (test-suite/point-put-y! 1.0 point₁))
  (builtin/assert-equal
   (begin
     (= record₅ (builtin/make-record))
     (builtin/record-put! :x 1.0 record₅)
     (builtin/record-put! :y 1.0 record₅)
     record₅)
   point₁))

(claim set-test void-t)

(define-test set-test
  (builtin/assert-equal
   (begin
     (= set₁ (builtin/make-set))
     (builtin/set-add! 1 set₁)
     (builtin/set-add! 2 set₁)
     (builtin/set-add! 3 set₁)
     set₁)
   (begin
     (= set₂ (builtin/make-set))
     (builtin/set-add! 3 set₂)
     (builtin/set-add! 2 set₂)
     (builtin/set-add! 1 set₂)
     set₂))
  (builtin/println
   (begin
     (= set₃ (builtin/make-set))
     (builtin/set-add! 1 set₃)
     (builtin/set-add! 2 set₃)
     (builtin/set-add! 3 set₃)
     set₃)))

(claim my-string-repeat
  (-> builtin/int-t builtin/string-t builtin/string-t))

(define (my-string-repeat n string)
  (if (builtin/equal? n 0)
    ""
    (builtin/string-append
     string
     (test-suite/my-string-repeat (builtin/isub n 1) string))))

(claim my-string-repeat-test void-t)

(define-test my-string-repeat-test
  (builtin/assert-equal
   ""
   (test-suite/my-string-repeat 0 "a"))
  (builtin/assert-equal
   "a"
   (test-suite/my-string-repeat 1 "a"))
  (builtin/assert-equal
   "aa"
   (test-suite/my-string-repeat 2 "a"))
  (builtin/assert-equal
   "aaa"
   (test-suite/my-string-repeat 3 "a")))

(claim string-test void-t)

(define-test string-test
  (builtin/assert-equal
   "abcdef"
   (builtin/string-append "abc" "def"))
  (builtin/println "abc"))

(claim symbol-test void-t)

(define-test symbol-test
  (builtin/assert-equal
   'abcdef
   (builtin/symbol-append 'abc 'def))
  (builtin/println 'abc))

(claim tuple-test void-t)

(define-test tuple-test
  (builtin/println
   (begin
     (= list₁ (builtin/make-list))
     (builtin/list-push! 1 list₁)
     (builtin/list-push! 2 list₁)
     list₁))
  (builtin/println
   (begin
     (= list₂ (builtin/make-list))
     (builtin/list-push! 1 list₂)
     (builtin/list-push! 'a list₂)
     list₂)))

(claim void-test void-t)

(define-test void-test (builtin/println builtin/void))