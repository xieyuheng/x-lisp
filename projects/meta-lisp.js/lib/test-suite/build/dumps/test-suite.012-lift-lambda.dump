(claim test-suite/with-color
  (polymorphic (A B C)
    (-> A (extend-interface B) (extend-interface B :color C))))

(define (test-suite/with-color color point)
  (= record‚āĀ point)
  (= record‚āā (record-put :color color record‚āĀ))
  record‚āā)

(claim test-suite/record-extend-test void-t)

(define-test test-suite/record-extend-test
  (= point‚āĀ
     (begin
       (= record‚āĀ (make-record))
       (record-put! :x 1.0 record‚āĀ)
       (record-put! :y 2.0 record‚āĀ)
       record‚āĀ))
  (assert-equal
    (begin
      (= record‚āĀ (make-record))
      (record-put! :x 1.0 record‚āĀ)
      (record-put! :y 2.0 record‚āĀ)
      (record-put! :color "red" record‚āĀ)
      record‚āĀ)
    (test-suite/with-color "red" point‚āĀ)))

(claim test-suite/point-put-x
  (polymorphic (A B C)
    (-> A
        (extend-interface B :x C)
        (extend-interface B :x C))))

(define (test-suite/point-put-x x point)
  (= record‚āĀ point)
  (= record‚āā (record-put :x x record‚āĀ))
  record‚āā)

(claim test-suite/point-put-y!
  (polymorphic (A B C)
    (-> A
        (extend-interface B :y C)
        (extend-interface B :y C))))

(define (test-suite/point-put-y! y point)
  (= record‚āĀ point)
  (record-put! :y y record‚āĀ)
  record‚āĀ)

(claim test-suite/record-update-test void-t)

(define-test test-suite/record-update-test
  (= point‚āĀ
     (begin
       (= record‚āĀ (make-record))
       (record-put! :x 1.0 record‚āĀ)
       (record-put! :y 2.0 record‚āĀ)
       record‚āĀ))
  (assert-equal
    (begin
      (= record‚āĀ (make-record))
      (record-put! :x 2.0 record‚āĀ)
      (record-put! :y 2.0 record‚āĀ)
      record‚āĀ)
    (test-suite/point-put-x 2.0 point‚āĀ))
  (assert-equal
    (begin
      (= record‚āĀ (make-record))
      (record-put! :x 1.0 record‚āĀ)
      (record-put! :y 2.0 record‚āĀ)
      record‚āĀ)
    point‚āĀ)
  (assert-equal
    (begin
      (= record‚āĀ (make-record))
      (record-put! :x 1.0 record‚āĀ)
      (record-put! :y 1.0 record‚āĀ)
      record‚āĀ)
    (test-suite/point-put-y! 1.0 point‚āĀ))
  (assert-equal
    (begin
      (= record‚āĀ (make-record))
      (record-put! :x 1.0 record‚āĀ)
      (record-put! :y 1.0 record‚āĀ)
      record‚āĀ)
    point‚āĀ))

(claim test-suite/set-test void-t)

(define-test test-suite/set-test
  (assert-equal
    (begin
      (= set‚āĀ (make-set))
      (set-add! 1 set‚āĀ)
      (set-add! 2 set‚āĀ)
      (set-add! 3 set‚āĀ)
      set‚āĀ)
    (begin
      (= set‚āĀ (make-set))
      (set-add! 3 set‚āĀ)
      (set-add! 2 set‚āĀ)
      (set-add! 1 set‚āĀ)
      set‚āĀ))
  (println
   (begin
     (= set‚āĀ (make-set))
     (set-add! 1 set‚āĀ)
     (set-add! 2 set‚āĀ)
     (set-add! 3 set‚āĀ)
     set‚āĀ)))

(claim test-suite/my-string-repeat
  (-> int-t string-t string-t))

(define (test-suite/my-string-repeat n string)
  (if (equal? n 0)
    ""
    (string-append
     string
     (test-suite/my-string-repeat (isub n 1) string))))

(claim test-suite/my-string-repeat-test void-t)

(define-test test-suite/my-string-repeat-test
  (assert-equal "" (test-suite/my-string-repeat 0 "a"))
  (assert-equal "a" (test-suite/my-string-repeat 1 "a"))
  (assert-equal "aa" (test-suite/my-string-repeat 2 "a"))
  (assert-equal "aaa" (test-suite/my-string-repeat 3 "a")))

(claim test-suite/string-test void-t)

(define-test test-suite/string-test
  (assert-equal "abcdef" (string-append "abc" "def"))
  (println "abc"))

(claim test-suite/symbol-test void-t)

(define-test test-suite/symbol-test
  (assert-equal 'abcdef (symbol-append 'abc 'def))
  (println 'abc))

(claim test-suite/tuple-test void-t)

(define-test test-suite/tuple-test
  (println
   (begin
     (= list‚āĀ (make-list))
     (list-push! 1 list‚āĀ)
     (list-push! 2 list‚āĀ)
     list‚āĀ))
  (println
   (begin
     (= list‚āĀ (make-list))
     (list-push! 1 list‚āĀ)
     (list-push! 'a list‚āĀ)
     list‚āĀ)))

(claim test-suite/void-test void-t)

(define-test test-suite/void-test (println void))