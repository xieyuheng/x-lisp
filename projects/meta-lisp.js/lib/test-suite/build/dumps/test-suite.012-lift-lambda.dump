(claim test-suite/file-test void-t)

(define-test test-suite/file-test
  (= file‚āĀ (open-input-file "src/file/file-1.txt"))
  (assert-equal "abc\n" (file-read file‚āĀ))
  (file-close file‚āĀ)
  (= file‚āā (open-output-file "src/file/file-2.txt"))
  (file-write file‚āā "123\n")
  (file-close file‚āā)
  (= file‚āÉ (open-input-file "src/file/file-2.txt"))
  (assert-equal "123\n" (file-read file‚āÉ))
  (file-close file‚āÉ)
  (= file‚āĄ (open-output-file "src/file/file-2.txt"))
  (file-write file‚āĄ "abc\n")
  (file-close file‚āĄ)
  (= file‚āÖ (open-input-file "src/file/file-2.txt"))
  (assert-equal "abc\n" (file-read file‚āÖ))
  (file-close file‚āÖ))

