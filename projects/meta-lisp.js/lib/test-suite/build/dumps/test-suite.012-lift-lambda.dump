(claim test-suite/list-test void-t)

(define-test test-suite/list-test
  (= list‚āĀ (make-list))
  (list-push! 1 list‚āĀ)
  (list-push! 2 list‚āĀ)
  (list-push! 3 list‚āĀ)
  (assert-equal
    (begin
      (= list‚āā (make-list))
      (list-push! 1 list‚āā)
      (list-push! 2 list‚āā)
      (list-push! 3 list‚āā)
      list‚āā)
    list‚āĀ)
  (assert-equal
    (begin
      (= list‚āā (make-list))
      (list-push! 1 list‚āā)
      (list-push! 2 list‚āā)
      (list-push! 3 list‚āā)
      list‚āā)
    (begin
      (= list‚āā (make-list))
      (list-push! 1 list‚āā)
      (list-push! 2 list‚āā)
      (list-push! 3 list‚āā)
      list‚āā))
  (assert-equal
    (begin
      (= list‚āā (make-list))
      (list-push! 'a list‚āā)
      (list-push! 'b list‚āā)
      (list-push! 'c list‚āā)
      list‚āā)
    (begin
      (= list‚āā (make-list))
      (list-push! 'a list‚āā)
      (list-push! 'b list‚āā)
      (list-push! 'c list‚āā)
      list‚āā))
  (assert-equal
    3
    (list-length
     (begin
       (= list‚āā (make-list))
       (list-push! 1 list‚āā)
       (list-push! 2 list‚āā)
       (list-push! 3 list‚āā)
       list‚āā)))
  (assert-equal
    0
    (list-length (begin (= list‚āā (make-list)) list‚āā)))
  (assert (list-empty? (begin (= list‚āā (make-list)) list‚āā)))
  (= list‚āā (make-list))
  (list-push! 1 list‚āā)
  (list-push! 2 list‚āā)
  (list-push! 3 list‚āā)
  (println list‚āā)
  (println
   (begin
     (= list‚āÉ (make-list))
     (list-push! 1 list‚āÉ)
     (list-push! 2 list‚āÉ)
     (list-push! 3 list‚āÉ)
     list‚āÉ))
  (println
   (begin
     (= list‚āÉ (make-list))
     (list-push! 1 list‚āÉ)
     (list-push! 2 list‚āÉ)
     (list-push! 3 list‚āÉ)
     list‚āÉ))
  (println
   (begin
     (= list‚āÉ (make-list))
     (list-push! 1 list‚āÉ)
     (list-push! 2 list‚āÉ)
     (list-push! 3 list‚āÉ)
     list‚āÉ))
  (println
   (begin
     (= list‚āÉ (make-list))
     (list-push! 1 list‚āÉ)
     (list-push! 2 list‚āÉ)
     (list-push! 3 list‚āÉ)
     list‚āÉ))
  (println
   (begin
     (= list‚āÉ (make-list))
     (list-push! 'a list‚āÉ)
     (list-push! 'b list‚āÉ)
     (list-push! 'c list‚āÉ)
     list‚āÉ))
  (println
   (begin
