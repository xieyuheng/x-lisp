(claim hash-test void-t)

(define-test hash-test
  (builtin/assert
   (builtin/hash-empty?
    (begin (= hash₁ (builtin/make-hash)) hash₁)))
  (builtin/println
   (begin (= hash₂ (builtin/make-hash)) hash₂))
  (builtin/println
   (begin
     (= hash₃ (builtin/make-hash))
     (builtin/hash-put! 1 2 hash₃)
     hash₃))
  (builtin/println
   (begin
     (= hash₄ (builtin/make-hash))
     (builtin/hash-put! 1 3 hash₄)
     hash₄))
  (builtin/println
   (begin
     (= hash₅ (builtin/make-hash))
     (builtin/hash-put! 1 2 hash₅)
     (builtin/hash-put! 3 4 hash₅)
     hash₅)))

(claim factorial (-> builtin/int-t builtin/int-t))

(define (factorial n)
  (if (builtin/int-less-or-equal? n 1)
    1
    (builtin/imul
     (test-suite/factorial (builtin/isub n 1))
     n)))

(claim factorial-test void-t)

(define-test factorial-test
  (builtin/assert-equal 1 (test-suite/factorial 0))
  (builtin/assert-equal 1 (test-suite/factorial 1))
  (builtin/assert-equal 2 (test-suite/factorial 2))
  (builtin/assert-equal 6 (test-suite/factorial 3))
  (builtin/assert-equal 24 (test-suite/factorial 4))
  (builtin/assert-equal 120 (test-suite/factorial 5))
  (builtin/assert-equal 720 (test-suite/factorial 6)))

(claim fibonacci (-> builtin/int-t builtin/int-t))

(define (fibonacci n)
  (if (builtin/int-less-or-equal? n 1)
    n
    (builtin/iadd
     (test-suite/fibonacci (builtin/isub n 1))
     (test-suite/fibonacci (builtin/isub n 2)))))

(claim fibonacci-test void-t)

(define-test fibonacci-test
  (builtin/assert-equal 0 (test-suite/fibonacci 0))
  (builtin/assert-equal 1 (test-suite/fibonacci 1))
  (builtin/assert-equal 1 (test-suite/fibonacci 2))
  (builtin/assert-equal 2 (test-suite/fibonacci 3))
  (builtin/assert-equal 3 (test-suite/fibonacci 4))
  (builtin/assert-equal 5 (test-suite/fibonacci 5))
  (builtin/assert-equal 8 (test-suite/fibonacci 6))
  (builtin/assert-equal 13 (test-suite/fibonacci 7))
  (builtin/assert-equal 21 (test-suite/fibonacci 8))
  (builtin/assert-equal 34 (test-suite/fibonacci 9)))

(claim gcd (-> builtin/int-t builtin/int-t builtin/int-t))

(define (gcd a b)
