(define (test-suite/I x) x)

(claim test-suite/SKI (polymorphic (A) (-> A A)))

(define test-suite/SKI
  (test-suite/S test-suite/K test-suite/I))

(claim test-suite/SKI-tuple
  (polymorphic (A B C D E F)
    (tau (-> (-> A B C) (-> A B) (-> A C))
         (-> D E D)
         (-> F F))))

(define test-suite/SKI-tuple
  (= S‚āĀ test-suite/SKI-tuple¬©őĽ‚āĀ)
  (= K‚āĀ test-suite/SKI-tuple¬©őĽ‚āā)
  (= I‚āĀ test-suite/SKI-tuple¬©őĽ‚āÉ)
  (= list‚āĀ (make-list))
  (list-push! S‚āĀ list‚āĀ)
  (list-push! K‚āĀ list‚āĀ)
  (list-push! I‚āĀ list‚āĀ)
  list‚āĀ)

(define (test-suite/SKI-tuple¬©őĽ‚āĀ x‚āĀ y‚āĀ z‚āĀ) (x‚āĀ z‚āĀ (y‚āĀ z‚āĀ)))

(define (test-suite/SKI-tuple¬©őĽ‚āā x‚āĀ y‚āĀ) x‚āĀ)

(define (test-suite/SKI-tuple¬©őĽ‚āÉ x‚āĀ) x‚āĀ)

