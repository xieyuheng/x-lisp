(claim string-repeat (-> int-t string-t string-t))

(define (string-repeat n string)
  (if (equal? n 0)
    ""
    (string-append
     string
     (meta/string-repeat (isub n 1) string))))

(claim string-repeat-test void-t)

(define-test string-repeat-test
  (assert-equal "" (meta/string-repeat 0 "a"))
  (assert-equal "a" (meta/string-repeat 1 "a"))
  (assert-equal "aa" (meta/string-repeat 2 "a"))
  (assert-equal "aaa" (meta/string-repeat 3 "a")))