(claim my-list-adjacent-dedup
  (polymorphic (E)
    (-> (my-list/my-list-t E) (my-list/my-list-t E))))

(define (my-list-adjacent-dedup list)
  (if (my-list/nil? list)
    my-list/nil
    (if (my-list/li? list)
      (begin
        (= tail₁ (my-list/li-tail list))
        (= head₁ (my-list/li-head list))
        (if (my-list/nil? tail₁)
          (begin
            (= head head₁)
            (my-list/li head my-list/nil))
          (if (my-list/li? tail₁)
            (begin
              (= tail₂ (my-list/li-tail tail₁))
              (= head₂ (my-list/li-head tail₁))
              (= rest tail₂)
              (= second head₂)
              (= first head₁)
              (if (equal? first second)
                (my-list/my-list-adjacent-dedup
                 (my-list/li second rest))
                (my-list/li
                 first
                 (my-list/my-list-adjacent-dedup
                  (my-list/li second rest)))))
            (error "cond mismatch"))))
      (error "cond mismatch"))))

(claim my-list-adjacent-dedup-test void-t)

(define-test my-list-adjacent-dedup-test
  (assert-equal
    my-list/nil
    (my-list/my-list-adjacent-dedup my-list/nil))
  (assert-equal
    (my-list/li
     1
     (my-list/li
      2
      (my-list/li
       3
       (my-list/li
        1
        (my-list/li 2 (my-list/li 3 my-list/nil))))))
    (my-list/my-list-adjacent-dedup
     (my-list/li
      1
      (my-list/li
       2
       (my-list/li
        3
        (my-list/li
         1
         (my-list/li 2 (my-list/li 3 my-list/nil))))))))
  (assert-equal
    (my-list/li 1 (my-list/li 2 (my-list/li 3 my-list/nil)))
    (my-list/my-list-adjacent-dedup
     (my-list/li
      1
      (my-list/li
       1
       (my-list/li
        2
        (my-list/li
         2
         (my-list/li 3 (my-list/li 3 my-list/nil)))))))))

(claim my-list-append
  (polymorphic (E)
    (-> (my-list/my-list-t E)
        (my-list/my-list-t E)
        (my-list/my-list-t E))))

(define (my-list-append left right)
  (if (my-list/nil? left)
    right
    (if (my-list/li? left)
      (begin
        (= tail₃ (my-list/li-tail left))
        (= head₃ (my-list/li-head left))
        (= tail tail₃)
        (= head head₃)
        (my-list/li head (my-list/my-list-append tail right)))
      (error "cond mismatch"))))

(claim my-list-append-test void-t)

(define-test my-list-append-test
  (assert-equal
    my-list/nil
    (my-list/my-list-append my-list/nil my-list/nil))
  (assert-equal
    (my-list/li
     1
     (my-list/li
      2
      (my-list/li
       3
       (my-list/li
        4
        (my-list/li 5 (my-list/li 6 my-list/nil))))))
    (my-list/my-list-append
     (my-list/li 1 (my-list/li 2 (my-list/li 3 my-list/nil)))
     (my-list/li 4 (my-list/li 5 (my-list/li 6 my-list/nil))))))

(claim my-list-length
  (polymorphic (E) (-> (my-list/my-list-t E) int-t)))

(define (my-list-length list)
  (if (my-list/nil? list)
    0
    (if (my-list/li? list)
      (begin
        (= tail₄ (my-list/li-tail list))
        (= head₄ (my-list/li-head list))
        (= tail tail₄)
        (= head head₄)
        (iadd 1 (my-list/my-list-length tail)))
      (error "cond mismatch"))))

(claim my-list-length-test void-t)

(define-test my-list-length-test
  (assert-equal 0 (my-list/my-list-length my-list/nil))
  (assert-equal
    3
    (my-list/my-list-length
     (my-list/li 1 (my-list/li 2 (my-list/li 3 my-list/nil))))))

(claim my-list-map-zip
  (polymorphic (A B C)
    (-> (-> A B C)
        (my-list/my-list-t A)
        (my-list/my-list-t B)
        (my-list/my-list-t C))))

(define (my-list-map-zip f list1 list2)
  (if (my-list/nil? list1)
    (begin (= _ list2) my-list/nil)
    (if (my-list/li? list1)
      (begin
        (= tail₅ (my-list/li-tail list1))
        (= head₅ (my-list/li-head list1))
        (if (my-list/nil? list2)
          (begin
            (= tail1 tail₅)
            (= head1 head₅)
            my-list/nil)
          (if (my-list/li? list2)
            (begin
              (= tail₆ (my-list/li-tail list2))
              (= head₆ (my-list/li-head list2))
              (= tail2 tail₆)
              (= head2 head₆)
              (= tail1 tail₅)
              (= head1 head₅)
              (my-list/li
               (f head1 head2)
               (my-list/my-list-map-zip f tail1 tail2)))
            (error "cond mismatch"))))
      (error "cond mismatch"))))

(claim my-list-map-zip-2
  (polymorphic (A B C)
    (-> (-> A B C)
        (my-list/my-list-t A)
        (my-list/my-list-t B)
        (my-list/my-list-t C))))

(define (my-list-map-zip-2 f list1 list2)
  (if (my-list/nil? list1)
    (begin (= _ list2) my-list/nil)
    (if (my-list/li? list1)
      (begin
        (= tail₁₀ (my-list/li-tail list1))
        (= head₁₀ (my-list/li-head list1))
        (if (my-list/nil? list2)
          (begin (= _ list1) my-list/nil)
          (if (my-list/li? list2)
            (begin
              (= tail₉ (my-list/li-tail list2))
              (= head₉ (my-list/li-head list2))
              (if (my-list/nil? list1)
                (error "match mismatch")
                (if (my-list/li? list1)
                  (begin
                    (= tail₇ (my-list/li-tail list1))
                    (= head₇ (my-list/li-head list1))
                    (if (my-list/nil? list2)
                      (error "match mismatch")
                      (if (my-list/li? list2)
                        (begin
                          (= tail₈ (my-list/li-tail list2))
                          (= head₈ (my-list/li-head list2))
                          (= tail2 tail₈)
                          (= head2 head₈)
                          (= tail1 tail₇)
                          (= head1 head₇)
                          (my-list/li
                           (f head1 head2)
                           (my-list/my-list-map-zip-2
                            f
                            tail1
                            tail2)))
                        (error "cond mismatch"))))
                  (error "cond mismatch"))))
            (error "cond mismatch"))))
      (error "cond mismatch"))))

(claim my-list-map-zip-test void-t)

(define-test my-list-map-zip-test
  (assert-equal
    my-list/nil
    (my-list/my-list-map-zip iadd my-list/nil my-list/nil))
  (assert-equal
    (my-list/li 2 (my-list/li 4 (my-list/li 6 my-list/nil)))
    (my-list/my-list-map-zip
     iadd
     (my-list/li 1 (my-list/li 2 (my-list/li 3 my-list/nil)))
     (my-list/li 1 (my-list/li 2 (my-list/li 3 my-list/nil)))))
  (assert-equal
    my-list/nil
    (my-list/my-list-map-zip-2 iadd my-list/nil my-list/nil))
  (assert-equal
    (my-list/li 2 (my-list/li 4 (my-list/li 6 my-list/nil)))
    (my-list/my-list-map-zip-2
     iadd
     (my-list/li 1 (my-list/li 2 (my-list/li 3 my-list/nil)))
     (my-list/li 1 (my-list/li 2 (my-list/li 3 my-list/nil))))))

(claim my-list-map
  (polymorphic (A B)
    (-> (-> A B) (my-list/my-list-t A) (my-list/my-list-t B))))

(define (my-list-map f list)
  (if (my-list/nil? list)
    my-list/nil
    (if (my-list/li? list)
      (begin
        (= tail₁₁ (my-list/li-tail list))
        (= head₁₁ (my-list/li-head list))
        (= tail tail₁₁)
        (= head head₁₁)
        (my-list/li (f head) (my-list/my-list-map f tail)))
      (error "cond mismatch"))))

(claim my-list-map-test void-t)

(define-test my-list-map-test
  (assert-equal
    my-list/nil
    (my-list/my-list-map (iadd 1) my-list/nil))
  (assert-equal
    (my-list/li 2 (my-list/li 3 (my-list/li 4 my-list/nil)))
    (my-list/my-list-map
     (iadd 1)
     (my-list/li 1 (my-list/li 2 (my-list/li 3 my-list/nil))))))

(claim my-list-snapshot void-t)

(define-test my-list-snapshot
  (println my-list/nil)
  (println
   (my-list/li 1 (my-list/li 2 (my-list/li 3 my-list/nil)))))

(claim my-list-test void-t)

(define-test my-list-test
  (assert (my-list/nil? my-list/nil))
  (assert
    (my-list/li?
     (my-list/li 1 (my-list/li 2 (my-list/li 3 my-list/nil)))))
  (assert-not (my-list/li? my-list/nil))
  (assert-not
    (my-list/nil?
     (my-list/li 1 (my-list/li 2 (my-list/li 3 my-list/nil)))))
  (assert-equal
    (my-list/li-tail (my-list/li 1 my-list/nil))
    my-list/nil)
  (assert-equal
    (my-list/li-head (my-list/li 1 my-list/nil))
    1)
  (= list
     (my-list/li 1 (my-list/li 2 (my-list/li 3 my-list/nil))))
  (assert-equal (my-list/li-head list) 1)
  (my-list/li-put-head! 111 list)
  (assert-equal (my-list/li-head list) 111)
  (assert-equal
    (my-list/li-tail list)
    (my-list/li 2 (my-list/li 3 my-list/nil)))
  (my-list/li-put-tail! my-list/nil list)
  (assert-equal (my-list/li-tail list) my-list/nil)
  (assert-equal
    (my-list/li 1 my-list/nil)
    ((my-list/li 1) my-list/nil)))

(define-data (my-list-t E)
  nil
  (li (head E) (tail (my-list/my-list-t E))))

(claim nil (polymorphic (E) (my-list/my-list-t E)))

(define nil 'nil)

(claim nil?
  (polymorphic (E) (-> (my-list/my-list-t E) bool-t)))

(define (nil? value) (equal? value 'nil))

(claim li
  (polymorphic (E)
    (-> E (my-list/my-list-t E) (my-list/my-list-t E))))

(define (li head tail)
  (= list (make-list))
  (list-push! 'li list)
  (list-push! head list)
  (list-push! tail list)
  list)

(claim li?
  (polymorphic (E) (-> (my-list/my-list-t E) bool-t)))

(define (li? value)
  (if (list? value)
    (if (equal? (list-length value) 3)
      (equal? (list-head value) 'li)
      false)
    false))

(claim li-head
  (polymorphic (E) (-> (my-list/my-list-t E) E)))

(define (li-head target) (list-get 1 target))

(claim li-tail
  (polymorphic (E)
    (-> (my-list/my-list-t E) (my-list/my-list-t E))))

(define (li-tail target) (list-get 2 target))

(claim li-put-head
  (polymorphic (E)
    (-> E (my-list/my-list-t E) (my-list/my-list-t E))))

(define (li-put-head value target)
  (list-put 1 value target))

(claim li-put-tail
  (polymorphic (E)
    (-> (my-list/my-list-t E)
        (my-list/my-list-t E)
        (my-list/my-list-t E))))

(define (li-put-tail value target)
  (list-put 2 value target))

(claim li-put-head!
  (polymorphic (E)
    (-> E (my-list/my-list-t E) (my-list/my-list-t E))))

(define (li-put-head! value target)
  (list-put! 1 value target))

(claim li-put-tail!
  (polymorphic (E)
    (-> (my-list/my-list-t E)
        (my-list/my-list-t E)
        (my-list/my-list-t E))))

(define (li-put-tail! value target)
  (list-put! 2 value target))