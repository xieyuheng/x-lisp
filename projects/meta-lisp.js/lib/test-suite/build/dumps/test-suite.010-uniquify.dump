(claim test-suite/file-test void-t)

(define-test test-suite/file-test
  (= file₁ (open-input-file "src/file/file-1.txt"))
  (assert-equal "abc\n" (file-read file₁))
  (file-close file₁)
  (= file₂ (open-output-file "src/file/file-2.txt"))
  (file-write file₂ "123\n")
  (file-close file₂)
  (= file₃ (open-input-file "src/file/file-2.txt"))
  (assert-equal "123\n" (file-read file₃))
  (file-close file₃)
  (= file₄ (open-output-file "src/file/file-2.txt"))
  (file-write file₄ "abc\n")
  (file-close file₄)
  (= file₅ (open-input-file "src/file/file-2.txt"))
  (assert-equal "abc\n" (file-read file₅))
  (file-close file₅))

(claim test-suite/fs-test void-t)

(define-test test-suite/fs-test
  (assert-equal "abc\n" (fs-read "src/fs/file-1.txt"))
  (fs-write "src/fs/file-2.txt" "123\n")
  (assert-equal "123\n" (fs-read "src/fs/file-2.txt"))
  (fs-write "src/fs/file-2.txt" "abc\n")
  (assert-equal "abc\n" (fs-read "src/fs/file-2.txt"))
  (println (fs-list "src/fs")))

(claim test-suite/S
  (polymorphic (A B C) (-> (-> A B C) (-> A B) (-> A C))))

(define (test-suite/S x y z) (x z (y z)))

(claim test-suite/K (polymorphic (A B) (-> A B A)))

(define (test-suite/K x y) x)

(claim test-suite/I (polymorphic (A) (-> A A)))

(define (test-suite/I x) x)

(claim test-suite/SKI (polymorphic (A) (-> A A)))

(define test-suite/SKI
  (test-suite/S test-suite/K test-suite/I))

(claim test-suite/SKI-tuple
  (polymorphic (A B C D E F)
    (tau (-> (-> A B C) (-> A B) (-> A C))
         (-> D E D)
         (-> F F))))

(define test-suite/SKI-tuple
  (= S₁ (lambda (x₁ y₁ z₁) (x₁ z₁ (y₁ z₁))))
  (= K₁ (lambda (x₁ y₁) x₁))
  (= I₁ (lambda (x₁) x₁))
  (= list₁ (make-list))
  (list-push! S₁ list₁)
  (list-push! K₁ list₁)
  (list-push! I₁ list₁)
  list₁)

(claim test-suite/compose
  (polymorphic (A B C) (-> (-> B C) (-> A B) (-> A C))))

(define (test-suite/compose f g x) (f (g x)))

(claim test-suite/compose-test void-t)

(define-test test-suite/compose-test
  (= add1₁ (iadd 1))
  (assert-equal 3 ((test-suite/compose add1₁ add1₁) 1)))

(claim test-suite/curry-test void-t)

(define-test test-suite/curry-test
  (assert-equal iadd iadd)
  (assert-equal (iadd 1) (iadd 1))
  (assert-not-equal (iadd 1) (iadd 2))
  (assert-equal ((iadd 1) 2) (iadd 1 2))
  (assert-equal 1 ((isub 2) 1))
  (assert-equal 1 (isub 2 1)))

(claim test-suite/swap
  (polymorphic (X Y Z) (-> (-> Y X Z) (-> X Y Z))))

(define (test-suite/swap f x y) (f y x))

(claim test-suite/drop
  (polymorphic (X Y Z) (-> (-> X Z) (-> Y X Z))))

(define (test-suite/drop f)
  (lambda (dropped₁) (lambda (x₁) (f x₁))))

(claim test-suite/dup
  (polymorphic (X Z) (-> (-> X X Z) (-> X Z))))

(define (test-suite/dup f) (lambda (x₁) (f x₁ x₁)))

