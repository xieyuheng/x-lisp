  (assert-equal 2 (add1₁ 1))
  (= add1₂
     (test-suite/identity (iadd (test-suite/identity 1))))
  test-suite/identity
  test-suite/identity
  test-suite/identity
  (assert-equal 2 (add1₂ 1)))

(claim test-suite/hash-test void-t)

(define-test test-suite/hash-test
  (assert (hash-empty? (begin (= hash₁ (make-hash)) hash₁)))
  (println (begin (= hash₁ (make-hash)) hash₁))
  (println
   (begin (= hash₁ (make-hash)) (hash-put! 1 2 hash₁) hash₁))
  (println
   (begin (= hash₁ (make-hash)) (hash-put! 1 3 hash₁) hash₁))
  (println
   (begin
     (= hash₁ (make-hash))
     (hash-put! 1 2 hash₁)
     (hash-put! 3 4 hash₁)
     hash₁)))

(claim test-suite/factorial (-> int-t int-t))

(define (test-suite/factorial n)
  (if (int-less-or-equal? n 1)
    1
    (imul (test-suite/factorial (isub n 1)) n)))

(claim test-suite/factorial-test void-t)

(define-test test-suite/factorial-test
  (assert-equal 1 (test-suite/factorial 0))
  (assert-equal 1 (test-suite/factorial 1))
  (assert-equal 2 (test-suite/factorial 2))
  (assert-equal 6 (test-suite/factorial 3))
  (assert-equal 24 (test-suite/factorial 4))
  (assert-equal 120 (test-suite/factorial 5))
  (assert-equal 720 (test-suite/factorial 6)))

(claim test-suite/fibonacci (-> int-t int-t))

(define (test-suite/fibonacci n)
  (if (int-less-or-equal? n 1)
    n
    (iadd
     (test-suite/fibonacci (isub n 1))
     (test-suite/fibonacci (isub n 2)))))

(claim test-suite/fibonacci-test void-t)

(define-test test-suite/fibonacci-test
  (assert-equal 0 (test-suite/fibonacci 0))
  (assert-equal 1 (test-suite/fibonacci 1))
  (assert-equal 1 (test-suite/fibonacci 2))
  (assert-equal 2 (test-suite/fibonacci 3))
  (assert-equal 3 (test-suite/fibonacci 4))
  (assert-equal 5 (test-suite/fibonacci 5))
  (assert-equal 8 (test-suite/fibonacci 6))
  (assert-equal 13 (test-suite/fibonacci 7))
  (assert-equal 21 (test-suite/fibonacci 8))
  (assert-equal 34 (test-suite/fibonacci 9)))

(claim test-suite/gcd (-> int-t int-t int-t))

(define (test-suite/gcd a b)
  (if (equal? b 0) a (test-suite/gcd b (imod a b))))

(claim test-suite/gcd-test void-t)

(define-test test-suite/gcd-test
  (assert-equal 1 (test-suite/gcd 13 7))
  (assert-equal 4 (test-suite/gcd 12 8)))

