(define-test test-suite/forth-test
  (= f₁ (lambda (x₁) x₁))
  (= square₁ (test-suite/dup imul))
  (println (square₁ (f₁ 1)))
  (println (square₁ (f₁ 2)))
  (println (square₁ (f₁ 3)))
  (println (square₁ (f₁ 4))))

