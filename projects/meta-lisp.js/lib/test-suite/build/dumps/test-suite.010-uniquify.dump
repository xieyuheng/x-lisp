(claim test-suite/list-test void-t)

(define-test test-suite/list-test
  (= list₁ (make-list))
  (list-push! 1 list₁)
  (list-push! 2 list₁)
  (list-push! 3 list₁)
  (assert-equal
    (begin
      (= list₂ (make-list))
      (list-push! 1 list₂)
      (list-push! 2 list₂)
      (list-push! 3 list₂)
      list₂)
    list₁)
  (assert-equal
    (begin
      (= list₂ (make-list))
      (list-push! 1 list₂)
      (list-push! 2 list₂)
      (list-push! 3 list₂)
      list₂)
    (begin
      (= list₂ (make-list))
      (list-push! 1 list₂)
      (list-push! 2 list₂)
      (list-push! 3 list₂)
      list₂))
  (assert-equal
    (begin
      (= list₂ (make-list))
      (list-push! 'a list₂)
      (list-push! 'b list₂)
      (list-push! 'c list₂)
      list₂)
    (begin
      (= list₂ (make-list))
      (list-push! 'a list₂)
      (list-push! 'b list₂)
      (list-push! 'c list₂)
      list₂))
  (assert-equal
    3
    (list-length
     (begin
       (= list₂ (make-list))
       (list-push! 1 list₂)
       (list-push! 2 list₂)
       (list-push! 3 list₂)
       list₂)))
  (assert-equal
    0
    (list-length (begin (= list₂ (make-list)) list₂)))
  (assert (list-empty? (begin (= list₂ (make-list)) list₂)))
  (= list₂ (make-list))
  (list-push! 1 list₂)
  (list-push! 2 list₂)
  (list-push! 3 list₂)
  (println list₂)
  (println
   (begin
     (= list₃ (make-list))
     (list-push! 1 list₃)
     (list-push! 2 list₃)
     (list-push! 3 list₃)
     list₃))
  (println
   (begin
     (= list₃ (make-list))
     (list-push! 1 list₃)
     (list-push! 2 list₃)
     (list-push! 3 list₃)
     list₃))
  (println
   (begin
     (= list₃ (make-list))
     (list-push! 1 list₃)
     (list-push! 2 list₃)
     (list-push! 3 list₃)
     list₃))
  (println
   (begin
     (= list₃ (make-list))
     (list-push! 1 list₃)
     (list-push! 2 list₃)
     (list-push! 3 list₃)
     list₃))
  (println
   (begin
     (= list₃ (make-list))
     (list-push! 'a list₃)
     (list-push! 'b list₃)
     (list-push! 'c list₃)
     list₃))
  (println
   (begin
     (= list₃ (make-list))
     (list-push! 'a list₃)
     (list-push! 'b list₃)
     (list-push! 'c list₃)
     list₃)))

(claim test-suite/cond-test void-t)

(define-test test-suite/cond-test
  (assert-equal
    1
    (if (equal? 1 1) 1 (if true 2 (error "cond mismatch"))))
  (assert-equal
    2
    (if (equal? 1 2) 1 (if true 2 (error "cond mismatch"))))
  (if (equal? 1 1)
    (assert true)
    (if true (assert false) (error "cond mismatch")))
  (if (equal? 1 2)
    (assert false)
    (if true (assert true) (error "cond mismatch"))))

(claim test-suite/if-test void-t)

(define-test test-suite/if-test
  (assert-equal (if true 1 2) 1)
  (assert-equal (if false 1 2) 2)
  (assert (if true (if true true false) false))
  (assert (not (if true (if true false false) false)))
  (assert (if false true (if false true true)))
  (assert (not (if false true (if false true false)))))

(claim test-suite/the-test void-t)

(define-test test-suite/the-test
  (assert-equal 1 1)
  (assert-equal 'a 'a))

(claim test-suite/path-test void-t)

(define-test test-suite/path-test
  (assert-equal
    "a/b/c"
    (path-directory-name "a/b/c/file.test.txt"))
  (assert-equal
    "file.test.txt"
    (path-base-name "a/b/c/file.test.txt"))
  (assert-equal
    ".txt"
    (path-extension "a/b/c/file.test.txt"))
  (assert-equal
    "file.test"
    (path-stem "a/b/c/file.test.txt"))
  (assert (path-absolute? "/a/b/c/file.test.txt"))
  (assert-not (path-relative? "/a/b/c/file.test.txt"))
  (assert (path-relative? "a/b/c/file.test.txt"))
  (assert (path-relative? "./a/b/c/file.test.txt"))
  (assert-not (path-absolute? "a/b/c/file.test.txt"))
  (assert-not (path-absolute? "./a/b/c/file.test.txt"))
  (assert-equal "a/b/c/d/e/f" (path-join "a/b/c" "d/e/f"))
  (assert-equal "a/b/c/d/e/f" (path-join "a/b/c/" "/d/e/f"))
  (assert-equal
    "/a/b/c/d/e/f"
    (path-join "/a/b/c/" "/d/e/f"))
  (assert-equal "a/b/d" (path-normalize "a/b/c/../d"))
  (assert-equal "/a/b/c" (path-normalize "///a/b/c/")))

