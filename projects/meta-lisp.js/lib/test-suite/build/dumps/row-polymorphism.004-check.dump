(define-interface point-t
  :x
  builtin/float-t
  :y
  builtin/float-t)

(claim point-x
  (polymorphic (A B) (-> (extend-interface A :x B) B)))

(define (point-x point) (:x point))

(claim point-y
  (polymorphic (R A) (-> (extend-interface R :y A) A)))

(define (point-y point) (:y point))

(claim point-distance-squared
  (polymorphic (A)
    (-> (extend-interface A :y float-t :x float-t) float-t)))

(define (point-distance-squared point)
  (builtin/fadd
   (builtin/fmul (:x point) (:x point))
   (builtin/fmul (:y point) (:y point))))

(claim row-polymorphism-test void-t)

(define-test row-polymorphism-test
  (= point (@record :x 1.0 :y 2.0))
  (builtin/assert-equal 1.0 (:x point))
  (builtin/assert-equal 2.0 (:y point))
  (builtin/assert-equal 1.0 (row-polymorphism/point-x point))
  (builtin/assert-equal 2.0 (row-polymorphism/point-y point))
  (builtin/assert-equal
   5.0
   (row-polymorphism/point-distance-squared point)))