(define-interface (pair-t A B) :first A :second B)

(claim make-pair
  (polymorphic (A B)
    (-> A B (interface :first A :second B))))

(define (make-pair first second)
  (= record₁ (builtin/make-record))
  (builtin/record-put! :first first record₁)
  (builtin/record-put! :second second record₁)
  record₁)

(claim pair-first
  (polymorphic (A B) (-> (extend-interface A :first B) B)))

(define (pair-first pair)
  ((builtin/record-get :first) pair))

(claim pair-second
  (polymorphic (A B) (-> (extend-interface A :second B) B)))

(define (pair-second pair)
  ((builtin/record-get :second) pair))

(claim pair-put-first
  (polymorphic (A B C)
    (-> A
        (extend-interface B :first C)
        (extend-interface B :first C))))

(define (pair-put-first first pair)
  (= record₁ pair)
  (= record₂ (builtin/record-put :first first record₁))
  record₂)

(claim pair-put-second
  (polymorphic (A B C)
    (-> A
        (extend-interface B :second C)
        (extend-interface B :second C))))

(define (pair-put-second second pair)
  (= record₁ pair)
  (= record₂ (builtin/record-put :second second record₁))
  record₂)

(claim pair-put-first!
  (polymorphic (A B C)
    (-> A
        (extend-interface B :first C)
        (extend-interface B :first C))))

(define (pair-put-first! first pair)
  (= record₁ pair)
  (builtin/record-put! :first first record₁)
  record₁)

(claim pair-put-second!
  (polymorphic (A B C)
    (-> A
        (extend-interface B :second C)
        (extend-interface B :second C))))

(define (pair-put-second! second pair)
  (= record₁ pair)
  (builtin/record-put! :second second record₁)
  record₁)

