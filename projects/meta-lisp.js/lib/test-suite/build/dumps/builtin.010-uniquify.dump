(claim int-sexp-content
  (-> builtin/located-sexp-t builtin/int-t))

(define (int-sexp-content target)
  (builtin/list-get 1 target))

(claim int-sexp-location
  (-> builtin/located-sexp-t builtin/source-location-t))

(define (int-sexp-location target)
  (builtin/list-get 2 target))

(claim int-sexp-put-content
  (-> builtin/int-t
      builtin/located-sexp-t
      builtin/located-sexp-t))

(define (int-sexp-put-content value target)
  (builtin/list-put 1 value target))

(claim int-sexp-put-location
  (-> builtin/source-location-t
      builtin/located-sexp-t
      builtin/located-sexp-t))

(define (int-sexp-put-location value target)
  (builtin/list-put 2 value target))

(claim int-sexp-put-content!
  (-> builtin/int-t
      builtin/located-sexp-t
      builtin/located-sexp-t))

(define (int-sexp-put-content! value target)
  (builtin/list-put! 1 value target))

(claim int-sexp-put-location!
  (-> builtin/source-location-t
      builtin/located-sexp-t
      builtin/located-sexp-t))

(define (int-sexp-put-location! value target)
  (builtin/list-put! 2 value target))

(claim float-sexp
  (-> builtin/float-t
      builtin/source-location-t
      builtin/located-sexp-t))

(define (float-sexp content location)
  (= list₁ (builtin/make-list))
  (builtin/list-push! 'float-sexp list₁)
  (builtin/list-push! content list₁)
  (builtin/list-push! location list₁)
  list₁)

(claim float-sexp?
  (-> builtin/located-sexp-t builtin/bool-t))

(define (float-sexp? value)
  (if (builtin/list? value)
    (if (builtin/equal? (builtin/list-length value) 3)
      (builtin/equal? (builtin/list-head value) 'float-sexp)
      builtin/false)
    builtin/false))

(claim float-sexp-content
  (-> builtin/located-sexp-t builtin/float-t))

(define (float-sexp-content target)
  (builtin/list-get 1 target))

(claim float-sexp-location
  (-> builtin/located-sexp-t builtin/source-location-t))

(define (float-sexp-location target)
  (builtin/list-get 2 target))

(claim float-sexp-put-content
  (-> builtin/float-t
      builtin/located-sexp-t
      builtin/located-sexp-t))

(define (float-sexp-put-content value target)
  (builtin/list-put 1 value target))

(claim float-sexp-put-location
  (-> builtin/source-location-t
      builtin/located-sexp-t
      builtin/located-sexp-t))

(define (float-sexp-put-location value target)
  (builtin/list-put 2 value target))

(claim float-sexp-put-content!
  (-> builtin/float-t
      builtin/located-sexp-t
      builtin/located-sexp-t))

(define (float-sexp-put-content! value target)
  (builtin/list-put! 1 value target))

(claim float-sexp-put-location!
  (-> builtin/source-location-t
      builtin/located-sexp-t
      builtin/located-sexp-t))

(define (float-sexp-put-location! value target)
  (builtin/list-put! 2 value target))

(claim list-sexp
  (-> (builtin/list-t builtin/located-sexp-t)
      builtin/source-location-t
      builtin/located-sexp-t))

(define (list-sexp elements location)
  (= list₁ (builtin/make-list))
  (builtin/list-push! 'list-sexp list₁)
  (builtin/list-push! elements list₁)
  (builtin/list-push! location list₁)
  list₁)

(claim list-sexp?
  (-> builtin/located-sexp-t builtin/bool-t))

(define (list-sexp? value)
  (if (builtin/list? value)
    (if (builtin/equal? (builtin/list-length value) 3)
      (builtin/equal? (builtin/list-head value) 'list-sexp)
      builtin/false)
    builtin/false))

(claim list-sexp-elements
  (-> builtin/located-sexp-t
      (builtin/list-t builtin/located-sexp-t)))

(define (list-sexp-elements target)
  (builtin/list-get 1 target))

(claim list-sexp-location
  (-> builtin/located-sexp-t builtin/source-location-t))

(define (list-sexp-location target)
  (builtin/list-get 2 target))

(claim list-sexp-put-elements
  (-> (builtin/list-t builtin/located-sexp-t)
      builtin/located-sexp-t
      builtin/located-sexp-t))

(define (list-sexp-put-elements value target)
  (builtin/list-put 1 value target))

(claim list-sexp-put-location
  (-> builtin/source-location-t
      builtin/located-sexp-t
      builtin/located-sexp-t))

(define (list-sexp-put-location value target)
  (builtin/list-put 2 value target))

(claim list-sexp-put-elements!
  (-> (builtin/list-t builtin/located-sexp-t)
      builtin/located-sexp-t
      builtin/located-sexp-t))

(define (list-sexp-put-elements! value target)
  (builtin/list-put! 1 value target))

(claim list-sexp-put-location!
  (-> builtin/source-location-t
      builtin/located-sexp-t
      builtin/located-sexp-t))

(define (list-sexp-put-location! value target)
  (builtin/list-put! 2 value target))

(claim string-repeat
  (-> builtin/int-t builtin/string-t builtin/string-t))

(define (string-repeat n string)
  (if (builtin/equal? n 0)
    ""
    (builtin/string-append
     string
     (builtin/string-repeat (builtin/isub n 1) string))))

(claim string-repeat-test void-t)

(define-test string-repeat-test
  (builtin/assert-equal "" (builtin/string-repeat 0 "a"))
  (builtin/assert-equal "a" (builtin/string-repeat 1 "a"))
  (builtin/assert-equal "aa" (builtin/string-repeat 2 "a"))
  (builtin/assert-equal "aaa" (builtin/string-repeat 3 "a")))