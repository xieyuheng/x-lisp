(claim list-zip
  (polymorphic (A B)
    (-> (builtin/list-t A)
        (builtin/list-t B)
        (builtin/list-t (builtin/pair-t A B)))))

(define (list-zip left right)
  (if
      (if (builtin/list-empty? left)
        builtin/true
        (builtin/list-empty? right))
    (begin (= list₁ (builtin/make-list)) list₁)
    (builtin/cons
     (builtin/make-pair
      (builtin/car left)
      (builtin/car right))
     (builtin/list-zip
      (builtin/cdr left)
      (builtin/cdr right)))))

(claim list-zip-test void-t)

(define-test list-zip-test
  (builtin/assert-equal
   (builtin/list-zip
    (begin
      (= list₁ (builtin/make-list))
