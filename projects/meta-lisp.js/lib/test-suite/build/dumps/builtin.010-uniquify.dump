      (builtin/list-push! 'b list₁)
      (builtin/list-push! 'c list₁)
      list₁)
    (begin
      (= list₂ (builtin/make-list))
      (builtin/list-push! 1 list₂)
      (builtin/list-push! 2 list₂)
      (builtin/list-push! 3 list₂)
      list₂))
   (begin
     (= list₃ (builtin/make-list))
     (builtin/list-push! (builtin/make-pair 'a 1) list₃)
     (builtin/list-push! (builtin/make-pair 'b 2) list₃)
     (builtin/list-push! (builtin/make-pair 'c 3) list₃)
     list₃))
  (builtin/assert-equal
   (builtin/list-zip
    (begin
      (= list₄ (builtin/make-list))
      (builtin/list-push! 'a list₄)
      (builtin/list-push! 'b list₄)
      (builtin/list-push! 'c list₄)
      list₄)
    (begin
      (= list₅ (builtin/make-list))
      (builtin/list-push! 1 list₅)
      (builtin/list-push! 2 list₅)
      list₅))
   (begin
     (= list₆ (builtin/make-list))
     (builtin/list-push! (builtin/make-pair 'a 1) list₆)
     (builtin/list-push! (builtin/make-pair 'b 2) list₆)
     list₆)))

(claim list-unzip
