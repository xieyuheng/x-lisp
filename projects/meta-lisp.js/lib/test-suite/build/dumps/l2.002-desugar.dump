(define (evaluate-and-print exp)
  (println (evaluate exp empty-env)))

(define-test l2-test
  (evaluate-and-print (lambda-exp 'x (var-exp 'x)))
  (evaluate-and-print
   (apply-exp
    (lambda-exp 'x (var-exp 'x))
    (lambda-exp 'x (var-exp 'x))))
  (evaluate-and-print
   (apply-exp
    (apply-exp
     (lambda-exp 'x (var-exp 'x))
     (lambda-exp 'x (var-exp 'x)))
    (apply-exp
     (lambda-exp 'x (var-exp 'x))
     (lambda-exp 'x (var-exp 'x)))))
  (evaluate-and-print
   (let-exp 'id (lambda-exp 'x (var-exp 'x)) (var-exp 'id)))
  (evaluate-and-print
   (let-exp
    'id
    (lambda-exp 'x (var-exp 'x))
    (apply-exp (var-exp 'id) (var-exp 'id))))
  (evaluate-and-print
   (let-exp
    'id
    (lambda-exp 'x (var-exp 'x))
    (apply-exp
     (apply-exp (var-exp 'id) (var-exp 'id))
     (apply-exp (var-exp 'id) (var-exp 'id))))))

(define-data exp-t
  (var-exp (name symbol-t))
  (apply-exp (target exp-t) (arg exp-t))
  (lambda-exp (parameter symbol-t) (body exp-t))
  (let-exp (name symbol-t) (rhs exp-t) (body exp-t)))

(claim var-exp (-> symbol-t l2/exp-t))

(define (var-exp name)
  (= list (make-list))
  (list-push! 'var-exp list)
  (list-push! name list)
  list)

(claim var-exp? (-> l2/exp-t bool-t))

(define (var-exp? value)
  (if (list? value)
    (if (equal? (list-length value) 2)
      (equal? (list-head value) 'var-exp)
      false)
    false))

(claim var-exp-name (-> l2/exp-t symbol-t))

(define (var-exp-name target) (list-get 1 target))

(claim var-exp-put-name (-> symbol-t l2/exp-t l2/exp-t))

(define (var-exp-put-name value target)
  (list-put 1 value target))

(claim var-exp-put-name! (-> symbol-t l2/exp-t l2/exp-t))

(define (var-exp-put-name! value target)
  (list-put! 1 value target))

(claim apply-exp (-> l2/exp-t l2/exp-t l2/exp-t))

(define (apply-exp target arg)
  (= list (make-list))
  (list-push! 'apply-exp list)
  (list-push! target list)
  (list-push! arg list)
  list)

(claim apply-exp? (-> l2/exp-t bool-t))

(define (apply-exp? value)
  (if (list? value)
    (if (equal? (list-length value) 3)
      (equal? (list-head value) 'apply-exp)
      false)
    false))

(claim apply-exp-target (-> l2/exp-t l2/exp-t))

(define (apply-exp-target target) (list-get 1 target))

(claim apply-exp-arg (-> l2/exp-t l2/exp-t))

(define (apply-exp-arg target) (list-get 2 target))

(claim apply-exp-put-target (-> l2/exp-t l2/exp-t l2/exp-t))

(define (apply-exp-put-target value target)
  (list-put 1 value target))

(claim apply-exp-put-arg (-> l2/exp-t l2/exp-t l2/exp-t))

(define (apply-exp-put-arg value target)
  (list-put 2 value target))

(claim apply-exp-put-target!
  (-> l2/exp-t l2/exp-t l2/exp-t))

(define (apply-exp-put-target! value target)
  (list-put! 1 value target))

(claim apply-exp-put-arg! (-> l2/exp-t l2/exp-t l2/exp-t))

(define (apply-exp-put-arg! value target)
  (list-put! 2 value target))

(claim lambda-exp (-> symbol-t l2/exp-t l2/exp-t))

(define (lambda-exp parameter body)
  (= list (make-list))
  (list-push! 'lambda-exp list)
  (list-push! parameter list)
  (list-push! body list)
  list)

(claim lambda-exp? (-> l2/exp-t bool-t))

(define (lambda-exp? value)
  (if (list? value)
    (if (equal? (list-length value) 3)
      (equal? (list-head value) 'lambda-exp)
      false)
    false))

(claim lambda-exp-parameter (-> l2/exp-t symbol-t))

(define (lambda-exp-parameter target) (list-get 1 target))

(claim lambda-exp-body (-> l2/exp-t l2/exp-t))

(define (lambda-exp-body target) (list-get 2 target))

(claim lambda-exp-put-parameter
  (-> symbol-t l2/exp-t l2/exp-t))

(define (lambda-exp-put-parameter value target)
  (list-put 1 value target))

(claim lambda-exp-put-body (-> l2/exp-t l2/exp-t l2/exp-t))

(define (lambda-exp-put-body value target)
  (list-put 2 value target))

(claim lambda-exp-put-parameter!
  (-> symbol-t l2/exp-t l2/exp-t))

(define (lambda-exp-put-parameter! value target)
  (list-put! 1 value target))

(claim lambda-exp-put-body! (-> l2/exp-t l2/exp-t l2/exp-t))

(define (lambda-exp-put-body! value target)
  (list-put! 2 value target))

(claim let-exp (-> symbol-t l2/exp-t l2/exp-t l2/exp-t))

(define (let-exp name rhs body)
  (= list (make-list))
  (list-push! 'let-exp list)
  (list-push! name list)
  (list-push! rhs list)
  (list-push! body list)
  list)

(claim let-exp? (-> l2/exp-t bool-t))

(define (let-exp? value)
  (if (list? value)
    (if (equal? (list-length value) 4)
      (equal? (list-head value) 'let-exp)
      false)
    false))

(claim let-exp-name (-> l2/exp-t symbol-t))

(define (let-exp-name target) (list-get 1 target))

(claim let-exp-rhs (-> l2/exp-t l2/exp-t))

(define (let-exp-rhs target) (list-get 2 target))

(claim let-exp-body (-> l2/exp-t l2/exp-t))

(define (let-exp-body target) (list-get 3 target))

(claim let-exp-put-name (-> symbol-t l2/exp-t l2/exp-t))

(define (let-exp-put-name value target)
  (list-put 1 value target))

(claim let-exp-put-rhs (-> l2/exp-t l2/exp-t l2/exp-t))

(define (let-exp-put-rhs value target)
  (list-put 2 value target))

(claim let-exp-put-body (-> l2/exp-t l2/exp-t l2/exp-t))

(define (let-exp-put-body value target)
  (list-put 3 value target))

(claim let-exp-put-name! (-> symbol-t l2/exp-t l2/exp-t))

(define (let-exp-put-name! value target)
  (list-put! 1 value target))

(claim let-exp-put-rhs! (-> l2/exp-t l2/exp-t l2/exp-t))

(define (let-exp-put-rhs! value target)
  (list-put! 2 value target))

(claim let-exp-put-body! (-> l2/exp-t l2/exp-t l2/exp-t))

(define (let-exp-put-body! value target)
  (list-put! 3 value target))

(define-data env-t
  empty-env
  (extend-env (key symbol-t) (value value-t) (rest env-t)))

(claim empty-env l2/env-t)

(define empty-env 'empty-env)

(claim empty-env? (-> l2/env-t bool-t))

(define (empty-env? value) (equal? value 'empty-env))

(claim extend-env
  (-> symbol-t l2/value-t l2/env-t l2/env-t))

(define (extend-env key value rest)
  (= list (make-list))
  (list-push! 'extend-env list)
  (list-push! key list)
  (list-push! value list)
  (list-push! rest list)
  list)

(claim extend-env? (-> l2/env-t bool-t))

(define (extend-env? value)
  (if (list? value)
    (if (equal? (list-length value) 4)
      (equal? (list-head value) 'extend-env)
      false)
    false))

(claim extend-env-key (-> l2/env-t symbol-t))

(define (extend-env-key target) (list-get 1 target))

(claim extend-env-value (-> l2/env-t l2/value-t))

(define (extend-env-value target) (list-get 2 target))

(claim extend-env-rest (-> l2/env-t l2/env-t))

(define (extend-env-rest target) (list-get 3 target))

(claim extend-env-put-key (-> symbol-t l2/env-t l2/env-t))

(define (extend-env-put-key value target)
  (list-put 1 value target))

(claim extend-env-put-value
  (-> l2/value-t l2/env-t l2/env-t))

(define (extend-env-put-value value target)
  (list-put 2 value target))

(claim extend-env-put-rest (-> l2/env-t l2/env-t l2/env-t))

(define (extend-env-put-rest value target)
  (list-put 3 value target))

(claim extend-env-put-key! (-> symbol-t l2/env-t l2/env-t))

(define (extend-env-put-key! value target)
  (list-put! 1 value target))

(claim extend-env-put-value!
  (-> l2/value-t l2/env-t l2/env-t))

(define (extend-env-put-value! value target)
  (list-put! 2 value target))

(claim extend-env-put-rest! (-> l2/env-t l2/env-t l2/env-t))

(define (extend-env-put-rest! value target)
  (list-put! 3 value target))

(claim env-has? (-> symbol-t l2/env-t bool-t))

(define (env-has? name env)
  (if (empty-env? env)
    false
    (if (extend-env? env)
      (begin
        (= rest₃ (extend-env-rest env))
        (= value₃ (extend-env-value env))
        (= key₃ (extend-env-key env))
        (= rest rest₃)
        (= value value₃)
        (= key key₃)
        (if (equal? key name) true (env-has? name rest)))
      (error "cond mismatch"))))

(claim env-lookup-of-fail (-> symbol-t l2/env-t l2/value-t))

(define (env-lookup-of-fail name env)
  (if (empty-env? env)
    (error "undefined name")
    (if (extend-env? env)
      (begin
        (= rest₄ (extend-env-rest env))
        (= value₄ (extend-env-value env))
        (= key₄ (extend-env-key env))
        (= rest rest₄)
        (= value value₄)
        (= key key₄)
        (if (equal? key name)
          value
          (env-lookup-of-fail name rest)))
      (error "cond mismatch"))))

(define-data value-t
  (closure-value
   (env env-t)
   (parameter symbol-t)
   (body exp-t)))

(claim closure-value
  (-> l2/env-t symbol-t l2/exp-t l2/value-t))

(define (closure-value env parameter body)
  (= list (make-list))
  (list-push! 'closure-value list)
  (list-push! env list)
  (list-push! parameter list)
  (list-push! body list)
  list)

(claim closure-value? (-> l2/value-t bool-t))

(define (closure-value? value)
  (if (list? value)
    (if (equal? (list-length value) 4)
      (equal? (list-head value) 'closure-value)
      false)
    false))

(claim closure-value-env (-> l2/value-t l2/env-t))

(define (closure-value-env target) (list-get 1 target))

(claim closure-value-parameter (-> l2/value-t symbol-t))

(define (closure-value-parameter target)
  (list-get 2 target))

(claim closure-value-body (-> l2/value-t l2/exp-t))

(define (closure-value-body target) (list-get 3 target))

(claim closure-value-put-env
  (-> l2/env-t l2/value-t l2/value-t))

(define (closure-value-put-env value target)
  (list-put 1 value target))

(claim closure-value-put-parameter
  (-> symbol-t l2/value-t l2/value-t))

(define (closure-value-put-parameter value target)
  (list-put 2 value target))

(claim closure-value-put-body
  (-> l2/exp-t l2/value-t l2/value-t))

(define (closure-value-put-body value target)
  (list-put 3 value target))

(claim closure-value-put-env!
  (-> l2/env-t l2/value-t l2/value-t))

(define (closure-value-put-env! value target)
  (list-put! 1 value target))

(claim closure-value-put-parameter!
  (-> symbol-t l2/value-t l2/value-t))

(define (closure-value-put-parameter! value target)
  (list-put! 2 value target))

(claim closure-value-put-body!
  (-> l2/exp-t l2/value-t l2/value-t))

(define (closure-value-put-body! value target)
  (list-put! 3 value target))

(claim evaluate (-> l2/exp-t l2/env-t l2/value-t))

(define (evaluate exp env)
  (if (var-exp? exp)
    (begin
      (= name₂ (var-exp-name exp))
      (= name name₂)
      (env-lookup-of-fail name env))
    (if (apply-exp? exp)
      (begin
        (= arg₂ (apply-exp-arg exp))
        (= target₂ (apply-exp-target exp))
        (= arg arg₂)
        (= target target₂)
        (apply (evaluate target env) (evaluate arg env)))
      (if (lambda-exp? exp)
        (begin
          (= body₃ (lambda-exp-body exp))
          (= parameter₃ (lambda-exp-parameter exp))
          (= body body₃)
          (= parameter parameter₃)
          (closure-value env parameter body))
        (if (let-exp? exp)
          (begin
            (= body₄ (let-exp-body exp))
            (= rhs₁ (let-exp-rhs exp))
            (= name₃ (let-exp-name exp))
            (= body body₄)
            (= rhs rhs₁)
            (= name name₃)
            (= env (extend-env name (evaluate rhs env) env))
            (evaluate body env))
          (error "cond mismatch"))))))

(claim apply (-> l2/value-t l2/value-t l2/value-t))

(define (apply target arg)
  (if (closure-value? target)
    (begin
      (= body₅ (closure-value-body target))
      (= parameter₄ (closure-value-parameter target))
      (= env₂ (closure-value-env target))
      (= body body₅)
      (= parameter parameter₄)
      (= env env₂)
      (evaluate body (extend-env parameter arg env)))
    (error "cond mismatch")))