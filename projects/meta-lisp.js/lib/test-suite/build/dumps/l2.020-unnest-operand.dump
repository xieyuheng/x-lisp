        (= value₄₁
           (begin (= _₄ l2/extend-env-value) (_₄ env)))
        (= key₄₁ (begin (= _₅ l2/extend-env-key) (_₅ env)))
        (= rest₁ rest₄₁)
        (= value₁ value₄₁)
        (= key₁ key₄₁)
        (if (equal? key₁ name)
          value₁
          (begin
            (= _₆ l2/env-lookup-of-fail)
            (_₆ name rest₁))))
      (error "cond mismatch"))))

(define-data value-t
