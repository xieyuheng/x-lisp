(claim evaluate (-> l2/exp-t l2/env-t l2/value-t))

(define (evaluate exp env)
  (if (begin (= _₁ l2/var-exp?) (_₁ exp))
    (begin
      (= name₂₁ (begin (= _₂ l2/var-exp-name) (_₂ exp)))
      (= name₁ name₂₁)
      (= _₃ l2/env-lookup-of-fail)
      (_₃ name₁ env))
    (if (begin (= _₄ l2/apply-exp?) (_₄ exp))
      (begin
        (= arg₂₁ (begin (= _₅ l2/apply-exp-arg) (_₅ exp)))
        (= target₂₁
           (begin (= _₆ l2/apply-exp-target) (_₆ exp)))
        (= arg₁ arg₂₁)
        (= target₁ target₂₁)
        (= _₇ l2/apply)
        (= _₈ l2/evaluate)
        (= _₉ (_₈ target₁ env))
        (= _₁₀ l2/evaluate)
        (= _₁₁ (_₁₀ arg₁ env))
        (_₇ _₉ _₁₁))
      (if (begin (= _₁₂ l2/lambda-exp?) (_₁₂ exp))
        (begin
          (= body₃₁
             (begin (= _₁₃ l2/lambda-exp-body) (_₁₃ exp)))
          (= parameter₃₁
             (begin
               (= _₁₄ l2/lambda-exp-parameter)
               (_₁₄ exp)))
          (= body₁ body₃₁)
          (= parameter₁ parameter₃₁)
          (= _₁₅ l2/closure-value)
          (_₁₅ env parameter₁ body₁))
        (if (begin (= _₁₆ l2/let-exp?) (_₁₆ exp))
          (begin
            (= body₄₁
               (begin (= _₁₇ l2/let-exp-body) (_₁₇ exp)))
            (= rhs₁₁
               (begin (= _₁₈ l2/let-exp-rhs) (_₁₈ exp)))
            (= name₃₁
               (begin (= _₁₉ l2/let-exp-name) (_₁₉ exp)))
            (= body₁ body₄₁)
            (= rhs₁ rhs₁₁)
            (= name₁ name₃₁)
            (= env₁
               (begin
                 (= _₂₀ l2/extend-env)
                 (= _₂₁ l2/evaluate)
                 (= _₂₂ (_₂₁ rhs₁ env))
                 (_₂₀ name₁ _₂₂ env)))
            (= _₂₃ l2/evaluate)
            (_₂₃ body₁ env₁))
          (error "cond mismatch"))))))

(claim apply (-> l2/value-t l2/value-t l2/value-t))

(define (apply target arg)
  (if (begin (= _₁ l2/closure-value?) (_₁ target))
    (begin
      (= body₅₁
         (begin (= _₂ l2/closure-value-body) (_₂ target)))
      (= parameter₄₁
         (begin
           (= _₃ l2/closure-value-parameter)
           (_₃ target)))
      (= env₂₁
         (begin (= _₄ l2/closure-value-env) (_₄ target)))
      (= body₁ body₅₁)
      (= parameter₁ parameter₄₁)
      (= env₁ env₂₁)
      (= _₅ l2/evaluate)
      (= _₆ l2/extend-env)
      (= _₇ (_₆ parameter₁ arg env₁))
      (_₅ body₁ _₇))
    (error "cond mismatch")))