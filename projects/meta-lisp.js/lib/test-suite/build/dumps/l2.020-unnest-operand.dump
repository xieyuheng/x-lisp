        (= key₃₁ (begin (= _₅ l2/extend-env-key) (_₅ env)))
        (= rest₁ rest₃₁)
        (= value₁ value₃₁)
        (= key₁ key₃₁)
        (if (equal? key₁ name)
          true
          (begin (= _₆ l2/env-has?) (_₆ name rest₁))))
      (error "cond mismatch"))))

(claim env-lookup-of-fail (-> symbol-t l2/env-t l2/value-t))

(define (env-lookup-of-fail name env)
  (if (begin (= _₁ l2/empty-env?) (_₁ env))
    (error "undefined name")
