    (= _₂₈ (_₁₉ _₂₃ _₂₇))
    (= _₂₉ l2/apply-exp)
    (= _₃₀ l2/lambda-exp)
    (= _₃₁ l2/var-exp)
    (= _₃₂ (_₃₁ 'x))
