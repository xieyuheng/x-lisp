(claim evaluate-and-print (-> exp-t void-t))

(define (evaluate-and-print exp)
  (= _₁ builtin/println)
  (= _₂ l2/evaluate)
  (= _₃ l2/empty-env)
  (= _₄ (_₂ exp _₃))
  (_₁ _₄))

(claim l2-l1-test void-t)

