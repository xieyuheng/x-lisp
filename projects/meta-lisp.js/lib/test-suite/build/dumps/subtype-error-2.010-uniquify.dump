(define-interface point-t :x float-t :y float-t)

(claim point-println (-> subtype-error-2/point-t void-t))

(define (point-println point) (println point))

(define (main)
  (subtype-error-2/point-println
   (begin
     (= record₁ (make-record))
     (record-put! :x 1.0 record₁)
     (record-put! :y 2.0 record₁)
     record₁))
  (subtype-error-2/point-println
   (begin
     (= record₂ (make-record))
     (record-put! :x 1.0 record₂)
     record₂)))