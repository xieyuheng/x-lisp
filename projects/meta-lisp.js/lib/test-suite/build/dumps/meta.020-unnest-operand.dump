(claim string-repeat (-> int-t string-t string-t))

(define (string-repeat n string)
  (if (equal? n 0)
    ""
    (begin
      (= _₁ meta/string-repeat)
      (= _₂ (isub n 1))
      (= _₃ (_₁ _₂ string))
      (string-append string _₃))))

(claim string-repeat-test void-t)

(define-test string-repeat-test
  (begin
    (= _₁ meta/string-repeat)
    (= _₂ (_₁ 0 "a"))
    (assert-equal "" _₂))
  (begin
    (= _₃ meta/string-repeat)
    (= _₄ (_₃ 1 "a"))
    (assert-equal "a" _₄))
  (begin
    (= _₅ meta/string-repeat)
    (= _₆ (_₅ 2 "a"))
    (assert-equal "aa" _₆))
  (= _₇ meta/string-repeat)
  (= _₈ (_₇ 3 "a"))
  (assert-equal "aaa" _₈))