(claim list-map
  (polymorphic (A B)
    (-> (-> A B) (builtin/list-t A) (builtin/list-t B))))

(define (list-map f list)
  (if (builtin/list-empty? list)
    (begin (= list₁ (builtin/make-list)) list₁)
    (builtin/cons
     (f (builtin/car list))
     (builtin/list-map f (builtin/cdr list)))))

(claim list-map-test void-t)

(define-test list-map-test
