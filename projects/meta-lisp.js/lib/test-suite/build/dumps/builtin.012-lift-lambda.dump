    (begin
      (= list₁ (builtin/make-list))
      (builtin/list-push! 1 list₁)
      (builtin/list-push! 2 list₁)
      (builtin/list-push! 3 list₁)
      (builtin/list-push! 4 list₁)
      list₁)))
  (builtin/assert-equal
   (begin
     (= list₂ (builtin/make-list))
     (builtin/list-push! 1 list₂)
     (builtin/list-push! 2 list₂)
     (builtin/list-push! 3 list₂)
     (builtin/list-push! 4 list₂)
     list₂)
   (builtin/list-fold-right
    builtin/cons
    (begin (= list₃ (builtin/make-list)) list₃)
    (begin
      (= list₄ (builtin/make-list))
      (builtin/list-push! 1 list₄)
      (builtin/list-push! 2 list₄)
      (builtin/list-push! 3 list₄)
      (builtin/list-push! 4 list₄)
      list₄))))

