(define (swap f x y) (f y x))

(claim drop (polymorphic (A B C) (-> (-> A B) (-> C A B))))

(define (drop f) (builtin/drop©λ₁ f))

(define (drop©λ₁ f dropped₁ x₁) (f x₁))

(claim dup (polymorphic (A B) (-> (-> A A B) (-> A B))))

(define (dup f) (builtin/dup©λ₁ f))

