    (-> (-> A builtin/void-t)
        (builtin/list-t A)
        builtin/void-t)))

(define (list-each f list)
  (if (builtin/list-empty? list)
    builtin/void
    (begin
      (f (builtin/car list))
      (builtin/list-each f (builtin/cdr list)))))

(claim list-each-test void-t)

(define-test list-each-test
  (builtin/list-each
   builtin/list-each-test©λ₁
   (begin
     (= list₁ (builtin/make-list))
     (builtin/list-push! 1 list₁)
     (builtin/list-push! 2 list₁)
     (builtin/list-push! 3 list₁)
