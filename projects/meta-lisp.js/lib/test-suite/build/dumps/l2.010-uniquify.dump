(claim l2/evaluate-and-print (-> l2/exp-t void-t))

(define (l2/evaluate-and-print exp)
  (println (l2/evaluate exp l2/empty-env)))

(claim l2/l2-test void-t)

(define-test l2/l2-test
  (l2/evaluate-and-print (l2/lambda-exp 'x (l2/var-exp 'x)))
  (l2/evaluate-and-print
   (l2/apply-exp
    (l2/lambda-exp 'x (l2/var-exp 'x))
    (l2/lambda-exp 'x (l2/var-exp 'x))))
  (l2/evaluate-and-print
   (l2/apply-exp
    (l2/apply-exp
     (l2/lambda-exp 'x (l2/var-exp 'x))
     (l2/lambda-exp 'x (l2/var-exp 'x)))
    (l2/apply-exp
     (l2/lambda-exp 'x (l2/var-exp 'x))
     (l2/lambda-exp 'x (l2/var-exp 'x)))))
  (l2/evaluate-and-print
   (l2/let-exp
    'id
    (l2/lambda-exp 'x (l2/var-exp 'x))
    (l2/var-exp 'id)))
  (l2/evaluate-and-print
   (l2/let-exp
    'id
    (l2/lambda-exp 'x (l2/var-exp 'x))
    (l2/apply-exp (l2/var-exp 'id) (l2/var-exp 'id))))
  (l2/evaluate-and-print
   (l2/let-exp
    'id
    (l2/lambda-exp 'x (l2/var-exp 'x))
    (l2/apply-exp
     (l2/apply-exp (l2/var-exp 'id) (l2/var-exp 'id))
     (l2/apply-exp (l2/var-exp 'id) (l2/var-exp 'id))))))

(define-data l2/exp-t
  (var-exp (name symbol-t))
  (apply-exp (target l2/exp-t) (arg l2/exp-t))
  (lambda-exp (parameter symbol-t) (body l2/exp-t))
  (let-exp (name symbol-t) (rhs l2/exp-t) (body l2/exp-t)))

(claim l2/var-exp (-> symbol-t l2/exp-t))

(define (l2/var-exp name)
  (= list₁ (make-list))
  (list-push! 'var-exp list₁)
  (list-push! name list₁)
  list₁)

(claim l2/var-exp? (-> l2/exp-t bool-t))

(define (l2/var-exp? value)
  (if (list? value)
    (if (equal? (list-length value) 2)
      (equal? (list-head value) 'var-exp)
      false)
    false))

(claim l2/var-exp-name (-> l2/exp-t symbol-t))

(define (l2/var-exp-name target) (list-get 1 target))

(claim l2/var-exp-put-name (-> symbol-t l2/exp-t l2/exp-t))

(define (l2/var-exp-put-name value target)
  (list-put 1 value target))

(claim l2/var-exp-put-name! (-> symbol-t l2/exp-t l2/exp-t))

(define (l2/var-exp-put-name! value target)
  (list-put! 1 value target))

(claim l2/apply-exp (-> l2/exp-t l2/exp-t l2/exp-t))

(define (l2/apply-exp target arg)
  (= list₁ (make-list))
  (list-push! 'apply-exp list₁)
  (list-push! target list₁)
  (list-push! arg list₁)
  list₁)

(claim l2/apply-exp? (-> l2/exp-t bool-t))

(define (l2/apply-exp? value)
  (if (list? value)
    (if (equal? (list-length value) 3)
      (equal? (list-head value) 'apply-exp)
      false)
    false))

(claim l2/apply-exp-target (-> l2/exp-t l2/exp-t))

(define (l2/apply-exp-target target) (list-get 1 target))

(claim l2/apply-exp-arg (-> l2/exp-t l2/exp-t))

(define (l2/apply-exp-arg target) (list-get 2 target))

(claim l2/apply-exp-put-target
  (-> l2/exp-t l2/exp-t l2/exp-t))

(define (l2/apply-exp-put-target value target)
  (list-put 1 value target))

(claim l2/apply-exp-put-arg (-> l2/exp-t l2/exp-t l2/exp-t))

(define (l2/apply-exp-put-arg value target)
  (list-put 2 value target))

(claim l2/apply-exp-put-target!
  (-> l2/exp-t l2/exp-t l2/exp-t))

(define (l2/apply-exp-put-target! value target)
  (list-put! 1 value target))

(claim l2/apply-exp-put-arg!
  (-> l2/exp-t l2/exp-t l2/exp-t))

(define (l2/apply-exp-put-arg! value target)
  (list-put! 2 value target))

(claim l2/lambda-exp (-> symbol-t l2/exp-t l2/exp-t))

(define (l2/lambda-exp parameter body)
  (= list₁ (make-list))
  (list-push! 'lambda-exp list₁)
  (list-push! parameter list₁)
  (list-push! body list₁)
  list₁)

(claim l2/lambda-exp? (-> l2/exp-t bool-t))

(define (l2/lambda-exp? value)
  (if (list? value)
    (if (equal? (list-length value) 3)
      (equal? (list-head value) 'lambda-exp)
      false)
    false))

(claim l2/lambda-exp-parameter (-> l2/exp-t symbol-t))

(define (l2/lambda-exp-parameter target)
  (list-get 1 target))

(claim l2/lambda-exp-body (-> l2/exp-t l2/exp-t))

(define (l2/lambda-exp-body target) (list-get 2 target))

(claim l2/lambda-exp-put-parameter
  (-> symbol-t l2/exp-t l2/exp-t))

(define (l2/lambda-exp-put-parameter value target)
  (list-put 1 value target))

(claim l2/lambda-exp-put-body
  (-> l2/exp-t l2/exp-t l2/exp-t))

(define (l2/lambda-exp-put-body value target)
  (list-put 2 value target))

(claim l2/lambda-exp-put-parameter!
  (-> symbol-t l2/exp-t l2/exp-t))

(define (l2/lambda-exp-put-parameter! value target)
  (list-put! 1 value target))

(claim l2/lambda-exp-put-body!
  (-> l2/exp-t l2/exp-t l2/exp-t))

(define (l2/lambda-exp-put-body! value target)
  (list-put! 2 value target))

(claim l2/let-exp (-> symbol-t l2/exp-t l2/exp-t l2/exp-t))

(define (l2/let-exp name rhs body)
  (= list₁ (make-list))
  (list-push! 'let-exp list₁)
  (list-push! name list₁)
  (list-push! rhs list₁)
  (list-push! body list₁)
  list₁)

(claim l2/let-exp? (-> l2/exp-t bool-t))

(define (l2/let-exp? value)
  (if (list? value)
    (if (equal? (list-length value) 4)
      (equal? (list-head value) 'let-exp)
      false)
    false))

(claim l2/let-exp-name (-> l2/exp-t symbol-t))

(define (l2/let-exp-name target) (list-get 1 target))

(claim l2/let-exp-rhs (-> l2/exp-t l2/exp-t))

(define (l2/let-exp-rhs target) (list-get 2 target))

(claim l2/let-exp-body (-> l2/exp-t l2/exp-t))

(define (l2/let-exp-body target) (list-get 3 target))

(claim l2/let-exp-put-name (-> symbol-t l2/exp-t l2/exp-t))

(define (l2/let-exp-put-name value target)
  (list-put 1 value target))

(claim l2/let-exp-put-rhs (-> l2/exp-t l2/exp-t l2/exp-t))

(define (l2/let-exp-put-rhs value target)
  (list-put 2 value target))

(claim l2/let-exp-put-body (-> l2/exp-t l2/exp-t l2/exp-t))

(define (l2/let-exp-put-body value target)
  (list-put 3 value target))

(claim l2/let-exp-put-name! (-> symbol-t l2/exp-t l2/exp-t))

(define (l2/let-exp-put-name! value target)
  (list-put! 1 value target))

(claim l2/let-exp-put-rhs! (-> l2/exp-t l2/exp-t l2/exp-t))

(define (l2/let-exp-put-rhs! value target)
  (list-put! 2 value target))

(claim l2/let-exp-put-body! (-> l2/exp-t l2/exp-t l2/exp-t))

(define (l2/let-exp-put-body! value target)
  (list-put! 3 value target))

(define-data l2/env-t
  empty-env
  (extend-env
   (key symbol-t)
   (value l2/value-t)
   (rest l2/env-t)))

(claim l2/empty-env l2/env-t)

(define l2/empty-env 'empty-env)

(claim l2/empty-env? (-> l2/env-t bool-t))

(define (l2/empty-env? value) (equal? value 'empty-env))

(claim l2/extend-env
  (-> symbol-t l2/value-t l2/env-t l2/env-t))

(define (l2/extend-env key value rest)
  (= list₁ (make-list))
  (list-push! 'extend-env list₁)
  (list-push! key list₁)
  (list-push! value list₁)
  (list-push! rest list₁)
  list₁)

(claim l2/extend-env? (-> l2/env-t bool-t))

(define (l2/extend-env? value)
  (if (list? value)
    (if (equal? (list-length value) 4)
      (equal? (list-head value) 'extend-env)
      false)
    false))

(claim l2/extend-env-key (-> l2/env-t symbol-t))

(define (l2/extend-env-key target) (list-get 1 target))

(claim l2/extend-env-value (-> l2/env-t l2/value-t))

(define (l2/extend-env-value target) (list-get 2 target))

(claim l2/extend-env-rest (-> l2/env-t l2/env-t))

(define (l2/extend-env-rest target) (list-get 3 target))

(claim l2/extend-env-put-key
  (-> symbol-t l2/env-t l2/env-t))

(define (l2/extend-env-put-key value target)
  (list-put 1 value target))

(claim l2/extend-env-put-value
  (-> l2/value-t l2/env-t l2/env-t))

(define (l2/extend-env-put-value value target)
  (list-put 2 value target))

(claim l2/extend-env-put-rest
  (-> l2/env-t l2/env-t l2/env-t))

(define (l2/extend-env-put-rest value target)
  (list-put 3 value target))

(claim l2/extend-env-put-key!
  (-> symbol-t l2/env-t l2/env-t))

(define (l2/extend-env-put-key! value target)
  (list-put! 1 value target))

(claim l2/extend-env-put-value!
  (-> l2/value-t l2/env-t l2/env-t))

(define (l2/extend-env-put-value! value target)
  (list-put! 2 value target))

(claim l2/extend-env-put-rest!
  (-> l2/env-t l2/env-t l2/env-t))

(define (l2/extend-env-put-rest! value target)
  (list-put! 3 value target))

(claim l2/env-has? (-> symbol-t l2/env-t bool-t))

(define (l2/env-has? name env)
  (if (l2/empty-env? env)
    false
    (if (l2/extend-env? env)
      (begin
        (= rest₃₁ (l2/extend-env-rest env))
        (= value₃₁ (l2/extend-env-value env))
        (= key₃₁ (l2/extend-env-key env))
        (= rest₁ rest₃₁)
        (= value₁ value₃₁)
        (= key₁ key₃₁)
        (if (equal? key₁ name)
          true
          (l2/env-has? name rest₁)))
      (error "cond mismatch"))))

(claim l2/env-lookup-of-fail
  (-> symbol-t l2/env-t l2/value-t))

(define (l2/env-lookup-of-fail name env)
  (if (l2/empty-env? env)
    (error "undefined name")
    (if (l2/extend-env? env)
      (begin
        (= rest₄₁ (l2/extend-env-rest env))
        (= value₄₁ (l2/extend-env-value env))
        (= key₄₁ (l2/extend-env-key env))
        (= rest₁ rest₄₁)
        (= value₁ value₄₁)
        (= key₁ key₄₁)
        (if (equal? key₁ name)
          value₁
          (l2/env-lookup-of-fail name rest₁)))
      (error "cond mismatch"))))

(define-data l2/value-t
  (closure-value
   (env l2/env-t)
   (parameter symbol-t)
   (body l2/exp-t)))

(claim l2/closure-value
  (-> l2/env-t symbol-t l2/exp-t l2/value-t))

(define (l2/closure-value env parameter body)
  (= list₁ (make-list))
  (list-push! 'closure-value list₁)
  (list-push! env list₁)
  (list-push! parameter list₁)
  (list-push! body list₁)
  list₁)

(claim l2/closure-value? (-> l2/value-t bool-t))

(define (l2/closure-value? value)
  (if (list? value)
    (if (equal? (list-length value) 4)
      (equal? (list-head value) 'closure-value)
      false)
    false))

(claim l2/closure-value-env (-> l2/value-t l2/env-t))

(define (l2/closure-value-env target) (list-get 1 target))

(claim l2/closure-value-parameter (-> l2/value-t symbol-t))

(define (l2/closure-value-parameter target)
  (list-get 2 target))

(claim l2/closure-value-body (-> l2/value-t l2/exp-t))

(define (l2/closure-value-body target) (list-get 3 target))

(claim l2/closure-value-put-env
  (-> l2/env-t l2/value-t l2/value-t))

(define (l2/closure-value-put-env value target)
  (list-put 1 value target))

(claim l2/closure-value-put-parameter
  (-> symbol-t l2/value-t l2/value-t))

(define (l2/closure-value-put-parameter value target)
  (list-put 2 value target))

(claim l2/closure-value-put-body
  (-> l2/exp-t l2/value-t l2/value-t))

(define (l2/closure-value-put-body value target)
  (list-put 3 value target))

(claim l2/closure-value-put-env!
  (-> l2/env-t l2/value-t l2/value-t))

(define (l2/closure-value-put-env! value target)
  (list-put! 1 value target))

(claim l2/closure-value-put-parameter!
  (-> symbol-t l2/value-t l2/value-t))

(define (l2/closure-value-put-parameter! value target)
  (list-put! 2 value target))

(claim l2/closure-value-put-body!
  (-> l2/exp-t l2/value-t l2/value-t))

(define (l2/closure-value-put-body! value target)
  (list-put! 3 value target))

(claim l2/evaluate (-> l2/exp-t l2/env-t l2/value-t))

(define (l2/evaluate exp env)
  (if (l2/var-exp? exp)
    (begin
      (= name₂₁ (l2/var-exp-name exp))
      (= name₁ name₂₁)
      (l2/env-lookup-of-fail name₁ env))
    (if (l2/apply-exp? exp)
      (begin
        (= arg₂₁ (l2/apply-exp-arg exp))
        (= target₂₁ (l2/apply-exp-target exp))
        (= arg₁ arg₂₁)
        (= target₁ target₂₁)
        (l2/apply
         (l2/evaluate target₁ env)
         (l2/evaluate arg₁ env)))
      (if (l2/lambda-exp? exp)
        (begin
          (= body₃₁ (l2/lambda-exp-body exp))
          (= parameter₃₁ (l2/lambda-exp-parameter exp))
          (= body₁ body₃₁)
          (= parameter₁ parameter₃₁)
          (l2/closure-value env parameter₁ body₁))
        (if (l2/let-exp? exp)
          (begin
            (= body₄₁ (l2/let-exp-body exp))
            (= rhs₁₁ (l2/let-exp-rhs exp))
            (= name₃₁ (l2/let-exp-name exp))
            (= body₁ body₄₁)
            (= rhs₁ rhs₁₁)
            (= name₁ name₃₁)
            (= env₁
               (l2/extend-env
                name₁
                (l2/evaluate rhs₁ env)
                env))
            (l2/evaluate body₁ env₁))
          (error "cond mismatch"))))))

(claim l2/apply (-> l2/value-t l2/value-t l2/value-t))

(define (l2/apply target arg)
  (if (l2/closure-value? target)
    (begin
      (= body₅₁ (l2/closure-value-body target))
      (= parameter₄₁ (l2/closure-value-parameter target))
      (= env₂₁ (l2/closure-value-env target))
      (= body₁ body₅₁)
      (= parameter₁ parameter₄₁)
      (= env₁ env₂₁)
      (l2/evaluate body₁ (l2/extend-env parameter₁ arg env₁)))
    (error "cond mismatch")))