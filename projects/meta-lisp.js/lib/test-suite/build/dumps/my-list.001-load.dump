(claim my-list-adjacent-dedup
  (polymorphic (E)
    (-> (my-list/my-list-t E) (my-list/my-list-t E))))

(define (my-list-adjacent-dedup list)
  (match list
    (nil nil)
    ((li head nil) (li head nil))
    ((li first (li second rest))
     (if (equal? first second)
       (my-list-adjacent-dedup (li second rest))
       (li first (my-list-adjacent-dedup (li second rest)))))))

(define-test my-list-adjacent-dedup-test
  (assert-equal nil (my-list-adjacent-dedup nil))
  (assert-equal
    (li 1 (li 2 (li 3 (li 1 (li 2 (li 3 nil))))))
    (my-list-adjacent-dedup
     (li 1 (li 2 (li 3 (li 1 (li 2 (li 3 nil))))))))
  (assert-equal
    (li 1 (li 2 (li 3 nil)))
    (my-list-adjacent-dedup
     (li 1 (li 1 (li 2 (li 2 (li 3 (li 3 nil)))))))))

(claim my-list-append
  (polymorphic (E)
    (-> (my-list/my-list-t E)
        (my-list/my-list-t E)
        (my-list/my-list-t E))))

(define (my-list-append left right)
  (match left
    (nil right)
    ((li head tail) (li head (my-list-append tail right)))))

(define-test my-list-append-test
  (assert-equal nil (my-list-append nil nil))
  (assert-equal
    (li 1 (li 2 (li 3 (li 4 (li 5 (li 6 nil))))))
    (my-list-append
     (li 1 (li 2 (li 3 nil)))
     (li 4 (li 5 (li 6 nil))))))

(claim my-list-length
  (polymorphic (E) (-> (my-list/my-list-t E) int-t)))

(define (my-list-length list)
  (match list
    (nil 0)
    ((li head tail) (iadd 1 (my-list-length tail)))))

(define-test my-list-length-test
  (assert-equal 0 (my-list-length nil))
  (assert-equal 3 (my-list-length (li 1 (li 2 (li 3 nil))))))

(claim my-list-map-zip
  (polymorphic (A B C)
    (-> (-> A B C)
        (my-list/my-list-t A)
        (my-list/my-list-t B)
        (my-list/my-list-t C))))

(define (my-list-map-zip f list1 list2)
  (match-many (list1 list2)
    ((nil _) nil)
    (((li head1 tail1) nil) nil)
    (((li head1 tail1) (li head2 tail2))
     (li (f head1 head2) (my-list-map-zip f tail1 tail2)))))

(claim my-list-map-zip-2
  (polymorphic (A B C)
    (-> (-> A B C)
        (my-list/my-list-t A)
        (my-list/my-list-t B)
        (my-list/my-list-t C))))

(define (my-list-map-zip-2 f list1 list2)
  (match-many (list1 list2)
    ((nil _) nil)
    ((_ nil) nil)
    (((li head1 tail1) (li head2 tail2))
     (li (f head1 head2) (my-list-map-zip-2 f tail1 tail2)))))

(define-test my-list-map-zip-test
  (assert-equal nil (my-list-map-zip iadd nil nil))
  (assert-equal
    (li 2 (li 4 (li 6 nil)))
    (my-list-map-zip
     iadd
     (li 1 (li 2 (li 3 nil)))
     (li 1 (li 2 (li 3 nil)))))
  (assert-equal nil (my-list-map-zip-2 iadd nil nil))
  (assert-equal
    (li 2 (li 4 (li 6 nil)))
    (my-list-map-zip-2
     iadd
     (li 1 (li 2 (li 3 nil)))
     (li 1 (li 2 (li 3 nil))))))

(claim my-list-map
  (polymorphic (A B)
    (-> (-> A B) (my-list/my-list-t A) (my-list/my-list-t B))))

(define (my-list-map f list)
  (match list
    (nil nil)
    ((li head tail) (li (f head) (my-list-map f tail)))))

(define-test my-list-map-test
  (assert-equal nil (my-list-map (iadd 1) nil))
  (assert-equal
    (li 2 (li 3 (li 4 nil)))
    (my-list-map (iadd 1) (li 1 (li 2 (li 3 nil))))))

(define-test my-list-snapshot
  (println nil)
  (println (li 1 (li 2 (li 3 nil)))))

(define-test my-list-test
  (assert (nil? nil))
  (assert (li? (li 1 (li 2 (li 3 nil)))))
  (assert-not (li? nil))
  (assert-not (nil? (li 1 (li 2 (li 3 nil)))))
  (assert-equal (li-tail (li 1 nil)) nil)
  (assert-equal (li-head (li 1 nil)) 1)
  (= list (li 1 (li 2 (li 3 nil))))
  (assert-equal (li-head list) 1)
  (li-put-head! 111 list)
  (assert-equal (li-head list) 111)
  (assert-equal (li-tail list) (li 2 (li 3 nil)))
  (li-put-tail! nil list)
  (assert-equal (li-tail list) nil)
  (assert-equal (li 1 nil) ((li 1) nil)))

(define-data (my-list-t E)
  nil
  (li (head E) (tail (my-list-t E))))

(claim nil (polymorphic (E) (my-list/my-list-t E)))

(define nil 'nil)

(claim nil?
  (polymorphic (E) (-> (my-list/my-list-t E) bool-t)))

(define (nil? value) (equal? value 'nil))

(claim li
  (polymorphic (E)
    (-> E (my-list/my-list-t E) (my-list/my-list-t E))))

(define (li head tail) ['li head tail])

(claim li?
  (polymorphic (E) (-> (my-list/my-list-t E) bool-t)))

(define (li? value)
  (and (list? value)
       (equal? (list-length value) 3)
       (equal? (list-head value) 'li)))

(claim li-head
  (polymorphic (E) (-> (my-list/my-list-t E) E)))

(define (li-head target) (list-get 1 target))

(claim li-tail
  (polymorphic (E)
    (-> (my-list/my-list-t E) (my-list/my-list-t E))))

(define (li-tail target) (list-get 2 target))

(claim li-put-head
  (polymorphic (E)
    (-> E (my-list/my-list-t E) (my-list/my-list-t E))))

(define (li-put-head value target)
  (list-put 1 value target))

(claim li-put-tail
  (polymorphic (E)
    (-> (my-list/my-list-t E)
        (my-list/my-list-t E)
        (my-list/my-list-t E))))

(define (li-put-tail value target)
  (list-put 2 value target))

(claim li-put-head!
  (polymorphic (E)
    (-> E (my-list/my-list-t E) (my-list/my-list-t E))))

(define (li-put-head! value target)
  (list-put! 1 value target))

(claim li-put-tail!
  (polymorphic (E)
    (-> (my-list/my-list-t E)
        (my-list/my-list-t E)
        (my-list/my-list-t E))))

(define (li-put-tail! value target)
  (list-put! 2 value target))