(define (evaluate-and-print exp)
  (println (evaluate exp empty-env)))

(define-test
 l1-test
 (evaluate-and-print (lambda-exp 'x (var-exp 'x)))
 (evaluate-and-print
  (apply-exp
   (lambda-exp 'x (var-exp 'x))
   (lambda-exp 'x (var-exp 'x))))
 (evaluate-and-print
  (apply-exp
   (apply-exp
    (lambda-exp 'x (var-exp 'x))
    (lambda-exp 'x (var-exp 'x)))
   (apply-exp
    (lambda-exp 'x (var-exp 'x))
    (lambda-exp 'x (var-exp 'x))))))

(define-data exp-t
  (var-exp (name symbol-t))
  (apply-exp (target exp-t) (arg exp-t))
  (lambda-exp (parameter symbol-t) (body exp-t)))

(claim var-exp (-> symbol-t l1/exp-t))

(define (var-exp name) ['var-exp name])

(claim var-exp? (-> l1/exp-t bool-t))

(define (var-exp? value)
  (and (list? value)
       (equal? (list-length value) 2)
       (equal? (list-head value) 'var-exp)))

(claim var-exp-name (-> l1/exp-t symbol-t))

(define (var-exp-name target) (list-get 1 target))

(claim var-exp-put-name (-> symbol-t l1/exp-t l1/exp-t))

(define (var-exp-put-name value target)
  (list-put 1 value target))

(claim var-exp-put-name! (-> symbol-t l1/exp-t l1/exp-t))

(define (var-exp-put-name! value target)
  (list-put! 1 value target))

(claim apply-exp (-> l1/exp-t l1/exp-t l1/exp-t))

(define (apply-exp target arg) ['apply-exp target arg])

(claim apply-exp? (-> l1/exp-t bool-t))

(define (apply-exp? value)
  (and (list? value)
       (equal? (list-length value) 3)
       (equal? (list-head value) 'apply-exp)))

(claim apply-exp-target (-> l1/exp-t l1/exp-t))

(define (apply-exp-target target) (list-get 1 target))

(claim apply-exp-arg (-> l1/exp-t l1/exp-t))

(define (apply-exp-arg target) (list-get 2 target))

(claim apply-exp-put-target (-> l1/exp-t l1/exp-t l1/exp-t))

(define (apply-exp-put-target value target)
  (list-put 1 value target))

(claim apply-exp-put-arg (-> l1/exp-t l1/exp-t l1/exp-t))

(define (apply-exp-put-arg value target)
  (list-put 2 value target))

(claim apply-exp-put-target!
  (-> l1/exp-t l1/exp-t l1/exp-t))

(define (apply-exp-put-target! value target)
  (list-put! 1 value target))

(claim apply-exp-put-arg! (-> l1/exp-t l1/exp-t l1/exp-t))

(define (apply-exp-put-arg! value target)
  (list-put! 2 value target))

(claim lambda-exp (-> symbol-t l1/exp-t l1/exp-t))

(define (lambda-exp parameter body)
  ['lambda-exp parameter body])

(claim lambda-exp? (-> l1/exp-t bool-t))

(define (lambda-exp? value)
  (and (list? value)
       (equal? (list-length value) 3)
       (equal? (list-head value) 'lambda-exp)))

(claim lambda-exp-parameter (-> l1/exp-t symbol-t))

(define (lambda-exp-parameter target) (list-get 1 target))

(claim lambda-exp-body (-> l1/exp-t l1/exp-t))

(define (lambda-exp-body target) (list-get 2 target))

(claim lambda-exp-put-parameter
  (-> symbol-t l1/exp-t l1/exp-t))

(define (lambda-exp-put-parameter value target)
  (list-put 1 value target))

(claim lambda-exp-put-body (-> l1/exp-t l1/exp-t l1/exp-t))

(define (lambda-exp-put-body value target)
  (list-put 2 value target))

(claim lambda-exp-put-parameter!
  (-> symbol-t l1/exp-t l1/exp-t))

(define (lambda-exp-put-parameter! value target)
  (list-put! 1 value target))

(claim lambda-exp-put-body! (-> l1/exp-t l1/exp-t l1/exp-t))

(define (lambda-exp-put-body! value target)
  (list-put! 2 value target))

(define-data env-t
  empty-env
  (extend-env (key symbol-t) (value value-t) (rest env-t)))

(claim empty-env l1/env-t)

(define empty-env 'empty-env)

(claim empty-env? (-> l1/env-t bool-t))

(define (empty-env? value) (equal? value 'empty-env))

(claim extend-env
  (-> symbol-t l1/value-t l1/env-t l1/env-t))

(define (extend-env key value rest)
  ['extend-env key value rest])

(claim extend-env? (-> l1/env-t bool-t))

(define (extend-env? value)
  (and (list? value)
       (equal? (list-length value) 4)
       (equal? (list-head value) 'extend-env)))

(claim extend-env-key (-> l1/env-t symbol-t))

(define (extend-env-key target) (list-get 1 target))

(claim extend-env-value (-> l1/env-t l1/value-t))

(define (extend-env-value target) (list-get 2 target))

(claim extend-env-rest (-> l1/env-t l1/env-t))

(define (extend-env-rest target) (list-get 3 target))

(claim extend-env-put-key (-> symbol-t l1/env-t l1/env-t))

(define (extend-env-put-key value target)
  (list-put 1 value target))

(claim extend-env-put-value
  (-> l1/value-t l1/env-t l1/env-t))

(define (extend-env-put-value value target)
  (list-put 2 value target))

(claim extend-env-put-rest (-> l1/env-t l1/env-t l1/env-t))

(define (extend-env-put-rest value target)
  (list-put 3 value target))

(claim extend-env-put-key! (-> symbol-t l1/env-t l1/env-t))

(define (extend-env-put-key! value target)
  (list-put! 1 value target))

(claim extend-env-put-value!
  (-> l1/value-t l1/env-t l1/env-t))

(define (extend-env-put-value! value target)
  (list-put! 2 value target))

(claim extend-env-put-rest! (-> l1/env-t l1/env-t l1/env-t))

(define (extend-env-put-rest! value target)
  (list-put! 3 value target))

(claim env-has? (-> symbol-t l1/env-t bool-t))

(define (env-has? name env)
  (match env
    (empty-env false)
    ((extend-env key value rest)
     (or (equal? key name) (env-has? name rest)))))

(claim env-lookup-of-fail (-> symbol-t l1/env-t l1/value-t))

(define (env-lookup-of-fail name env)
  (match env
    (empty-env (error "undefined name"))
    ((extend-env key value rest)
     (if (equal? key name)
       value
       (env-lookup-of-fail name rest)))))

(define-data value-t
  (closure-value
   (env env-t)
   (parameter symbol-t)
   (body exp-t)))

(claim closure-value
  (-> l1/env-t symbol-t l1/exp-t l1/value-t))

(define (closure-value env parameter body)
  ['closure-value env parameter body])

(claim closure-value? (-> l1/value-t bool-t))

(define (closure-value? value)
  (and (list? value)
       (equal? (list-length value) 4)
       (equal? (list-head value) 'closure-value)))

(claim closure-value-env (-> l1/value-t l1/env-t))

(define (closure-value-env target) (list-get 1 target))

(claim closure-value-parameter (-> l1/value-t symbol-t))

(define (closure-value-parameter target)
  (list-get 2 target))

(claim closure-value-body (-> l1/value-t l1/exp-t))

(define (closure-value-body target) (list-get 3 target))

(claim closure-value-put-env
  (-> l1/env-t l1/value-t l1/value-t))

(define (closure-value-put-env value target)
  (list-put 1 value target))

(claim closure-value-put-parameter
  (-> symbol-t l1/value-t l1/value-t))

(define (closure-value-put-parameter value target)
  (list-put 2 value target))

(claim closure-value-put-body
  (-> l1/exp-t l1/value-t l1/value-t))

(define (closure-value-put-body value target)
  (list-put 3 value target))

(claim closure-value-put-env!
  (-> l1/env-t l1/value-t l1/value-t))

(define (closure-value-put-env! value target)
  (list-put! 1 value target))

(claim closure-value-put-parameter!
  (-> symbol-t l1/value-t l1/value-t))

(define (closure-value-put-parameter! value target)
  (list-put! 2 value target))

(claim closure-value-put-body!
  (-> l1/exp-t l1/value-t l1/value-t))

(define (closure-value-put-body! value target)
  (list-put! 3 value target))

(claim evaluate (-> l1/exp-t l1/env-t l1/value-t))

(define (evaluate exp env)
  (match exp
    ((var-exp name) (env-lookup-of-fail name env))
    ((apply-exp target arg)
     (apply (evaluate target env) (evaluate arg env)))
    ((lambda-exp parameter body)
     (closure-value env parameter body))))

(claim apply (-> l1/value-t l1/value-t l1/value-t))

(define (apply target arg)
  (match target
    ((closure-value env parameter body)
     (evaluate body (extend-env parameter arg env)))))