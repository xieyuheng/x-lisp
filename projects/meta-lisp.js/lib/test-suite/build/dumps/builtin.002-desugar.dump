(claim list-each
  (polymorphic (A Any)
    (-> (-> A Any) (builtin/list-t A) builtin/void-t)))

(define (list-each f list)
  (if (list-empty? list)
    void
    (begin (f (car list)) (list-each f (cdr list)))))

(define-test list-each-test
  (list-each
   (lambda (x) (print x) (write "\n"))
   (begin
     (= list (builtin/make-list))
     (builtin/list-push! 1 list)
     (builtin/list-push! 2 list)
     (builtin/list-push! 3 list)
     list)))

(claim list-every?
  (polymorphic (A)
    (-> (-> A builtin/bool-t)
        (builtin/list-t A)
        builtin/bool-t)))

(define (list-every? p list)
  (if (list-empty? list)
    true
    (if (not (p (car list)))
      false
      (if true
        (list-every? p (cdr list))
        (builtin/error "cond mismatch")))))

(define-test list-every-test
  (assert
    (list-every?
     int-non-negative?
     (begin
       (= list (builtin/make-list))
       (builtin/list-push! 0 list)
       (builtin/list-push! 1 list)
       (builtin/list-push! 2 list)
       (builtin/list-push! 3 list)
       list)))
  (assert-not
    (list-every?
     int-non-negative?
     (begin
       (= list (builtin/make-list))
       (builtin/list-push! 0 list)
       (builtin/list-push! 1 list)
       (builtin/list-push! -1 list)
       (builtin/list-push! 2 list)
       (builtin/list-push! 3 list)
       list))))

(claim list-some?
  (polymorphic (A)
    (-> (-> A builtin/bool-t)
        (builtin/list-t A)
        builtin/bool-t)))

(define (list-some? p list)
  (if (list-empty? list)
    false
    (if (p (car list))
      true
      (if true
        (list-some? p (cdr list))
        (builtin/error "cond mismatch")))))

(define-test list-some-test
  (assert
    (list-some?
     int-non-negative?
     (begin
       (= list (builtin/make-list))
       (builtin/list-push! -1 list)
       (builtin/list-push! -2 list)
       (builtin/list-push! 0 list)
       list)))
  (assert-not
    (list-some?
     int-non-negative?
     (begin
       (= list (builtin/make-list))
       (builtin/list-push! -1 list)
       (builtin/list-push! -2 list)
       (builtin/list-push! -3 list)
       list))))

(claim list-find
  (polymorphic (A)
    (-> (-> A builtin/bool-t)
        (builtin/list-t A)
        (builtin/maybe-t A))))

(define (list-find p list)
  (if (list-empty? list)
    nothing
    (if (p (car list))
      (just (car list))
      (if true
        (list-find p (cdr list))
        (builtin/error "cond mismatch")))))

(define-test list-find-test
  (assert-equal
    (just 3)
    (list-find
     int?
     (begin
       (= list (builtin/make-list))
       (builtin/list-push! 'a list)
       (builtin/list-push! 'b list)
       (builtin/list-push! 3 list)
       (builtin/list-push! 'd list)
       list)))
  (assert-equal
    nothing
    (list-find
     int?
     (begin
       (= list (builtin/make-list))
       (builtin/list-push! 'a list)
       (builtin/list-push! 'b list)
       (builtin/list-push! 'c list)
       (builtin/list-push! 'd list)
       list))))

(claim list-find-index
  (polymorphic (A)
    (-> (-> A builtin/bool-t)
        (builtin/list-t A)
        (builtin/maybe-t builtin/int-t))))

(define (list-find-index p list)
  (list-find-index-aux p list 0))

(claim list-find-index-aux
  (polymorphic (A)
    (-> (-> A builtin/bool-t)
        (builtin/list-t A)
        builtin/int-t
        (builtin/maybe-t builtin/int-t))))

(define (list-find-index-aux p list index)
  (if (list-empty? list)
    nothing
    (if (p (car list))
      (just index)
      (if true
        (list-find-index-aux p (cdr list) (iadd 1 index))
        (builtin/error "cond mismatch")))))

(define-test list-find-index-test
  (assert-equal
    (just 2)
    (list-find-index
     int?
     (begin
       (= list (builtin/make-list))
       (builtin/list-push! 'a list)
       (builtin/list-push! 'b list)
       (builtin/list-push! 3 list)
       (builtin/list-push! 'd list)
       list)))
  (assert-equal
    nothing
    (list-find-index
     int?
     (begin
       (= list (builtin/make-list))
       (builtin/list-push! 'a list)
       (builtin/list-push! 'b list)
       (builtin/list-push! 'c list)
       (builtin/list-push! 'd list)
       list))))

(claim list-fold-left
  (polymorphic (E R) (-> (-> R E R) R (builtin/list-t E) R)))

(define (list-fold-left op e list)
  (if (list-empty? list)
    e
    (list-fold-left
     op
     (op e (list-head list))
     (list-tail list))))

(define-test list-fold-left-test
  (assert-equal
    10
    (list-fold-left
     iadd
     0
     (begin
       (= list (builtin/make-list))
       (builtin/list-push! 1 list)
       (builtin/list-push! 2 list)
       (builtin/list-push! 3 list)
       (builtin/list-push! 4 list)
       list)))
  (assert-equal
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 4 list)
      (builtin/list-push! 3 list)
      (builtin/list-push! 2 list)
      (builtin/list-push! 1 list)
      list)
    (list-fold-left
     (swap cons)
     (begin (= list (builtin/make-list)) list)
     (begin
       (= list (builtin/make-list))
       (builtin/list-push! 1 list)
       (builtin/list-push! 2 list)
       (builtin/list-push! 3 list)
       (builtin/list-push! 4 list)
       list))))

(claim list-fold-right
  (polymorphic (E R) (-> (-> E R R) R (builtin/list-t E) R)))

(define (list-fold-right op e list)
  (if (list-empty? list)
    e
    (list-fold-right
     op
     (op (list-last list) e)
     (list-init list))))

(define-test list-fold-right-test
  (assert-equal
    10
    (list-fold-right
     iadd
     0
     (begin
       (= list (builtin/make-list))
       (builtin/list-push! 1 list)
       (builtin/list-push! 2 list)
       (builtin/list-push! 3 list)
       (builtin/list-push! 4 list)
       list)))
  (assert-equal
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 1 list)
      (builtin/list-push! 2 list)
      (builtin/list-push! 3 list)
      (builtin/list-push! 4 list)
      list)
    (list-fold-right
     cons
     (begin (= list (builtin/make-list)) list)
     (begin
       (= list (builtin/make-list))
       (builtin/list-push! 1 list)
       (builtin/list-push! 2 list)
       (builtin/list-push! 3 list)
       (builtin/list-push! 4 list)
       list))))

(define (list-first list) (car list))

(define (list-second list) (car (cdr list)))

(define (list-third list) (car (cdr (cdr list))))

(claim list-group
  (polymorphic (K V)
    (-> (-> V K)
        (builtin/list-t V)
        (builtin/hash-t K (builtin/list-t V)))))

(define (list-group f list)
  (= new-hash (begin (= hash (builtin/make-hash)) hash))
  (list-each
   (lambda (value)
     (= key (f value))
     (if (hash-has? key new-hash)
       void
       (begin
         (hash-put!
          key
          (begin
            (= list (builtin/make-list))
            (builtin/list-push! value list)
            list)
          new-hash)
         void))
     (= group (hash-get key new-hash))
     (list-push! value group))
   list)
  new-hash)

(define-test list-group-test
  (assert-equal
    (begin
      (= hash (builtin/make-hash))
      (builtin/hash-put!
       0
       (begin
         (= list (builtin/make-list))
         (builtin/list-push! 0 list)
         (builtin/list-push! 3 list)
         list)
       hash)
      (builtin/hash-put!
       1
       (begin
         (= list (builtin/make-list))
         (builtin/list-push! 1 list)
         (builtin/list-push! 4 list)
         list)
       hash)
      (builtin/hash-put!
       2
       (begin
         (= list (builtin/make-list))
         (builtin/list-push! 2 list)
         (builtin/list-push! 5 list)
         list)
       hash)
      hash)
    (list-group
     (swap imod 3)
     (begin
       (= list (builtin/make-list))
       (builtin/list-push! 0 list)
       (builtin/list-push! 1 list)
       (builtin/list-push! 2 list)
       (builtin/list-push! 3 list)
       (builtin/list-push! 4 list)
       (builtin/list-push! 5 list)
       list))))

(claim list-map-zip
  (polymorphic (A B C)
    (-> (-> A B C)
        (builtin/list-t A)
        (builtin/list-t B)
        (builtin/list-t C))))

(define (list-map-zip f left right)
  (list-map
   (lambda (pair) (f (pair-first pair) (pair-second pair)))
   (list-zip left right)))

(define-test list-map-zip-test
  (assert-equal
