       (= list (builtin/make-list))
       (builtin/list-push! 10 list)
       (builtin/list-push! 20 list)
       (builtin/list-push! 30 list)
       list))
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 11 list)
      (builtin/list-push! 22 list)
      (builtin/list-push! 33 list)
      list)))

(claim list-map
  (polymorphic (A B)
    (-> (-> A B) (builtin/list-t A) (builtin/list-t B))))

(define (list-map f list)
  (if (list-empty? list)
    (begin (= list (builtin/make-list)) list)
    (cons (f (car list)) (list-map f (cdr list)))))

(define-test list-map-test
