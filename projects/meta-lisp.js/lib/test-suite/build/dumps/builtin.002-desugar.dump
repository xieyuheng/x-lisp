(define (negate p) (lambda (x) (not (p x))))

(define-test negate-test
  (assert (not (int? 'a)))
  (assert ((negate int?) 'a))
  (assert (negate int? 'a)))

(claim call-with-input-file
  (polymorphic (A)
    (-> builtin/string-t (-> builtin/file-t A) A)))

(define (call-with-input-file path f)
  (= file (open-input-file path))
  (= result (f file))
  (file-close file)
  result)

(claim call-with-output-file
  (polymorphic (A)
    (-> builtin/string-t (-> builtin/file-t A) A)))

(define (call-with-output-file path f)
  (= file (open-output-file path))
  (= result (f file))
  (file-close file)
  result)

(claim float-product
  (-> (builtin/list-t builtin/float-t) builtin/float-t))

(define (float-product xs)
  (if (list-empty? xs)
    1.0
    (fmul (car xs) (float-product (cdr xs)))))

(define-test float-product-test
  (assert-equal
    1.0
    (float-product (begin (= list (builtin/make-list)) list)))
  (assert-equal
    6.0
    (float-product
     (begin
       (= list (builtin/make-list))
       (builtin/list-push! 1.0 list)
       (builtin/list-push! 2.0 list)
       (builtin/list-push! 3.0 list)
       list)))
  (assert-equal
    24.0
    (float-product
     (begin
       (= list (builtin/make-list))
       (builtin/list-push! 1.0 list)
       (builtin/list-push! 2.0 list)
       (builtin/list-push! 3.0 list)
       (builtin/list-push! 4.0 list)
       list))))

(claim float-sum
  (-> (builtin/list-t builtin/float-t) builtin/float-t))

(define (float-sum xs)
  (if (list-empty? xs)
    0.0
    (fadd (car xs) (float-sum (cdr xs)))))

(define-test float-sum-test
  (assert-equal
    0.0
    (float-sum (begin (= list (builtin/make-list)) list)))
  (assert-equal
    6.0
    (float-sum
     (begin
       (= list (builtin/make-list))
       (builtin/list-push! 1.0 list)
       (builtin/list-push! 2.0 list)
       (builtin/list-push! 3.0 list)
       list)))
  (assert-equal
    10.0
    (float-sum
     (begin
       (= list (builtin/make-list))
       (builtin/list-push! 1.0 list)
       (builtin/list-push! 2.0 list)
       (builtin/list-push! 3.0 list)
       (builtin/list-push! 4.0 list)
       list))))

(claim int-align
  (-> builtin/int-t builtin/int-t builtin/int-t))

(define (int-align alignment n)
  (= remainder (imod n alignment))
  (if (equal? 0 remainder)
    n
    (iadd (isub n remainder) alignment)))

(define-test int-align-test
  (assert-equal 0 (int-align 16 0))
  (assert-equal 16 (int-align 16 8))
  (assert-equal 16 (int-align 16 16))
  (assert-equal 32 (int-align 16 24)))

(claim int-product
  (-> (builtin/list-t builtin/int-t) builtin/int-t))

(define (int-product xs)
  (if (list-empty? xs)
    1
    (imul (car xs) (int-product (cdr xs)))))

(define-test int-product-test
  (assert-equal
    1
    (int-product (begin (= list (builtin/make-list)) list)))
  (assert-equal
    6
    (int-product
     (begin
       (= list (builtin/make-list))
       (builtin/list-push! 1 list)
       (builtin/list-push! 2 list)
       (builtin/list-push! 3 list)
       list)))
  (assert-equal
    24
    (int-product
     (begin
       (= list (builtin/make-list))
       (builtin/list-push! 1 list)
       (builtin/list-push! 2 list)
       (builtin/list-push! 3 list)
       (builtin/list-push! 4 list)
       list))))

(claim int-sum
  (-> (builtin/list-t builtin/int-t) builtin/int-t))

(define (int-sum xs)
  (if (list-empty? xs) 0 (iadd (car xs) (int-sum (cdr xs)))))

(define-test int-sum-test
  (assert-equal
    0
    (int-sum (begin (= list (builtin/make-list)) list)))
  (assert-equal
    6
    (int-sum
     (begin
       (= list (builtin/make-list))
       (builtin/list-push! 1 list)
       (builtin/list-push! 2 list)
       (builtin/list-push! 3 list)
       list)))
  (assert-equal
    10
    (int-sum
     (begin
       (= list (builtin/make-list))
       (builtin/list-push! 1 list)
       (builtin/list-push! 2 list)
       (builtin/list-push! 3 list)
       (builtin/list-push! 4 list)
       list))))

(claim list-append
  (polymorphic (A)
    (-> (builtin/list-t A)
        (builtin/list-t A)
        (builtin/list-t A))))

(define (list-append list tail)
  (if (list-empty? list)
    tail
    (cons (car list) (list-append (cdr list) tail))))

(define-test list-append-test
  (assert-equal
    (list-append
     (begin
       (= list (builtin/make-list))
       (builtin/list-push! 1 list)
       (builtin/list-push! 2 list)
       (builtin/list-push! 3 list)
       list)
     (begin
       (= list (builtin/make-list))
       (builtin/list-push! 4 list)
       (builtin/list-push! 5 list)
       (builtin/list-push! 6 list)
       list))
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 1 list)
      (builtin/list-push! 2 list)
      (builtin/list-push! 3 list)
      (builtin/list-push! 4 list)
      (builtin/list-push! 5 list)
      (builtin/list-push! 6 list)
      list)))

(claim list-concat
  (polymorphic (A)
    (-> (builtin/list-t (builtin/list-t A))
        (builtin/list-t A))))

(define (list-concat lists)
  (if (list-empty? lists)
    (begin (= list (builtin/make-list)) list)
    (list-append (car lists) (list-concat (cdr lists)))))

(define-test list-concat-test
  (assert-equal
    (list-concat
     (begin
       (= list (builtin/make-list))
       (builtin/list-push!
        (begin
          (= list (builtin/make-list))
          (builtin/list-push! 1 list)
          (builtin/list-push! 2 list)
          (builtin/list-push! 3 list)
          list)
        list)
       (builtin/list-push!
        (begin
          (= list (builtin/make-list))
          (builtin/list-push! 4 list)
          (builtin/list-push! 5 list)
          (builtin/list-push! 6 list)
          list)
        list)
       list))
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 1 list)
      (builtin/list-push! 2 list)
      (builtin/list-push! 3 list)
      (builtin/list-push! 4 list)
      (builtin/list-push! 5 list)
      (builtin/list-push! 6 list)
      list)))

(claim list-each
  (polymorphic (A)
    (-> (-> A builtin/void-t)
        (builtin/list-t A)
        builtin/void-t)))

(define (list-each f list)
  (if (list-empty? list)
    void
    (begin (f (car list)) (list-each f (cdr list)))))

(define-test list-each-test
  (list-each
   (lambda (x) (print x) (write "\n"))
   (begin
     (= list (builtin/make-list))
     (builtin/list-push! 1 list)
     (builtin/list-push! 2 list)
     (builtin/list-push! 3 list)
     list)))

(define (list-first list) (car list))

(define (list-second list) (car (cdr list)))

(define (list-third list) (car (cdr (cdr list))))

(claim list-map
  (polymorphic (A B)
    (-> (-> A B) (builtin/list-t A) (builtin/list-t B))))

(define (list-map f list)
  (if (list-empty? list)
    (begin (= list (builtin/make-list)) list)
    (cons (f (car list)) (list-map f (cdr list)))))

(define-test list-map-test
  (assert-equal
    (list-map
     (iadd 10)
     (begin
       (= list (builtin/make-list))
       (builtin/list-push! 1 list)
       (builtin/list-push! 2 list)
       (builtin/list-push! 3 list)
       list))
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 11 list)
      (builtin/list-push! 12 list)
      (builtin/list-push! 13 list)
      list)))

(claim list-select
  (polymorphic (A)
    (-> (-> A builtin/bool-t)
        (builtin/list-t A)
        (builtin/list-t A))))

(define (list-select p list)
  (if (list-empty? list)
    list
    (if (p (car list))
      (cons (car list) (list-select p (cdr list)))
      (if true
        (list-select p (cdr list))
        (builtin/error "cond mismatch")))))

(define-test list-select-test
  (assert-equal
    (list-select
     (negate (equal? 0))
     (begin
       (= list (builtin/make-list))
       (builtin/list-push! 0 list)
       (builtin/list-push! 1 list)
       (builtin/list-push! 0 list)
       (builtin/list-push! 2 list)
       (builtin/list-push! 0 list)
       (builtin/list-push! 3 list)
       list))
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 1 list)
      (builtin/list-push! 2 list)
      (builtin/list-push! 3 list)
      list)))

(claim list-reject
  (polymorphic (A)
    (-> (-> A builtin/bool-t)
        (builtin/list-t A)
        (builtin/list-t A))))

(define (list-reject p list) (list-select (negate p) list))

(define-test list-reject-test
  (assert-equal
    (list-reject
     (equal? 0)
     (begin
       (= list (builtin/make-list))
       (builtin/list-push! 0 list)
       (builtin/list-push! 1 list)
       (builtin/list-push! 0 list)
       (builtin/list-push! 2 list)
       (builtin/list-push! 0 list)
       (builtin/list-push! 3 list)
       list))
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 1 list)
      (builtin/list-push! 2 list)
      (builtin/list-push! 3 list)
      list)))

(claim list-take
  (polymorphic (A)
    (-> builtin/int-t (builtin/list-t A) (builtin/list-t A))))

(define (list-take n list)
  (assert (int-non-negative? n))
  (if (if (equal? n 0) true (list-empty? list))
    (begin (= list (builtin/make-list)) list)
    (cons (car list) (list-take (isub n 1) (cdr list)))))

(define-test list-take-test
  (assert-equal
    (list-take
     0
     (begin
       (= list (builtin/make-list))
       (builtin/list-push! 1 list)
       (builtin/list-push! 2 list)
       (builtin/list-push! 3 list)
       list))
    (begin (= list (builtin/make-list)) list))
  (assert-equal
    (list-take
     1
     (begin
       (= list (builtin/make-list))
       (builtin/list-push! 1 list)
       (builtin/list-push! 2 list)
       (builtin/list-push! 3 list)
       list))
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 1 list)
      list))
  (assert-equal
    (list-take
     2
     (begin
       (= list (builtin/make-list))
       (builtin/list-push! 1 list)
       (builtin/list-push! 2 list)
       (builtin/list-push! 3 list)
       list))
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 1 list)
      (builtin/list-push! 2 list)
      list))
  (assert-equal
    (list-take
     3
     (begin
       (= list (builtin/make-list))
       (builtin/list-push! 1 list)
       (builtin/list-push! 2 list)
       (builtin/list-push! 3 list)
       list))
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 1 list)
      (builtin/list-push! 2 list)
      (builtin/list-push! 3 list)
      list))
  (assert-equal
    (list-take
     4
     (begin
       (= list (builtin/make-list))
       (builtin/list-push! 1 list)
       (builtin/list-push! 2 list)
       (builtin/list-push! 3 list)
       list))
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 1 list)
      (builtin/list-push! 2 list)
      (builtin/list-push! 3 list)
      list)))

(claim list-drop
  (polymorphic (A)
    (-> builtin/int-t (builtin/list-t A) (builtin/list-t A))))

(define (list-drop n list)
  (assert (int-non-negative? n))
  (if (if (equal? n 0) true (list-empty? list))
    list
    (list-drop (isub n 1) (cdr list))))

(define-test list-drop-test
  (assert-equal
    (list-drop
     0
     (begin
       (= list (builtin/make-list))
       (builtin/list-push! 1 list)
       (builtin/list-push! 2 list)
       (builtin/list-push! 3 list)
       list))
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 1 list)
      (builtin/list-push! 2 list)
      (builtin/list-push! 3 list)
      list))
  (assert-equal
    (list-drop
     1
     (begin
       (= list (builtin/make-list))
       (builtin/list-push! 1 list)
       (builtin/list-push! 2 list)
       (builtin/list-push! 3 list)
       list))
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 2 list)
      (builtin/list-push! 3 list)
      list))
  (assert-equal
    (list-drop
     2
     (begin
       (= list (builtin/make-list))
       (builtin/list-push! 1 list)
       (builtin/list-push! 2 list)
       (builtin/list-push! 3 list)
       list))
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 3 list)
      list))
  (assert-equal
    (list-drop
     3
     (begin
       (= list (builtin/make-list))
       (builtin/list-push! 1 list)
       (builtin/list-push! 2 list)
       (builtin/list-push! 3 list)
       list))
    (begin (= list (builtin/make-list)) list))
  (assert-equal
    (list-drop
     4
     (begin
       (= list (builtin/make-list))
       (builtin/list-push! 1 list)
       (builtin/list-push! 2 list)
       (builtin/list-push! 3 list)
       list))
    (begin (= list (builtin/make-list)) list)))

(define-test list-test
  (assert-equal
    (begin
      (= list (builtin/make-list))
      (builtin/list-push!
       (begin
         (= list (builtin/make-list))
         (builtin/list-push! 1 list)
         (builtin/list-push! 2 list)
         (builtin/list-push! 3 list)
         list)
       list)
      (builtin/list-push!
       (begin
         (= list (builtin/make-list))
         (builtin/list-push! 4 list)
         (builtin/list-push! 5 list)
         (builtin/list-push! 6 list)
         list)
       list)
      (builtin/list-push!
       (begin
         (= list (builtin/make-list))
         (builtin/list-push! 7 list)
         (builtin/list-push! 8 list)
         (builtin/list-push! 9 list)
         list)
       list)
      list)
    (begin
      (= list (builtin/make-list))
      (builtin/list-push!
       (begin
         (= list (builtin/make-list))
         (builtin/list-push! 1 list)
         (builtin/list-push! 2 list)
         (builtin/list-push! 3 list)
         list)
       list)
      (builtin/list-push!
       (begin
         (= list (builtin/make-list))
         (builtin/list-push! 4 list)
         (builtin/list-push! 5 list)
         (builtin/list-push! 6 list)
         list)
       list)
      (builtin/list-push!
       (begin
         (= list (builtin/make-list))
         (builtin/list-push! 7 list)
         (builtin/list-push! 8 list)
         (builtin/list-push! 9 list)
         list)
       list)
      list))
  (assert-not-equal
    (begin
      (= list (builtin/make-list))
      (builtin/list-push!
       (begin
         (= list (builtin/make-list))
         (builtin/list-push! 1 list)
         (builtin/list-push! 2 list)
         (builtin/list-push! 3 list)
         list)
       list)
      (builtin/list-push!
       (begin
         (= list (builtin/make-list))
         (builtin/list-push! 4 list)
         (builtin/list-push! 5 list)
         (builtin/list-push! 6 list)
         list)
       list)
      (builtin/list-push!
       (begin
         (= list (builtin/make-list))
         (builtin/list-push! 7 list)
         (builtin/list-push! 8 list)
         (builtin/list-push! 9 list)
         list)
       list)
      list)
    (begin
      (= list (builtin/make-list))
      (builtin/list-push!
       (begin
         (= list (builtin/make-list))
         (builtin/list-push! 1 list)
         (builtin/list-push! 2 list)
         (builtin/list-push! 3 list)
         list)
       list)
      (builtin/list-push!
       (begin
         (= list (builtin/make-list))
         (builtin/list-push! 4 list)
         (builtin/list-push! 5 list)
         (builtin/list-push! 6 list)
         list)
       list)
      (builtin/list-push!
       (begin
         (= list (builtin/make-list))
         (builtin/list-push! 7 list)
         (builtin/list-push! 8 list)
         (builtin/list-push! 10 list)
         list)
       list)
      list))
  (assert
    (list-empty? (begin (= list (builtin/make-list)) list)))
  (assert-not
    (list-empty?
     (begin
       (= list (builtin/make-list))
       (builtin/list-push! 1 list)
       list)))
  (assert-equal
    (cons
     1
     (cons
      2
      (cons 3 (begin (= list (builtin/make-list)) list))))
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 1 list)
      (builtin/list-push! 2 list)
      (builtin/list-push! 3 list)
      list))
  (assert-equal
    (car (begin
           (= list (builtin/make-list))
           (builtin/list-push! 1 list)
           (builtin/list-push! 2 list)
           (builtin/list-push! 3 list)
           list))
    1)
  (assert-equal
    (cdr (begin
           (= list (builtin/make-list))
           (builtin/list-push! 1 list)
           (builtin/list-push! 2 list)
           (builtin/list-push! 3 list)
           list))
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 2 list)
      (builtin/list-push! 3 list)
      list))
  (assert-equal
    (list-head
     (begin
       (= list (builtin/make-list))
       (builtin/list-push! 1 list)
       (builtin/list-push! 2 list)
       (builtin/list-push! 3 list)
       list))
    1)
  (assert-equal
    (list-tail
     (begin
       (= list (builtin/make-list))
       (builtin/list-push! 1 list)
       (builtin/list-push! 2 list)
       (builtin/list-push! 3 list)
       list))
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 2 list)
      (builtin/list-push! 3 list)
      list))
  (assert-equal
    (list-init
     (begin
       (= list (builtin/make-list))
       (builtin/list-push! 1 list)
       (builtin/list-push! 2 list)
       (builtin/list-push! 3 list)
       list))
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 1 list)
      (builtin/list-push! 2 list)
      list))
  (assert-equal
    (list-last
     (begin
       (= list (builtin/make-list))
       (builtin/list-push! 1 list)
       (builtin/list-push! 2 list)
       (builtin/list-push! 3 list)
       list))
    3)
  (assert-equal
    (begin
      (= set (builtin/make-set))
      (builtin/set-add! 1 set)
      (builtin/set-add! 2 set)
      (builtin/set-add! 3 set)
      set)
    (list-to-set
     (begin
       (= list (builtin/make-list))
       (builtin/list-push! 1 list)
       (builtin/list-push! 2 list)
       (builtin/list-push! 3 list)
       list)))
  (assert-equal
    (list-copy
     (begin
       (= list (builtin/make-list))
       (builtin/list-push! 1 list)
       (builtin/list-push! 2 list)
       (builtin/list-push! 3 list)
       list))
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 1 list)
      (builtin/list-push! 2 list)
      (builtin/list-push! 3 list)
      list))
  (assert-equal
    (list-get
     0
     (begin
       (= list (builtin/make-list))
       (builtin/list-push! 1 list)
       (builtin/list-push! 2 list)
       (builtin/list-push! 3 list)
       list))
    1)
  (assert-equal
    (list-get
     1
     (begin
       (= list (builtin/make-list))
       (builtin/list-push! 1 list)
       (builtin/list-push! 2 list)
       (builtin/list-push! 3 list)
       list))
    2)
  (assert-equal
    (list-get
     2
     (begin
       (= list (builtin/make-list))
       (builtin/list-push! 1 list)
       (builtin/list-push! 2 list)
       (builtin/list-push! 3 list)
       list))
    3)
  (assert-equal
    (list-length (begin (= list (builtin/make-list)) list))
    0)
  (assert-equal
    (list-length
     (begin
       (= list (builtin/make-list))
       (builtin/list-push! 1 list)
       (builtin/list-push! 2 list)
       (builtin/list-push! 3 list)
       list))
    3)
  (assert-equal
    (list-length
     (begin
       (= list (builtin/make-list))
       (builtin/list-push!
        (begin
          (= list (builtin/make-list))
          (builtin/list-push! 1 list)
          (builtin/list-push! 2 list)
          (builtin/list-push! 3 list)
          list)
        list)
       (builtin/list-push!
        (begin
          (= list (builtin/make-list))
          (builtin/list-push! 4 list)
          (builtin/list-push! 5 list)
          (builtin/list-push! 6 list)
          list)
        list)
       (builtin/list-push!
        (begin
          (= list (builtin/make-list))
          (builtin/list-push! 7 list)
          (builtin/list-push! 8 list)
          (builtin/list-push! 9 list)
          list)
        list)
       list))
    3)
  (= fs
     (the (list-t (-> int-t int-t))
       (begin
         (= list (builtin/make-list))
         (builtin/list-push! (iadd 1) list)
         (builtin/list-push! (iadd 2) list)
         (builtin/list-push! (iadd 3) list)
         list)))
  (assert-equal 1 ((list-get 0 fs) 0))
  (assert-equal 2 ((list-get 1 fs) 0))
  (assert-equal 3 ((list-get 2 fs) 0)))

(define-test list-pop-test
  (= list
     (begin
       (= list (builtin/make-list))
       (builtin/list-push! 1 list)
       (builtin/list-push! 2 list)
       (builtin/list-push! 3 list)
       list))
  (assert-equal 3 (list-pop! list))
  (assert-equal 2 (list-pop! list))
  (assert-equal 1 (list-pop! list))
  (assert-equal
    list
    (begin (= list (builtin/make-list)) list)))

(define-test list-push-test
  (begin
    (= list (begin (= list (builtin/make-list)) list))
    (= list (list-push 1 list))
    (= list (list-push 2 list))
    (= list (list-push 3 list))
    (assert-equal
      list
      (begin
        (= list (builtin/make-list))
        (builtin/list-push! 1 list)
        (builtin/list-push! 2 list)
        (builtin/list-push! 3 list)
        list)))
  (begin
    (= list (begin (= list (builtin/make-list)) list))
    (list-push 1 list)
    (list-push 2 list)
    (list-push 3 list)
    (assert-equal
      list
      (begin (= list (builtin/make-list)) list)))
  (= list (begin (= list (builtin/make-list)) list))
  (list-push! 1 list)
  (list-push! 2 list)
  (list-push! 3 list)
  (assert-equal
    list
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 1 list)
      (builtin/list-push! 2 list)
      (builtin/list-push! 3 list)
      list)))

(define-test list-put-test
  (begin
    (= list
       (begin
         (= list (builtin/make-list))
         (builtin/list-push! 0 list)
         (builtin/list-push! 0 list)
         (builtin/list-push! 0 list)
         list))
    (= list (list-put 0 1 list))
    (= list (list-put 1 2 list))
    (= list (list-put 2 3 list))
    (assert-equal
      list
      (begin
        (= list (builtin/make-list))
        (builtin/list-push! 1 list)
        (builtin/list-push! 2 list)
        (builtin/list-push! 3 list)
        list)))
  (begin
    (= list
       (begin
         (= list (builtin/make-list))
         (builtin/list-push! 0 list)
         (builtin/list-push! 0 list)
         (builtin/list-push! 0 list)
         list))
    (list-put 0 1 list)
    (list-put 1 2 list)
    (list-put 2 3 list)
    (assert-equal
      list
      (begin
        (= list (builtin/make-list))
        (builtin/list-push! 0 list)
        (builtin/list-push! 0 list)
        (builtin/list-push! 0 list)
        list)))
  (= list
     (begin
       (= list (builtin/make-list))
       (builtin/list-push! 0 list)
       (builtin/list-push! 0 list)
       (builtin/list-push! 0 list)
       list))
  (list-put! 0 1 list)
  (list-put! 1 2 list)
  (list-put! 2 3 list)
  (assert-equal
    list
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 1 list)
      (builtin/list-push! 2 list)
      (builtin/list-push! 3 list)
      list)))

(define-test list-reverse-test
  (assert-equal
    (list-reverse
     (begin
       (= list (builtin/make-list))
       (builtin/list-push! 1 list)
       (builtin/list-push! 2 list)
       (builtin/list-push! 3 list)
       list))
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 3 list)
      (builtin/list-push! 2 list)
      (builtin/list-push! 1 list)
      list)))

(define-test list-shift-test
  (begin
    (= list
       (begin
         (= list (builtin/make-list))
         (builtin/list-push! 1 list)
         (builtin/list-push! 2 list)
         (builtin/list-push! 3 list)
         list))
    (assert-equal 1 (list-shift! list))
    (assert-equal 2 (list-shift! list))
    (assert-equal 3 (list-shift! list))
    (assert-equal
      list
      (begin (= list (builtin/make-list)) list)))
  (= list (begin (= list (builtin/make-list)) list))
  (list-unshift! 3 list)
  (list-unshift! 2 list)
  (list-unshift! 1 list)
  (assert-equal
    list
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 1 list)
      (builtin/list-push! 2 list)
      (builtin/list-push! 3 list)
      list)))

(define-interface source-location-t
  :span
  source-span-t
  :path
  string-t)

(define-interface source-span-t
  :start
  source-position-t
  :end
  source-position-t)

(define-interface source-position-t
  :index
  int-t
  :row
  int-t
  :column
  int-t)

(define-data located-sexp-t
  (symbol-sexp
   (content symbol-t)
   (location source-location-t))
  (keyword-sexp
   (content keyword-t)
   (location source-location-t))
  (string-sexp
   (content string-t)
   (location source-location-t))
  (int-sexp (content int-t) (location source-location-t))
  (float-sexp (content float-t) (location source-location-t))
  (list-sexp
   (elements (list-t located-sexp-t))
   (location source-location-t)))

(claim symbol-sexp
  (-> builtin/symbol-t
      builtin/source-location-t
      builtin/located-sexp-t))

(define (symbol-sexp content location)
  (= list (builtin/make-list))
  (builtin/list-push! 'symbol-sexp list)
  (builtin/list-push! content list)
  (builtin/list-push! location list)
  list)

(claim symbol-sexp?
  (-> builtin/located-sexp-t builtin/bool-t))

(define (symbol-sexp? value)
  (if (list? value)
    (if (equal? (list-length value) 3)
      (equal? (list-head value) 'symbol-sexp)
      false)
    false))

(claim symbol-sexp-content
  (-> builtin/located-sexp-t builtin/symbol-t))

(define (symbol-sexp-content target) (list-get 1 target))

(claim symbol-sexp-location
  (-> builtin/located-sexp-t builtin/source-location-t))

(define (symbol-sexp-location target) (list-get 2 target))

(claim symbol-sexp-put-content
  (-> builtin/symbol-t
      builtin/located-sexp-t
      builtin/located-sexp-t))

(define (symbol-sexp-put-content value target)
  (list-put 1 value target))

(claim symbol-sexp-put-location
  (-> builtin/source-location-t
      builtin/located-sexp-t
      builtin/located-sexp-t))

(define (symbol-sexp-put-location value target)
  (list-put 2 value target))

(claim symbol-sexp-put-content!
  (-> builtin/symbol-t
      builtin/located-sexp-t
      builtin/located-sexp-t))

(define (symbol-sexp-put-content! value target)
  (list-put! 1 value target))

(claim symbol-sexp-put-location!
  (-> builtin/source-location-t
      builtin/located-sexp-t
      builtin/located-sexp-t))

(define (symbol-sexp-put-location! value target)
  (list-put! 2 value target))

