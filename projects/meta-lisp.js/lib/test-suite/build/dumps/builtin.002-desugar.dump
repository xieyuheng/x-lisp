(define (negate p x) (not (p x)))

(define-test negate-test
  (assert (not (int? 'a)))
  (assert (negate int? 'a))
  (assert ((negate int?) 'a)))

(claim call-with-input-file
  (polymorphic (A)
    (-> builtin/string-t (-> builtin/file-t A) A)))

(define (call-with-input-file path f)
  (= file (open-input-file path))
  (= result (f file))
  (file-close file)
  result)

(claim call-with-output-file
  (polymorphic (A)
    (-> builtin/string-t (-> builtin/file-t A) A)))

(define (call-with-output-file path f)
  (= file (open-output-file path))
  (= result (f file))
  (file-close file)
  result)

(claim float-product
  (-> (builtin/list-t builtin/float-t) builtin/float-t))

(define (float-product xs)
  (if (list-empty? xs)
    1.0
    (fmul (car xs) (float-product (cdr xs)))))

(define-test float-product-test
  (assert-equal
    1.0
    (float-product (begin (= list (builtin/make-list)) list)))
  (assert-equal
    6.0
    (float-product
     (begin
       (= list (builtin/make-list))
       (builtin/list-push! 1.0 list)
       (builtin/list-push! 2.0 list)
       (builtin/list-push! 3.0 list)
       list)))
  (assert-equal
    24.0
    (float-product
     (begin
       (= list (builtin/make-list))
       (builtin/list-push! 1.0 list)
       (builtin/list-push! 2.0 list)
       (builtin/list-push! 3.0 list)
       (builtin/list-push! 4.0 list)
       list))))

(claim float-sum
  (-> (builtin/list-t builtin/float-t) builtin/float-t))

(define (float-sum xs)
  (if (list-empty? xs)
    0.0
    (fadd (car xs) (float-sum (cdr xs)))))

(define-test float-sum-test
  (assert-equal
    0.0
    (float-sum (begin (= list (builtin/make-list)) list)))
  (assert-equal
    6.0
    (float-sum
     (begin
       (= list (builtin/make-list))
       (builtin/list-push! 1.0 list)
       (builtin/list-push! 2.0 list)
       (builtin/list-push! 3.0 list)
       list)))
  (assert-equal
    10.0
    (float-sum
     (begin
       (= list (builtin/make-list))
       (builtin/list-push! 1.0 list)
       (builtin/list-push! 2.0 list)
       (builtin/list-push! 3.0 list)
       (builtin/list-push! 4.0 list)
       list))))

(claim constant (polymorphic (A B) (-> A B A)))

(define (constant x y) x)

(define-test constant-test
  (assert-equal 1 (constant 1 "a")))

(claim swap
  (polymorphic (A B C) (-> (-> A B C) (-> B A C))))

(define (swap f x y) (f y x))

(claim drop (polymorphic (A B C) (-> (-> A B) (-> C A B))))

(define (drop f) (lambda (dropped x) (f x)))

(claim dup (polymorphic (A B) (-> (-> A A B) (-> A B))))

(define (dup f) (lambda (x) (f x x)))

(claim identity (polymorphic (A) (-> A A)))

(define (identity x) x)

(define-test identity-test (assert-equal 1 (identity 1)))

(claim hash-append
  (polymorphic (K V)
    (-> (builtin/hash-t K V)
        (builtin/hash-t K V)
        (builtin/hash-t K V))))

(define (hash-append hash rest)
  (= new-hash (hash-copy hash))
  (hash-each
   (lambda (key value) (hash-put! key value new-hash) void)
   rest)
  new-hash)

(define-test hash-append-test
  (assert-equal
    (begin
      (= hash (builtin/make-hash))
      (builtin/hash-put! 1 2 hash)
      (builtin/hash-put! 3 4 hash)
      hash)
    (hash-append
     (begin
       (= hash (builtin/make-hash))
       (builtin/hash-put! 1 2 hash)
       hash)
     (begin
       (= hash (builtin/make-hash))
       (builtin/hash-put! 3 4 hash)
       hash)))
  (assert-equal
    (begin
      (= hash (builtin/make-hash))
      (builtin/hash-put! 1 2 hash)
      (builtin/hash-put! 3 4 hash)
      hash)
    (hash-append
     (begin
       (= hash (builtin/make-hash))
       (builtin/hash-put! 1 2 hash)
       (builtin/hash-put! 3 5 hash)
       hash)
     (begin
       (= hash (builtin/make-hash))
       (builtin/hash-put! 3 4 hash)
       hash))))

(claim hash-each-value
  (polymorphic (K V Any)
    (-> (-> V Any) (builtin/hash-t K V) builtin/void-t)))

(define (hash-each-value f hash)
  (list-each f (hash-values hash)))

(claim hash-each-key
  (polymorphic (K V Any)
    (-> (-> K Any) (builtin/hash-t K V) builtin/void-t)))

(define (hash-each-key f hash)
  (list-each f (hash-keys hash)))

(claim hash-each-entry
  (polymorphic (K V Any)
    (-> (-> (builtin/hash-entry-t K V) Any)
        (builtin/hash-t K V)
        builtin/void-t)))

(define (hash-each-entry f hash)
  (list-each f (hash-entries hash)))

(claim hash-each
  (polymorphic (K V Any)
    (-> (-> K V Any) (builtin/hash-t K V) builtin/void-t)))

(define (hash-each f hash)
  (list-each
   (lambda (entry) (f (:key entry) (:value entry)))
   (hash-entries hash)))

(define-test hash-each-value-test
  (= hash
     (begin
       (= hash (builtin/make-hash))
       (builtin/hash-put! 1 2 hash)
       (builtin/hash-put! 3 4 hash)
       hash))
  (= list (begin (= list (builtin/make-list)) list))
  (hash-each-value
   (lambda (value) (list-push! value list))
   hash)
  (assert-equal
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 2 list)
      (builtin/list-push! 4 list)
      list)
    list))

(define-test hash-each-key-test
  (= hash
     (begin
       (= hash (builtin/make-hash))
       (builtin/hash-put! 1 2 hash)
       (builtin/hash-put! 3 4 hash)
       hash))
  (= list (begin (= list (builtin/make-list)) list))
  (hash-each-key (lambda (key) (list-push! key list)) hash)
  (assert-equal
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 1 list)
      (builtin/list-push! 3 list)
      list)
    list))

(define-test hash-each-entry-test
  (= hash
     (begin
       (= hash (builtin/make-hash))
       (builtin/hash-put! 1 2 hash)
       (builtin/hash-put! 3 4 hash)
       hash))
  (= list (begin (= list (builtin/make-list)) list))
  (hash-each-entry
   (lambda (entry) (list-push! entry list))
   hash)
  (assert-equal
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! (make-hash-entry 1 2) list)
      (builtin/list-push! (make-hash-entry 3 4) list)
      list)
    list))

(define-test hash-each-test
  (= hash
     (begin
       (= hash (builtin/make-hash))
       (builtin/hash-put! 1 2 hash)
       (builtin/hash-put! 3 4 hash)
       hash))
  (= list (begin (= list (builtin/make-list)) list))
  (hash-each
   (lambda (key value)
     (list-push! key list)
     (list-push! value list))
   hash)
  (assert-equal
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! 1 list)
      (builtin/list-push! 2 list)
      (builtin/list-push! 3 list)
      (builtin/list-push! 4 list)
      list)
    list))

(claim hash-from-entries
  (polymorphic (K V)
    (-> (builtin/list-t (builtin/hash-entry-t K V))
        (builtin/hash-t K V))))

(define (hash-from-entries entries)
  (hash-put-entries
   entries
   (begin (= hash (builtin/make-hash)) hash)))

(define-test hash-from-entries-test
  (assert-equal
    (begin
      (= hash (builtin/make-hash))
      (builtin/hash-put! 'a 1 hash)
      (builtin/hash-put! 'b 2 hash)
      hash)
    (hash-from-entries
     (begin
       (= list (builtin/make-list))
       (builtin/list-push! (make-hash-entry 'a 1) list)
       (builtin/list-push! (make-hash-entry 'b 2) list)
       list))))

(claim hash-get-maybe
  (polymorphic (K V)
    (-> K (builtin/hash-t K V) (builtin/maybe-t V))))

(define (hash-get-maybe key hash)
  (if (hash-has? key hash)
    (just (hash-get key hash))
    nothing))

(define-test hash-get-maybe-test
  (assert-equal
    (just "b")
    (hash-get-maybe
     2
     (begin
       (= hash (builtin/make-hash))
       (builtin/hash-put! 1 "a" hash)
       (builtin/hash-put! 2 "b" hash)
       (builtin/hash-put! 3 "c" hash)
       hash)))
  (assert-equal
    nothing
    (hash-get-maybe
     4
     (begin
       (= hash (builtin/make-hash))
       (builtin/hash-put! 1 "a" hash)
       (builtin/hash-put! 2 "b" hash)
       (builtin/hash-put! 3 "c" hash)
       hash))))

(claim hash-invert
  (polymorphic (K V)
    (-> (builtin/hash-t K V) (builtin/hash-t V K))))

(define (hash-invert hash)
  (hash-map (lambda (k v) (make-hash-entry v k)) hash))

(define-test hash-invert-test
  (assert-equal
    (begin
      (= hash (builtin/make-hash))
      (builtin/hash-put! 2 1 hash)
      (builtin/hash-put! 4 3 hash)
      hash)
    (hash-invert
     (begin
       (= hash (builtin/make-hash))
       (builtin/hash-put! 1 2 hash)
       (builtin/hash-put! 3 4 hash)
       hash))))

(claim hash-invert-group
  (polymorphic (K V)
    (-> (builtin/hash-t K V)
        (builtin/hash-t V (builtin/set-t K)))))

(define (hash-invert-group hash)
  (= new-hash (begin (= hash (builtin/make-hash)) hash))
  (hash-each-value
   (lambda (value)
     (= keys
        (hash-keys (hash-select-value (equal? value) hash)))
     (hash-put! value (list-to-set keys) new-hash))
   hash)
  new-hash)

(define-test hash-invert-group-test
  (assert-equal
    (begin
      (= hash (builtin/make-hash))
      (builtin/hash-put!
       2
       (begin
         (= set (builtin/make-set))
         (builtin/set-add! 1 set)
         (builtin/set-add! 2 set)
         set)
       hash)
      (builtin/hash-put!
       4
       (begin
         (= set (builtin/make-set))
         (builtin/set-add! 3 set)
         (builtin/set-add! 4 set)
         set)
       hash)
      hash)
    (hash-invert-group
     (begin
       (= hash (builtin/make-hash))
       (builtin/hash-put! 1 2 hash)
       (builtin/hash-put! 3 4 hash)
       (builtin/hash-put! 2 2 hash)
       (builtin/hash-put! 4 4 hash)
       hash))))

(claim hash-map-key
  (polymorphic (K1 K2 V)
    (-> (-> K1 K2)
        (builtin/hash-t K1 V)
        (builtin/hash-t K2 V))))

(define (hash-map-key f hash)
  (hash-from-entries
   (list-map
    (lambda (entry)
      (make-hash-entry (f (:key entry)) (:value entry)))
    (hash-entries hash))))

(define-test hash-map-key-test
  (assert-equal
    (begin
      (= hash (builtin/make-hash))
      (builtin/hash-put! 2 2 hash)
      (builtin/hash-put! 4 4 hash)
      hash)
    (hash-map-key
     (iadd 1)
     (begin
       (= hash (builtin/make-hash))
       (builtin/hash-put! 1 2 hash)
       (builtin/hash-put! 3 4 hash)
       hash))))

(claim hash-map-value
  (polymorphic (K V1 V2)
    (-> (-> V1 V2)
        (builtin/hash-t K V1)
        (builtin/hash-t K V2))))

(define (hash-map-value f hash)
  (hash-from-entries
   (list-map
    (lambda (entry)
      (make-hash-entry (:key entry) (f (:value entry))))
    (hash-entries hash))))

(define-test hash-map-value-test
  (assert-equal
    (begin
      (= hash (builtin/make-hash))
      (builtin/hash-put! 1 3 hash)
      (builtin/hash-put! 3 5 hash)
      hash)
    (hash-map-value
     (iadd 1)
     (begin
       (= hash (builtin/make-hash))
       (builtin/hash-put! 1 2 hash)
       (builtin/hash-put! 3 4 hash)
       hash))))

(claim hash-map-entry
  (polymorphic (K1 V1 K2 V2)
    (-> (-> (builtin/hash-entry-t K1 V1)
            (builtin/hash-entry-t K2 V2))
        (builtin/hash-t K1 V1)
        (builtin/hash-t K2 V2))))

(define (hash-map-entry f hash)
  (hash-from-entries (list-map f (hash-entries hash))))

(define-test hash-map-entry-test
  (assert-equal
    (begin
      (= hash (builtin/make-hash))
      (builtin/hash-put! 2 3 hash)
      (builtin/hash-put! 4 5 hash)
      hash)
    (hash-map-entry
     (lambda (entry)
       (make-hash-entry
        (iadd 1 (:key entry))
        (iadd 1 (:value entry))))
     (begin
       (= hash (builtin/make-hash))
       (builtin/hash-put! 1 2 hash)
       (builtin/hash-put! 3 4 hash)
       hash))))

(claim hash-map
  (polymorphic (K1 V1 K2 V2)
    (-> (-> K1 V1 (builtin/hash-entry-t K2 V2))
        (builtin/hash-t K1 V1)
        (builtin/hash-t K2 V2))))

(define (hash-map f hash)
  (hash-from-entries
   (list-map
    (lambda (entry) (f (:key entry) (:value entry)))
    (hash-entries hash))))

(define-test hash-map-test
  (assert-equal
    (begin
      (= hash (builtin/make-hash))
      (builtin/hash-put! 2 3 hash)
      (builtin/hash-put! 4 5 hash)
      hash)
    (hash-map
     (lambda (key value)
       (make-hash-entry (iadd 1 key) (iadd 1 value)))
     (begin
       (= hash (builtin/make-hash))
       (builtin/hash-put! 1 2 hash)
       (builtin/hash-put! 3 4 hash)
       hash))))

(claim hash-put-entries
  (polymorphic (K V)
    (-> (builtin/list-t (builtin/hash-entry-t K V))
        (builtin/hash-t K V)
        (builtin/hash-t K V))))

(define (hash-put-entries entries hash)
  (hash-put-entries! entries (hash-copy hash)))

(claim hash-put-entries!
  (polymorphic (K V)
    (-> (builtin/list-t (builtin/hash-entry-t K V))
        (builtin/hash-t K V)
        (builtin/hash-t K V))))

(define (hash-put-entries! entries hash)
  (if (list-empty? entries)
    hash
    (if true
      (begin
        (= entry (car entries))
        (hash-put-entry! entry hash)
        (hash-put-entries! (cdr entries) hash))
      (builtin/error "cond mismatch"))))

(define-test hash-put-entries-test
  (assert-equal
    (begin
      (= hash (builtin/make-hash))
      (builtin/hash-put! 'a 1 hash)
      (builtin/hash-put! 'b 2 hash)
      hash)
    (hash-put-entries
     (begin
       (= list (builtin/make-list))
       (builtin/list-push! (make-hash-entry 'a 1) list)
       (builtin/list-push! (make-hash-entry 'b 2) list)
       list)
     (begin (= hash (builtin/make-hash)) hash)))
  (= hash (begin (= hash (builtin/make-hash)) hash))
  (assert-equal
    (begin
      (= hash (builtin/make-hash))
      (builtin/hash-put! 'a 1 hash)
      (builtin/hash-put! 'b 2 hash)
      hash)
    (hash-put-entries!
     (begin
       (= list (builtin/make-list))
       (builtin/list-push! (make-hash-entry 'a 1) list)
       (builtin/list-push! (make-hash-entry 'b 2) list)
       list)
     hash))
  (assert-equal
    (begin
      (= hash (builtin/make-hash))
      (builtin/hash-put! 'a 1 hash)
      (builtin/hash-put! 'b 2 hash)
      hash)
    hash))

(define (hash-put-entry entry hash)
  (hash-put (:key entry) (:value entry) hash))

(define (hash-put-entry! entry hash)
  (hash-put! (:key entry) (:value entry) hash))

(claim hash-select
  (polymorphic (K V)
    (-> (-> K V builtin/bool-t)
        (builtin/hash-t K V)
        (builtin/hash-t K V))))

(define (hash-select p hash)
  (hash-from-entries
   (list-select
    (lambda (entry) (p (:key entry) (:value entry)))
    (hash-entries hash))))

(claim hash-select-key
  (polymorphic (K V)
    (-> (-> K builtin/bool-t)
        (builtin/hash-t K V)
        (builtin/hash-t K V))))

(define (hash-select-key p hash)
  (hash-from-entries
   (list-select
    (lambda (entry) (p (:key entry)))
    (hash-entries hash))))

(claim hash-select-value
  (polymorphic (K V)
    (-> (-> V builtin/bool-t)
        (builtin/hash-t K V)
        (builtin/hash-t K V))))

(define (hash-select-value p hash)
  (hash-from-entries
   (list-select
    (lambda (entry) (p (:value entry)))
    (hash-entries hash))))

(claim hash-reject
  (polymorphic (K V)
    (-> (-> K V builtin/bool-t)
        (builtin/hash-t K V)
        (builtin/hash-t K V))))

(define (hash-reject p hash)
  (hash-select (lambda (key value) (not (p key value))) hash))

(claim hash-reject-key
  (polymorphic (K V)
    (-> (-> K builtin/bool-t)
        (builtin/hash-t K V)
        (builtin/hash-t K V))))

(define (hash-reject-key p hash)
  (hash-select-key (negate p) hash))

(claim hash-reject-value
  (polymorphic (K V)
    (-> (-> V builtin/bool-t)
        (builtin/hash-t K V)
        (builtin/hash-t K V))))

(define (hash-reject-value p hash)
  (hash-select-value (negate p) hash))

(define-test test-hash-select
  (assert-equal
    (begin
      (= hash (builtin/make-hash))
      (builtin/hash-put! 'a 1 hash)
      (builtin/hash-put! 'b 2 hash)
      hash)
    (hash-select
     (drop int-non-negative?)
     (begin
       (= hash (builtin/make-hash))
       (builtin/hash-put! 'a 1 hash)
       (builtin/hash-put! 'b 2 hash)
       (builtin/hash-put! 'x -1 hash)
       (builtin/hash-put! 'y -2 hash)
       hash)))
  (assert-equal
    (begin
      (= hash (builtin/make-hash))
      (builtin/hash-put! 'a 1 hash)
      (builtin/hash-put! 'b 2 hash)
      hash)
    (hash-select-value
     int-non-negative?
     (begin
       (= hash (builtin/make-hash))
       (builtin/hash-put! 'a 1 hash)
       (builtin/hash-put! 'b 2 hash)
       (builtin/hash-put! 'x -1 hash)
       (builtin/hash-put! 'y -2 hash)
       hash)))
  (assert-equal
    (begin
      (= hash (builtin/make-hash))
      (builtin/hash-put! 1 'a hash)
      (builtin/hash-put! 2 'b hash)
      hash)
    (hash-select-key
     int-non-negative?
     (begin
       (= hash (builtin/make-hash))
       (builtin/hash-put! 1 'a hash)
       (builtin/hash-put! 2 'b hash)
       (builtin/hash-put! -1 'x hash)
       (builtin/hash-put! -2 'y hash)
       hash)))
  (assert-equal
    (begin
      (= hash (builtin/make-hash))
      (builtin/hash-put! 'x -1 hash)
      (builtin/hash-put! 'y -2 hash)
      hash)
    (hash-reject
     (drop int-non-negative?)
     (begin
       (= hash (builtin/make-hash))
       (builtin/hash-put! 'a 1 hash)
       (builtin/hash-put! 'b 2 hash)
       (builtin/hash-put! 'x -1 hash)
       (builtin/hash-put! 'y -2 hash)
       hash)))
  (assert-equal
    (begin
      (= hash (builtin/make-hash))
      (builtin/hash-put! 'x -1 hash)
      (builtin/hash-put! 'y -2 hash)
      hash)
    (hash-reject-value
     int-non-negative?
     (begin
       (= hash (builtin/make-hash))
       (builtin/hash-put! 'a 1 hash)
       (builtin/hash-put! 'b 2 hash)
       (builtin/hash-put! 'x -1 hash)
       (builtin/hash-put! 'y -2 hash)
       hash)))
  (assert-equal
    (begin
      (= hash (builtin/make-hash))
      (builtin/hash-put! -1 'x hash)
      (builtin/hash-put! -2 'y hash)
      hash)
    (hash-reject-key
     int-non-negative?
     (begin
       (= hash (builtin/make-hash))
       (builtin/hash-put! 1 'a hash)
       (builtin/hash-put! 2 'b hash)
       (builtin/hash-put! -1 'x hash)
       (builtin/hash-put! -2 'y hash)
       hash))))

(define-interface (hash-entry-t K V) :key K :value V)

(define (make-hash-entry key value)
  (@record :key key :value value))

(claim int-align
  (-> builtin/int-t builtin/int-t builtin/int-t))

(define (int-align alignment n)
  (= remainder (imod n alignment))
  (if (equal? 0 remainder)
    n
    (iadd (isub n remainder) alignment)))

(define-test int-align-test
  (assert-equal 0 (int-align 16 0))
  (assert-equal 16 (int-align 16 8))
  (assert-equal 16 (int-align 16 16))
  (assert-equal 32 (int-align 16 24)))

(claim int-product
  (-> (builtin/list-t builtin/int-t) builtin/int-t))

(define (int-product xs)
  (if (list-empty? xs)
    1
    (imul (car xs) (int-product (cdr xs)))))

(define-test int-product-test
  (assert-equal
    1
    (int-product (begin (= list (builtin/make-list)) list)))
  (assert-equal
    6
    (int-product
     (begin
       (= list (builtin/make-list))
       (builtin/list-push! 1 list)
       (builtin/list-push! 2 list)
       (builtin/list-push! 3 list)
       list)))
  (assert-equal
    24
    (int-product
     (begin
       (= list (builtin/make-list))
       (builtin/list-push! 1 list)
       (builtin/list-push! 2 list)
       (builtin/list-push! 3 list)
       (builtin/list-push! 4 list)
       list))))

(claim int-sum
  (-> (builtin/list-t builtin/int-t) builtin/int-t))

(define (int-sum xs)
  (if (list-empty? xs) 0 (iadd (car xs) (int-sum (cdr xs)))))

(define-test int-sum-test
  (assert-equal
    0
    (int-sum (begin (= list (builtin/make-list)) list)))
  (assert-equal
    6
    (int-sum
     (begin
       (= list (builtin/make-list))
       (builtin/list-push! 1 list)
       (builtin/list-push! 2 list)
       (builtin/list-push! 3 list)
       list)))
  (assert-equal
    10
    (int-sum
     (begin
       (= list (builtin/make-list))
       (builtin/list-push! 1 list)
       (builtin/list-push! 2 list)
       (builtin/list-push! 3 list)
       (builtin/list-push! 4 list)
       list))))

(claim list-append
  (polymorphic (A)
    (-> (builtin/list-t A)
        (builtin/list-t A)
        (builtin/list-t A))))

(define (list-append list tail)
  (if (list-empty? list)
    tail
    (cons (car list) (list-append (cdr list) tail))))

(define-test list-append-test
  (assert-equal
