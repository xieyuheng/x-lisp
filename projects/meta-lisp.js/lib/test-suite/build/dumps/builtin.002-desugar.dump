      (builtin/list-push! (make-pair 2 1) list)
      (builtin/list-push! (make-pair 2 2) list)
      (builtin/list-push! (make-pair 2 3) list)
      (builtin/list-push! (make-pair 3 1) list)
      (builtin/list-push! (make-pair 3 2) list)
      (builtin/list-push! (make-pair 3 3) list)
      list)
    (list-product
     (begin
       (= list (builtin/make-list))
       (builtin/list-push! 1 list)
       (builtin/list-push! 2 list)
       (builtin/list-push! 3 list)
       list)
     (begin
       (= list (builtin/make-list))
       (builtin/list-push! 1 list)
       (builtin/list-push! 2 list)
       (builtin/list-push! 3 list)
       list))))

(claim list-select
  (polymorphic (A)
    (-> (-> A builtin/bool-t)
        (builtin/list-t A)
        (builtin/list-t A))))

(define (list-select p list)
  (if (list-empty? list)
    list
    (if (p (car list))
      (cons (car list) (list-select p (cdr list)))
      (if true
        (list-select p (cdr list))
        (builtin/error "cond mismatch")))))

(define-test list-select-test
  (assert-equal
