(claim list-zip
  (polymorphic (A B)
    (-> (builtin/list-t A)
        (builtin/list-t B)
        (builtin/list-t (builtin/pair-t A B)))))

(define (list-zip left right)
  (if (if (list-empty? left) true (list-empty? right))
    (begin (= list (builtin/make-list)) list)
    (cons
     (make-pair (car left) (car right))
     (list-zip (cdr left) (cdr right)))))

(define-test list-zip-test
  (assert-equal
    (list-zip
     (begin
       (= list (builtin/make-list))
       (builtin/list-push! 'a list)
       (builtin/list-push! 'b list)
       (builtin/list-push! 'c list)
       list)
     (begin
       (= list (builtin/make-list))
       (builtin/list-push! 1 list)
       (builtin/list-push! 2 list)
       (builtin/list-push! 3 list)
       list))
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! (make-pair 'a 1) list)
      (builtin/list-push! (make-pair 'b 2) list)
      (builtin/list-push! (make-pair 'c 3) list)
      list))
  (assert-equal
    (list-zip
     (begin
       (= list (builtin/make-list))
       (builtin/list-push! 'a list)
       (builtin/list-push! 'b list)
       (builtin/list-push! 'c list)
       list)
     (begin
       (= list (builtin/make-list))
       (builtin/list-push! 1 list)
       (builtin/list-push! 2 list)
       list))
    (begin
      (= list (builtin/make-list))
      (builtin/list-push! (make-pair 'a 1) list)
      (builtin/list-push! (make-pair 'b 2) list)
      list)))

(claim list-unzip
  (polymorphic (A B)
    (-> (builtin/list-t (builtin/pair-t A B))
        (builtin/pair-t
         (builtin/list-t A)
         (builtin/list-t B)))))

(define (list-unzip pairs)
  (make-pair
   (list-map pair-first pairs)
   (list-map pair-second pairs)))

(define-test list-unzip-test
  (assert-equal
    (list-unzip
     (begin
       (= list (builtin/make-list))
       (builtin/list-push! (make-pair 'a 1) list)
       (builtin/list-push! (make-pair 'b 2) list)
       (builtin/list-push! (make-pair 'c 3) list)
       list))
    (make-pair
     (begin
       (= list (builtin/make-list))
       (builtin/list-push! 'a list)
       (builtin/list-push! 'b list)
       (builtin/list-push! 'c list)
       list)
     (begin
       (= list (builtin/make-list))
       (builtin/list-push! 1 list)
       (builtin/list-push! 2 list)
       (builtin/list-push! 3 list)
       list))))

(define-data (maybe-t A) (just (value A)) nothing)

(claim just (polymorphic (A) (-> A (builtin/maybe-t A))))

(define (just value)
  (= list (builtin/make-list))
  (builtin/list-push! 'just list)
  (builtin/list-push! value list)
  list)

(claim just?
  (polymorphic (A) (-> (builtin/maybe-t A) builtin/bool-t)))

(define (just? value)
  (if (list? value)
    (if (equal? (list-length value) 2)
      (equal? (list-head value) 'just)
      false)
    false))

(claim just-value
  (polymorphic (A) (-> (builtin/maybe-t A) A)))

(define (just-value target) (list-get 1 target))

(claim just-put-value
  (polymorphic (A)
    (-> A (builtin/maybe-t A) (builtin/maybe-t A))))

(define (just-put-value value target)
  (list-put 1 value target))

(claim just-put-value!
  (polymorphic (A)
    (-> A (builtin/maybe-t A) (builtin/maybe-t A))))

(define (just-put-value! value target)
  (list-put! 1 value target))

(claim nothing (polymorphic (A) (builtin/maybe-t A)))

(define nothing 'nothing)

(claim nothing?
  (polymorphic (A) (-> (builtin/maybe-t A) builtin/bool-t)))

(define (nothing? value) (equal? value 'nothing))

(define-interface (pair-t A B) :first A :second B)

(define (make-pair first second)
  (@record :first first :second second))

(define (pair-first pair) (:first pair))

(define (pair-second pair) (:second pair))

(define (pair-put-first first pair)
  (update pair :first first))

(define (pair-put-second second pair)
  (update pair :second second))

(define (pair-put-first! first pair)
  (update! pair :first first))

(define (pair-put-second! second pair)
  (update! pair :second second))

(claim set-each
  (polymorphic (A Any)
    (-> (-> A Any) (builtin/set-t A) builtin/void-t)))

(define (set-each f set)
  (list-each f (set-to-list set))
  void)

(claim set-every?
  (polymorphic (A)
    (-> (-> A builtin/bool-t)
        (builtin/set-t A)
        builtin/bool-t)))

(define (set-every? p set)
  (list-every? p (set-to-list set)))

(define-test set-every-test
  (assert
    (set-every?
     int-non-negative?
     (begin
       (= set (builtin/make-set))
       (builtin/set-add! 0 set)
       (builtin/set-add! 1 set)
       (builtin/set-add! 2 set)
       (builtin/set-add! 3 set)
       set)))
  (assert-not
    (set-every?
     int-non-negative?
     (begin
       (= set (builtin/make-set))
       (builtin/set-add! 0 set)
       (builtin/set-add! 1 set)
       (builtin/set-add! -1 set)
       (builtin/set-add! 2 set)
       (builtin/set-add! 3 set)
       set))))

(claim set-some?
  (polymorphic (A)
    (-> (-> A builtin/bool-t)
        (builtin/set-t A)
        builtin/bool-t)))

(define (set-some? p set) (list-some? p (set-to-list set)))

(define-test set-some-test
  (assert
    (set-some?
     int-non-negative?
     (begin
       (= set (builtin/make-set))
       (builtin/set-add! -1 set)
       (builtin/set-add! -2 set)
       (builtin/set-add! 0 set)
       set)))
  (assert-not
    (set-some?
     int-non-negative?
     (begin
       (= set (builtin/make-set))
       (builtin/set-add! -1 set)
       (builtin/set-add! -2 set)
       (builtin/set-add! -3 set)
       set))))

(claim set-map
  (polymorphic (A B)
    (-> (-> A B) (builtin/set-t A) (builtin/set-t B))))

(define (set-map f set)
  (= new-set (make-set))
  (set-each (lambda (e) (set-add! (f e) new-set)) set)
  new-set)

(define-test set-map-test
  (assert-equal
    (begin
      (= set (builtin/make-set))
      (builtin/set-add! 2 set)
      (builtin/set-add! 4 set)
      (builtin/set-add! 6 set)
      set)
    (set-map
     (lambda (n) (iadd n n))
     (begin
       (= set (builtin/make-set))
       (builtin/set-add! 1 set)
       (builtin/set-add! 2 set)
       (builtin/set-add! 3 set)
       set))))

(claim set-select
  (polymorphic (A)
    (-> (-> A builtin/bool-t)
        (builtin/set-t A)
        (builtin/set-t A))))

(define (set-select p set)
  (= new-set (begin (= set (builtin/make-set)) set))
  (set-each
   (lambda (e)
     (if (p e) (begin (set-add! e new-set) void) void))
   set)
  new-set)

(define-test set-select-test
  (assert-equal
    (begin
      (= set (builtin/make-set))
      (builtin/set-add! 0 set)
      (builtin/set-add! 1 set)
      (builtin/set-add! 2 set)
      set)
    (set-select
     int-non-negative?
     (begin
       (= set (builtin/make-set))
       (builtin/set-add! -2 set)
       (builtin/set-add! -1 set)
       (builtin/set-add! 0 set)
       (builtin/set-add! 1 set)
       (builtin/set-add! 2 set)
       set))))

(claim set-reject
  (polymorphic (A)
    (-> (-> A builtin/bool-t)
        (builtin/set-t A)
        (builtin/set-t A))))

(define (set-reject p set) (set-select (negate p) set))

(define-test set-reject-test
  (assert-equal
    (begin
      (= set (builtin/make-set))
      (builtin/set-add! -1 set)
      (builtin/set-add! -2 set)
      set)
    (set-reject
     int-non-negative?
     (begin
       (= set (builtin/make-set))
       (builtin/set-add! -2 set)
       (builtin/set-add! -1 set)
       (builtin/set-add! 0 set)
       (builtin/set-add! 1 set)
       (builtin/set-add! 2 set)
       set))))

(define-interface source-location-t
  :span
  source-span-t
  :path
  string-t)

(define-interface source-span-t
  :start
  source-position-t
  :end
  source-position-t)

(define-interface source-position-t
  :index
  int-t
  :row
  int-t
  :column
  int-t)

(define-data located-sexp-t
  (symbol-sexp
   (content symbol-t)
   (location source-location-t))
  (keyword-sexp
   (content keyword-t)
   (location source-location-t))
  (string-sexp
   (content string-t)
   (location source-location-t))
  (int-sexp (content int-t) (location source-location-t))
  (float-sexp (content float-t) (location source-location-t))
  (list-sexp
   (elements (list-t located-sexp-t))
   (location source-location-t)))

(claim symbol-sexp
  (-> builtin/symbol-t
      builtin/source-location-t
      builtin/located-sexp-t))

