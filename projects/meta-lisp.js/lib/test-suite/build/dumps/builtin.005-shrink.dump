(claim list-zip
  (polymorphic (A B)
    (-> (builtin/list-t A)
        (builtin/list-t B)
        (builtin/list-t (tau A B)))))

(define (list-zip left right)
  (if
      (if (builtin/list-empty? left)
        builtin/true
        (builtin/list-empty? right))
    (begin (= list (builtin/make-list)) list)
    (builtin/cons
     (begin
       (= list (builtin/make-list))
       (builtin/list-push! (builtin/car left) list)
       (builtin/list-push! (builtin/car right) list)
       list)
     (builtin/list-zip
      (builtin/cdr left)
      (builtin/cdr right)))))

