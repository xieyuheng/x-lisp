(claim float-product (-> (list-t float-t) float-t))

(define (float-product xs)
  (if (list-empty? xs)
    1.0
    (begin
      (= _₁ (car xs))
      (= _₂ (cdr xs))
      (= _₃ (float-product _₂))
      (fmul _₁ _₃))))

(claim float-product-test void-t)

