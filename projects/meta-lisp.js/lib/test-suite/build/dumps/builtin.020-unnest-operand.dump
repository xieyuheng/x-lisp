(claim string-repeat (-> int-t string-t string-t))

(define (string-repeat n string)
  (if (equal? n 0)
    ""
    (begin
      (= _₁ (isub n 1))
      (= _₂ (string-repeat _₁ string))
      (string-append string _₂))))

(claim string-repeat-test void-t)

(define-test string-repeat-test
  (begin (= _₁ (string-repeat 0 "a")) (assert-equal "" _₁))
  (begin (= _₂ (string-repeat 1 "a")) (assert-equal "a" _₂))
  (begin
    (= _₃ (string-repeat 2 "a"))
    (assert-equal "aa" _₃))
  (= _₄ (string-repeat 3 "a"))
  (assert-equal "aaa" _₄))