(claim list-append
  (polymorphic (A) (-> (list-t A) (list-t A) (list-t A))))

(define (list-append list tail)
  (if (list-empty? list)
    tail
    (begin
      (= _₁ (car list))
      (= _₂ (cdr list))
      (= _₃ (list-append _₂ tail))
      (cons _₁ _₃))))

