(claim float-product (-> (list-t float-t) float-t))

(define (float-product xs)
  (if (list-empty? xs)
    1.0
    (begin
      (= _₁ (car xs))
      (= _₂ (cdr xs))
      (= _₃ (float-product _₂))
      (fmul _₁ _₃))))

(claim float-product-test void-t)

(define-test float-product-test
  (begin
    (= list₁ (make-list))
    (= _₁ (float-product list₁))
    (assert-equal 1.0 _₁))
  (begin
    (= list₂ (make-list))
    (list-push! 1.0 list₂)
    (list-push! 2.0 list₂)
    (list-push! 3.0 list₂)
    (= _₂ (float-product list₂))
    (assert-equal 6.0 _₂))
  (= list₃ (make-list))
  (list-push! 1.0 list₃)
  (list-push! 2.0 list₃)
  (list-push! 3.0 list₃)
  (list-push! 4.0 list₃)
  (= _₃ (float-product list₃))
  (assert-equal 24.0 _₃))

(claim float-sum (-> (list-t float-t) float-t))

(define (float-sum xs)
  (if (list-empty? xs)
    0.0
    (begin
      (= _₁ (car xs))
      (= _₂ (cdr xs))
      (= _₃ (float-sum _₂))
      (fadd _₁ _₃))))

(claim float-sum-test void-t)

(define-test float-sum-test
  (begin
    (= list₁ (make-list))
    (= _₁ (float-sum list₁))
    (assert-equal 0.0 _₁))
  (begin
    (= list₂ (make-list))
    (list-push! 1.0 list₂)
    (list-push! 2.0 list₂)
    (list-push! 3.0 list₂)
    (= _₂ (float-sum list₂))
    (assert-equal 6.0 _₂))
  (= list₃ (make-list))
  (list-push! 1.0 list₃)
  (list-push! 2.0 list₃)
  (list-push! 3.0 list₃)
  (list-push! 4.0 list₃)
  (= _₃ (float-sum list₃))
  (assert-equal 10.0 _₃))

(claim int-align (-> int-t int-t int-t))

(define (int-align alignment n)
  (= remainder₁ (imod n alignment))
  (if (equal? 0 remainder₁)
    n
    (begin (= _₁ (isub n remainder₁)) (iadd _₁ alignment))))

(claim int-align-test void-t)

(define-test int-align-test
  (begin (= _₁ (int-align 16 0)) (assert-equal 0 _₁))
  (begin (= _₂ (int-align 16 8)) (assert-equal 16 _₂))
  (begin (= _₃ (int-align 16 16)) (assert-equal 16 _₃))
  (= _₄ (int-align 16 24))
  (assert-equal 32 _₄))

