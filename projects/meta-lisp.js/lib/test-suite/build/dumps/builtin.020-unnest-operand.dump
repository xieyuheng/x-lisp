  (list-push! 2 list₃)
  (list-push! 3 list₃)
  (list-push! 4 list₃)
  (list-push! 5 list₃)
  (list-push! 6 list₃)
  (assert-equal _₁ list₃))

(claim list-concat
  (polymorphic (A) (-> (list-t (list-t A)) (list-t A))))

(define (list-concat lists)
  (if (list-empty? lists)
    (begin (= list₁ (make-list)) list₁)
    (begin
      (= _₁ (car lists))
      (= _₂ (cdr lists))
      (= _₃ (list-concat _₂))
      (list-append _₁ _₃))))

(claim list-concat-test void-t)

(define-test list-concat-test
  (= list₁ (make-list))
  (begin
    (= list₂ (make-list))
    (list-push! 1 list₂)
    (list-push! 2 list₂)
    (list-push! 3 list₂)
    (list-push! list₂ list₁))
  (begin
    (= list₃ (make-list))
    (list-push! 4 list₃)
    (list-push! 5 list₃)
    (list-push! 6 list₃)
    (list-push! list₃ list₁))
  (= _₁ (list-concat list₁))
  (= list₄ (make-list))
  (list-push! 1 list₄)
  (list-push! 2 list₄)
  (list-push! 3 list₄)
  (list-push! 4 list₄)
  (list-push! 5 list₄)
  (list-push! 6 list₄)
  (assert-equal _₁ list₄))

(define-interface source-location-t
  :span
  source-span-t
  :path
  string-t)

(define-interface source-span-t
  :start
  source-position-t
  :end
  source-position-t)

(define-interface source-position-t
  :index
  int-t
  :row
  int-t
  :column
  int-t)

(define-data located-sexp-t
  (symbol-sexp
   (content symbol-t)
   (location source-location-t))
  (keyword-sexp
   (content keyword-t)
   (location source-location-t))
  (string-sexp
   (content string-t)
   (location source-location-t))
  (int-sexp (content int-t) (location source-location-t))
  (float-sexp (content float-t) (location source-location-t))
  (list-sexp
   (elements (list-t located-sexp-t))
   (location source-location-t)))

(claim symbol-sexp
  (-> symbol-t source-location-t located-sexp-t))

(define (symbol-sexp content location)
  (= list₁ (make-list))
  (list-push! 'symbol-sexp list₁)
  (list-push! content list₁)
  (list-push! location list₁)
  list₁)

(claim symbol-sexp? (-> located-sexp-t bool-t))

(define (symbol-sexp? value)
  (if (list? value)
    (if (begin (= _₁ (list-length value)) (equal? _₁ 3))
      (begin
        (= _₂ (list-head value))
        (equal? _₂ 'symbol-sexp))
      false)
    false))

(claim symbol-sexp-content (-> located-sexp-t symbol-t))

(define (symbol-sexp-content target) (list-get 1 target))

(claim symbol-sexp-location
  (-> located-sexp-t source-location-t))

(define (symbol-sexp-location target) (list-get 2 target))

(claim symbol-sexp-put-content
