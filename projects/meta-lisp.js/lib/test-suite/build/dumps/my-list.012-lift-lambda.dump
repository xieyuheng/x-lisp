(claim my-list-test void-t)

(define-test my-list-test
  (assert (my-list/nil? my-list/nil))
  (assert
    (my-list/li?
     (my-list/li 1 (my-list/li 2 (my-list/li 3 my-list/nil)))))
  (assert-not (my-list/li? my-list/nil))
  (assert-not
    (my-list/nil?
     (my-list/li 1 (my-list/li 2 (my-list/li 3 my-list/nil)))))
  (assert-equal
    (my-list/li-tail (my-list/li 1 my-list/nil))
    my-list/nil)
  (assert-equal
    (my-list/li-head (my-list/li 1 my-list/nil))
    1)
  (= list₁
     (my-list/li 1 (my-list/li 2 (my-list/li 3 my-list/nil))))
  (assert-equal (my-list/li-head list₁) 1)
  (my-list/li-put-head! 111 list₁)
  (assert-equal (my-list/li-head list₁) 111)
  (assert-equal
    (my-list/li-tail list₁)
    (my-list/li 2 (my-list/li 3 my-list/nil)))
  (my-list/li-put-tail! my-list/nil list₁)
  (assert-equal (my-list/li-tail list₁) my-list/nil)
  (assert-equal
    (my-list/li 1 my-list/nil)
    ((my-list/li 1) my-list/nil)))

(define-data (my-list-t E)
  nil
  (li (head E) (tail (my-list/my-list-t E))))

(claim nil (polymorphic (E) (my-list/my-list-t E)))

(define nil 'nil)

(claim nil?
  (polymorphic (E) (-> (my-list/my-list-t E) bool-t)))

(define (nil? value) (equal? value 'nil))

(claim li
  (polymorphic (E)
    (-> E (my-list/my-list-t E) (my-list/my-list-t E))))

(define (li head tail)
  (= list₁ (make-list))
  (list-push! 'li list₁)
  (list-push! head list₁)
  (list-push! tail list₁)
  list₁)

(claim li?
  (polymorphic (E) (-> (my-list/my-list-t E) bool-t)))

(define (li? value)
  (if (list? value)
    (if (equal? (list-length value) 3)
      (equal? (list-head value) 'li)
      false)
    false))

(claim li-head
  (polymorphic (E) (-> (my-list/my-list-t E) E)))

(define (li-head target) (list-get 1 target))

(claim li-tail
  (polymorphic (E)
    (-> (my-list/my-list-t E) (my-list/my-list-t E))))

(define (li-tail target) (list-get 2 target))

(claim li-put-head
  (polymorphic (E)
    (-> E (my-list/my-list-t E) (my-list/my-list-t E))))

(define (li-put-head value target)
  (list-put 1 value target))

(claim li-put-tail
  (polymorphic (E)
    (-> (my-list/my-list-t E)
        (my-list/my-list-t E)
        (my-list/my-list-t E))))

(define (li-put-tail value target)
  (list-put 2 value target))

(claim li-put-head!
  (polymorphic (E)
    (-> E (my-list/my-list-t E) (my-list/my-list-t E))))

(define (li-put-head! value target)
  (list-put! 1 value target))

(claim li-put-tail!
  (polymorphic (E)
    (-> (my-list/my-list-t E)
        (my-list/my-list-t E)
        (my-list/my-list-t E))))

(define (li-put-tail! value target)
  (list-put! 2 value target))