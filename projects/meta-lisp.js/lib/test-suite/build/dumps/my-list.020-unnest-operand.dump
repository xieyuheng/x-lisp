  (= _₆₅ (_₆₃ _₆₄))
  (assert-equal _₆₁ _₆₅))

(define-data (my-list-t E)
  nil
  (li (head E) (tail (my-list/my-list-t E))))

(claim nil (polymorphic (E) (my-list/my-list-t E)))

(define nil 'nil)

(claim nil?
  (polymorphic (E) (-> (my-list/my-list-t E) bool-t)))

(define (nil? value) (equal? value 'nil))

(claim li
  (polymorphic (E)
    (-> E (my-list/my-list-t E) (my-list/my-list-t E))))

(define (li head tail)
  (= list₁ (make-list))
  (list-push! 'li list₁)
  (list-push! head list₁)
  (list-push! tail list₁)
  list₁)

(claim li?
  (polymorphic (E) (-> (my-list/my-list-t E) bool-t)))

(define (li? value)
  (if (list? value)
    (if (begin (= _₁ (list-length value)) (equal? _₁ 3))
      (begin (= _₂ (list-head value)) (equal? _₂ 'li))
      false)
    false))

(claim li-head
  (polymorphic (E) (-> (my-list/my-list-t E) E)))

(define (li-head target) (list-get 1 target))

(claim li-tail
  (polymorphic (E)
    (-> (my-list/my-list-t E) (my-list/my-list-t E))))

(define (li-tail target) (list-get 2 target))

(claim li-put-head
  (polymorphic (E)
    (-> E (my-list/my-list-t E) (my-list/my-list-t E))))

(define (li-put-head value target)
  (list-put 1 value target))

(claim li-put-tail
  (polymorphic (E)
    (-> (my-list/my-list-t E)
        (my-list/my-list-t E)
        (my-list/my-list-t E))))

(define (li-put-tail value target)
  (list-put 2 value target))

(claim li-put-head!
  (polymorphic (E)
    (-> E (my-list/my-list-t E) (my-list/my-list-t E))))

(define (li-put-head! value target)
  (list-put! 1 value target))

(claim li-put-tail!
  (polymorphic (E)
    (-> (my-list/my-list-t E)
        (my-list/my-list-t E)
        (my-list/my-list-t E))))

(define (li-put-tail! value target)
  (list-put! 2 value target))