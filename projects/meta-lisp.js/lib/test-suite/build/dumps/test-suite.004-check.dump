(claim file-test void-t)

(define-test
 file-test
 (= file (open-input-file "src/file/file-1.txt"))
 (assert-equal "abc\n" (file-read file))
 (file-close file)
 (= file (open-output-file "src/file/file-2.txt"))
 (file-write file "123\n")
 (file-close file)
 (= file (open-input-file "src/file/file-2.txt"))
 (assert-equal "123\n" (file-read file))
 (file-close file)
 (= file (open-output-file "src/file/file-2.txt"))
 (file-write file "abc\n")
 (file-close file)
 (= file (open-input-file "src/file/file-2.txt"))
 (assert-equal "abc\n" (file-read file))
 (file-close file))

(claim fs-test void-t)

(define-test
 fs-test
 (assert-equal "abc\n" (fs-read "src/fs/file-1.txt"))
 (fs-write "src/fs/file-2.txt" "123\n")
 (assert-equal "123\n" (fs-read "src/fs/file-2.txt"))
 (fs-write "src/fs/file-2.txt" "abc\n")
 (assert-equal "abc\n" (fs-read "src/fs/file-2.txt"))
 (println (fs-list "src/fs")))

(claim S
  (polymorphic (A B C) (-> (-> A B C) (-> A B) (-> A C))))

(define (S x y z) (x z (y z)))

(claim K (polymorphic (A B) (-> A B A)))

(define (K x y) x)

(claim I (polymorphic (A) (-> A A)))

(define (I x) x)

(claim SKI (polymorphic (A) (-> A A)))

(define SKI (test-suite/S test-suite/K test-suite/I))

(claim SKI-tuple
  (polymorphic (A B C D E F)
    (tau (-> (-> A B C) (-> A B) (-> A C))
         (-> D E D)
         (-> F F))))

(define SKI-tuple
  (= S (lambda (x y z) (x z (y z))))
  (= K (lambda (x y) x))
  (= I (lambda (x) x))
  (@tuple S K I))

(claim compose
  (polymorphic (A B C) (-> (-> B C) (-> A B) (-> A C))))

(define (compose f g x) (f (g x)))

(claim compose-test void-t)

(define-test
 compose-test
 (= add1 (iadd 1))
 (assert-equal 3 ((test-suite/compose add1 add1) 1)))

(claim curry-test void-t)

(define-test
 curry-test
 (assert-equal iadd iadd)
 (assert-equal (iadd 1) (iadd 1))
 (assert-not-equal (iadd 1) (iadd 2))
 (assert-equal ((iadd 1) 2) (iadd 1 2))
 (assert-equal 1 ((isub 2) 1))
 (assert-equal 1 (isub 2 1)))

(claim swap
  (polymorphic (X Y Z) (-> (-> Y X Z) (-> X Y Z))))

(define (swap f x y) (f y x))

(claim drop (polymorphic (X Y Z) (-> (-> X Z) (-> Y X Z))))

(define (drop f) (lambda (dropped) (lambda (x) (f x))))

(claim dup (polymorphic (X Z) (-> (-> X X Z) (-> X Z))))

(define (dup f) (lambda (x) (f x x)))

(claim forth-test void-t)

(define-test
 forth-test
 (= f (lambda (x) x))
 (= square (test-suite/dup imul))
 (println (square (f 1)))
 (println (square (f 2)))
 (println (square (f 3)))
 (println (square (f 4))))

