(claim list-test void-t)

(define-test
 list-test
 (= list (make-list))
 (list-push! 1 list)
 (list-push! 2 list)
 (list-push! 3 list)
 (assert-equal
   (begin
     (= list (make-list))
     (list-push! 1 list)
     (list-push! 2 list)
     (list-push! 3 list)
     list)
   list)
 (assert-equal
   (begin
     (= list (make-list))
     (list-push! 1 list)
     (list-push! 2 list)
     (list-push! 3 list)
     list)
   (begin
     (= list (make-list))
     (list-push! 1 list)
     (list-push! 2 list)
     (list-push! 3 list)
     list))
 (assert-equal
   (begin
     (= list (make-list))
     (list-push! 'a list)
     (list-push! 'b list)
     (list-push! 'c list)
     list)
   (begin
     (= list (make-list))
     (list-push! 'a list)
     (list-push! 'b list)
     (list-push! 'c list)
     list))
 (assert-equal
   3
   (list-length
    (begin
      (= list (make-list))
      (list-push! 1 list)
      (list-push! 2 list)
      (list-push! 3 list)
      list)))
 (assert-equal
   0
   (list-length (begin (= list (make-list)) list)))
 (assert (list-empty? (begin (= list (make-list)) list)))
 (= list (make-list))
 (list-push! 1 list)
 (list-push! 2 list)
 (list-push! 3 list)
 (println list)
 (println
  (the (list-t int-t)
    (begin
      (= list (make-list))
      (list-push! 1 list)
      (list-push! 2 list)
      (list-push! 3 list)
      list)))
 (println
  (begin
    (= list (make-list))
    (list-push! 1 list)
    (list-push! 2 list)
    (list-push! 3 list)
    list))
 (println
  (begin
    (= list (make-list))
    (list-push! 1 list)
    (list-push! 2 list)
    (list-push! 3 list)
    list))
 (println
  (begin
    (= list (make-list))
    (list-push! 1 list)
    (list-push! 2 list)
    (list-push! 3 list)
    list))
 (println
  (begin
    (= list (make-list))
    (list-push! 'a list)
    (list-push! 'b list)
    (list-push! 'c list)
    list))
 (println
  (begin
    (= list (make-list))
    (list-push! 'a list)
    (list-push! 'b list)
    (list-push! 'c list)
    list)))

(claim cond-mismatch-test void-t)

(define-test
 cond-mismatch-test
 (if (equal? 1 2)
   void
   (if (equal? 1 2) void (error "cond mismatch"))))

(claim cond-test void-t)

(define-test
 cond-test
 (assert-equal
   1
   (if (equal? 1 1) 1 (if true 2 (error "cond mismatch"))))
 (assert-equal
   2
   (if (equal? 1 2) 1 (if true 2 (error "cond mismatch"))))
 (if (equal? 1 1)
   (assert true)
   (if true (assert false) (error "cond mismatch")))
 (if (equal? 1 2)
   (assert false)
   (if true (assert true) (error "cond mismatch"))))

(claim if-test void-t)

(define-test
 if-test
 (assert-equal (if true 1 2) 1)
 (assert-equal (if false 1 2) 2)
 (assert (if true (if true true false) false))
 (assert (not (if true (if true false false) false)))
 (assert (if false true (if false true true)))
 (assert (not (if false true (if false true false)))))

(claim the-test void-t)

(define-test
 the-test
 (assert-equal 1 (the int-t 1))
 (assert-equal 'a (the symbol-t 'a)))

(claim path-test void-t)

(define-test
 path-test
 (assert-equal
   "a/b/c"
   (path-directory-name "a/b/c/file.test.txt"))
 (assert-equal
   "file.test.txt"
   (path-base-name "a/b/c/file.test.txt"))
 (assert-equal
   ".txt"
   (path-extension "a/b/c/file.test.txt"))
 (assert-equal
   "file.test"
   (path-stem "a/b/c/file.test.txt"))
 (assert (path-absolute? "/a/b/c/file.test.txt"))
 (assert-not (path-relative? "/a/b/c/file.test.txt"))
 (assert (path-relative? "a/b/c/file.test.txt"))
 (assert (path-relative? "./a/b/c/file.test.txt"))
 (assert-not (path-absolute? "a/b/c/file.test.txt"))
 (assert-not (path-absolute? "./a/b/c/file.test.txt"))
 (assert-equal "a/b/c/d/e/f" (path-join "a/b/c" "d/e/f"))
 (assert-equal "a/b/c/d/e/f" (path-join "a/b/c/" "/d/e/f"))
 (assert-equal
   "/a/b/c/d/e/f"
   (path-join "/a/b/c/" "/d/e/f"))
 (assert-equal "a/b/d" (path-normalize "a/b/c/../d"))
 (assert-equal "/a/b/c" (path-normalize "///a/b/c/")))

(claim reocrd-test void-t)

(define-test
 reocrd-test
 (println
  (the (interface :x int-t :y int-t) (@record :x 1 :y 2)))
 (println
  (the (interface :x int-t :y int-t) (@record :x 1 :y 2))))

(define-interface point-t :x float-t :y float-t)

(claim with-color
  (polymorphic (A B C)
    (-> A (extend-interface B) (extend-interface B :color C))))

(define (with-color color point)
  (extend point :color color))

(claim record-extend-test void-t)

(define-test
 record-extend-test
 (= point (@record :x 1.0 :y 2.0))
 (assert-equal
   (@record :x 1.0 :y 2.0 :color "red")
   (test-suite/with-color "red" point)))

(claim point-put-x
  (polymorphic (A B C)
    (-> A
        (extend-interface B :x C)
        (extend-interface B :x C))))

(define (point-put-x x point) (update point :x x))

(claim point-put-y!
  (polymorphic (A B C)
    (-> A
        (extend-interface B :y C)
        (extend-interface B :y C))))

(define (point-put-y! y point) (update! point :y y))

(claim record-update-test void-t)

(define-test
 record-update-test
 (= point (@record :x 1.0 :y 2.0))
 (assert-equal
   (@record :x 2.0 :y 2.0)
   (test-suite/point-put-x 2.0 point))
 (assert-equal (@record :x 1.0 :y 2.0) point)
 (assert-equal
   (@record :x 1.0 :y 1.0)
   (test-suite/point-put-y! 1.0 point))
 (assert-equal (@record :x 1.0 :y 1.0) point))

(claim set-test void-t)

(define-test
 set-test
 (assert-equal
   (begin
     (= set (make-set))
     (set-add! 1 set)
     (set-add! 2 set)
     (set-add! 3 set)
     set)
   (begin
     (= set (make-set))
     (set-add! 3 set)
     (set-add! 2 set)
     (set-add! 1 set)
     set))
 (println
  (the (set-t int-t)
    (begin
      (= set (make-set))
      (set-add! 1 set)
      (set-add! 2 set)
      (set-add! 3 set)
      set))))

(claim my-string-repeat (-> int-t string-t string-t))

(define (my-string-repeat n string)
  (if (equal? n 0)
    ""
    (string-append
     string
     (test-suite/my-string-repeat (isub n 1) string))))

(claim my-string-repeat-test void-t)

(define-test
 my-string-repeat-test
 (assert-equal "" (test-suite/my-string-repeat 0 "a"))
 (assert-equal "a" (test-suite/my-string-repeat 1 "a"))
 (assert-equal "aa" (test-suite/my-string-repeat 2 "a"))
 (assert-equal "aaa" (test-suite/my-string-repeat 3 "a")))

