(define-interface point-t
  :x
  builtin/float-t
  :y
  builtin/float-t)

(claim point-println
  (-> subtype-error-2/point-t builtin/void-t))

(define (point-println point)
  (= _₁ builtin/println)
  (_₁ point))

(define (main)
  (begin
    (= _₁ subtype-error-2/point-println)
    (= record₁ (begin (= _₂ builtin/make-record) (_₂)))
    (begin (= _₃ builtin/record-put!) (_₃ :x 1.0 record₁))
    (begin (= _₄ builtin/record-put!) (_₄ :y 2.0 record₁))
    (_₁ record₁))
  (= _₅ subtype-error-2/point-println)
  (= record₂ (begin (= _₆ builtin/make-record) (_₆)))
  (begin (= _₇ builtin/record-put!) (_₇ :x 1.0 record₂))
  (_₅ record₂))