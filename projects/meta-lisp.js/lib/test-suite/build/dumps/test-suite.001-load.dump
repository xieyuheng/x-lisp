  (= x 1)
  (println
   (iadd
    x
    (begin (= x (begin (= x 5) (iadd x x))) (iadd x 100)))))

(define-test eoc-02-20
  (= x 1)
  (println
   (iadd
    x
    (begin (= x (begin (= y 5) (iadd y x))) (iadd x 100)))))

(define-test eoc-02-21
  (= y 6)
