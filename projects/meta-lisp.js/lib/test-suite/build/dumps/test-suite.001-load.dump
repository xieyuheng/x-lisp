(define-test eoc-04-02
  (println
   (begin
     (= x (random-dice))
     (= y (random-dice))
     (if (if (int-less? x 1) (equal? x 0) (equal? x 2))
       (iadd y 2)
       (iadd y 10)))))

(define-test eoc-04-03
  (println
   (begin
     (= x (random-dice))
     (= y (random-dice))
     (iadd
      (if (if (int-less? x 1) (equal? x 0) (equal? x 2))
        (iadd y 2)
        (iadd y 10))
      (if (if (int-less? x 1) (equal? x 0) (equal? x 2))
        (iadd y 2)
        (iadd y 10))))))

(define-test eoc-04-04
  (println
   (if
       (and (equal? (random-dice) 1)
            (equal? (random-dice) 2))
     0
     42)))

(define-test eoc-05-01
  (print 1)
  (newline)
  (print 2)
  (newline)
  (print 3)
  (newline)
  void)

(define-test eoc-05-02
  (= x
     (begin
       (print 1)
       (newline)
       (print 2)
       (newline)
       (print 3)
       (newline)
       6))
  (begin
    (print 4)
    (newline)
    (print 5)
    (newline)
    (print 6)
    (newline)
    (print (iadd x x))
    (newline)
    void))

(define-test eoc-05-03
  (if
      (begin
        (print 1)
        (newline)
        (print 2)
        (newline)
        (print 3)
        (newline)
        (equal? 1 2))
    (begin (print 111) (newline))
    (begin (print 222) (newline))))

(define-test file-test
  (= file (open-input-file "src/file/file-1.txt"))
  (assert-equal "abc\n" (file-read file))
  (file-close file)
  (= file (open-output-file "src/file/file-2.txt"))
  (file-write file "123\n")
  (file-close file)
  (= file (open-input-file "src/file/file-2.txt"))
  (assert-equal "123\n" (file-read file))
  (file-close file)
  (= file (open-output-file "src/file/file-2.txt"))
  (file-write file "abc\n")
  (file-close file)
  (= file (open-input-file "src/file/file-2.txt"))
  (assert-equal "abc\n" (file-read file))
  (file-close file))

(define-test fs-test
  (assert-equal "abc\n" (fs-read "src/fs/file-1.txt"))
  (fs-write "src/fs/file-2.txt" "123\n")
  (assert-equal "123\n" (fs-read "src/fs/file-2.txt"))
  (fs-write "src/fs/file-2.txt" "abc\n")
  (assert-equal "abc\n" (fs-read "src/fs/file-2.txt"))
  (println (fs-list "src/fs")))

(define (S x y z) (x z (y z)))

(define (K x y) x)

(define (I x) x)

(define SKI (S K I))

(define SKI-tuple
  (= S (lambda (x y z) (x z (y z))))
  (= K (lambda (x y) x))
  (= I (lambda (x) x))
  (@tuple S K I))

(claim compose
  (polymorphic (A B C) (-> (-> B C) (-> A B) (-> A C))))

(define (compose f g x) (f (g x)))

(define-test compose-test
  (= add1 (iadd 1))
  (assert-equal 3 ((compose add1 add1) 1)))

(define-test curry-test
  (assert-equal iadd iadd)
  (assert-equal (iadd 1) (iadd 1))
  (assert-not-equal (iadd 1) (iadd 2))
  (assert-equal ((iadd 1) 2) (iadd 1 2))
  (assert-equal 1 ((isub 2) 1))
  (assert-equal 1 (isub 2 1)))

(claim swap
  (polymorphic (X Y Z) (-> (-> Y X Z) (-> X Y Z))))

(define (swap f x y) (f y x))

(claim drop (polymorphic (X Y Z) (-> (-> X Z) (-> Y X Z))))

(define (drop f) (lambda (dropped) (lambda (x) (f x))))

(claim dup (polymorphic (X Z) (-> (-> X X Z) (-> X Z))))

(define (dup f) (lambda (x) (f x x)))

(define-test forth-test
  (= f (lambda (x) x))
  (= square (dup imul))
  (println (square (f 1)))
  (println (square (f 2)))
  (println (square (f 3)))
  (println (square (f 4))))

(define-test function-test
  (println iadd)
  (println (iadd 1)))

(claim identity (polymorphic (A) (-> A A)))

(define (identity x) x)

(define-test identity-test
  (= add1 (iadd 1))
  (assert-equal 2 (add1 1))
  (= add1 (identity (iadd (identity 1))))
  (the (-> int-t int-t) identity)
  (the (-> float-t float-t) identity)
  (the (polymorphic (A) (-> A A)) identity)
  (assert-equal 2 (add1 1)))

(define-test hash-test
  (assert (hash-empty? (@hash)))
  (println (@hash))
  (println (@hash 1 2))
  (println (@hash 1 3))
  (println (@hash 1 2 3 4)))

(claim factorial (-> int-t int-t))

(define (factorial n)
  (if (int-less-or-equal? n 1)
    1
    (imul (factorial (isub n 1)) n)))

(define-test factorial-test
  (assert-equal 1 (factorial 0))
  (assert-equal 1 (factorial 1))
  (assert-equal 2 (factorial 2))
  (assert-equal 6 (factorial 3))
  (assert-equal 24 (factorial 4))
  (assert-equal 120 (factorial 5))
  (assert-equal 720 (factorial 6)))

(claim fibonacci (-> int-t int-t))

(define (fibonacci n)
  (if (int-less-or-equal? n 1)
    n
    (iadd (fibonacci (isub n 1)) (fibonacci (isub n 2)))))

(define-test fibonacci-test
  (assert-equal 0 (fibonacci 0))
  (assert-equal 1 (fibonacci 1))
  (assert-equal 1 (fibonacci 2))
  (assert-equal 2 (fibonacci 3))
  (assert-equal 3 (fibonacci 4))
  (assert-equal 5 (fibonacci 5))
  (assert-equal 8 (fibonacci 6))
  (assert-equal 13 (fibonacci 7))
  (assert-equal 21 (fibonacci 8))
  (assert-equal 34 (fibonacci 9)))

(claim gcd (-> int-t int-t int-t))

(define (gcd a b) (if (equal? b 0) a (gcd b (imod a b))))

(define-test gcd-test
  (assert-equal 1 (gcd 13 7))
  (assert-equal 4 (gcd 12 8)))

(claim square (-> int-t int-t))

(define (square x) (imul x x))

(define-test square-test
  (assert-equal 81 (square (square 3))))

(define-test keyword-test
  (assert-equal :abcdef (keyword-append :abc :def))
  (println :abc))

(define-test list-test
  (= list (make-list))
  (list-push! 1 list)
  (list-push! 2 list)
  (list-push! 3 list)
  (assert-equal [1 2 3] list)
  (assert-equal [1 2 3] '(1 2 3))
  (assert-equal ['a 'b 'c] '(a b c))
  (assert-equal 3 (list-length [1 2 3]))
  (assert-equal 0 (list-length []))
  (assert (list-empty? []))
  (= list (make-list))
  (list-push! 1 list)
  (list-push! 2 list)
  (list-push! 3 list)
  (println list)
  (println (the (list-t int-t) [1 2 3]))
  (println [1 2 3])
  (println '(1 2 3))
  (println [1 2 3])
  (println ['a 'b 'c])
  (println '(a b c)))

(define-test cond-test
  (assert-equal 1 (cond ((equal? 1 1) 1) (true 2)))
  (assert-equal 2 (cond ((equal? 1 2) 1) (true 2)))
  (cond ((equal? 1 1) (assert true)) (true (assert false)))
  (cond ((equal? 1 2) (assert false)) (true (assert true))))

(define-test if-test
  (assert-equal (if true 1 2) 1)
  (assert-equal (if false 1 2) 2)
  (assert (and true true true))
  (assert (not (and true true false)))
  (assert (or false false true))
  (assert (not (or false false false))))

(define-test the-test
  (assert-equal 1 (the int-t 1))
  (assert-equal 'a (the symbol-t 'a)))

(define-test path-test
  (assert-equal
    "a/b/c"
    (path-directory-name "a/b/c/file.test.txt"))
  (assert-equal
    "file.test.txt"
    (path-base-name "a/b/c/file.test.txt"))
  (assert-equal
    ".txt"
    (path-extension "a/b/c/file.test.txt"))
  (assert-equal
    "file.test"
    (path-stem "a/b/c/file.test.txt"))
  (assert (path-absolute? "/a/b/c/file.test.txt"))
  (assert-not (path-relative? "/a/b/c/file.test.txt"))
  (assert (path-relative? "a/b/c/file.test.txt"))
  (assert (path-relative? "./a/b/c/file.test.txt"))
  (assert-not (path-absolute? "a/b/c/file.test.txt"))
  (assert-not (path-absolute? "./a/b/c/file.test.txt"))
  (assert-equal "a/b/c/d/e/f" (path-join "a/b/c" "d/e/f"))
  (assert-equal "a/b/c/d/e/f" (path-join "a/b/c/" "/d/e/f"))
  (assert-equal
    "/a/b/c/d/e/f"
    (path-join "/a/b/c/" "/d/e/f"))
  (assert-equal "a/b/d" (path-normalize "a/b/c/../d"))
  (assert-equal "/a/b/c" (path-normalize "///a/b/c/")))

(define-test reocrd-test
  (println
   (the (interface :x int-t :y int-t) (@record :x 1 :y 2)))
  (println
   (the (interface :x int-t :y int-t) (@record :x 1 :y 2))))

(define-interface point-t :x float-t :y float-t)

(define (with-color color point)
  (extend point :color color))

(define-test record-extend-test
  (= point (@record :x 1.0 :y 2.0))
  (assert-equal
    (@record :x 1.0 :y 2.0 :color "red")
    (with-color "red" point)))

(define (point-put-x x point) (update point :x x))

(define (point-put-y! y point) (update! point :y y))

(define-test record-put-test
  (= point (@record :x 1.0 :y 2.0))
  (assert-equal
    (@record :x 2.0 :y 2.0)
    (point-put-x 2.0 point))
  (assert-equal (@record :x 1.0 :y 2.0) point)
  (assert-equal
    (@record :x 1.0 :y 1.0)
    (point-put-y! 1.0 point))
  (assert-equal (@record :x 1.0 :y 1.0) point))

(define-test set-test
  (assert-equal {1 2 3} {3 2 1})
  (println (the (set-t int-t) {1 2 3})))

(claim my-string-repeat (-> int-t string-t string-t))

(define (my-string-repeat n string)
  (if (equal? n 0)
    ""
    (string-append
     string
     (my-string-repeat (isub n 1) string))))

(define-test my-string-repeat-test
  (assert-equal "" (my-string-repeat 0 "a"))
  (assert-equal "a" (my-string-repeat 1 "a"))
  (assert-equal "aa" (my-string-repeat 2 "a"))
  (assert-equal "aaa" (my-string-repeat 3 "a")))

(define-test string-test
  (assert-equal "abcdef" (string-append "abc" "def"))
  (println "abc"))

(define-test symbol-test
  (assert-equal 'abcdef (symbol-append 'abc 'def))
  (println 'abc))

(define-test tuple-test
  (println (the (tau int-t int-t) (@tuple 1 2)))
  (println (the (tau int-t symbol-t) (@tuple 1 'a))))

(define-test void-test (println void))