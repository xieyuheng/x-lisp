  (println (iadd x 2)))

(define-test eoc-02-16 (println (isub 50 8)))

(define-test eoc-02-17
  (println (iadd 1 (iadd (random-dice) 1))))

(define-test eoc-02-18
  (println (iadd (iadd (iadd (iadd (random-dice) 1) 1) 1) 1)))

