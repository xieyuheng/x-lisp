(define-test eoc-02-03
  (= y (begin (= x 20) (begin (= z 22) (iadd x z))))
  (println y))

(define-test eoc-02-04
  (= z (begin (= y (begin (= x (ineg 42)) x)) y))
  (println (ineg z)))

(define-test eoc-02-05 (= a 42) (= b a) (println b))

