(define-interface row-polymorphism/point-t
  :x
  float-t
  :y
  float-t)

(claim row-polymorphism/point-x
  (polymorphic (A B) (-> (extend-interface A :x B) B)))

(define (row-polymorphism/point-x point)
  ((record-get :x) point))

(claim row-polymorphism/point-y
  (polymorphic (R A) (-> (extend-interface R :y A) A)))

(define (row-polymorphism/point-y point)
  ((record-get :y) point))

(claim row-polymorphism/point-distance-squared
  (polymorphic (A)
    (-> (extend-interface A :y float-t :x float-t) float-t)))

(define (row-polymorphism/point-distance-squared point)
  (fadd
   (fmul ((record-get :x) point) ((record-get :x) point))
   (fmul ((record-get :y) point) ((record-get :y) point))))

(claim row-polymorphism/row-polymorphism-test void-t)

(define-test row-polymorphism/row-polymorphism-test
  (= point
     (begin
       (= record (make-record))
       (record-put! :x 1.0 record)
       (record-put! :y 2.0 record)
       record))
  (assert-equal 1.0 ((record-get :x) point))
  (assert-equal 2.0 ((record-get :y) point))
  (assert-equal 1.0 (row-polymorphism/point-x point))
  (assert-equal 2.0 (row-polymorphism/point-y point))
  (assert-equal
    5.0
    (row-polymorphism/point-distance-squared point)))