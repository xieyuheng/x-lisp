(define-interface point-t
  :x
  builtin/float-t
  :y
  builtin/float-t)

(claim point-println
  (-> subtype-error-2/point-t builtin/void-t))

(define (point-println point) (builtin/println point))

(define (main)
  (subtype-error-2/point-println
   (begin
     (= record (builtin/make-record))
     (builtin/record-put! :x 1.0 record)
     (builtin/record-put! :y 2.0 record)
     record))
  (subtype-error-2/point-println
   (begin
     (= record (builtin/make-record))
     (builtin/record-put! :x 1.0 record)
     record)))