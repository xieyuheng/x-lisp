(claim l1/evaluate-and-print (-> l1/exp-t void-t))

(define (l1/evaluate-and-print exp)
  (println (l1/evaluate exp l1/empty-env)))

(claim l1/l1-test void-t)

(define-test l1/l1-test
  (l1/evaluate-and-print (l1/lambda-exp 'x (l1/var-exp 'x)))
  (l1/evaluate-and-print
   (l1/apply-exp
    (l1/lambda-exp 'x (l1/var-exp 'x))
    (l1/lambda-exp 'x (l1/var-exp 'x))))
  (l1/evaluate-and-print
   (l1/apply-exp
    (l1/apply-exp
     (l1/lambda-exp 'x (l1/var-exp 'x))
     (l1/lambda-exp 'x (l1/var-exp 'x)))
    (l1/apply-exp
     (l1/lambda-exp 'x (l1/var-exp 'x))
     (l1/lambda-exp 'x (l1/var-exp 'x))))))

(define-data l1/exp-t
  (var-exp (name symbol-t))
  (apply-exp (target l1/exp-t) (arg l1/exp-t))
  (lambda-exp (parameter symbol-t) (body l1/exp-t)))

(claim l1/var-exp (-> symbol-t l1/exp-t))

(define (l1/var-exp name)
  (= list (make-list))
  (list-push! 'var-exp list)
  (list-push! name list)
  list)

(claim l1/var-exp? (-> l1/exp-t bool-t))

(define (l1/var-exp? value)
  (if (list? value)
    (if (equal? (list-length value) 2)
      (equal? (list-head value) 'var-exp)
      false)
    false))

(claim l1/var-exp-name (-> l1/exp-t symbol-t))

(define (l1/var-exp-name target) (list-get 1 target))

(claim l1/var-exp-put-name (-> symbol-t l1/exp-t l1/exp-t))

(define (l1/var-exp-put-name value target)
  (list-put 1 value target))

(claim l1/var-exp-put-name! (-> symbol-t l1/exp-t l1/exp-t))

(define (l1/var-exp-put-name! value target)
  (list-put! 1 value target))

(claim l1/apply-exp (-> l1/exp-t l1/exp-t l1/exp-t))

(define (l1/apply-exp target arg)
  (= list (make-list))
  (list-push! 'apply-exp list)
  (list-push! target list)
  (list-push! arg list)
  list)

(claim l1/apply-exp? (-> l1/exp-t bool-t))

(define (l1/apply-exp? value)
  (if (list? value)
    (if (equal? (list-length value) 3)
      (equal? (list-head value) 'apply-exp)
      false)
    false))

(claim l1/apply-exp-target (-> l1/exp-t l1/exp-t))

(define (l1/apply-exp-target target) (list-get 1 target))

(claim l1/apply-exp-arg (-> l1/exp-t l1/exp-t))

(define (l1/apply-exp-arg target) (list-get 2 target))

(claim l1/apply-exp-put-target
  (-> l1/exp-t l1/exp-t l1/exp-t))

(define (l1/apply-exp-put-target value target)
  (list-put 1 value target))

(claim l1/apply-exp-put-arg (-> l1/exp-t l1/exp-t l1/exp-t))

(define (l1/apply-exp-put-arg value target)
  (list-put 2 value target))

(claim l1/apply-exp-put-target!
  (-> l1/exp-t l1/exp-t l1/exp-t))

(define (l1/apply-exp-put-target! value target)
  (list-put! 1 value target))

(claim l1/apply-exp-put-arg!
  (-> l1/exp-t l1/exp-t l1/exp-t))

(define (l1/apply-exp-put-arg! value target)
  (list-put! 2 value target))

(claim l1/lambda-exp (-> symbol-t l1/exp-t l1/exp-t))

(define (l1/lambda-exp parameter body)
  (= list (make-list))
  (list-push! 'lambda-exp list)
  (list-push! parameter list)
  (list-push! body list)
  list)

(claim l1/lambda-exp? (-> l1/exp-t bool-t))

(define (l1/lambda-exp? value)
  (if (list? value)
    (if (equal? (list-length value) 3)
      (equal? (list-head value) 'lambda-exp)
      false)
    false))

(claim l1/lambda-exp-parameter (-> l1/exp-t symbol-t))

(define (l1/lambda-exp-parameter target)
  (list-get 1 target))

(claim l1/lambda-exp-body (-> l1/exp-t l1/exp-t))

(define (l1/lambda-exp-body target) (list-get 2 target))

(claim l1/lambda-exp-put-parameter
  (-> symbol-t l1/exp-t l1/exp-t))

(define (l1/lambda-exp-put-parameter value target)
  (list-put 1 value target))

(claim l1/lambda-exp-put-body
  (-> l1/exp-t l1/exp-t l1/exp-t))

(define (l1/lambda-exp-put-body value target)
  (list-put 2 value target))

(claim l1/lambda-exp-put-parameter!
  (-> symbol-t l1/exp-t l1/exp-t))

(define (l1/lambda-exp-put-parameter! value target)
  (list-put! 1 value target))

(claim l1/lambda-exp-put-body!
  (-> l1/exp-t l1/exp-t l1/exp-t))

(define (l1/lambda-exp-put-body! value target)
  (list-put! 2 value target))

(define-data l1/env-t
  empty-env
  (extend-env
   (key symbol-t)
   (value l1/value-t)
   (rest l1/env-t)))

(claim l1/empty-env l1/env-t)

(define l1/empty-env 'empty-env)

(claim l1/empty-env? (-> l1/env-t bool-t))

(define (l1/empty-env? value) (equal? value 'empty-env))

(claim l1/extend-env
  (-> symbol-t l1/value-t l1/env-t l1/env-t))

(define (l1/extend-env key value rest)
  (= list (make-list))
  (list-push! 'extend-env list)
  (list-push! key list)
  (list-push! value list)
  (list-push! rest list)
  list)

(claim l1/extend-env? (-> l1/env-t bool-t))

(define (l1/extend-env? value)
  (if (list? value)
    (if (equal? (list-length value) 4)
      (equal? (list-head value) 'extend-env)
      false)
    false))

(claim l1/extend-env-key (-> l1/env-t symbol-t))

(define (l1/extend-env-key target) (list-get 1 target))

(claim l1/extend-env-value (-> l1/env-t l1/value-t))

(define (l1/extend-env-value target) (list-get 2 target))

(claim l1/extend-env-rest (-> l1/env-t l1/env-t))

(define (l1/extend-env-rest target) (list-get 3 target))

(claim l1/extend-env-put-key
  (-> symbol-t l1/env-t l1/env-t))

(define (l1/extend-env-put-key value target)
  (list-put 1 value target))

(claim l1/extend-env-put-value
  (-> l1/value-t l1/env-t l1/env-t))

(define (l1/extend-env-put-value value target)
  (list-put 2 value target))

(claim l1/extend-env-put-rest
  (-> l1/env-t l1/env-t l1/env-t))

(define (l1/extend-env-put-rest value target)
  (list-put 3 value target))

(claim l1/extend-env-put-key!
  (-> symbol-t l1/env-t l1/env-t))

(define (l1/extend-env-put-key! value target)
  (list-put! 1 value target))

(claim l1/extend-env-put-value!
  (-> l1/value-t l1/env-t l1/env-t))

(define (l1/extend-env-put-value! value target)
  (list-put! 2 value target))

(claim l1/extend-env-put-rest!
  (-> l1/env-t l1/env-t l1/env-t))

(define (l1/extend-env-put-rest! value target)
  (list-put! 3 value target))

(claim l1/env-has? (-> symbol-t l1/env-t bool-t))

(define (l1/env-has? name env)
  (if (l1/empty-env? env)
    false
    (if (l1/extend-env? env)
      (begin
        (= rest₁ (l1/extend-env-rest env))
        (= value₁ (l1/extend-env-value env))
        (= key₁ (l1/extend-env-key env))
        (= rest rest₁)
        (= value value₁)
        (= key key₁)
        (if (equal? key name) true (l1/env-has? name rest)))
      (error "cond mismatch"))))

(claim l1/env-lookup-of-fail
  (-> symbol-t l1/env-t l1/value-t))

(define (l1/env-lookup-of-fail name env)
  (if (l1/empty-env? env)
    (error "undefined name")
    (if (l1/extend-env? env)
      (begin
        (= rest₂ (l1/extend-env-rest env))
        (= value₂ (l1/extend-env-value env))
        (= key₂ (l1/extend-env-key env))
        (= rest rest₂)
        (= value value₂)
        (= key key₂)
        (if (equal? key name)
          value
          (l1/env-lookup-of-fail name rest)))
      (error "cond mismatch"))))

(define-data l1/value-t
  (closure-value
   (env l1/env-t)
   (parameter symbol-t)
   (body l1/exp-t)))

(claim l1/closure-value
  (-> l1/env-t symbol-t l1/exp-t l1/value-t))

(define (l1/closure-value env parameter body)
  (= list (make-list))
  (list-push! 'closure-value list)
  (list-push! env list)
  (list-push! parameter list)
  (list-push! body list)
  list)

(claim l1/closure-value? (-> l1/value-t bool-t))

(define (l1/closure-value? value)
  (if (list? value)
    (if (equal? (list-length value) 4)
      (equal? (list-head value) 'closure-value)
      false)
    false))

(claim l1/closure-value-env (-> l1/value-t l1/env-t))

(define (l1/closure-value-env target) (list-get 1 target))

(claim l1/closure-value-parameter (-> l1/value-t symbol-t))

(define (l1/closure-value-parameter target)
  (list-get 2 target))

(claim l1/closure-value-body (-> l1/value-t l1/exp-t))

(define (l1/closure-value-body target) (list-get 3 target))

(claim l1/closure-value-put-env
  (-> l1/env-t l1/value-t l1/value-t))

(define (l1/closure-value-put-env value target)
  (list-put 1 value target))

(claim l1/closure-value-put-parameter
  (-> symbol-t l1/value-t l1/value-t))

(define (l1/closure-value-put-parameter value target)
  (list-put 2 value target))

(claim l1/closure-value-put-body
  (-> l1/exp-t l1/value-t l1/value-t))

(define (l1/closure-value-put-body value target)
  (list-put 3 value target))

(claim l1/closure-value-put-env!
  (-> l1/env-t l1/value-t l1/value-t))

(define (l1/closure-value-put-env! value target)
  (list-put! 1 value target))

(claim l1/closure-value-put-parameter!
  (-> symbol-t l1/value-t l1/value-t))

(define (l1/closure-value-put-parameter! value target)
  (list-put! 2 value target))

(claim l1/closure-value-put-body!
  (-> l1/exp-t l1/value-t l1/value-t))

(define (l1/closure-value-put-body! value target)
  (list-put! 3 value target))

(claim l1/evaluate (-> l1/exp-t l1/env-t l1/value-t))

(define (l1/evaluate exp env)
  (if (l1/var-exp? exp)
    (begin
      (= name₁ (l1/var-exp-name exp))
      (= name name₁)
      (l1/env-lookup-of-fail name env))
    (if (l1/apply-exp? exp)
      (begin
        (= arg₁ (l1/apply-exp-arg exp))
        (= target₁ (l1/apply-exp-target exp))
        (= arg arg₁)
        (= target target₁)
        (l1/apply
         (l1/evaluate target env)
         (l1/evaluate arg env)))
      (if (l1/lambda-exp? exp)
        (begin
          (= body₁ (l1/lambda-exp-body exp))
          (= parameter₁ (l1/lambda-exp-parameter exp))
          (= body body₁)
          (= parameter parameter₁)
          (l1/closure-value env parameter body))
        (error "cond mismatch")))))

(claim l1/apply (-> l1/value-t l1/value-t l1/value-t))

(define (l1/apply target arg)
  (if (l1/closure-value? target)
    (begin
      (= body₂ (l1/closure-value-body target))
      (= parameter₂ (l1/closure-value-parameter target))
      (= env₁ (l1/closure-value-env target))
      (= body body₂)
      (= parameter parameter₂)
      (= env env₁)
      (l1/evaluate body (l1/extend-env parameter arg env)))
    (error "cond mismatch")))