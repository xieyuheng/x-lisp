(claim my-string-repeat
  (-> builtin/int-t builtin/string-t builtin/string-t))

(define (my-string-repeat n string)
  (if (begin (= _₁ builtin/equal?) (_₁ n 0))
    ""
    (begin
      (= _₂ builtin/string-append)
      (= _₃ test-suite/my-string-repeat)
      (= _₄ builtin/isub)
      (= _₅ (_₄ n 1))
      (= _₆ (_₃ _₅ string))
      (_₂ string _₆))))

(claim my-string-repeat-test void-t)

(define-test my-string-repeat-test
  (begin
    (= _₁ builtin/assert-equal)
    (= _₂ test-suite/my-string-repeat)
    (= _₃ (_₂ 0 "a"))
    (_₁ "" _₃))
  (begin
    (= _₄ builtin/assert-equal)
    (= _₅ test-suite/my-string-repeat)
    (= _₆ (_₅ 1 "a"))
    (_₄ "a" _₆))
  (begin
    (= _₇ builtin/assert-equal)
    (= _₈ test-suite/my-string-repeat)
    (= _₉ (_₈ 2 "a"))
    (_₇ "aa" _₉))
  (= _₁₀ builtin/assert-equal)
  (= _₁₁ test-suite/my-string-repeat)
  (= _₁₂ (_₁₁ 3 "a"))
  (_₁₀ "aaa" _₁₂))

