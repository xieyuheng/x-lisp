(claim test-suite/my-string-repeat
  (-> int-t string-t string-t))

(define (test-suite/my-string-repeat n string)
  (if (equal? n 0)
    ""
    (begin
      (= _₁ test-suite/my-string-repeat)
      (= _₂ (isub n 1))
      (= _₃ (_₁ _₂ string))
      (string-append string _₃))))

(claim test-suite/my-string-repeat-test void-t)

(define-test test-suite/my-string-repeat-test
  (begin
    (= _₁ test-suite/my-string-repeat)
    (= _₂ (_₁ 0 "a"))
    (assert-equal "" _₂))
  (begin
    (= _₃ test-suite/my-string-repeat)
    (= _₄ (_₃ 1 "a"))
    (assert-equal "a" _₄))
  (begin
    (= _₅ test-suite/my-string-repeat)
    (= _₆ (_₅ 2 "a"))
    (assert-equal "aa" _₆))
  (= _₇ test-suite/my-string-repeat)
  (= _₈ (_₇ 3 "a"))
  (assert-equal "aaa" _₈))

