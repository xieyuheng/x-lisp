(define (test-suite/K x y) x)

(claim test-suite/I (polymorphic (A) (-> A A)))

(define (test-suite/I x) x)

(claim test-suite/SKI (polymorphic (A) (-> A A)))

(define test-suite/SKI
  (= _₁ test-suite/S)
  (= _₂ test-suite/K)
  (= _₃ test-suite/I)
  (_₁ _₂ _₃))

(claim test-suite/SKI-tuple
  (polymorphic (A B C D E F)
    (tau (-> (-> A B C) (-> A B) (-> A C))
         (-> D E D)
         (-> F F))))

(define test-suite/SKI-tuple
  (= S₁ test-suite/SKI-tuple©λ₁)
  (= K₁ test-suite/SKI-tuple©λ₂)
  (= I₁ test-suite/SKI-tuple©λ₃)
  (= list₁ (make-list))
  (list-push! S₁ list₁)
  (list-push! K₁ list₁)
  (list-push! I₁ list₁)
  list₁)

(define (test-suite/SKI-tuple©λ₁ x₁ y₁ z₁)
  (= _₁ (y₁ z₁))
  (x₁ z₁ _₁))

(define (test-suite/SKI-tuple©λ₂ x₁ y₁) x₁)

(define (test-suite/SKI-tuple©λ₃ x₁) x₁)

