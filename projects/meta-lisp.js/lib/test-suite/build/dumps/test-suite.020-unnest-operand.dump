  (begin
    (= _₅ test-suite/fibonacci)
    (= _₆ (_₅ 2))
    (assert-equal 1 _₆))
  (begin
    (= _₇ test-suite/fibonacci)
    (= _₈ (_₇ 3))
    (assert-equal 2 _₈))
  (begin
    (= _₉ test-suite/fibonacci)
    (= _₁₀ (_₉ 4))
    (assert-equal 3 _₁₀))
  (begin
    (= _₁₁ test-suite/fibonacci)
    (= _₁₂ (_₁₁ 5))
    (assert-equal 5 _₁₂))
  (begin
    (= _₁₃ test-suite/fibonacci)
    (= _₁₄ (_₁₃ 6))
    (assert-equal 8 _₁₄))
  (begin
    (= _₁₅ test-suite/fibonacci)
    (= _₁₆ (_₁₅ 7))
    (assert-equal 13 _₁₆))
  (begin
    (= _₁₇ test-suite/fibonacci)
    (= _₁₈ (_₁₇ 8))
    (assert-equal 21 _₁₈))
  (= _₁₉ test-suite/fibonacci)
  (= _₂₀ (_₁₉ 9))
  (assert-equal 34 _₂₀))

