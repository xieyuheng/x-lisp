     (begin
       (= record₁ (begin (= _₁ builtin/make-record) (_₁)))
       (begin
         (= _₂ builtin/record-put!)
         (_₂ :x 1.0 record₁))
       (begin
         (= _₃ builtin/record-put!)
         (_₃ :y 2.0 record₁))
       record₁))
  (begin
    (= _₄ builtin/assert-equal)
    (= record₂ (begin (= _₅ builtin/make-record) (_₅)))
    (begin (= _₆ builtin/record-put!) (_₆ :x 2.0 record₂))
    (begin (= _₇ builtin/record-put!) (_₇ :y 2.0 record₂))
    (= _₈ test-suite/point-put-x)
    (= _₉ (_₈ 2.0 point₁))
    (_₄ record₂ _₉))
  (begin
    (= _₁₀ builtin/assert-equal)
    (= record₃ (begin (= _₁₁ builtin/make-record) (_₁₁)))
    (begin (= _₁₂ builtin/record-put!) (_₁₂ :x 1.0 record₃))
    (begin (= _₁₃ builtin/record-put!) (_₁₃ :y 2.0 record₃))
    (_₁₀ record₃ point₁))
  (begin
    (= _₁₄ builtin/assert-equal)
    (= record₄ (begin (= _₁₅ builtin/make-record) (_₁₅)))
    (begin (= _₁₆ builtin/record-put!) (_₁₆ :x 1.0 record₄))
    (begin (= _₁₇ builtin/record-put!) (_₁₇ :y 1.0 record₄))
    (= _₁₈ test-suite/point-put-y!)
    (= _₁₉ (_₁₈ 1.0 point₁))
    (_₁₄ record₄ _₁₉))
  (= _₂₀ builtin/assert-equal)
  (= record₅ (begin (= _₂₁ builtin/make-record) (_₂₁)))
  (begin (= _₂₂ builtin/record-put!) (_₂₂ :x 1.0 record₅))
  (begin (= _₂₃ builtin/record-put!) (_₂₃ :y 1.0 record₅))
  (_₂₀ record₅ point₁))

