(claim test-suite/list-test void-t)

(define-test test-suite/list-test
  (= list₁ (make-list))
  (list-push! 1 list₁)
  (list-push! 2 list₁)
  (list-push! 3 list₁)
  (begin
    (= list₂ (make-list))
    (list-push! 1 list₂)
    (list-push! 2 list₂)
    (list-push! 3 list₂)
    (assert-equal list₂ list₁))
  (begin
    (= list₂ (make-list))
    (list-push! 1 list₂)
    (list-push! 2 list₂)
    (list-push! 3 list₂)
    (= list₂ (make-list))
    (list-push! 1 list₂)
    (list-push! 2 list₂)
    (list-push! 3 list₂)
    (assert-equal list₂ list₂))
  (begin
    (= list₂ (make-list))
    (list-push! 'a list₂)
    (list-push! 'b list₂)
    (list-push! 'c list₂)
    (= list₂ (make-list))
    (list-push! 'a list₂)
    (list-push! 'b list₂)
    (list-push! 'c list₂)
    (assert-equal list₂ list₂))
  (begin
    (= list₂ (make-list))
    (list-push! 1 list₂)
    (list-push! 2 list₂)
    (list-push! 3 list₂)
    (= _₁ (list-length list₂))
    (assert-equal 3 _₁))
  (begin
    (= list₂ (make-list))
    (= _₂ (list-length list₂))
    (assert-equal 0 _₂))
  (begin
    (= list₂ (make-list))
    (= _₃ (list-empty? list₂))
    (assert _₃))
  (= list₂ (make-list))
  (list-push! 1 list₂)
  (list-push! 2 list₂)
  (list-push! 3 list₂)
  (println list₂)
  (begin
    (= list₃ (make-list))
    (list-push! 1 list₃)
    (list-push! 2 list₃)
    (list-push! 3 list₃)
    (println list₃))
  (begin
    (= list₃ (make-list))
    (list-push! 1 list₃)
    (list-push! 2 list₃)
    (list-push! 3 list₃)
    (println list₃))
  (begin
    (= list₃ (make-list))
    (list-push! 1 list₃)
    (list-push! 2 list₃)
    (list-push! 3 list₃)
    (println list₃))
  (begin
    (= list₃ (make-list))
    (list-push! 1 list₃)
    (list-push! 2 list₃)
    (list-push! 3 list₃)
    (println list₃))
  (begin
    (= list₃ (make-list))
    (list-push! 'a list₃)
    (list-push! 'b list₃)
    (list-push! 'c list₃)
    (println list₃))
  (= list₃ (make-list))
  (list-push! 'a list₃)
  (list-push! 'b list₃)
  (list-push! 'c list₃)
  (println list₃))

(claim test-suite/cond-mismatch-test void-t)

(define-test test-suite/cond-mismatch-test
  (if (equal? 1 2)
    void
    (if (equal? 1 2) void (error "cond mismatch"))))

(claim test-suite/cond-test void-t)

(define-test test-suite/cond-test
  (begin
    (= _₁
       (if (equal? 1 1)
         1
         (if true 2 (error "cond mismatch"))))
    (assert-equal 1 _₁))
  (begin
    (= _₂
       (if (equal? 1 2)
         1
         (if true 2 (error "cond mismatch"))))
    (assert-equal 2 _₂))
  (if (equal? 1 1)
    (assert true)
    (if true (assert false) (error "cond mismatch")))
  (if (equal? 1 2)
    (assert false)
    (if true (assert true) (error "cond mismatch"))))

(claim test-suite/if-test void-t)

(define-test test-suite/if-test
  (begin (= _₁ (if true 1 2)) (assert-equal _₁ 1))
  (begin (= _₂ (if false 1 2)) (assert-equal _₂ 2))
  (begin
    (= _₃ (if true (if true true false) false))
    (assert _₃))
  (begin
    (= _₄ (if true (if true false false) false))
    (= _₅ (not _₄))
    (assert _₅))
  (begin
    (= _₆ (if false true (if false true true)))
    (assert _₆))
  (= _₇ (if false true (if false true false)))
  (= _₈ (not _₇))
  (assert _₈))

(claim test-suite/the-test void-t)

(define-test test-suite/the-test
  (assert-equal 1 1)
  (assert-equal 'a 'a))

(claim test-suite/path-test void-t)

(define-test test-suite/path-test
  (begin
    (= _₁ (path-directory-name "a/b/c/file.test.txt"))
    (assert-equal "a/b/c" _₁))
  (begin
    (= _₂ (path-base-name "a/b/c/file.test.txt"))
    (assert-equal "file.test.txt" _₂))
  (begin
    (= _₃ (path-extension "a/b/c/file.test.txt"))
    (assert-equal ".txt" _₃))
  (begin
    (= _₄ (path-stem "a/b/c/file.test.txt"))
    (assert-equal "file.test" _₄))
  (begin
    (= _₅ (path-absolute? "/a/b/c/file.test.txt"))
    (assert _₅))
  (begin
    (= _₆ (path-relative? "/a/b/c/file.test.txt"))
    (assert-not _₆))
  (begin
    (= _₇ (path-relative? "a/b/c/file.test.txt"))
    (assert _₇))
  (begin
    (= _₈ (path-relative? "./a/b/c/file.test.txt"))
    (assert _₈))
  (begin
    (= _₉ (path-absolute? "a/b/c/file.test.txt"))
    (assert-not _₉))
  (begin
    (= _₁₀ (path-absolute? "./a/b/c/file.test.txt"))
    (assert-not _₁₀))
  (begin
    (= _₁₁ (path-join "a/b/c" "d/e/f"))
    (assert-equal "a/b/c/d/e/f" _₁₁))
  (begin
    (= _₁₂ (path-join "a/b/c/" "/d/e/f"))
    (assert-equal "a/b/c/d/e/f" _₁₂))
  (begin
    (= _₁₃ (path-join "/a/b/c/" "/d/e/f"))
    (assert-equal "/a/b/c/d/e/f" _₁₃))
  (begin
    (= _₁₄ (path-normalize "a/b/c/../d"))
    (assert-equal "a/b/d" _₁₄))
  (= _₁₅ (path-normalize "///a/b/c/"))
  (assert-equal "/a/b/c" _₁₅))

(claim test-suite/reocrd-test void-t)

(define-test test-suite/reocrd-test
  (begin
    (= record₁ (make-record))
    (record-put! :x 1 record₁)
    (record-put! :y 2 record₁)
    (println record₁))
  (= record₁ (make-record))
  (record-put! :x 1 record₁)
  (record-put! :y 2 record₁)
  (println record₁))

(define-interface test-suite/point-t :x float-t :y float-t)

(claim test-suite/with-color
  (polymorphic (A B C)
    (-> A (extend-interface B) (extend-interface B :color C))))

(define (test-suite/with-color color point)
  (= record₁ point)
  (= record₂ (record-put :color color record₁))
  record₂)

(claim test-suite/record-extend-test void-t)

(define-test test-suite/record-extend-test
  (= point₁
     (begin
       (= record₁ (make-record))
       (record-put! :x 1.0 record₁)
       (record-put! :y 2.0 record₁)
       record₁))
  (= record₁ (make-record))
  (record-put! :x 1.0 record₁)
  (record-put! :y 2.0 record₁)
  (record-put! :color "red" record₁)
  (= _₁ test-suite/with-color)
  (= _₂ (_₁ "red" point₁))
  (assert-equal record₁ _₂))

(claim test-suite/point-put-x
  (polymorphic (A B C)
    (-> A
        (extend-interface B :x C)
        (extend-interface B :x C))))

(define (test-suite/point-put-x x point)
  (= record₁ point)
  (= record₂ (record-put :x x record₁))
  record₂)

(claim test-suite/point-put-y!
  (polymorphic (A B C)
    (-> A
        (extend-interface B :y C)
        (extend-interface B :y C))))

(define (test-suite/point-put-y! y point)
  (= record₁ point)
  (record-put! :y y record₁)
  record₁)

(claim test-suite/record-update-test void-t)

(define-test test-suite/record-update-test
  (= point₁
     (begin
       (= record₁ (make-record))
       (record-put! :x 1.0 record₁)
       (record-put! :y 2.0 record₁)
       record₁))
  (begin
    (= record₁ (make-record))
    (record-put! :x 2.0 record₁)
    (record-put! :y 2.0 record₁)
    (= _₁ test-suite/point-put-x)
    (= _₂ (_₁ 2.0 point₁))
    (assert-equal record₁ _₂))
  (begin
    (= record₁ (make-record))
    (record-put! :x 1.0 record₁)
    (record-put! :y 2.0 record₁)
    (assert-equal record₁ point₁))
  (begin
    (= record₁ (make-record))
    (record-put! :x 1.0 record₁)
    (record-put! :y 1.0 record₁)
    (= _₃ test-suite/point-put-y!)
    (= _₄ (_₃ 1.0 point₁))
    (assert-equal record₁ _₄))
  (= record₁ (make-record))
  (record-put! :x 1.0 record₁)
  (record-put! :y 1.0 record₁)
  (assert-equal record₁ point₁))

