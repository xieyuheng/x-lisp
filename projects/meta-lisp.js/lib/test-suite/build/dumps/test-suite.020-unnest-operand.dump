(claim test-suite/file-test void-t)

(define-test test-suite/file-test
  (= file₁ (open-input-file "src/file/file-1.txt"))
  (begin (= _₁ (file-read file₁)) (assert-equal "abc\n" _₁))
  (file-close file₁)
  (= file₂ (open-output-file "src/file/file-2.txt"))
  (file-write file₂ "123\n")
  (file-close file₂)
  (= file₃ (open-input-file "src/file/file-2.txt"))
  (begin (= _₂ (file-read file₃)) (assert-equal "123\n" _₂))
  (file-close file₃)
  (= file₄ (open-output-file "src/file/file-2.txt"))
  (file-write file₄ "abc\n")
  (file-close file₄)
  (= file₅ (open-input-file "src/file/file-2.txt"))
  (begin (= _₃ (file-read file₅)) (assert-equal "abc\n" _₃))
  (file-close file₅))

(claim test-suite/fs-test void-t)

(define-test test-suite/fs-test
  (begin
    (= _₁ (fs-read "src/fs/file-1.txt"))
    (assert-equal "abc\n" _₁))
  (fs-write "src/fs/file-2.txt" "123\n")
  (begin
    (= _₂ (fs-read "src/fs/file-2.txt"))
    (assert-equal "123\n" _₂))
  (fs-write "src/fs/file-2.txt" "abc\n")
  (begin
    (= _₃ (fs-read "src/fs/file-2.txt"))
    (assert-equal "abc\n" _₃))
  (= _₄ (fs-list "src/fs"))
  (println _₄))

(claim test-suite/S
