(claim test-suite/factorial (-> int-t int-t))

(define (test-suite/factorial n)
  (if (int-less-or-equal? n 1)
    1
    (begin
      (= _₁ test-suite/factorial)
      (= _₂ (isub n 1))
      (= _₃ (_₁ _₂))
      (imul _₃ n))))

(claim test-suite/factorial-test void-t)

(define-test test-suite/factorial-test
  (begin
    (= _₁ test-suite/factorial)
    (= _₂ (_₁ 0))
    (assert-equal 1 _₂))
  (begin
    (= _₃ test-suite/factorial)
    (= _₄ (_₃ 1))
    (assert-equal 1 _₄))
  (begin
    (= _₅ test-suite/factorial)
    (= _₆ (_₅ 2))
    (assert-equal 2 _₆))
  (begin
    (= _₇ test-suite/factorial)
    (= _₈ (_₇ 3))
    (assert-equal 6 _₈))
  (begin
    (= _₉ test-suite/factorial)
    (= _₁₀ (_₉ 4))
    (assert-equal 24 _₁₀))
  (begin
    (= _₁₁ test-suite/factorial)
    (= _₁₂ (_₁₁ 5))
    (assert-equal 120 _₁₂))
  (= _₁₃ test-suite/factorial)
  (= _₁₄ (_₁₃ 6))
  (assert-equal 720 _₁₄))

