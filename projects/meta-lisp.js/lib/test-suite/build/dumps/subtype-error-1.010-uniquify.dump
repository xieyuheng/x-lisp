(define-interface point-t
  :x
  builtin/float-t
  :y
  builtin/float-t)

(define (main)
  (begin
    (= record₁ (builtin/make-record))
    (builtin/record-put! :x 1.0 record₁)
    (builtin/record-put! :y 2.0 record₁)
    record₁)
  (= record₂ (builtin/make-record))
  (builtin/record-put! :x 1.0 record₂)
  record₂)