(claim S
  (polymorphic (A B C) (-> (-> A B C) (-> A B) (-> A C))))

(define (S x y z) (x z (y z)))

(claim K (polymorphic (A B) (-> A B A)))

(define (K x y) x)

(claim I (polymorphic (A) (-> A A)))

(define (I x) x)

(claim main (polymorphic (A) (-> (-> A A))))

(define (main) (S K I))

(claim local-SKI
  (polymorphic (A B C D E F)
    (tau (-> (-> A B C) (-> A B) (-> A C))
         (-> D E D)
         (-> F F))))

(define local-SKI
  (= S₁ (lambda (x₁ y₁ z₁) (x₁ z₁ (y₁ z₁))))
  (= K₁ (lambda (x₁ y₁) x₁))
  (= I₁ (lambda (x₁) x₁))
  (= list₁ (make-list))
  (list-push! S₁ list₁)
  (list-push! K₁ list₁)
  (list-push! I₁ list₁)
  list₁)