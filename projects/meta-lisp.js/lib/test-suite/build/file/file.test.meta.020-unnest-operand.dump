(claim main (-> void-t))

(define (main)
  (= file₁ (open-input-file "src/file/file-1.txt"))
  (begin (= _₁ (file-read file₁)) (assert-equal "abc\n" _₁))
  (file-close file₁)
  (= file₂ (open-output-file "src/file/file-2.txt"))
  (file-write file₂ "123\n")
  (file-close file₂)
  (= file₃ (open-input-file "src/file/file-2.txt"))
  (begin (= _₂ (file-read file₃)) (assert-equal "123\n" _₂))
  (file-close file₃)
  (= file₄ (open-output-file "src/file/file-2.txt"))
  (file-write file₄ "abc\n")
  (file-close file₄)
  (= file₅ (open-input-file "src/file/file-2.txt"))
  (begin (= _₃ (file-read file₅)) (assert-equal "abc\n" _₃))
  (file-close file₅))