(claim main (-> void-t))

(define (main)
  (= file₁ (open-input-file "src/file/file-1.txt"))
  (assert-equal "abc\n" (file-read file₁))
  (file-close file₁)
  (= file₂ (open-output-file "src/file/file-2.txt"))
  (file-write file₂ "123\n")
  (file-close file₂)
  (= file₃ (open-input-file "src/file/file-2.txt"))
  (assert-equal "123\n" (file-read file₃))
  (file-close file₃)
  (= file₄ (open-output-file "src/file/file-2.txt"))
  (file-write file₄ "abc\n")
  (file-close file₄)
  (= file₅ (open-input-file "src/file/file-2.txt"))
  (assert-equal "abc\n" (file-read file₅))
  (file-close file₅))