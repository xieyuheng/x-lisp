(claim main (-> void-t))

(define (main)
  (assert-equal iadd iadd)
  (begin
    (= _₁ (iadd 1))
    (= _₂ (iadd 1))
    (assert-equal _₁ _₂))
  (begin
    (= _₃ (iadd 1))
    (= _₄ (iadd 2))
    (assert-not-equal _₃ _₄))
  (begin
    (= _₅ (iadd 1))
    (= _₆ (_₅ 2))
    (= _₇ (iadd 1 2))
    (assert-equal _₆ _₇))
  (begin (= _₈ (isub 2)) (= _₉ (_₈ 1)) (assert-equal 1 _₉))
  (= _₁₀ (isub 2 1))
  (assert-equal 1 _₁₀))