(claim my-list-adjacent-dedup
  (polymorphic (E) (-> (my-list-t E) (my-list-t E))))

(define (my-list-adjacent-dedup list)
  (if (nil? list)
    nil
    (if (li? list)
      (begin
        (= tail₁₁ (li-tail list))
        (= head₁₁ (li-head list))
        (if (nil? tail₁₁)
          (begin (= head₁ head₁₁) (li head₁ nil))
          (if (li? tail₁₁)
            (begin
              (= tail₂₁ (li-tail tail₁₁))
              (= head₂₁ (li-head tail₁₁))
              (= rest₁ tail₂₁)
              (= second₁ head₂₁)
              (= first₁ head₁₁)
              (if (equal? first₁ second₁)
                (begin
                  (= _₁ (li second₁ rest₁))
                  (my-list-adjacent-dedup _₁))
                (begin
                  (= _₂ (li second₁ rest₁))
                  (= _₃ (my-list-adjacent-dedup _₂))
                  (li first₁ _₃))))
            (error "cond mismatch"))))
      (error "cond mismatch"))))