(claim main (-> void-t))

(define (main)
  (begin
    (= _₁ (my-string-repeat 0 "a"))
    (assert-equal "" _₁))
  (begin
    (= _₂ (my-string-repeat 1 "a"))
    (assert-equal "a" _₂))
  (begin
    (= _₃ (my-string-repeat 2 "a"))
    (assert-equal "aa" _₃))
  (= _₄ (my-string-repeat 3 "a"))
  (assert-equal "aaa" _₄))