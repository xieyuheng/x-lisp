;;; input

(claim main (-> void-t))

(define (main)
  (assert-equal 1 (cond ((equal? 1 1) 1) (true 2)))
  (assert-equal 2 (cond ((equal? 1 2) 1) (true 2)))
  (cond ((equal? 1 1) (assert true)) (true (assert false)))
  (cond ((equal? 1 2) (assert false)) (true (assert true))))

;;; loaded

(claim main (-> void-t))

(define (main)
  (assert-equal 1 (cond ((equal? 1 1) 1) (true 2)))
  (assert-equal 2 (cond ((equal? 1 2) 1) (true 2)))
  (cond ((equal? 1 1) (assert true)) (true (assert false)))
  (cond ((equal? 1 2) (assert false)) (true (assert true))))

;;; desugared

(claim main (-> void-t))

(define (main)
  (assert-equal
    1
    (if (equal? 1 1) 1 (if true 2 (error "cond mismatch"))))
  (assert-equal
    2
    (if (equal? 1 2) 1 (if true 2 (error "cond mismatch"))))
  (if (equal? 1 1)
    (assert true)
    (if true (assert false) (error "cond mismatch")))
  (if (equal? 1 2)
    (assert false)
    (if true (assert true) (error "cond mismatch"))))

;;; checked

(claim main (-> void-t))

(define (main)
  (assert-equal
    1
    (if (equal? 1 1) 1 (if true 2 (error "cond mismatch"))))
  (assert-equal
    2
    (if (equal? 1 2) 1 (if true 2 (error "cond mismatch"))))
  (if (equal? 1 1)
    (assert true)
    (if true (assert false) (error "cond mismatch")))
  (if (equal? 1 2)
    (assert false)
    (if true (assert true) (error "cond mismatch"))))

