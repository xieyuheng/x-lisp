;;; input

(claim main (-> void-t))

(define (main)
  (cond ((equal? 1 2) void) ((equal? 1 2) void)))

;;; loaded

(claim main (-> void-t))

(define (main)
  (cond ((equal? 1 2) void) ((equal? 1 2) void)))

;;; desugared

(claim main (-> void-t))

(define (main)
  (if (equal? 1 2)
    void
    (if (equal? 1 2) void (error "cond mismatch"))))

;;; checked

(claim main (-> void-t))

(define (main)
  (if (equal? 1 2)
    void
    (if (equal? 1 2) void (error "cond mismatch"))))

