(import-all "lambda-with-let")

(define-function (evaluate-and-print exp)
  (block body
    (= _₁ (evaluate exp empty-env))
    (return (println _₁))))

(define-function (main)
  (block body
    (= _₁ (var-exp 'x))
    (= _₂ (lambda-exp 'x _₁))
    (perform (evaluate-and-print _₂))
    (= _₃ (var-exp 'x))
    (= _₄ (lambda-exp 'x _₃))
    (= _₅ (var-exp 'x))
    (= _₆ (lambda-exp 'x _₅))
    (= _₇ (apply-exp _₄ _₆))
    (perform (evaluate-and-print _₇))
    (= _₈ (var-exp 'x))
    (= _₉ (lambda-exp 'x _₈))
    (= _₁₀ (var-exp 'x))
    (= _₁₁ (lambda-exp 'x _₁₀))
    (= _₁₂ (apply-exp _₉ _₁₁))
    (= _₁₃ (var-exp 'x))
    (= _₁₄ (lambda-exp 'x _₁₃))
    (= _₁₅ (var-exp 'x))
    (= _₁₆ (lambda-exp 'x _₁₅))
    (= _₁₇ (apply-exp _₁₄ _₁₆))
    (= _₁₈ (apply-exp _₁₂ _₁₇))
    (perform (evaluate-and-print _₁₈))
    (= _₁₉ (var-exp 'x))
    (= _₂₀ (lambda-exp 'x _₁₉))
    (= _₂₁ (var-exp 'id))
    (= _₂₂ (let-exp 'id _₂₀ _₂₁))
    (perform (evaluate-and-print _₂₂))
    (= _₂₃ (var-exp 'x))
    (= _₂₄ (lambda-exp 'x _₂₃))
    (= _₂₅ (var-exp 'id))
    (= _₂₆ (var-exp 'id))
    (= _₂₇ (apply-exp _₂₅ _₂₆))
    (= _₂₈ (let-exp 'id _₂₄ _₂₇))
    (perform (evaluate-and-print _₂₈))
    (= _₂₉ (var-exp 'x))
    (= _₃₀ (lambda-exp 'x _₂₉))
    (= _₃₁ (var-exp 'id))
    (= _₃₂ (var-exp 'id))
    (= _₃₃ (apply-exp _₃₁ _₃₂))
    (= _₃₄ (var-exp 'id))
    (= _₃₅ (var-exp 'id))
    (= _₃₆ (apply-exp _₃₄ _₃₅))
    (= _₃₇ (apply-exp _₃₃ _₃₆))
    (= _₃₈ (let-exp 'id _₃₀ _₃₇))
    (return (evaluate-and-print _₃₈))))