(import-as "lambda" l1/)

(import-as "lambda-with-let" l2/)

(define-function (evaluate-and-print exp)
  (block body
    (= _₁ (l1/evaluate exp l1/empty-env))
    (return (println _₁))))

(define-function (main)
  (block body
    (= _₁ (l1/var-exp 'x))
    (= _₂ (l1/lambda-exp 'x _₁))
    (perform (evaluate-and-print _₂))
    (= _₃ (l1/var-exp 'x))
    (= _₄ (l1/lambda-exp 'x _₃))
    (= _₅ (l1/var-exp 'x))
    (= _₆ (l1/lambda-exp 'x _₅))
    (= _₇ (l1/apply-exp _₄ _₆))
    (perform (evaluate-and-print _₇))
    (= _₈ (l1/var-exp 'x))
    (= _₉ (l1/lambda-exp 'x _₈))
    (= _₁₀ (l1/var-exp 'x))
    (= _₁₁ (l1/lambda-exp 'x _₁₀))
    (= _₁₂ (l1/apply-exp _₉ _₁₁))
    (= _₁₃ (l1/var-exp 'x))
    (= _₁₄ (l1/lambda-exp 'x _₁₃))
    (= _₁₅ (l1/var-exp 'x))
    (= _₁₆ (l1/lambda-exp 'x _₁₅))
    (= _₁₇ (l1/apply-exp _₁₄ _₁₆))
    (= _₁₈ (l1/apply-exp _₁₂ _₁₇))
    (perform (evaluate-and-print _₁₈))
    (= _₁₉ (l2/var-exp 'x))
    (= _₂₀ (l2/lambda-exp 'x _₁₉))
    (perform (evaluate-and-print _₂₀))
    (= _₂₁ (l2/var-exp 'x))
    (= _₂₂ (l2/lambda-exp 'x _₂₁))
    (= _₂₃ (l2/var-exp 'x))
    (= _₂₄ (l2/lambda-exp 'x _₂₃))
    (= _₂₅ (l2/apply-exp _₂₂ _₂₄))
    (perform (evaluate-and-print _₂₅))
    (= _₂₆ (l2/var-exp 'x))
    (= _₂₇ (l2/lambda-exp 'x _₂₆))
    (= _₂₈ (l2/var-exp 'x))
    (= _₂₉ (l2/lambda-exp 'x _₂₈))
    (= _₃₀ (l2/apply-exp _₂₇ _₂₉))
    (= _₃₁ (l2/var-exp 'x))
    (= _₃₂ (l2/lambda-exp 'x _₃₁))
    (= _₃₃ (l2/var-exp 'x))
    (= _₃₄ (l2/lambda-exp 'x _₃₃))
    (= _₃₅ (l2/apply-exp _₃₂ _₃₄))
    (= _₃₆ (l2/apply-exp _₃₀ _₃₅))
    (perform (evaluate-and-print _₃₆))
    (= _₃₇ (l2/var-exp 'x))
    (= _₃₈ (l2/lambda-exp 'x _₃₇))
    (= _₃₉ (l2/var-exp 'id))
    (= _₄₀ (l2/let-exp 'id _₃₈ _₃₉))
    (perform (evaluate-and-print _₄₀))
    (= _₄₁ (l2/var-exp 'x))
    (= _₄₂ (l2/lambda-exp 'x _₄₁))
    (= _₄₃ (l2/var-exp 'id))
    (= _₄₄ (l2/var-exp 'id))
    (= _₄₅ (l2/apply-exp _₄₃ _₄₄))
    (= _₄₆ (l2/let-exp 'id _₄₂ _₄₅))
    (perform (evaluate-and-print _₄₆))
    (= _₄₇ (l2/var-exp 'x))
    (= _₄₈ (l2/lambda-exp 'x _₄₇))
    (= _₄₉ (l2/var-exp 'id))
    (= _₅₀ (l2/var-exp 'id))
    (= _₅₁ (l2/apply-exp _₄₉ _₅₀))
    (= _₅₂ (l2/var-exp 'id))
    (= _₅₃ (l2/var-exp 'id))
    (= _₅₄ (l2/apply-exp _₅₂ _₅₃))
    (= _₅₅ (l2/apply-exp _₅₁ _₅₄))
    (= _₅₆ (l2/let-exp 'id _₄₈ _₅₅))
    (return (evaluate-and-print _₅₆))))