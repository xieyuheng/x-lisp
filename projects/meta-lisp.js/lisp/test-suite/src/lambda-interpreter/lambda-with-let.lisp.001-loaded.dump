(define-datatype exp-t
  (var-exp (name symbol-t))
  (apply-exp (target exp-t) (arg exp-t))
  (lambda-exp (parameter symbol-t) (body exp-t))
  (let-exp (name symbol-t) (rhs exp-t) (body exp-t)))

(claim var-exp (-> symbol-t exp-t))

(define (var-exp name) ['var-exp name])

(claim var-exp? (-> exp-t bool-t))

(define (var-exp? value)
  (and (list? value)
       (equal? (list-length value) 2)
       (equal? (list-head value) 'var-exp)))

(claim var-exp-name (-> exp-t symbol-t))

(define (var-exp-name target) (list-get 1 target))

(claim var-exp-put-name (-> symbol-t exp-t exp-t))

(define (var-exp-put-name value target)
  (list-put 1 value target))

(claim var-exp-put-name! (-> symbol-t exp-t exp-t))

(define (var-exp-put-name! value target)
  (list-put! 1 value target))

(claim apply-exp (-> exp-t exp-t exp-t))

(define (apply-exp target arg) ['apply-exp target arg])

(claim apply-exp? (-> exp-t bool-t))

(define (apply-exp? value)
  (and (list? value)
       (equal? (list-length value) 3)
       (equal? (list-head value) 'apply-exp)))

(claim apply-exp-target (-> exp-t exp-t))

(define (apply-exp-target target) (list-get 1 target))

(claim apply-exp-arg (-> exp-t exp-t))

(define (apply-exp-arg target) (list-get 2 target))

(claim apply-exp-put-target (-> exp-t exp-t exp-t))

(define (apply-exp-put-target value target)
  (list-put 1 value target))

(claim apply-exp-put-arg (-> exp-t exp-t exp-t))

(define (apply-exp-put-arg value target)
  (list-put 2 value target))

(claim apply-exp-put-target! (-> exp-t exp-t exp-t))

(define (apply-exp-put-target! value target)
  (list-put! 1 value target))

(claim apply-exp-put-arg! (-> exp-t exp-t exp-t))

(define (apply-exp-put-arg! value target)
  (list-put! 2 value target))

(claim lambda-exp (-> symbol-t exp-t exp-t))

(define (lambda-exp parameter body)
  ['lambda-exp parameter body])

(claim lambda-exp? (-> exp-t bool-t))

(define (lambda-exp? value)
  (and (list? value)
       (equal? (list-length value) 3)
       (equal? (list-head value) 'lambda-exp)))

(claim lambda-exp-parameter (-> exp-t symbol-t))

(define (lambda-exp-parameter target) (list-get 1 target))

(claim lambda-exp-body (-> exp-t exp-t))

(define (lambda-exp-body target) (list-get 2 target))

(claim lambda-exp-put-parameter (-> symbol-t exp-t exp-t))

(define (lambda-exp-put-parameter value target)
  (list-put 1 value target))

(claim lambda-exp-put-body (-> exp-t exp-t exp-t))

(define (lambda-exp-put-body value target)
  (list-put 2 value target))

(claim lambda-exp-put-parameter! (-> symbol-t exp-t exp-t))

(define (lambda-exp-put-parameter! value target)
  (list-put! 1 value target))

(claim lambda-exp-put-body! (-> exp-t exp-t exp-t))

(define (lambda-exp-put-body! value target)
  (list-put! 2 value target))

(claim let-exp (-> symbol-t exp-t exp-t exp-t))

(define (let-exp name rhs body) ['let-exp name rhs body])

(claim let-exp? (-> exp-t bool-t))

(define (let-exp? value)
  (and (list? value)
       (equal? (list-length value) 4)
       (equal? (list-head value) 'let-exp)))

(claim let-exp-name (-> exp-t symbol-t))

(define (let-exp-name target) (list-get 1 target))

(claim let-exp-rhs (-> exp-t exp-t))

(define (let-exp-rhs target) (list-get 2 target))

(claim let-exp-body (-> exp-t exp-t))

(define (let-exp-body target) (list-get 3 target))

(claim let-exp-put-name (-> symbol-t exp-t exp-t))

(define (let-exp-put-name value target)
  (list-put 1 value target))

(claim let-exp-put-rhs (-> exp-t exp-t exp-t))

(define (let-exp-put-rhs value target)
  (list-put 2 value target))

(claim let-exp-put-body (-> exp-t exp-t exp-t))

(define (let-exp-put-body value target)
  (list-put 3 value target))

(claim let-exp-put-name! (-> symbol-t exp-t exp-t))

(define (let-exp-put-name! value target)
  (list-put! 1 value target))

(claim let-exp-put-rhs! (-> exp-t exp-t exp-t))

(define (let-exp-put-rhs! value target)
  (list-put! 2 value target))

(claim let-exp-put-body! (-> exp-t exp-t exp-t))

(define (let-exp-put-body! value target)
  (list-put! 3 value target))

(define-datatype env-t
  empty-env
  (extend-env (key symbol-t) (value value-t) (rest env-t)))

(claim empty-env env-t)

(define empty-env 'empty-env)

(claim empty-env? (-> env-t bool-t))

(define (empty-env? value) (equal? value 'empty-env))

(claim extend-env (-> symbol-t value-t env-t env-t))

(define (extend-env key value rest)
  ['extend-env key value rest])

(claim extend-env? (-> env-t bool-t))

(define (extend-env? value)
  (and (list? value)
       (equal? (list-length value) 4)
       (equal? (list-head value) 'extend-env)))

(claim extend-env-key (-> env-t symbol-t))

(define (extend-env-key target) (list-get 1 target))

(claim extend-env-value (-> env-t value-t))

(define (extend-env-value target) (list-get 2 target))

(claim extend-env-rest (-> env-t env-t))

(define (extend-env-rest target) (list-get 3 target))

(claim extend-env-put-key (-> symbol-t env-t env-t))

(define (extend-env-put-key value target)
  (list-put 1 value target))

(claim extend-env-put-value (-> value-t env-t env-t))

(define (extend-env-put-value value target)
  (list-put 2 value target))

(claim extend-env-put-rest (-> env-t env-t env-t))

(define (extend-env-put-rest value target)
  (list-put 3 value target))

(claim extend-env-put-key! (-> symbol-t env-t env-t))

(define (extend-env-put-key! value target)
  (list-put! 1 value target))

(claim extend-env-put-value! (-> value-t env-t env-t))

(define (extend-env-put-value! value target)
  (list-put! 2 value target))

(claim extend-env-put-rest! (-> env-t env-t env-t))

(define (extend-env-put-rest! value target)
  (list-put! 3 value target))

(claim env-has? (-> symbol-t env-t bool-t))

(define (env-has? name env)
  (match env
    (empty-env false)
    ((extend-env key value rest)
     (or (equal? key name) (env-has? name rest)))))

(claim env-lookup-of-fail (-> symbol-t env-t value-t))

(define (env-lookup-of-fail name env)
  (match env
    (empty-env (error "undefined name"))
    ((extend-env key value rest)
     (if (equal? key name)
       value
       (env-lookup-of-fail name rest)))))

(define-datatype value-t
  (closure-value
   (env env-t)
   (parameter symbol-t)
   (body exp-t)))

(claim closure-value (-> env-t symbol-t exp-t value-t))

(define (closure-value env parameter body)
  ['closure-value env parameter body])

(claim closure-value? (-> value-t bool-t))

(define (closure-value? value)
  (and (list? value)
       (equal? (list-length value) 4)
       (equal? (list-head value) 'closure-value)))

(claim closure-value-env (-> value-t env-t))

(define (closure-value-env target) (list-get 1 target))

(claim closure-value-parameter (-> value-t symbol-t))

(define (closure-value-parameter target)
  (list-get 2 target))

(claim closure-value-body (-> value-t exp-t))

(define (closure-value-body target) (list-get 3 target))

(claim closure-value-put-env (-> env-t value-t value-t))

(define (closure-value-put-env value target)
  (list-put 1 value target))

(claim closure-value-put-parameter
  (-> symbol-t value-t value-t))

(define (closure-value-put-parameter value target)
  (list-put 2 value target))

(claim closure-value-put-body (-> exp-t value-t value-t))

(define (closure-value-put-body value target)
  (list-put 3 value target))

(claim closure-value-put-env! (-> env-t value-t value-t))

(define (closure-value-put-env! value target)
  (list-put! 1 value target))

(claim closure-value-put-parameter!
  (-> symbol-t value-t value-t))

(define (closure-value-put-parameter! value target)
  (list-put! 2 value target))

(claim closure-value-put-body! (-> exp-t value-t value-t))

(define (closure-value-put-body! value target)
  (list-put! 3 value target))

(claim evaluate (-> exp-t env-t value-t))

(define (evaluate exp env)
  (match exp
    ((var-exp name) (env-lookup-of-fail name env))
    ((apply-exp target arg)
     (apply (evaluate target env) (evaluate arg env)))
    ((lambda-exp parameter body)
     (closure-value env parameter body))
    ((let-exp name rhs body)
     (= env (extend-env name (evaluate rhs env) env))
     (evaluate body env))))

(claim apply (-> value-t value-t value-t))

(define (apply target arg)
  (match target
    ((closure-value env parameter body)
     (evaluate body (extend-env parameter arg env)))))