(claim evaluate-and-print (-> exp-t void-t))

(define (evaluate-and-print exp)
  (= _₁ (l2/evaluate exp l2/empty-env))
  (println _₁))

(claim main (-> void-t))

(define (main)
  (begin
    (= _₁ (l2/var-exp 'x))
    (= _₂ (l2/lambda-exp 'x _₁))
    (evaluate-and-print _₂))
  (begin
    (= _₃ (l2/var-exp 'x))
    (= _₄ (l2/lambda-exp 'x _₃))
    (= _₅ (l2/var-exp 'x))
    (= _₆ (l2/lambda-exp 'x _₅))
    (= _₇ (l2/apply-exp _₄ _₆))
    (evaluate-and-print _₇))
  (begin
    (= _₈ (l2/var-exp 'x))
    (= _₉ (l2/lambda-exp 'x _₈))
    (= _₁₀ (l2/var-exp 'x))
    (= _₁₁ (l2/lambda-exp 'x _₁₀))
    (= _₁₂ (l2/apply-exp _₉ _₁₁))
    (= _₁₃ (l2/var-exp 'x))
    (= _₁₄ (l2/lambda-exp 'x _₁₃))
    (= _₁₅ (l2/var-exp 'x))
    (= _₁₆ (l2/lambda-exp 'x _₁₅))
    (= _₁₇ (l2/apply-exp _₁₄ _₁₆))
    (= _₁₈ (l2/apply-exp _₁₂ _₁₇))
    (evaluate-and-print _₁₈))
  (begin
    (= _₁₉ (l2/var-exp 'x))
    (= _₂₀ (l2/lambda-exp 'x _₁₉))
    (= _₂₁ (l2/var-exp 'id))
    (= _₂₂ (l2/let-exp 'id _₂₀ _₂₁))
    (evaluate-and-print _₂₂))
  (begin
    (= _₂₃ (l2/var-exp 'x))
    (= _₂₄ (l2/lambda-exp 'x _₂₃))
    (= _₂₅ (l2/var-exp 'id))
    (= _₂₆ (l2/var-exp 'id))
    (= _₂₇ (l2/apply-exp _₂₅ _₂₆))
    (= _₂₈ (l2/let-exp 'id _₂₄ _₂₇))
    (evaluate-and-print _₂₈))
  (begin
    (= _₂₉ (l2/var-exp 'x))
    (= _₃₀ (l2/lambda-exp 'x _₂₉))
    (= _₃₁ (l2/var-exp 'id))
    (= _₃₂ (l2/var-exp 'id))
    (= _₃₃ (l2/apply-exp _₃₁ _₃₂))
    (= _₃₄ (l2/var-exp 'id))
    (= _₃₅ (l2/var-exp 'id))
    (= _₃₆ (l2/apply-exp _₃₄ _₃₅))
    (= _₃₇ (l2/apply-exp _₃₃ _₃₆))
    (= _₃₈ (l2/let-exp 'id _₃₀ _₃₇))
    (evaluate-and-print _₃₈))
  (begin
    (= _₃₉ (l1/var-exp 'x))
    (= _₄₀ (l1/lambda-exp 'x _₃₉))
    (evaluate-and-print _₄₀))
  (begin
    (= _₄₁ (l1/var-exp 'x))
    (= _₄₂ (l1/lambda-exp 'x _₄₁))
    (= _₄₃ (l1/var-exp 'x))
    (= _₄₄ (l1/lambda-exp 'x _₄₃))
    (= _₄₅ (l1/apply-exp _₄₂ _₄₄))
    (evaluate-and-print _₄₅))
  (= _₄₆ (l1/var-exp 'x))
  (= _₄₇ (l1/lambda-exp 'x _₄₆))
  (= _₄₈ (l1/var-exp 'x))
  (= _₄₉ (l1/lambda-exp 'x _₄₈))
  (= _₅₀ (l1/apply-exp _₄₇ _₄₉))
  (= _₅₁ (l1/var-exp 'x))
  (= _₅₂ (l1/lambda-exp 'x _₅₁))
  (= _₅₃ (l1/var-exp 'x))
  (= _₅₄ (l1/lambda-exp 'x _₅₃))
  (= _₅₅ (l1/apply-exp _₅₂ _₅₄))
  (= _₅₆ (l1/apply-exp _₅₀ _₅₅))
  (evaluate-and-print _₅₆))