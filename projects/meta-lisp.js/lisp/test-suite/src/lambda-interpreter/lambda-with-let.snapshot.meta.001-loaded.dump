(define (evaluate-and-print exp)
  (println (evaluate exp empty-env)))

(define (main)
  (evaluate-and-print (lambda-exp 'x (var-exp 'x)))
  (evaluate-and-print
   (apply-exp
    (lambda-exp 'x (var-exp 'x))
    (lambda-exp 'x (var-exp 'x))))
  (evaluate-and-print
   (apply-exp
    (apply-exp
     (lambda-exp 'x (var-exp 'x))
     (lambda-exp 'x (var-exp 'x)))
    (apply-exp
     (lambda-exp 'x (var-exp 'x))
     (lambda-exp 'x (var-exp 'x)))))
  (evaluate-and-print
   (let-exp 'id (lambda-exp 'x (var-exp 'x)) (var-exp 'id)))
  (evaluate-and-print
   (let-exp
    'id
    (lambda-exp 'x (var-exp 'x))
    (apply-exp (var-exp 'id) (var-exp 'id))))
  (evaluate-and-print
   (let-exp
    'id
    (lambda-exp 'x (var-exp 'x))
    (apply-exp
     (apply-exp (var-exp 'id) (var-exp 'id))
     (apply-exp (var-exp 'id) (var-exp 'id))))))