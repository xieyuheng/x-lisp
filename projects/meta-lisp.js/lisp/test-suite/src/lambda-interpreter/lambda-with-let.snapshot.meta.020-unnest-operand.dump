(claim evaluate-and-print (-> exp-t void-t))

(define (evaluate-and-print exp)
  (= _₁ (evaluate exp empty-env))
  (println _₁))

(claim main (-> void-t))

(define (main)
  (begin
    (= _₁ (var-exp 'x))
    (= _₂ (lambda-exp 'x _₁))
    (evaluate-and-print _₂))
  (begin
    (= _₃ (var-exp 'x))
    (= _₄ (lambda-exp 'x _₃))
    (= _₅ (var-exp 'x))
    (= _₆ (lambda-exp 'x _₅))
    (= _₇ (apply-exp _₄ _₆))
    (evaluate-and-print _₇))
  (begin
    (= _₈ (var-exp 'x))
    (= _₉ (lambda-exp 'x _₈))
    (= _₁₀ (var-exp 'x))
    (= _₁₁ (lambda-exp 'x _₁₀))
    (= _₁₂ (apply-exp _₉ _₁₁))
    (= _₁₃ (var-exp 'x))
    (= _₁₄ (lambda-exp 'x _₁₃))
    (= _₁₅ (var-exp 'x))
    (= _₁₆ (lambda-exp 'x _₁₅))
    (= _₁₇ (apply-exp _₁₄ _₁₆))
    (= _₁₈ (apply-exp _₁₂ _₁₇))
    (evaluate-and-print _₁₈))
  (begin
    (= _₁₉ (var-exp 'x))
    (= _₂₀ (lambda-exp 'x _₁₉))
    (= _₂₁ (var-exp 'id))
    (= _₂₂ (let-exp 'id _₂₀ _₂₁))
    (evaluate-and-print _₂₂))
  (begin
    (= _₂₃ (var-exp 'x))
    (= _₂₄ (lambda-exp 'x _₂₃))
    (= _₂₅ (var-exp 'id))
    (= _₂₆ (var-exp 'id))
    (= _₂₇ (apply-exp _₂₅ _₂₆))
    (= _₂₈ (let-exp 'id _₂₄ _₂₇))
    (evaluate-and-print _₂₈))
  (= _₂₉ (var-exp 'x))
  (= _₃₀ (lambda-exp 'x _₂₉))
  (= _₃₁ (var-exp 'id))
  (= _₃₂ (var-exp 'id))
  (= _₃₃ (apply-exp _₃₁ _₃₂))
  (= _₃₄ (var-exp 'id))
  (= _₃₅ (var-exp 'id))
  (= _₃₆ (apply-exp _₃₄ _₃₅))
  (= _₃₇ (apply-exp _₃₃ _₃₆))
  (= _₃₈ (let-exp 'id _₃₀ _₃₇))
  (evaluate-and-print _₃₈))