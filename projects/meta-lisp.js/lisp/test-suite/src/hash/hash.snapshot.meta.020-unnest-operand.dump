(claim main (-> void-t))

(define (main)
  (begin (= hash₁ (make-hash)) (println hash₁))
  (begin
    (= hash₁ (make-hash))
    (hash-put! 1 2 hash₁)
    (println hash₁))
  (begin
    (= hash₁ (make-hash))
    (hash-put! 1 3 hash₁)
    (println hash₁))
  (= hash₁ (make-hash))
  (hash-put! 1 2 hash₁)
  (hash-put! 3 4 hash₁)
  (println hash₁))