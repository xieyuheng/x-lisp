(claim main (-> void-t))

(define (main)
  (println (begin (= hash (make-hash)) hash))
  (println
   (begin (= hash (make-hash)) (hash-put! 1 2 hash) hash))
  (println
   (begin (= hash (make-hash)) (hash-put! 1 3 hash) hash))
  (println
   (begin
     (= hash (make-hash))
     (hash-put! 1 2 hash)
     (hash-put! 3 4 hash)
     hash)))