(import-all "my-list")

(export-all)

(define-function (my-list-map-zip f list1 list2)
  (block body (test (nil? list1)) (branch then₇ else₈))
  (block then₁
    (= tail₆₁ (li-tail list2))
    (= head₆₁ (li-head list2))
    (= tail2₁ tail₆₁)
    (= head2₁ head₆₁)
    (= tail1₁ tail₅₁)
    (= head1₁ head₅₁)
    (= _₁ (f head1₁ head2₁))
    (= _₂ (my-list-map-zip f tail1₁ tail2₁))
    (return (li _₁ _₂)))
  (block else₂ (return (error "cond mismatch")))
  (block then₃
    (= tail1₁ tail₅₁)
    (= head1₁ head₅₁)
    (return nil))
  (block else₄ (test (li? list2)) (branch then₁ else₂))
  (block then₅
    (= tail₅₁ (li-tail list1))
    (= head₅₁ (li-head list1))
    (test (nil? list2))
    (branch then₃ else₄))
  (block else₆ (return (error "cond mismatch")))
  (block then₇ (= _₁ list2) (return nil))
  (block else₈ (test (li? list1)) (branch then₅ else₆)))

(define-function (my-list-map-zip-2 f list1 list2)
  (block body (test (nil? list1)) (branch then₁₅ else₁₆))
  (block then₁
    (= tail₈₁ (li-tail list2))
    (= head₈₁ (li-head list2))
    (= tail2₁ tail₈₁)
    (= head2₁ head₈₁)
    (= tail1₁ tail₇₁)
    (= head1₁ head₇₁)
    (= _₁ (f head1₁ head2₁))
    (= _₂ (my-list-map-zip-2 f tail1₁ tail2₁))
    (return (li _₁ _₂)))
  (block else₂ (return (error "cond mismatch")))
  (block then₃ (return (error "match mismatch")))
  (block else₄ (test (li? list2)) (branch then₁ else₂))
  (block then₅
    (= tail₇₁ (li-tail list1))
    (= head₇₁ (li-head list1))
    (test (nil? list2))
    (branch then₃ else₄))
  (block else₆ (return (error "cond mismatch")))
  (block then₇ (return (error "match mismatch")))
  (block else₈ (test (li? list1)) (branch then₅ else₆))
  (block then₉
    (= tail₉₁ (li-tail list2))
    (= head₉₁ (li-head list2))
    (test (nil? list1))
    (branch then₇ else₈))
  (block else₁₀ (return (error "cond mismatch")))
  (block then₁₁ (= _₁ list1) (return nil))
  (block else₁₂ (test (li? list2)) (branch then₉ else₁₀))
  (block then₁₃
    (= tail₁₀₁ (li-tail list1))
    (= head₁₀₁ (li-head list1))
    (test (nil? list2))
    (branch then₁₁ else₁₂))
  (block else₁₄ (return (error "cond mismatch")))
  (block then₁₅ (= _₁ list2) (return nil))
  (block else₁₆ (test (li? list1)) (branch then₁₃ else₁₄)))