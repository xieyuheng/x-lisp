(import-all "my-list")

(export-all)

(define-function (my-list-map f list)
  (block body (test (nil? list)) (branch then₃ else₄))
  (block then₁
    (= tail₁₁₁ (li-tail list))
    (= head₁₁₁ (li-head list))
    (= tail₁ tail₁₁₁)
    (= head₁ head₁₁₁)
    (= _₁ (f head₁))
    (= _₂ (my-list-map f tail₁))
    (return (li _₁ _₂)))
  (block else₂ (return (error "cond mismatch")))
  (block then₃ (return nil))
  (block else₄ (test (li? list)) (branch then₁ else₂)))