(claim main (-> void-t))

(define (main)
  (begin
    (= _₁ (my-list-adjacent-dedup nil))
    (assert-equal nil _₁))
  (begin
    (= _₂ (li 3 nil))
    (= _₃ (li 2 _₂))
    (= _₄ (li 1 _₃))
    (= _₅ (li 3 _₄))
    (= _₆ (li 2 _₅))
    (= _₇ (li 1 _₆))
    (= _₈ (li 3 nil))
    (= _₉ (li 2 _₈))
    (= _₁₀ (li 1 _₉))
    (= _₁₁ (li 3 _₁₀))
    (= _₁₂ (li 2 _₁₁))
    (= _₁₃ (li 1 _₁₂))
    (= _₁₄ (my-list-adjacent-dedup _₁₃))
    (assert-equal _₇ _₁₄))
  (= _₁₅ (li 3 nil))
  (= _₁₆ (li 2 _₁₅))
  (= _₁₇ (li 1 _₁₆))
  (= _₁₈ (li 3 nil))
  (= _₁₉ (li 3 _₁₈))
  (= _₂₀ (li 2 _₁₉))
  (= _₂₁ (li 2 _₂₀))
  (= _₂₂ (li 1 _₂₁))
  (= _₂₃ (li 1 _₂₂))
  (= _₂₄ (my-list-adjacent-dedup _₂₃))
  (assert-equal _₁₇ _₂₄))