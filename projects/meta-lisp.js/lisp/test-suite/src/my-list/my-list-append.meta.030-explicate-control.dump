(import-all "my-list")

(export-all)

(define-function (my-list-append left right)
  (block body (test (nil? left)) (branch then₃ else₄))
  (block then₁
    (= tail₃₁ (li-tail left))
    (= head₃₁ (li-head left))
    (= tail₁ tail₃₁)
    (= head₁ head₃₁)
    (= _₁ (my-list-append tail₁ right))
    (return (li head₁ _₁)))
  (block else₂ (return (error "cond mismatch")))
  (block then₃ (return right))
  (block else₄ (test (li? left)) (branch then₁ else₂)))