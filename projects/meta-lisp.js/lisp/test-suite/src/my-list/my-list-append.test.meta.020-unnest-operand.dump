(claim main (-> void-t))

(define (main)
  (begin
    (= _₁ (my-list-append nil nil))
    (assert-equal nil _₁))
  (= _₂ (li 6 nil))
  (= _₃ (li 5 _₂))
  (= _₄ (li 4 _₃))
  (= _₅ (li 3 _₄))
  (= _₆ (li 2 _₅))
  (= _₇ (li 1 _₆))
  (= _₈ (li 3 nil))
  (= _₉ (li 2 _₈))
  (= _₁₀ (li 1 _₉))
  (= _₁₁ (li 6 nil))
  (= _₁₂ (li 5 _₁₁))
  (= _₁₃ (li 4 _₁₂))
  (= _₁₄ (my-list-append _₁₀ _₁₃))
  (assert-equal _₇ _₁₄))