(claim main (-> void-t))

(define (main)
  (begin
    (= _₁ (iadd 1))
    (= _₂ (my-list-map _₁ nil))
    (assert-equal nil _₂))
  (= _₃ (li 4 nil))
  (= _₄ (li 3 _₃))
  (= _₅ (li 2 _₄))
  (= _₆ (iadd 1))
  (= _₇ (li 3 nil))
  (= _₈ (li 2 _₇))
  (= _₉ (li 1 _₈))
  (= _₁₀ (my-list-map _₆ _₉))
  (assert-equal _₅ _₁₀))