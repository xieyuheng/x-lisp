(claim my-list-map
  (polymorphic (A B)
    (-> (-> A B) (my-list-t A) (my-list-t B))))

(define (my-list-map f list)
  (if (nil? list)
    nil
    (if (li? list)
      (begin
        (= tail₁₁ (li-tail list))
        (= head₁₁ (li-head list))
        (= tail tail₁₁)
        (= head head₁₁)
        (li (f head) (my-list-map f tail)))
      (error "cond mismatch"))))