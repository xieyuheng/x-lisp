(claim my-list-append
  (polymorphic (E)
    (-> (my-list-t E) (my-list-t E) (my-list-t E))))

(define (my-list-append left right)
  (if (nil? left)
    right
    (if (li? left)
      (begin
        (= tail₃₁ (li-tail left))
        (= head₃₁ (li-head left))
        (= tail₁ tail₃₁)
        (= head₁ head₃₁)
        (= _₁ (my-list-append tail₁ right))
        (li head₁ _₁))
      (error "cond mismatch"))))