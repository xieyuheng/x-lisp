(claim my-list-length
  (polymorphic (E) (-> (my-list-t E) int-t)))

(define (my-list-length list)
  (if ((@require "my-list.lisp" nil?) list)
    0
    (if ((@require "my-list.lisp" li?) list)
      (begin
        (= tail₂ ((@require "my-list.lisp" li-tail) list))
        (= head₂ ((@require "my-list.lisp" li-head) list))
        (= tail tail₂)
        (= head head₂)
        (iadd 1 (my-list-length tail)))
      (error "cond mismatch"))))