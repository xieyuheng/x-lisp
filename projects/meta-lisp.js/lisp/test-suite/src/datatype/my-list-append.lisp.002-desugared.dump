(claim my-list-append
  (polymorphic (E)
    (-> (my-list-t E) (my-list-t E) (my-list-t E))))

(define (my-list-append left right)
  (if ((@require "my-list.lisp" nil?) left)
    right
    (if ((@require "my-list.lisp" li?) left)
      (begin
        (= tail₁ ((@require "my-list.lisp" li-tail) left))
        (= head₁ ((@require "my-list.lisp" li-head) left))
        (= tail tail₁)
        (= head head₁)
        (li head (my-list-append tail right)))
      (error "cond mismatch"))))