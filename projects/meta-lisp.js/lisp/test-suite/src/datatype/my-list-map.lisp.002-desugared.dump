(claim my-list-map
  (polymorphic (A B)
    (-> (-> A B) (my-list-t A) (my-list-t B))))

(define (my-list-map f list)
  (if (nil? list)
    nil
    (if (li? list)
      (begin
        (= tail₉ (li-tail list))
        (= head₉ (li-head list))
        (= tail tail₉)
        (= head head₉)
        (li (f head) (my-list-map f tail)))
      (error "cond mismatch"))))