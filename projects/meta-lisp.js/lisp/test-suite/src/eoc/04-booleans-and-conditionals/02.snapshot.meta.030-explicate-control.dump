(define-function (main)
  (block body
    (= x‚āĀ (random-dice))
    (= y‚āĀ (random-dice))
    (test (int-less? x‚āĀ 1))
    (branch then‚āĀ‚āá else‚āĀ‚āą))
  (block let-body‚āĀ
    (= _‚āÉ (iadd _‚āĀ _‚āā))
    (return (println _‚āÉ)))
  (block then‚āā (= _‚āā (iadd y‚āĀ 2)) (goto let-body‚āĀ))
  (block else‚āÉ (= _‚āā (iadd y‚āĀ 10)) (goto let-body‚āĀ))
  (block then‚āĄ (goto then‚āā))
  (block else‚āÖ (goto else‚āÉ))
  (block then‚āÜ (goto then‚āā))
  (block else‚āá (goto else‚āÉ))
  (block then‚āą (test (equal? x‚āĀ 0)) (branch then‚āĄ else‚āÖ))
  (block else‚āČ (test (equal? x‚āĀ 2)) (branch then‚āÜ else‚āá))
  (block let-body‚āĀ‚āÄ
    (test (int-less? x‚āĀ 1))
    (branch then‚āą else‚āČ))
  (block then‚āĀ‚āĀ (= _‚āĀ (iadd y‚āĀ 2)) (goto let-body‚āĀ‚āÄ))
  (block else‚āĀ‚āā (= _‚āĀ (iadd y‚āĀ 10)) (goto let-body‚āĀ‚āÄ))
  (block then‚āĀ‚āÉ (goto then‚āĀ‚āĀ))
  (block else‚āĀ‚āĄ (goto else‚āĀ‚āā))
  (block then‚āĀ‚āÖ (goto then‚āĀ‚āĀ))
  (block else‚āĀ‚āÜ (goto else‚āĀ‚āā))
  (block then‚āĀ‚āá (test (equal? x‚āĀ 0)) (branch then‚āĀ‚āÉ else‚āĀ‚āĄ))
  (block else‚āĀ‚āą (test (equal? x‚āĀ 2)) (branch then‚āĀ‚āÖ else‚āĀ‚āÜ)))