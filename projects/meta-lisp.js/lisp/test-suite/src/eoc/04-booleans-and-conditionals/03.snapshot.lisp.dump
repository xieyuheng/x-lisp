;;; input

(claim main (-> void-t))

(define (main)
  (println
   (if
       (and (equal? (random-dice) 1)
            (equal? (random-dice) 2))
     0
     42)))

;;; loaded

(claim main (-> void-t))

(define (main)
  (println
   (if
       (and (equal? (random-dice) 1)
            (equal? (random-dice) 2))
     0
     42)))

;;; desugared

(claim main (-> void-t))

(define (main)
  (println
   (if
       (if (equal? (random-dice) 1)
         (equal? (random-dice) 2)
         false)
     0
     42)))

;;; checked

(claim main (-> void-t))

(define (main)
  (println
   (if
       (if (equal? (random-dice) 1)
         (equal? (random-dice) 2)
         false)
     0
     42)))

