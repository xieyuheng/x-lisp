;;; input

(claim main (-> void-t))

(define (main)
  (= y (begin (= x 20) (begin (= z 22) (iadd x z))))
  (println y))

;;; loaded

(claim main (-> void-t))

(define (main)
  (= y (begin (= x 20) (begin (= z 22) (iadd x z))))
  (println y))

;;; desugared

(claim main (-> void-t))

(define (main)
  (= y (begin (= x 20) (= z 22) (iadd x z)))
  (println y))

;;; checked

(claim main (-> void-t))

(define (main)
  (= y (begin (= x 20) (= z 22) (iadd x z)))
  (println y))

