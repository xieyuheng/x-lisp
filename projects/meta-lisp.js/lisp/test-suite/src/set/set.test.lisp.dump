;;; input

(claim main (-> void-t))

(define (main) (assert-equal {1 2 3} {3 2 1}))

;;; loaded

(claim main (-> void-t))

(define (main) (assert-equal {1 2 3} {3 2 1}))

;;; desugared

(claim main (-> void-t))

(define (main)
  (assert-equal
    (begin
      (= set (make-set))
      (set-add! 1 set)
      (set-add! 2 set)
      (set-add! 3 set)
      set)
    (begin
      (= set (make-set))
      (set-add! 3 set)
      (set-add! 2 set)
      (set-add! 1 set)
      set)))

;;; checked

(claim main (-> void-t))

(define (main)
  (assert-equal
    (begin
      (= set (make-set))
      (set-add! 1 set)
      (set-add! 2 set)
      (set-add! 3 set)
      set)
    (begin
      (= set (make-set))
      (set-add! 3 set)
      (set-add! 2 set)
      (set-add! 1 set)
      set)))

