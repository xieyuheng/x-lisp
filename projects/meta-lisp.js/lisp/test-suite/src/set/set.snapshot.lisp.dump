;;; input

(claim main (-> void-t))

(define (main) (println (the (set-t int-t) {1 2 3})))

;;; loaded

(claim main (-> void-t))

(define (main) (println (the (set-t int-t) {1 2 3})))

;;; desugared

(claim main (-> void-t))

(define (main)
  (println
   (the (set-t int-t)
     (begin
       (= set (make-set))
       (set-add! 1 set)
       (set-add! 2 set)
       (set-add! 3 set)
       set))))

;;; checked

(claim main (-> void-t))

(define (main)
  (println
   (the (set-t int-t)
     (begin
       (= set (make-set))
       (set-add! 1 set)
       (set-add! 2 set)
       (set-add! 3 set)
       set))))

