(claim main (-> void-t))

(define (main)
  (assert-equal
    (begin
      (= set₁ (make-set))
      (set-add! 1 set₁)
      (set-add! 2 set₁)
      (set-add! 3 set₁)
      set₁)
    (begin
      (= set₁ (make-set))
      (set-add! 3 set₁)
      (set-add! 2 set₁)
      (set-add! 1 set₁)
      set₁)))