(claim main (-> void-t))

(define (main)
  (= list₁ (make-list))
  (list-push! 1 list₁)
  (list-push! 2 list₁)
  (list-push! 3 list₁)
  (begin
    (= list₂ (make-list))
    (list-push! 1 list₂)
    (list-push! 2 list₂)
    (list-push! 3 list₂)
    (assert-equal list₂ list₁))
  (begin
    (= list₂ (make-list))
    (list-push! 1 list₂)
    (list-push! 2 list₂)
    (list-push! 3 list₂)
    (= list₂ (make-list))
    (list-push! 1 list₂)
    (list-push! 2 list₂)
    (list-push! 3 list₂)
    (assert-equal list₂ list₂))
  (begin
    (= list₂ (make-list))
    (list-push! 'a list₂)
    (list-push! 'b list₂)
    (list-push! 'c list₂)
    (= list₂ (make-list))
    (list-push! 'a list₂)
    (list-push! 'b list₂)
    (list-push! 'c list₂)
    (assert-equal list₂ list₂))
  (begin
    (= list₂ (make-list))
    (list-push! 1 list₂)
    (list-push! 2 list₂)
    (list-push! 3 list₂)
    (= _₁ (list-length list₂))
    (assert-equal 3 _₁))
  (begin
    (= list₂ (make-list))
    (= _₂ (list-length list₂))
    (assert-equal 0 _₂))
  (= list₂ (make-list))
  (= _₃ (list-empty? list₂))
  (assert _₃))