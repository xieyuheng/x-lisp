;;; input

(claim main (-> void-t))

(define (main)
  (= list (make-list))
  (list-push! 1 list)
  (list-push! 2 list)
  (list-push! 3 list)
  (assert-equal [1 2 3] list)
  (assert-equal [1 2 3] '(1 2 3))
  (assert-equal ['a 'b 'c] '(a b c))
  (assert-equal 3 (list-length [1 2 3]))
  (assert-equal 0 (list-length []))
  (assert (list-empty? [])))

;;; loaded

(claim main (-> void-t))

(define (main)
  (= list (make-list))
  (list-push! 1 list)
  (list-push! 2 list)
  (list-push! 3 list)
  (assert-equal [1 2 3] list)
  (assert-equal [1 2 3] '(1 2 3))
  (assert-equal ['a 'b 'c] '(a b c))
  (assert-equal 3 (list-length [1 2 3]))
  (assert-equal 0 (list-length []))
  (assert (list-empty? [])))

;;; desugared

(claim main (-> void-t))

(define (main)
  (= list (make-list))
  (list-push! 1 list)
  (list-push! 2 list)
  (list-push! 3 list)
  (assert-equal
    (begin
      (= list (make-list))
      (list-push! 1 list)
      (list-push! 2 list)
      (list-push! 3 list)
      list)
    list)
  (assert-equal
    (begin
      (= list (make-list))
      (list-push! 1 list)
      (list-push! 2 list)
      (list-push! 3 list)
      list)
    (begin
      (= list (make-list))
      (list-push! 1 list)
      (list-push! 2 list)
      (list-push! 3 list)
      list))
  (assert-equal
    (begin
      (= list (make-list))
      (list-push! 'a list)
      (list-push! 'b list)
      (list-push! 'c list)
      list)
    (begin
      (= list (make-list))
      (list-push! 'a list)
      (list-push! 'b list)
      (list-push! 'c list)
      list))
  (assert-equal
    3
    (list-length
     (begin
       (= list (make-list))
       (list-push! 1 list)
       (list-push! 2 list)
       (list-push! 3 list)
       list)))
  (assert-equal
    0
    (list-length (begin (= list (make-list)) list)))
  (assert (list-empty? (begin (= list (make-list)) list))))

;;; checked

