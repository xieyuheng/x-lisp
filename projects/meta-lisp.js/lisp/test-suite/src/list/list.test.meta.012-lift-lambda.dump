(claim main (-> void-t))

(define (main)
  (= list₁ (make-list))
  (list-push! 1 list₁)
  (list-push! 2 list₁)
  (list-push! 3 list₁)
  (assert-equal
    (begin
      (= list₂ (make-list))
      (list-push! 1 list₂)
      (list-push! 2 list₂)
      (list-push! 3 list₂)
      list₂)
    list₁)
  (assert-equal
    (begin
      (= list₂ (make-list))
      (list-push! 1 list₂)
      (list-push! 2 list₂)
      (list-push! 3 list₂)
      list₂)
    (begin
      (= list₂ (make-list))
      (list-push! 1 list₂)
      (list-push! 2 list₂)
      (list-push! 3 list₂)
      list₂))
  (assert-equal
    (begin
      (= list₂ (make-list))
      (list-push! 'a list₂)
      (list-push! 'b list₂)
      (list-push! 'c list₂)
      list₂)
    (begin
      (= list₂ (make-list))
      (list-push! 'a list₂)
      (list-push! 'b list₂)
      (list-push! 'c list₂)
      list₂))
  (assert-equal
    3
    (list-length
     (begin
       (= list₂ (make-list))
       (list-push! 1 list₂)
       (list-push! 2 list₂)
       (list-push! 3 list₂)
       list₂)))
  (assert-equal
    0
    (list-length (begin (= list₂ (make-list)) list₂)))
  (assert (list-empty? (begin (= list₂ (make-list)) list₂))))