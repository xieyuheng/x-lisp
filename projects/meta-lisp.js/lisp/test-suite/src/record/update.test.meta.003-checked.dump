(define-interface point-t :x float-t :y float-t)

(claim point-put-x
  (polymorphic (A B C)
    (-> A
        (extend-interface B :x C)
        (extend-interface B :x C))))

(define (point-put-x x point) (update point :x x))

(claim point-put-y!
  (polymorphic (A B C)
    (-> A
        (extend-interface B :y C)
        (extend-interface B :y C))))

(define (point-put-y! y point) (update! point :y y))

(claim main (-> void-t))

(define (main)
  (= point (@record :x 1.0 :y 2.0))
  (assert-equal
    (@record :x 2.0 :y 2.0)
    (point-put-x 2.0 point))
  (assert-equal (@record :x 1.0 :y 2.0) point)
  (assert-equal
    (@record :x 1.0 :y 1.0)
    (point-put-y! 1.0 point))
  (assert-equal (@record :x 1.0 :y 1.0) point))