(define-interface point-t :x float-t :y float-t)

(claim point-put-x
  (polymorphic (A B C)
    (-> A
        (extend-interface B :x C)
        (extend-interface B :x C))))

(define (point-put-x x point)
  (= record point)
  (= record (record-put :x x record))
  record)

(claim point-put-y!
  (polymorphic (A B C)
    (-> A
        (extend-interface B :y C)
        (extend-interface B :y C))))

(define (point-put-y! y point)
  (= record point)
  (record-put! :y y record)
  record)

(claim main (-> void-t))

(define (main)
  (= point
     (begin
       (= record (make-record))
       (record-put! :x 1.0 record)
       (record-put! :y 2.0 record)
       record))
  (assert-equal
    (begin
      (= record (make-record))
      (record-put! :x 2.0 record)
      (record-put! :y 2.0 record)
      record)
    (point-put-x 2.0 point))
  (assert-equal
    (begin
      (= record (make-record))
      (record-put! :x 1.0 record)
      (record-put! :y 2.0 record)
      record)
    point)
  (assert-equal
    (begin
      (= record (make-record))
      (record-put! :x 1.0 record)
      (record-put! :y 1.0 record)
      record)
    (point-put-y! 1.0 point))
  (assert-equal
    (begin
      (= record (make-record))
      (record-put! :x 1.0 record)
      (record-put! :y 1.0 record)
      record)
    point))