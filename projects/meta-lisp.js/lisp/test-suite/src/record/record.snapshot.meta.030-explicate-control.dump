(define-function (main)
  (block body
    (= record₁ (make-record))
    (perform (record-put! #x 1 record₁))
    (perform (record-put! #y 2 record₁))
    (perform (println record₁))
    (= record₁ (make-record))
    (perform (record-put! #x 1 record₁))
    (perform (record-put! #y 2 record₁))
    (return (println record₁))))