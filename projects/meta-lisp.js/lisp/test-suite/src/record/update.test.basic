(define-function (point-put-x x point)
  (block body
    (= record₁ point)
    (= record₂ (record-put :x x record₁))
    (return record₂)))

(define-function (point-put-y! y point)
  (block body
    (= record₁ point)
    (perform (record-put! :y y record₁))
    (return record₁)))

(define-function (main)
  (block body
    (= record₁ (make-record))
    (perform (record-put! :x 1.0 record₁))
    (perform (record-put! :y 2.0 record₁))
    (= point₁ record₁)
    (= record₁ (make-record))
    (perform (record-put! :x 2.0 record₁))
    (perform (record-put! :y 2.0 record₁))
    (= _₁ (point-put-x 2.0 point₁))
    (perform (assert-equal record₁ _₁))
    (= record₁ (make-record))
    (perform (record-put! :x 1.0 record₁))
    (perform (record-put! :y 2.0 record₁))
    (perform (assert-equal record₁ point₁))
    (= record₁ (make-record))
    (perform (record-put! :x 1.0 record₁))
    (perform (record-put! :y 1.0 record₁))
    (= _₂ (point-put-y! 1.0 point₁))
    (perform (assert-equal record₁ _₂))
    (= record₁ (make-record))
    (perform (record-put! :x 1.0 record₁))
    (perform (record-put! :y 1.0 record₁))
    (return (assert-equal record₁ point₁))))