(module builtin)

(claim list-fold-left
  (polymorphic (E R)
    (-> (-> R E R)
        R (list-t E)
        R)))

(define (list-fold-left op e list)
  (if (list-empty? list)
    e
    (list-fold-left
     op (op e (list-head list))
     (list-tail list))))

(define-test list-fold-left-test
  (assert-equal 10 (list-fold-left iadd 0 [1 2 3 4]))
  (assert-equal [4 3 2 1] (list-fold-left (swap cons) [] [1 2 3 4])))

(claim list-fold-right
  (polymorphic (E R)
    (-> (-> E R R)
        R (list-t E)
        R)))

(define (list-fold-right op e list)
  (if (list-empty? list)
    e
    (list-fold-right
     op (op (list-last list) e)
     (list-init list))))

(define-test list-fold-right-test
  (assert-equal 10 (list-fold-right iadd 0 [1 2 3 4]))
  (assert-equal [1 2 3 4] (list-fold-right cons [] [1 2 3 4])))
