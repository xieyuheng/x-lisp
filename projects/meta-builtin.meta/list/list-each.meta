(module builtin)

(claim list-each
  (polymorphic (A Any)
    (-> (-> A Any) (list-t A)
        void-t)))

(define (list-each f list)
  (if (list-empty? list)
    void
    (begin
      (f (car list))
      (list-each f (cdr list)))))

(define-test list-each-test
  (list-each
   (lambda (x)
     (print x)
     (write "\n"))
   [1 2 3]))
