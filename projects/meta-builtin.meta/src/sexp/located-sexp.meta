(module builtin)

(define-interface source-location-t
  :span source-span-t
  :path string-t)

(define-interface source-span-t
  :start source-position-t
  :end source-position-t)

(define-interface source-position-t
  :index int-t
  :row int-t
  :column int-t)

(define-data located-sexp-t
  (symbol-sexp (content symbol-t) (location source-location-t))
  (keyword-sexp (content keyword-t) (location source-location-t))
  (string-sexp (content string-t) (location source-location-t))
  (int-sexp (content int-t) (location source-location-t))
  (float-sexp (content float-t) (location source-location-t))
  (list-sexp (elements (list-t located-sexp-t))
             (location source-location-t)))

(declare-primitive-function parse-located-sexps 2)

(claim parse-located-sexps (-> string-t string-t located-sexp-t))
