(module builtin)

(declare-primitive-variable string-t)
(declare-primitive-function string? 1)
(declare-primitive-function string-length 1)
(declare-primitive-function string-empty? 1)
(declare-primitive-function string-blank? 1)
(declare-primitive-function string-substring 3)
(declare-primitive-function string-append 2)
(declare-primitive-function string-concat 1)
(declare-primitive-function string-compare-lexical 2)
(declare-primitive-function string-to-symbol 1)
(declare-primitive-function string-chars 1)
(declare-primitive-function string-lines 1)
(declare-primitive-function string-split 2)
(declare-primitive-function string-join 2)
(declare-primitive-function string-replace 3)
(declare-primitive-function string-starts-with? 2)
(declare-primitive-function string-ends-with? 2)
(declare-primitive-function string-to-upper-case 1)
(declare-primitive-function string-to-lower-case 1)
(declare-primitive-function string-get-code-point 2)
(declare-primitive-function string-contains? 2)
(declare-primitive-function string-find-index 2)
(declare-primitive-function string-trim-left 1)
(declare-primitive-function string-trim-right 1)
(declare-primitive-function string-trim-start 1)
(declare-primitive-function string-trim-end 1)
(declare-primitive-function string-trim 1)
(declare-primitive-function string-int? 1)
(declare-primitive-function string-float? 1)

(claim string-t type-t)
(claim string? (polymorphic (A) (-> A bool-t)))
(claim string-length (-> string-t int-t))
(claim string-empty? (-> string-t bool-t))
(claim string-blank? (-> string-t bool-t))
(claim string-substring (-> int-t int-t string-t string-t))
(claim string-append (-> string-t string-t string-t))
(claim string-concat (-> (list-t string-t) string-t))
(claim string-compare-lexical (-> string-t string-t int-t))
(claim string-to-symbol (-> string-t symbol-t))
(claim string-chars (-> string-t (list-t string-t)))
(claim string-lines (-> string-t (list-t string-t)))
(claim string-split (-> string-t string-t (list-t string-t)))
(claim string-join (-> string-t (list-t string-t) string-t))
(claim string-replace (-> string-t string-t string-t string-t))
(claim string-starts-with? (-> string-t string-t bool-t))
(claim string-ends-with? (-> string-t string-t bool-t))
(claim string-to-upper-case (-> string-t string-t))
(claim string-to-lower-case (-> string-t string-t))
(claim string-get-code-point (-> int-t string-t int-t))
(claim string-contains? (-> string-t string-t bool-t))
(claim string-find-index (-> string-t string-t int-t))
(claim string-trim-left (-> string-t string-t))
(claim string-trim-right (-> string-t string-t))
(claim string-trim-start (-> string-t string-t))
(claim string-trim-end (-> string-t string-t))
(claim string-trim (-> string-t string-t))
(claim string-int? (-> string-t bool-t))
(claim string-float? (-> string-t bool-t))
