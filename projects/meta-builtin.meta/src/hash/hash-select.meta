(module builtin)

(claim hash-select
  (polymorphic (K V)
    (-> (-> K V bool-t) (hash-t K V)
        (hash-t K V))))

(define (hash-select p hash)
  (hash-from-entries
   (list-select
    (lambda (entry) (p (:key entry) (:value entry)))
    (hash-entries hash))))

(claim hash-select-key
  (polymorphic (K V)
    (-> (-> K bool-t) (hash-t K V)
        (hash-t K V))))

(define (hash-select-key p hash)
  (hash-from-entries
   (list-select
    (lambda (entry) (p (:key entry)))
    (hash-entries hash))))

(claim hash-select-value
  (polymorphic (K V)
    (-> (-> V bool-t) (hash-t K V)
        (hash-t K V))))

(define (hash-select-value p hash)
  (hash-from-entries
   (list-select
    (lambda (entry) (p (:value entry)))
    (hash-entries hash))))

(claim hash-reject
  (polymorphic (K V)
    (-> (-> K V bool-t) (hash-t K V)
        (hash-t K V))))

(define (hash-reject p hash)
  (hash-select (lambda (key value) (not (p key value)))
               hash))

(claim hash-reject-key
  (polymorphic (K V)
    (-> (-> K bool-t) (hash-t K V)
        (hash-t K V))))

(define (hash-reject-key p hash)
  (hash-select-key (negation p) hash))

(claim hash-reject-value
  (polymorphic (K V)
    (-> (-> V bool-t) (hash-t K V)
        (hash-t K V))))

(define (hash-reject-value p hash)
  (hash-select-value (negation p) hash))

(define-test test-hash-select
 (assert-equal
   (@hash 'a 1 'b 2)
   (hash-select (drop int-non-negative?) (@hash 'a 1 'b 2 'x -1 'y -2)))

 (assert-equal
   (@hash 'a 1 'b 2)
   (hash-select-value int-non-negative? (@hash 'a 1 'b 2 'x -1 'y -2)))

 (assert-equal
   (@hash 1 'a 2 'b)
   (hash-select-key int-non-negative? (@hash 1 'a 2 'b -1 'x -2 'y)))

 (assert-equal
   (@hash 'x -1 'y -2)
   (hash-reject (drop int-non-negative?) (@hash 'a 1 'b 2 'x -1 'y -2)))

 (assert-equal
   (@hash 'x -1 'y -2)
   (hash-reject-value int-non-negative? (@hash 'a 1 'b 2 'x -1 'y -2)))

 (assert-equal
   (@hash -1 'x -2 'y)
   (hash-reject-key int-non-negative? (@hash 1 'a 2 'b -1 'x -2 'y))))
