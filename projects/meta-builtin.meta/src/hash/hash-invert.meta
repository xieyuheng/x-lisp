(module builtin)

(claim hash-invert
  (polymorphic (K V)
    (-> (hash-t K V)
        (hash-t V K))))

(define (hash-invert hash)
  (hash-map (lambda (k v) (make-hash-entry v k))
            hash))

(define-test hash-invert-test
  (assert-equal
    (@hash 2 1 4 3)
    (hash-invert (@hash 1 2 3 4))))

(claim hash-invert-group
  (polymorphic (K V)
    (-> (hash-t K V)
        (hash-t V (set-t K)))))

(define (hash-invert-group hash)
  (= new-hash (@hash))
  (hash-each-value
   (lambda (value)
     (= keys (hash-keys (hash-select-value (equal? value) hash)))
     (hash-put! value (list-to-set keys) new-hash))
   hash)
  new-hash)

(define-test hash-invert-group-test
  (assert-equal
    (@hash 2 (@set 1 2)
           4 (@set 3 4))
    (hash-invert-group
     (@hash 1 2
            3 4
            2 2
            4 4))))
