(module builtin)

(declare-primitive-function assert 1)
(declare-primitive-function assert-not 1)
(declare-primitive-function assert-equal 2)
(declare-primitive-function assert-not-equal 2)
(declare-primitive-function assert-with-location 2)
(declare-primitive-function assert-not-with-location 2)
(declare-primitive-function assert-equal-with-location 3)
(declare-primitive-function assert-not-equal-with-location 3)

(claim assert (-> bool-t void-t))
(claim assert-not (-> bool-t void-t))
(claim assert-equal (polymorphic (A) (-> A A void-t)))
(claim assert-not-equal (polymorphic (A) (-> A A void-t)))
(claim assert-with-location (-> bool-t source-location-t void-t))
(claim assert-not-with-location (-> bool-t source-location-t void-t))
(claim assert-equal-with-location (polymorphic (A) (-> A A source-location-t void-t)))
(claim assert-not-equal-with-location (polymorphic (A) (-> A A source-location-t void-t)))
