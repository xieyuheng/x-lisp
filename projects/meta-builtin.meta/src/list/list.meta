(module builtin)

(declare-primitive-function list-t 1)
(declare-primitive-function list? 1)
(declare-primitive-function make-list 0)
(declare-primitive-function car 1)
(declare-primitive-function cdr 1)
(declare-primitive-function cons 2)
(declare-primitive-function list-head 1)
(declare-primitive-function list-tail 1)
(declare-primitive-function list-init 1)
(declare-primitive-function list-last 1)
(declare-primitive-function list-length 1)
(declare-primitive-function list-empty? 1)
(declare-primitive-function list-copy 1)
(declare-primitive-function list-get 2)
(declare-primitive-function list-put 3)
(declare-primitive-function list-put! 3)
(declare-primitive-function list-push 2)
(declare-primitive-function list-push! 2)
(declare-primitive-function list-pop! 1)
(declare-primitive-function list-pop-front! 1)
(declare-primitive-function list-push-front! 2)
(declare-primitive-function list-reverse 1)
(declare-primitive-function list-to-set 1)

(claim list-t (-> type-t type-t))
(claim list? (polymorphic (A) (-> A bool-t)))
(claim make-list (polymorphic (E) (-> (list-t E))))
(claim car (polymorphic (E) (-> (list-t E) E)))
(claim cdr (polymorphic (E) (-> (list-t E) (list-t E))))
(claim cons (polymorphic (E) (-> E (list-t E) (list-t E))))
(claim list-head (polymorphic (E) (-> (list-t E) E)))
(claim list-tail (polymorphic (E) (-> (list-t E) (list-t E))))
(claim list-init (polymorphic (E) (-> (list-t E) (list-t E))))
(claim list-last (polymorphic (E) (-> (list-t E) E)))
(claim list-length (polymorphic (E) (-> (list-t E) int-t)))
(claim list-empty? (polymorphic (E) (-> (list-t E) bool-t)))
(claim list-copy (polymorphic (E) (-> (list-t E) (list-t E))))
(claim list-get (polymorphic (E) (-> int-t (list-t E) E)))
(claim list-put (polymorphic (E) (-> int-t E (list-t E) (list-t E))))
(claim list-put! (polymorphic (E) (-> int-t E (list-t E) (list-t E))))
(claim list-push (polymorphic (E) (-> E (list-t E) (list-t E))))
(claim list-push! (polymorphic (E) (-> E (list-t E) (list-t E))))
(claim list-pop! (polymorphic (E) (-> (list-t E) E)))
(claim list-pop-front! (polymorphic (E) (-> (list-t E) E)))
(claim list-push-front! (polymorphic (E) (-> E (list-t E) (list-t E))))
(claim list-reverse (polymorphic (E) (-> (list-t E) (list-t E))))
(claim list-to-set (polymorphic (E) (-> (list-t E) (set-t E))))
