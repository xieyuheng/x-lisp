(module meta)

(define (load-mod-fragment path)
  (= code (fs-read path))
  (= sexps (parse-sexps path code))
  (= stmts (list-map parse-stmt sexps))
  (= module-stmt
     (pipe stmts
       (list-find
        (lambda (stmt)
          (or (declare-module-stmt? stmt)
              (declare-type-error-module-stmt? stmt))))))
  (match module-stmt
    ((just (declare-module-stmt name location))
     {:mod-name name :stmts stmts :is-type-error-module false})
    ((just (declare-type-error-module-stmt name location))
     {:mod-name name :stmts stmts :is-type-error-module true})
    ((nothing)
     (error "(load-mod-fragment) expect (module) statement in fragment"))))
