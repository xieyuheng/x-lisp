(module meta)

(define (load-mod-fragment path)
  (= code (fs-read path))
  (= sexps (parse-sexps path code))
  ;; (= stmts (list-map parse-stmt sexps))
  (= stmts (make-list))
  (= result (find-mod-name path stmts))
  {:mod-name (:name result)
   :is-type-error-module (:is-type-error-module result)
   :stmts stmts})

(define (find-mod-name stmts)
  (pipe stmts
    (list-find
     (lambda (stmt)
       (or (declare-module-stmt? stmt)
           (declare-type-error-module-stmt? stmt))))))
