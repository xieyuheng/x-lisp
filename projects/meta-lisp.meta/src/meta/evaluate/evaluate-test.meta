(module meta)

(define-test evaluate-test
  (= path "src/meta/evaluate/meta-example-1.txt")
  (= text (fs-read path))
  (list-each
    (lambda (sexp)
      (= exp (parse-exp sexp))
      (= mod (make-mod 'evaluate-test (make-project "." (make-project-config))))
      (= env (empty-env))
      (print exp)
      (write " -> ")
      (print (evaluate mod env exp))
      (newline))
    (parse-located-sexps path text)))
