(module meta)

(define-test parse-project-config-test
  (= sexps (parse-sexps "test"
            "(list :name \"test-project\" :version \"0.1.0\" :build (list :source-directory \"src\" :output-directory \"lib\" :snapshot-directory \"snapshot\"))"))
  (= config (parse-project-config-from-sexp (car sexps)))
  (assert-equal "test-project" (:name config))
  (assert-equal "0.1.0" (:version config))
  (assert-equal "src" (:source-directory (:build config)))
  (assert-equal "lib" (:output-directory (:build config)))
  (assert-equal "snapshot" (:snapshot-directory (:build config))))
