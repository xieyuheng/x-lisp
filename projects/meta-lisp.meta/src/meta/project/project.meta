(module meta)

(define-interface project-t
  :root-directory string-t
  :config project-config-t)

(define (make-project root-directory config)
  {:root-directory root-directory
   :config config})

(define (load-project config-path)
  (= config (load-project-config config-path))
  (= root-directory (path-directory-name config-path))
  (= project (make-project root-directory config))
  ;; (load-builtin-mod project) ;; not implemented yet
  (= source-directory (project-source-directory project))
  ;; (project-load-mod-fragments project source-directory) ;; not implemented yet
  project)

(define (project-source-directory project)
  (path-join
    (:root-directory project)
    (:source-directory (:build (:config project)))))
