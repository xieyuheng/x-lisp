(module meta)

(define-interface project-config-t
  :name string-t
  :version string-t
  :build (interface
           :source-directory string-t
           :output-directory string-t
           :snapshot-directory string-t))

(define (parse-project-config path string)
  (= sexps (parse-sexps path string))
  (parse-project-config-from-sexp (car sexps)))

(define (parse-build-config sexp)
  (= elements (list-sexp-elements sexp))
  (= hash (sexp-collect-key-value-hash elements))
  {:source-directory (string-sexp-content (hash-get :source-directory hash))
   :output-directory (string-sexp-content (hash-get :output-directory hash))
   :snapshot-directory (string-sexp-content (hash-get :snapshot-directory hash))})

(define (parse-project-config-from-sexp sexp)
  (= elements (list-sexp-elements sexp))
  (= hash (sexp-collect-key-value-hash elements))
  {:name (string-sexp-content (hash-get :name hash))
   :version (string-sexp-content (hash-get :version hash))
   :build (parse-build-config (hash-get :build hash))})

(define (load-project-config path)
  (= file (open-input-file path))
  (= string (file-read file))
  (file-close file)
  (parse-project-config path string))

(define-test load-project-config-test
  (= path "project.sexp")
  (= config (load-project-config path))
  (assert-equal "meta-lisp" (:name config)))
