(module meta)

(define-data definition-t
  (primitive-function-definition
   (name symbol-t)
   (arity int-t)
   (fn (-> (list-t value-t) value-t))
   (location source-location-t))
  (primitive-variable-definition
   (name symbol-t)
   (value value-t)
   (location source-location-t))
  (primitive-function-declaration
   (name symbol-t)
   (arity int-t)
   (location source-location-t))
  (primitive-variable-declaration
   (name symbol-t)
   (location source-location-t))
  (function-definition
   (name symbol-t)
   (parameters (list-t symbol-t))
   (body exp-t)
   (location source-location-t))
  (variable-definition
   (name symbol-t)
   (body exp-t)
   (value (maybe-t value-t))
   (location source-location-t))
  (test-definition
   (name symbol-t)
   (body exp-t)
   (location source-location-t))
  (type-definition
   (name symbol-t)
   (parameters (list-t symbol-t))
   (body exp-t)
   (location source-location-t))
  (data-definition
   (name symbol-t)
   (data-type-constructor data-type-constructor-t)
   (data-constructors (list-t data-constructor-t))
   (location source-location-t))
  (interface-definition
   (name symbol-t)
   (interface-constructor interface-constructor-t)
   (attribute-types (hash-t keyword-t exp-t))
   (location source-location-t)))

(define-interface data-type-constructor-t
  :name symbol-t
  :parameters (list-t symbol-t))

(define-interface data-constructor-t
  :name symbol-t
  :fields (list-t data-field-t))

(define-interface data-field-t
  :name symbol-t
  :type exp-t)

(define-interface interface-constructor-t
  :name symbol-t
  :parameters (list-t symbol-t))
