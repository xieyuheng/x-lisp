;; module declaration

(module test)

;; definition

(define (add x y) (iadd x y))
(define-test my-test (= 3 (add 1 2)))

;; type declaration

(claim add (-> int-t int-t int-t))
(admit cons (-> int-t (list-t int-t) (list-t int-t)))
(private internal-fn)

;; conditional

(if (equal? x 1) 1 2)
(when (true? x) (println "yes"))
(unless (false? x) (println "no"))
(cond ((= x 1) 1) (else 0))
(and true true)
(or false true)
(match exp
  ((var-exp name) name)
  (else (error "unknown")))

;; binding

(let ((x 1) (y 2)) (iadd x y))
(let* ((x 1) (y (iadd 1 x))) (iadd x y))
(begin (println "hello") (println "world"))
(lambda (x) x)
(polymorphic (A) (-> A A))

;; module system

(import builtin foo)
(import-as builtin b)
(import-all builtin)

;; type

(the int-t 42)
(-> int-t int-t)

;; record

(extend base :x 1 :y 2)
(update base :x 3)
(update! base :y 4)
(interface (:x int-t :y int-t))
(extend-interface base (:z int-t))

;; literal

[1 2 3]
[1 2 3
 1 2 3]
{:x 1 :y 2}
{:x 1
 :y 2}
(@set 1 2 3)
(@hash "x" 1 "y" 2)
(@quote (a b c))

;; keyword

:foo :bar :baz

;; algebraic data type

(define-data (my-list-t E)
  (nil)
  (li (head E) (tail (my-list-t E))))

;; interface

(define-interface point-t
  :x float-t
  :y float-t)
